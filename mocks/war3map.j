//textmacro instance: DISPLAY_CODE()
    
    function CodeVersioning__OnDisplayCode takes string str returns nothing
    local integer i= 0
    local string dire= null

    local string infoo= "\r\n\n\r\nHero: " + GetUnitName(udg_PHero[CodeVersioning__playerId]) + "\r\n"
    local string kills="Kills: " + I2S(GetUnitUserData(udg_PHero[CodeVersioning__playerId])) + "\r\n"
    local string codeee="Code: -load " + udg_tmpcode + "\r\n\r\n\r\n"
    local string hnames= GetUnitName(udg_PHero[CodeVersioning__playerId])
    local string hlevel= I2S(GetUnitLevel(udg_PHero[CodeVersioning__playerId]))
    local string fname= udg_Fname[udg_Faction[CodeVersioning__playerId]]

    
    set dire=GetPlayerName(CodeVersioning__triggerPlayer) + "\\\\"
    set dire=dire + hnames + "\\\\Lvl_" + hlevel + "_" + fname + ".txt"
  //  set dire = dire + I2S(GetUnitLevel(udg_PHero[playerId])) + "_"
   // set dire = dire + udg_Fname[udg_Faction[playerId]] + ".txt"

    set dire=udg_ruta + CodeVersioning__mode + dire


        call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, .3, .2, 15, "Saving code into: |cffffcc00...Your war3 folder\\" + dire + "|r")
       
      if ( GetLocalPlayer() == CodeVersioning__triggerPlayer ) then
       
       if saveddataI[9] < 1 or saveddataI[9] > 45 then
       
        call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, .3, .2, 8, "|cffff7700CIntegrity Failed, please make a backup of your current file and try again in few minutes!|r")
        call TriggerExecute(gg_trg_setherotype)
    
       else
      
        call PreloadGenClear()
        call PreloadGenStart()
        call Preload(infoo + kills + codeee)
        call PreloadGenEnd(dire)
        call PreloadGenEnd(dire)

         call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, .3, .2, 8, "Code integrity OK!")
       
       

        
        endif
       endif
      
    
    
    
    if ( dumprisk[CodeVersioning__playerId] == true ) then
      set dumprisk[CodeVersioning__playerId]=false
    elseif ( dumprisk[CodeVersioning__playerId] == false ) then
      set dumprisk[CodeVersioning__playerId]=true
    endif
    

    set codeee=null
    set infoo=null
    
    set dire=null
    set udg_tmpcode=null
    endfunction
//end of: DISPLAY_CODE()
//textmacro instance: CORE_ENCRYPTION()
    
    function CodeVersioning__Encrypt takes nothing returns string
        return EncryptNumberVersion(CodeVersioning__stack , CodeVersioning__checksum , CodeVersioning__shuffles , CodeVersioning__playerId , CodeVersioning__password , .85 , CodeVersioning__MAX_CODE_VERSIONS , CodeVersioning__VERSION_COUNT)
    endfunction
    function CodeVersioning__Decrypt takes string s returns integer
        local integer i= DecryptNumberVersion(s , CodeVersioning__encryptionKey , CodeVersioning__checksum , CodeVersioning__shuffles , CodeVersioning__playerId , CodeVersioning__password , .85 , CodeVersioning__MAX_CODE_VERSIONS)
        set CodeVersioning__loadedVersion=(NumberEncrypter__v) // INLINED!!
        return i
    endfunction
//end of: CORE_ENCRYPTION()
//textmacro instance: CORE_STRING_MARKING()
    
    function CodeVersioning__MarkString takes string s returns string
        set s=AddRepeatedString(s , CodeVersioning__DELIMITER , CodeVersioning__DELIMITER_SPACING , 0)
        set udg_tmpcode=s
        set s=ColorCodeString(s , CodeVersioning__NUM_COLOR , CodeVersioning__LOWERCASE_COLOR , CodeVersioning__UPPERCASE_COLOR , CodeVersioning__SPEC_CHAR_COLOR , 0)
        return s
    endfunction
//end of: CORE_STRING_MARKING()
//textmacro instance: CORE_STRING_STRIPPING()
    
    function CodeVersioning__StripLoadCode takes string str returns string
        set str=RemoveString(str , GetEventPlayerChatStringMatched() , 1 , 0) //remove "-load "

            set str=RemoveString(str , " " , 0 , 0) //remove " "

        set str=RemoveString(str , CodeVersioning__DELIMITER , 0 , 0) //remove DELIMITER
        return str
    endfunction
//end of: CORE_STRING_STRIPPING()
//textmacro instance: CORE_LOAD()
    
    function CodeVersioning__Load takes nothing returns boolean
        local string s
        local integer ver
        

            local integer crc



        
        set CodeVersioning__triggerPlayer=GetTriggerPlayer()
        set CodeVersioning__playerId=GetPlayerId(CodeVersioning__triggerPlayer)
        
        
          if ( udg_PlayerReady[GetPlayerId(GetTriggerPlayer())] == true ) then
            return false
          endif
        
        if ( (true) ) then // INLINED!!
            call s__Buffer_reset()
        
            set s=CodeVersioning__StripLoadCode(GetEventPlayerChatString())
            
            if ( 1 > StringLength(s) ) then
                call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, 0, 0, 20, "Invalid Code") // INLINED!!
                return false
            endif
            
            set CodeVersioning__stack=CodeVersioning__Decrypt(s)
            

                set crc=CodeVersioning__loadedVersion

            
            if ( 0 == CodeVersioning__stack or CodeVersioning__loadedVersion > CodeVersioning__VERSION_COUNT ) then
                call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, 0, 0, 20, "Invalid Code") // INLINED!!
                return false
            endif
            
            call ExecuteFunc("CodeVersioning__" + "OnLoadBuffer" + I2S(CodeVersioning__loadedVersion))
            
            if ( crc == (s__BigInt_toInt(((CodeVersioning__stack)))) ) then // INLINED!!
                call CodeVersioning__OnSuccessfulLoad()
                call ExecuteFunc("CodeVersioning__" + "OnLoad" + I2S(CodeVersioning__loadedVersion))
            else
                call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, 0, 0, 20, "Invalid Code") // INLINED!!
                call ExecuteFunc("CodeVersioning__" + "OnUnload" + I2S(CodeVersioning__loadedVersion))
            endif
            
            call s__BigInt_destroy(((CodeVersioning__stack))) // INLINED!!
        endif
        
        set CodeVersioning__triggerPlayer=null
        
        return false
    endfunction
//end of: CORE_LOAD()
//textmacro instance: CORE_SAVE()
    
    function CodeVersioning__Save takes nothing returns boolean
        local string str
        
       
        set CodeVersioning__triggerPlayer=GetTriggerPlayer()
        set CodeVersioning__playerId=GetPlayerId(CodeVersioning__triggerPlayer)
        
      //  call BJDebugMsg("NumberStack is going to run")
        
       // set stack=NumberStack.create(Base["abcdefghijklmnopqrstuvwxyz"])
        set CodeVersioning__stack=(s__BigInt_create((CodeVersioning__encryptionKey))) // INLINED!!
       // call BJDebugMsg("NumberStack done")
        
      //  call BJDebugMsg("IMPROVED_CRC is going to run")

            call s__BigInt_add((CodeVersioning__stack),CodeVersioning__VERSION_COUNT , 0)



     //    call BJDebugMsg("IMPROVED_CRC Done")
        
      //  call BJDebugMsg("OnSave() is going to run")
        call CodeVersioning__OnSave()
       // call BJDebugMsg("OnSave() done")
        
        set str=(EncryptNumberVersion(CodeVersioning__stack , CodeVersioning__checksum , CodeVersioning__shuffles , CodeVersioning__playerId , CodeVersioning__password , .85 , CodeVersioning__MAX_CODE_VERSIONS , CodeVersioning__VERSION_COUNT)) // INLINED!!
        set str=CodeVersioning__MarkString(str)
            
        call CodeVersioning__OnDisplayCode(str)
        
        call s__BigInt_destroy(((CodeVersioning__stack))) // INLINED!!
        set CodeVersioning__triggerPlayer=null
        
        set str=null
        return false
    endfunction
//end of: CORE_SAVE()
//textmacro instance: CORE_INITIALIZATION()
    function CodeVersioning__IsGameOffline takes nothing returns boolean
        return ReloadGameCachesFromDisk()
    endfunction
//Implemented from module CodeVersioning__I:
        function s__CodeVersioning__N_CodeVersioning__I___onInit takes nothing returns nothing

            call InitSave(CodeVersioning__SAVE_COMMAND , CodeVersioning__LOAD_COMMAND , Condition(function CodeVersioning__Save) , Condition(function CodeVersioning__Load))
            
            //set udg_ruta = null

            if ( (ReloadGameCachesFromDisk()) ) then // INLINED!!
                set CodeVersioning__mode="local\\\\"
                
                set CodeVersioning__encryptionKey=s__Base__staticgetindex(CodeVersioning__OFFLINE_ENCRYPTION_KEY)
                set CodeVersioning__checksum=CodeVersioning__OFFLINE_CHECKSUM
                set CodeVersioning__password=CodeVersioning__OFFLINE_PASSWORD
                set CodeVersioning__shuffles=CodeVersioning__OFFLINE_SHUFFLES
              
            else
               set CodeVersioning__mode="multiplayer\\\\"
             
                set CodeVersioning__encryptionKey=s__Base__staticgetindex(CodeVersioning__ONLINE_ENCRYPTION_KEY)
                set CodeVersioning__checksum=CodeVersioning__ONLINE_CHECKSUM
                set CodeVersioning__password=CodeVersioning__ONLINE_PASSWORD
                set CodeVersioning__shuffles=CodeVersioning__ONLINE_SHUFFLES
            
            endif
        endfunction
//end of: CORE_INITIALIZATION()
// scope CodeVersioning ends
