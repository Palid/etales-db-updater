// function derogateEdict takes string edict, string Pname, real duration
//===========================================================================
function minwealthc takes nothing returns boolean
     return ( GetItemTypeId(GetManipulatedItem()) == 'I0F3' )
endfunction

function minwealtha takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  //local unit hero = udg_PHero[id]
  
  if Reputation[id] < 90 then
     call RejectByRep(id)
     return
  endif
  
   if edictWealth == false then
     set edictWealth=true
     set globalWealth=2
     
     set Reputation[id]=Reputation[id] - 90
     
     call promoteEdict("|cffffcc00Minor Wealth|r" , GetPlayerName(Player(id)) , I2S(2) , I2S(R2I(750 / 50)) , 18)
     call TriggerSleepAction(750)
     set edictWealth=false
     set globalWealth=1
     call derogateEdict("|cffffcc00Minor Wealth|r" , GetPlayerName(Player(id)) , 5)
   else
      call DisplayTimedTextToPlayer(Player((id)), 0, 0, 5, "There's already an edict related to these issues. Please wait until previous edict ends") // INLINED!!
   endif
 
 
endfunction

//===========================================================================
function InitTrig_promoteMinorWealth takes nothing returns nothing
    
    local integer index= 0
    set gg_trg_promoteMinorWealth=CreateTrigger()
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_promoteMinorWealth, Player(index), EVENT_PLAYER_UNIT_PICKUP_ITEM, null)

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
   // call TriggerRegisterAnyUnitEventBJ( gg_trg_promoteMinorWealth, EVENT_PLAYER_UNIT_PICKUP_ITEM )
    call TriggerAddCondition(gg_trg_promoteMinorWealth, Condition(function minwealthc))
    call TriggerAddAction(gg_trg_promoteMinorWealth, function minwealtha)
endfunction


//===========================================================================
// Trigger: promoteWealth
//
// oolean edictFortune = false
// boolean edictWealth = false
// boolean edictKnowledge = false
// real globalFortune = 1
// real globalWealth = 1
// integer globalKnowledge = 1
// function promoteEdict takes string edict, string Pname, string amount, string time, real duration returns nothing
// function derogateEdict takes string edict, string Pname, real duration
//===========================================================================
//TESH.scrollpos=21
//TESH.alwaysfold=0
function maxwealthc takes nothing returns boolean
     return ( GetItemTypeId(GetManipulatedItem()) == 'I0EV' )
endfunction

function maxwealtha takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  //local unit hero = udg_PHero[id]
  
  if Reputation[id] < 270 then
     call RejectByRep(id)
     return
  endif
  
   if edictWealth == false then
     set edictWealth=true
     set globalWealth=5
     
     set Reputation[id]=Reputation[id] - 270
     
     call promoteEdict("|cffffcc00Wealth|r" , GetPlayerName(Player(id)) , I2S(5) , I2S(R2I(1500 / 50)) , 18)
     call TriggerSleepAction(1500)
     set edictWealth=false
     set globalWealth=1
     call derogateEdict("|cffffcc00Wealth|r" , GetPlayerName(Player(id)) , 5)
   else
      call DisplayTimedTextToPlayer(Player((id)), 0, 0, 5, "There's already an edict related to these issues. Please wait until previous edict ends") // INLINED!!
   endif
 
 
endfunction

//===========================================================================
function InitTrig_promoteWealth takes nothing returns nothing
    
    local integer index= 0
    set gg_trg_promoteWealth=CreateTrigger()
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_promoteWealth, Player(index), EVENT_PLAYER_UNIT_PICKUP_ITEM, null)

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
   // call TriggerRegisterAnyUnitEventBJ( gg_trg_promoteWealth, EVENT_PLAYER_UNIT_PICKUP_ITEM )
    call TriggerAddCondition(gg_trg_promoteWealth, Condition(function maxwealthc))
    call TriggerAddAction(gg_trg_promoteWealth, function maxwealtha)
endfunction


//===========================================================================
// Trigger: sanctus
//===========================================================================
function Trig_sanctus_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0UD' )
endfunction

function Trig_sanctus_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local item itm
 local real x= GetUnitX(GetTriggerUnit())
 local real y= GetUnitY(GetTriggerUnit())
 
   if ( rubi[id] >= 60 and emerald[id] >= 40 and saphire[id] >= 50 ) then
  
    set itm=CreateItem('I0UC', x, y) //rare chest
      call UnitAddItem(GetTriggerUnit(), itm)
      set rubi[id]=rubi[id] - 60
      set saphire[id]=saphire[id] - 50
      set emerald[id]=emerald[id] - 40
      
        //call RemoveItemFromStock(udg_MAVault[id], 'I0MJ')
       // call AddItemToStock(udg_MAVault[id],'I0MJ', onix[id],onix[id])
       
        call RemoveItemFromStock(udg_MAVault[id], 'I0MM')
        call AddItemToStock(udg_MAVault[id], 'I0MM', emerald[id], emerald[id])

	    call RemoveItemFromStock(udg_MAVault[id], 'I0MN')
        call AddItemToStock(udg_MAVault[id], 'I0MN', saphire[id], saphire[id])

	   //call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
       //call AddItemToStock(udg_MAVault[id],'I0ML',diamond[id],diamond[id])

	    call RemoveItemFromStock(udg_MAVault[id], 'I0MK')
        call AddItemToStock(udg_MAVault[id], 'I0MK', rubi[id], rubi[id])
      
  else
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00The supposed angel says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Sorry, you don't have the required jewels, come back later...")
     
  endif
  
set itm=null



endfunction

//===========================================================================
function InitTrig_sanctus takes nothing returns nothing
    set gg_trg_sanctus=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_sanctus, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_sanctus, Condition(function Trig_sanctus_Conditions))
    call TriggerAddAction(gg_trg_sanctus, function Trig_sanctus_Actions)
endfunction


//===========================================================================
// Trigger: hats
//
// if (GemVar_A[playerId]>0)
//===========================================================================
function hatsc takes nothing returns boolean
    return ( GetWidgetLife(GetManipulatedItem()) == 59 )
endfunction
function notjewels takes integer id returns nothing
 call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00The seller says:|r")
 call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Sorry, you don't have the required jewels, come back later...")
     
endfunction

function hatsca takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local item it= GetManipulatedItem()
 local item itm
 local real x= GetUnitX(GetTriggerUnit())
 local real y= GetUnitY(GetTriggerUnit())
 
     if GetItemTypeId(it) == 'I07U' then //silent garment //160pvp
        if ( GemVar_A[id] >= 160 ) then
            set itm=CreateItem('I05T', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set GemVar_A[id]=GemVar_A[id] - 160
         
            call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
            call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
      
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I074' then //helm of pain//80e//80r//80s
            if ( rubi[id] >= 70 and emerald[id] >= 70 and saphire[id] >= 70 ) then
            set itm=CreateItem('I06V', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set rubi[id]=rubi[id] - 70
            set saphire[id]=saphire[id] - 70
            set emerald[id]=emerald[id] - 70
            call RemoveItemFromStock(udg_MAVault[id], 'I0MM')
            call AddItemToStock(udg_MAVault[id], 'I0MM', emerald[id], emerald[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0MN')
            call AddItemToStock(udg_MAVault[id], 'I0MN', saphire[id], saphire[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0MK')
            call AddItemToStock(udg_MAVault[id], 'I0MK', rubi[id], rubi[id])
      
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I078' then //general headgear//80o//80d//80r
            if ( rubi[id] >= 70 and diamond[id] >= 70 and onix[id] >= 70 ) then
            set itm=CreateItem('I06A', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set rubi[id]=rubi[id] - 70
            set onix[id]=onix[id] - 70
            set diamond[id]=diamond[id] - 70
            call RemoveItemFromStock(udg_MAVault[id], 'I0MJ')
            call AddItemToStock(udg_MAVault[id], 'I0MJ', onix[id], onix[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0MM')
            call AddItemToStock(udg_MAVault[id], 'I0MK', rubi[id], rubi[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
            call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I071' then //cryptlord headgear//70d//70s//70o
            if ( onix[id] >= 70 and diamond[id] >= 70 and saphire[id] >= 70 ) then
            set itm=CreateItem('I06G', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set onix[id]=onix[id] - 70
            set saphire[id]=saphire[id] - 70
            set diamond[id]=diamond[id] - 70
            call RemoveItemFromStock(udg_MAVault[id], 'I0MN')
            call AddItemToStock(udg_MAVault[id], 'I0MN', saphire[id], saphire[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0MJ')
            call AddItemToStock(udg_MAVault[id], 'I0MJ', onix[id], onix[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
            call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
           else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I079' then //flowered topper//50o//50pvp
            if ( onix[id] >= 50 and GemVar_A[id] >= 50 ) then
            set itm=CreateItem('I06U', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set onix[id]=onix[id] - 60
            set GemVar_A[id]=GemVar_A[id] - 50
           
             call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
             call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
             call RemoveItemFromStock(udg_MAVault[id], 'I0MJ')
             call AddItemToStock(udg_MAVault[id], 'I0MJ', onix[id], onix[id])
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I07T' then //samurais//50r//50d//50e
            if ( rubi[id] >= 50 and emerald[id] >= 50 and diamond[id] >= 50 ) then
            set itm=CreateItem('I06O', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set rubi[id]=rubi[id] - 50
            set diamond[id]=diamond[id] - 50
            set emerald[id]=emerald[id] - 50
            call RemoveItemFromStock(udg_MAVault[id], 'I0MM')
            call AddItemToStock(udg_MAVault[id], 'I0MM', emerald[id], emerald[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0MK')
            call AddItemToStock(udg_MAVault[id], 'I0MK', rubi[id], rubi[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
            call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I07F' then //skull mask//40s//30pvp
            if ( GemVar_A[id] >= 20 and saphire[id] >= 20 ) then
            set itm=CreateItem('I068', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
           
            set saphire[id]=saphire[id] - 20
            set GemVar_A[id]=GemVar_A[id] - 20
 
            call RemoveItemFromStock(udg_MAVault[id], 'I0MN')
            call AddItemToStock(udg_MAVault[id], 'I0MN', saphire[id], saphire[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
            call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
      
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I07A' then //wolf's head//100d//100s//100o
            if ( diamond[id] >= 90 and onix[id] >= 80 and saphire[id] >= 80 ) then
            set itm=CreateItem('I069', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set diamond[id]=diamond[id] - 90
            set saphire[id]=saphire[id] - 80
            set onix[id]=onix[id] - 80
            call RemoveItemFromStock(udg_MAVault[id], 'I0MN')
