function Trig_ankitarrive_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetEnteringUnit()) == 'h036' ) //ankit
endfunction

function scoutstop takes nothing returns nothing
local unit s= GetEnumUnit()
call IssueImmediateOrder(s, "stop")
call SetUnitPosition(s, GetUnitX(s), GetUnitY(s))
call MakeFaceToUnit(s , scoutguard) //wolfang
call SetUnitMoveSpeed(s, 0)

set s=null

endfunction

function Trig_ankitarrive_Actions takes nothing returns nothing
call DisableTrigger(gg_trg_ankitarrive)
call TriggerSleepAction(1)
call ForGroup(vguard, function scoutstop)
call SetUnitMoveSpeed(ankit, 220)
call MakeFaceToUnit(ankit , scoutguard) //wolfang
call TriggerSleepAction(1)
call UnitChat("Guard!!, How are things proceeding?" , ankit)
call TriggerSleepAction(2)
call MakeFaceToUnit(scoutguard , ankit) //wolfang
call UnitChat("Sir, It's going well, no nearby menaces, just this guy asking about the incident..." , scoutguard)
call TriggerSleepAction(4)
call UnitChat("No problem, Remember that any questioner must be sent to talk with me..." , ankit)
call SetUnitPosition(ankit, GetUnitX(ankit), GetUnitY(ankit))
call SetUnitFacing(ankit, 270)
call TriggerSleepAction(4)
call UnitChat("Sir, yes sir!!.." , scoutguard)
call TriggerSleepAction(2)
call UnitAddAbility(ankit, newquest)
call AddItemToStock(ankit, farm, 1, 1)


endfunction

