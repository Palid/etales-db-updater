function pvparenaclosing takes nothing returns nothing
local integer id= GetPlayerId(GetEnumPlayer())
    call ForceRemovePlayer(udg_pvp, GetEnumPlayer())
    call SetUnitPositionLoc(udg_PHero[id], udg_RevivalPoints[id])
    call SetUnitPositionLoc(udg_Slave[id], udg_RevivalPoints[id])
    call SetUnitPositionLoc(udg_Familiar[id], udg_RevivalPoints[id])
    call DisplayTimedTextToPlayer(GetEnumPlayer(), 0, 0, 6, "PvP Arena is closing due the incomming conflict.")
    
endfunction





