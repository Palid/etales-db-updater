//===========================================================================
// Trigger: FAMIR
//
// Pick Enchanted Armors 
// to get wich stat are increased i use the item level with mod operation:
// 2=AGI
// 3=STR
// 4=INT
// 5=""
// 6=Mana
// 7=Move Speed
// 8=Level ability
// 9=New ability
// HERO CLASS
// 1=archer
// 2=Assasin
// 3=paladin
// 4=Knight
// 5=Priest
// 6=mage
// 7=Available
// 8=availabe
// 9=Available
//===========================================================================
function FAMITRC takes nothing returns boolean
    return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_ARTIFACT and GetUnitPointValue(GetManipulatingUnit()) == 334 )
endfunction


function FAMITRA takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local integer itemlevel= GetItemLevel(GetManipulatedItem())
 local integer islevel=  ( ( ( ( itemlevel / 1000000 ) - 1 ) * 15 ) + 5 ) + ( ( ModuloInteger(itemlevel, 10000) / 1000 ) * 4 )
 local integer dmp= LoadInteger(nodump, GetHandleId(GetManipulatedItem()), GetHandleId(GetManipulatedItem()))
 local boolean owner= dmp - 10 == id
 if ( dmp > 9 and owner == false and not ( itemlevel == 222 ) ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, GetManipulatedItem())

     set u=null
     return
   endif
 //local integer isherotype =  ModuloInteger(itemlevel, 1000000) / 100000 
 //local integer unitclass = ModuloInteger(GetUnitPointValue(u)-100,20)
 
 
// call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()),.75,.2,2,I2S(unitclass))
 
    if ( GetUnitTypeId(u) == 'H00G' ) then
        set udg_HeroTipe[0]='H00G'
    endif
    
    if ( islevel > GetHeroLevel(udg_PHero[id]) ) then
       call UnitChat("|cffffcc00Low Level...!|r" , GetTriggerUnit())
       call UnitRemoveItem(u, GetManipulatedItem())
    endif

   
    set u=null
endfunction

