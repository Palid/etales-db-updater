endfunction

function Trig_PSK_Actions takes nothing returns nothing
   local unit u= GetSpellTargetUnit()
    call SetUnitVertexColorBJ(u, 10, 60, 100.00, 0.00)
    call TriggerSleepAction(15.00)
    call SetUnitVertexColorBJ(u, 100, 100, 100.00, 0.00)
    set u=null
endfunction

