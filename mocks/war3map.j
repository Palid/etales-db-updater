function InitTrig_ScorpionEngage takes nothing returns nothing
    set ScorpionTrg=CreateTrigger()
    call TriggerAddCondition(ScorpionTrg, Condition(function Scorpionec))
    call TriggerAddAction(ScorpionTrg, function Scorpionea)
endfunction


//===========================================================================
// Trigger: ScorpionWounded
//===========================================================================
function Trig_ScorpionWounded_Conditions takes nothing returns boolean
    return GetUnitStatePercent(gg_unit_U00O_0266, UNIT_STATE_LIFE, UNIT_STATE_MAX_LIFE) < 33.0
endfunction

function scorphelp takes nothing returns nothing
local timer t= GetExpiredTimer()
local integer te= LoadInteger(AiHash, GetHandleId(t), 0)
local integer i= 1

 
loop
  exitwhen i > te
  call RemoveDestructable(LoadDestructableHandle(AiHash, GetHandleId(t), i))
  set i=i + 1
 endloop
  
  
  
  call FlushChildHashtable(AiHash, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)


  set t=null
endfunction



function Trig_ScorpionWounded_Actions takes nothing returns nothing
local unit B= gg_unit_U00O_0266
local real x= 0
local real y= 0
local real xd= 0
local real yd= 0
local real sAng= 0
local timer t= null
local timer h= null
local integer i= 1
local integer te= 0
local unit dfx= null
local destructable d= null
local unit dmy= null
local unit gu= null
local boolexpr xfilter= Condition(function Scorpionfilter)
local group dmgg= CreateGroup()

call DisableTrigger(gg_trg_ScorpionWounded)
 call PauseUnit(B, true)
 call SetUnitInvulnerable(B, true)
 call SetUnitTimeScale(B, 0.65)
 call SetUnitAnimationByIndex(B, 6)
 call TriggerSleepAction(0.7)
 set sAng=GetUnitFacing(B)
 set x=GetUnitX(B)
 set y=GetUnitY(B)
 
 set xd=x + 100 * Cos(sAng * bj_DEGTORAD)
 set yd=y + 100 * Sin(sAng * bj_DEGTORAD)
 
 set dfx=CreateUnit(Player(12), 'n08X', xd, yd, 270) //enragerunit
 call SetUnitVertexColor(dfx, 127, 127, 127, 48)
 
 
 call PlaySoundBJ(gg_snd_scorWelcome)
 
 call TriggerSleepAction(0.6)
 call SetUnitTimeScale(B, 0.2)
 //call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "|cffffcc00Scorpion King screamss|r: Woooooaarrrggg..." )

 //call PlaySoundOnUnitBJ(gg_snd_scorWelcome, 127, B ) 
  call UnitApplyTimedLife(dfx, 'BTLF', 0.5)
     
    set x=GetUnitX(B)
    set y=GetUnitY(B)
    call GroupEnumUnitsInRange(dmgg, x, y, 1024, xfilter)
    call DestroyBoolExpr(xfilter)
    set xfilter=null

	   loop
	    set gu=FirstOfGroup(dmgg)
		  exitwhen gu == null
            if ( IsUnitEnemy(gu, GetOwningPlayer(B)) == true ) then
                set te=te + 1
           endif
                    
           call GroupRemoveUnit(dmgg, gu)
        endloop
        
       call DestroyGroup(dmgg)
       set dmgg=null
 
 set h=(NewTimerEx(0)) // INLINED!!
 set te=te + 1
   call SaveInteger(AiHash, GetHandleId(h), 0, te)
 loop
  exitwhen i > te
  set shelpX[i]=GetRandomReal(GetRectMinX(gg_rct_scorpion5), GetRectMaxX(gg_rct_scorpion3))
  set shelpY[i]=GetRandomReal(GetRectMinY(gg_rct_scorpion5), GetRectMaxY(gg_rct_scorpion3))
  
   set d=CreateDestructable('B00W', shelpX[i], shelpY[i], 270, 1.00, 0)
   call SaveDestructableHandle(AiHash, GetHandleId(h), i, d)
 
 
  set i=i + 1
 endloop
 
 
 call TimerStart(h, 6, false, function scorphelp)
 
 call TriggerSleepAction(3.6)

  set i=1

 
  loop
  exitwhen i > te

  set dmy=CreateUnit(Player(12), 'n04N', shelpX[i], shelpY[i], GetRandomReal(0, 359)) //black scorpion elite
  call ShowUnit(dmy, false)
  call UnitAddAbilityBJ('Amrf', dmy)
  call UnitRemoveAbilityBJ('Amrf', dmy)
  call SetUnitFlyHeight(dmy, 500, 0)
  call ShowUnit(dmy, true)
  call SetUnitFlyHeight(dmy, 0, 500)
  set i=i + 1
 endloop
 
 call PauseUnit(B, false)
 call SetUnitInvulnerable(B, false)
 
 
 
 
 set d=null
 set B=null
 set t=null
 set h=null
 set dfx=null
 set dmy=null
 set gu=null
endfunction

