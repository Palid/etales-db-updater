function lona takes nothing returns nothing
  local integer j= 0
  
  loop
    exitwhen j > 11
    
      if ( GetPlayerSlotState(Player(j)) == PLAYER_SLOT_STATE_PLAYING ) then
         set lights[j]=AddSpecialEffectTarget("Light.mdx", udg_PHero[j], "origin")
      endif
    
    set j=j + 1
    endloop
 

     set nightime=true
 
endfunction

