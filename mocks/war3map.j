//===========================================================================
// Trigger: upgrade
//===========================================================================
//===========================================================================
// Trigger: walffang test
//===========================================================================
function WFTC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0M7' )
endfunction

function WFTA takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer lev= GetUnitPointValue(udg_PHero[id]) - 100
local location p=udg_Pit_loc[1]

  if ( udg_Ogre_pit_ocu == true ) then
       call UnitChat("Wait a moment, someone is taking the test now...." , gg_unit_H01G_0302)
  elseif ( GetUnitTypeId(udg_PHero[id]) == 'H00G' or GetUnitTypeId(udg_PHero[id]) == 'H00G' ) then
        call UnitChat("Novices are not allowed to take this test!" , gg_unit_H01G_0302)
   elseif ( GetUnitUserData(udg_PHero[id]) < 900 ) then
            call UnitChat("You dont have neccesary experience to take this examen |n|cffffcc00Need 900 kills|r" , gg_unit_H01G_0302)
   elseif ( GetHeroLevel(udg_PHero[id]) < 17 ) then
           call UnitChat("You dont have neccesary level to take this examen |n|cffffcc00Need level 17|r" , gg_unit_H01G_0302)
   elseif ( 0 < lev and lev < 20 ) then
    
            call UnitChat("We need to check your powers. You will be sent to the Ogre Lord`s Arena" , gg_unit_H01G_0302)

            call TriggerSleepAction(2)
            call SetUnitPositionLoc(udg_PHero[id], p)
            call SetUnitPositionLoc(udg_Slave[id], p)
            call SetUnitPositionLoc(udg_Familiar[id], p)
            call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
            set udg_Ogre_pit_ocu=true
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "NEW QUEST")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "Kill the Ogre Lord...")
            call StartSound(bj_questDiscoveredSound)
            set udg_unit_hunt_ogre=udg_PHero[id]
            set PlayerInTest[id]=true
    endif
        

set p=null
set u=null

endfunction

//===========================================================================
function InitTrig_walffang_test takes nothing returns nothing
    set gg_trg_walffang_test=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_walffang_test, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_walffang_test, Condition(function WFTC))
    call TriggerAddAction(gg_trg_walffang_test, function WFTA)
endfunction


