//===========================================================================
// Trigger: chargue
//===========================================================================
// scope charguer begins

 
function btrue takes nothing returns boolean
return true
endfunction

function damaget takes unit u,unit a,real dmg returns nothing
 call UnitDamageTarget(u, a, dmg, true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_CLAW_HEAVY_SLICE)
endfunction

function iswalk takes location p returns boolean
  return IsTerrainPathable(GetLocationX(p), GetLocationY(p), PATHING_TYPE_WALKABILITY)
endfunction

function charguec takes nothing returns boolean
  return GetSpellAbilityId() == charguer__skillid
endfunction

function dartc takes nothing returns boolean
  return GetSpellAbilityId() == charguer__dartid
endfunction

function fastc takes nothing returns boolean
  return GetSpellAbilityId() == charguer__fastid
endfunction

function getfilter takes nothing returns boolean
    return true
endfunction

function fastbu takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local integer id= GetPlayerId(GetOwningPlayer(u))
local real face= LoadReal(hts, GetHandleId(t), 1)
local integer dist= LoadInteger(hts, GetHandleId(t), 2)
local location p= GetUnitLoc(u)
local real x= GetLocationX(p) + dist * Cos(face * bj_DEGTORAD)
local real y= GetLocationY(p) + dist * Sin(face * bj_DEGTORAD)
local group g= CreateGroup()
local unit gu= null
local boolexpr filter= Condition(function getfilter)
local location q= Location(x, y)
local real dmg
local real inspired= LoadReal(hts, GetHandleId(t), 4)
local real basedmg= 30
local real distbonus


if ( dist > 0 ) then
 set dist=dist - 2
else
 set dist=0
endif
 
 call SaveInteger(hts, GetHandleId(t), 2, dist)

 if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.3 ) then
     if IsTerrainWalkable(x , y) then
     call SetUnitPosition(u, x, y)
    endif
endif
  
   call GroupEnumUnitsInRange(g, x, y, 150, filter)
   //call GroupEnumUnitsInRangeOfLoc(g, q, 150, filter)
   call DestroyBoolExpr(filter)
   set filter=null

   loop

     set gu=FirstOfGroup(g)
        exitwhen gu == null
       
       if ( IsUnitEnemy(gu, GetOwningPlayer(u)) == true and GetWidgetLife(gu) > 0.405 ) then
      //  
        set distbonus=LoadReal(hts, GetHandleId(gu), 0) + 2
        
        set dmg=distbonus * inspired
        set dmg=dmg + dmg * AddRacialBonus(gu , id)
        if dmg > 0 then
        call DestroyEffect(AddSpecialEffectTarget(seffect, gu, "chest"))
        endif
        
        if IsUnitInGroup(gu, DartGroup) == true then
         set basedmg=GetHeroAgi(u, true) * 0.1
        endif
        
        call UnitDamageTarget(u, gu, basedmg * ( 7 + dmg ), true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
        endif
       
    call GroupRemoveUnit(g, gu)
    set gu=null
    endloop

call DestroyGroup(g)
set g=null
 
call RemoveLocation(p)
set p=null
call RemoveLocation(q)
set q=null


set t=null
set u=null
set gu=null

endfunction




function dartb takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real face= LoadReal(hts, GetHandleId(t), 2)
local real distance= LoadReal(hts, GetHandleId(t), 4)
local lightning l__l= LoadLightningHandle(hts, GetHandleId(t), 5)


local location p= GetUnitLoc(u)
local location q= GetUnitLoc(a)

local real x= GetLocationX(q) + distance * Cos(face * bj_DEGTORAD)
local real y= GetLocationY(q) + distance * Sin(face * bj_DEGTORAD)

if ( distance > 0 ) then
 set distance=distance - 2
else
 set distance=0
endif

call SaveReal(hts, GetHandleId(t), 4, distance)
call SaveReal(hts, GetHandleId(a), 0, distance)

call SetUnitPosition(a, x, y)
call MoveLightningEx(l__l, true, GetLocationX(p), GetLocationY(p), GetLocationZ(p) + 70, GetLocationX(q), GetLocationY(q), GetLocationZ(q) + 70)


call RemoveLocation(p)
set p=null
call RemoveLocation(q)
set q=null

set a=null
set u=null
set t=null
set l__l=null


endfunction


function dart takes nothing returns nothing
local unit u= GetTriggerUnit()
local unit a= GetSpellTargetUnit()
local real face= GetUnitFacing(u)
local location p= GetUnitLoc(u)
local location q= GetUnitLoc(a)
local real dx
local real dy
local real d
local timer t= (NewTimerEx(0)) // INLINED!!
local integer dist= 10

local lightning l__l= null

call GroupAddUnit(DartGroup, a)
set dx=GetLocationX(q) - GetLocationX(p)
set dy=GetLocationY(q) - GetLocationY(p)

set d=SquareRoot(dx * dx + dy * dy) / 15

set face=face + 180




call TriggerSleepAction(0.1)
set l__l=AddLightningEx("CLSB", true, GetLocationX(p), GetLocationY(p), GetLocationZ(p) + 70, GetLocationX(q), GetLocationY(q), GetLocationZ(q) + 70)
call SetLightningColor(l__l, 0.7, 0.2, 0.4, 0.5)
call DestroyEffect(AddSpecialEffectTarget(seffectb, a, "head"))


call SetUnitPathing(a, false)

call SaveUnitHandle(hts, GetHandleId(t), 0, u)
call SaveUnitHandle(hts, GetHandleId(t), 1, a)
call SaveReal(hts, GetHandleId(t), 2, face)
//call SaveInteger(hts,GetHandleId(t),3,dist)
call SaveReal(hts, GetHandleId(t), 4, d)
call SaveLightningHandle(hts, GetHandleId(t), 5, l__l)
call SetUnitAnimationByIndex(u, 1)

call TriggerSleepAction(0.2)
call SetUnitAnimation(a, "death")
call TimerStart(t, 0.02, true, function dartb)

call TriggerSleepAction(1)
call FlushChildHashtable(hts, GetHandleId(t))
call FlushChildHashtable(hts, GetHandleId(a))
call PauseTimer(t)
call ReleaseTimer(t)
call DestroyLightning(l__l)
set l__l=null
call SetUnitAnimation(u, "stand")


call RemoveLocation(p)
set p=null
call RemoveLocation(q)
set q=null
call SetUnitPathing(a, true)


call GroupRemoveUnit(DartGroup, a)
set u=null
set a=null

endfunction



function buclea takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local real face= LoadReal(hts, GetHandleId(t), 1)
local integer dist= LoadInteger(hts, GetHandleId(t), 2)
local location p= GetUnitLoc(u)
local real x= GetLocationX(p) + dist * Cos(face * bj_DEGTORAD)
local real y= GetLocationY(p) + dist * Sin(face * bj_DEGTORAD)
 
 
local location q= Location(x, y)


if ( dist > 0 ) then
 set dist=dist - 1
else
 set dist=0
endif
 
 call SaveInteger(hts, GetHandleId(t), 2, dist)

if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.3 ) then
  if IsTerrainWalkable(x , y) then
   call SetUnitPosition(u, x, y)
  endif
endif

//if (iswalk(q) == false) then

 
//else
 //call ReleaseTimer(t)
 //set t = null
//endif
 
call RemoveLocation(p)
set p=null
call RemoveLocation(q)

set q=null
set u=null
set t=null
endfunction


function bucles takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local real face= LoadReal(hts, GetHandleId(t), 1)
local integer dist= LoadInteger(hts, GetHandleId(t), 2)
local location p= GetUnitLoc(u)
local real x= GetLocationX(p) + dist * Cos(face * bj_DEGTORAD)
local real y= GetLocationY(p) + dist * Sin(face * bj_DEGTORAD)
 
 
local location q= Location(x, y)

if ( dist > 0 ) then
 set dist=dist - 2
else
 set dist=0
endif
 
 call SaveInteger(hts, GetHandleId(t), 2, dist)
 
 if IsTerrainWalkable(x , y) then
 call SetUnitPosition(u, x, y)
endif


//if (iswalk(q) == false) then

 
//else
 //call ReleaseTimer(t)
 //set t = null
//endif
 
call RemoveLocation(p)
set p=null
call RemoveLocation(q)
set q=null
set u=null
set t=null
endfunction



function moveat takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local unit a= GetSpellTargetUnit()
 local real face= GetUnitFacing(u)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local timer ta= (NewTimerEx(0)) // INLINED!!
 local integer dist= 30
 local integer dista= 20
 local location p= GetUnitLoc(u)
 local integer agi= GetHeroAgi(u, true)
 local real inspired= 1
 local real dmg= 0

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

 
   call SetUnitInvulnerable(u, true)
   call DestroyEffect(AddSpecialEffectTarget(seffect, a, "head"))
   call SaveUnitHandle(hts, GetHandleId(t), 0, u)
   call SaveReal(hts, GetHandleId(t), 1, face)
   call SaveInteger(hts, GetHandleId(t), 2, dist)
   
   call SaveUnitHandle(hts, GetHandleId(ta), 0, a)
   call SaveReal(hts, GetHandleId(ta), 1, face)
   call SaveInteger(hts, GetHandleId(ta), 2, dista)
   
   call SetUnitPathing(u, false)
   call SetUnitPathing(a, false)
  // call SetUnitVertexColor(u,255,55,55,170)
   if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.3 ) then
    set dmg=agi * 3.3 * inspired
    set dmg=dmg + dmg * AddRacialBonus(a , id)
   call UnitDamageTarget((u ), ( a ), (( dmg)*1.0), true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_CLAW_HEAVY_SLICE) // INLINED!!
   call CreateUbersplatBJ(p, "THND", 100, 100, 100, 0, false, false)
   call SetUbersplatRenderAlways(GetLastCreatedUbersplat(), true)
  
 
    call SetUnitFacing(u, face + 90)
   call PlaySoundOnUnitBJ(gg_snd_destajador, 45, u)
   call TimerStart(t, 0.02, true, function bucles)
   call SetUnitAnimationByIndex(u, 6)
   call TimerStart(ta, 0.02, true, function buclea)
   call SetUnitFacing(a, face - 315)
   call TriggerSleepAction(0.7)
   call PauseTimer(t)
   call PauseTimer(ta)
   endif
   
    if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.3 ) then
   set p=GetUnitLoc(u)
   call CreateUbersplatBJ(p, "THND", 100, 100, 100, 0, false, false)
   call SetUbersplatRenderAlways(GetLastCreatedUbersplat(), true)
   set dmg=agi * 1.5 * inspired
   set dmg=dmg + dmg * AddRacialBonus(a , id)
   call UnitDamageTarget((u ), ( a ), (( dmg)*1.0), true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_CLAW_HEAVY_SLICE) // INLINED!!
   call SetUnitFacing(u, face)
   call SetUnitAnimationByIndex(u, 9)
  // call SetUnitFacing(a, face - 390)
    call DestroyEffect(AddSpecialEffectTarget(seffect, a, "head"))
   set dist=30
   set dista=20
   call SaveInteger(hts, GetHandleId(t), 2, dist)
   call SaveInteger(hts, GetHandleId(ta), 2, dista)
   call TimerStart(t, 0.02, true, function bucles)
   call TimerStart(ta, 0.02, true, function buclea)

   call TriggerSleepAction(0.4)
   call PauseTimer(t)
    call PauseTimer(ta)
   endif
    
   if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.3 ) then
     
   set p=GetUnitLoc(u)
   call CreateUbersplatBJ(p, "THND", 100, 100, 100, 0, false, false)
   call SetUbersplatRenderAlways(GetLastCreatedUbersplat(), true)
   call SetUnitFacing(u, face + 20)
   call SetUnitAnimationByIndex(u, 5)
  // call SetUnitFacing(a, face - 480 )
   set dist=30
   set dista=25
   call SaveInteger(hts, GetHandleId(t), 2, dist)
   call SaveInteger(hts, GetHandleId(ta), 2, dista)
   call TimerStart(t, 0.02, true, function bucles)
   call TimerStart(ta, 0.02, true, function buclea)
  
  call TriggerSleepAction(0.3)
  call DestroyEffect(AddSpecialEffectTarget(seffect, a, "chest"))
  set dmg=agi * 1.5 * inspired
  set dmg=dmg + dmg * AddRacialBonus(a , id)
  call UnitDamageTarget((u ), ( a ), (( dmg)*1.0), true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_CLAW_HEAVY_SLICE) // INLINED!!
  call TriggerSleepAction(0.2)
  endif
  call FlushChildHashtable(hts, GetHandleId(t))
  call ReleaseTimer(t)
  
  call FlushChildHashtable(hts, GetHandleId(ta))
  call ReleaseTimer(ta)
  
  
  call SetUnitPathing(u, true)
  call SetUnitPathing(a, true)
  call SetUnitInvulnerable(u, false)
  call SetUnitAnimation(u, "stand")
//<  call SetUnitVertexColor(u,255,2555,255,255)
 set t=null
 set ta=null
 set u=null
 set a=null
 call RemoveLocation(p)
 set p=null
endfunction

function fast takes nothing returns nothing

 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local real face= GetUnitFacing(u)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer dist= 50
 local integer a= GetRandomInt(1, 3)
 local group enemy= CreateGroup()
 local location p= null
 local real amount= 300
 local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

 
  // call DestroyEffect(AddSpecialEffectTarget(seffect,a,"head"))
   call SaveUnitHandle(hts, GetHandleId(t), 0, u)
   call SaveReal(hts, GetHandleId(t), 1, face)
   call SaveInteger(hts, GetHandleId(t), 2, dist)
   call SaveGroupHandle(hts, GetHandleId(t), 3, enemy)
   call SaveReal(hts, GetHandleId(t), 4, inspired)
   call SetUnitVertexColor(u, 55, 55, 55, 70)

   call SetUnitPathing(u, false)
  
    call SetUnitFacing(u, face + 90)
   
   call TimerStart(t, 0.02, true, function fastbu)
   call SetUnitAnimationByIndex(u, 6)

   call TriggerSleepAction(0.5)
   
   call SetUnitFacing(u, face)
   call PauseTimer(t)
   call ReleaseTimer(t)


 
    
   call SetUnitVertexColor(u, 255, 255, 255, 255)
   call SetUnitPathing(u, true)
   call SetUnitAnimation(u, "stand")
   call RemoveLocation(p)
   set p=null

   call DestroyGroup(enemy)
   set enemy=null

   set u=null
   set t=null
  // set gu = null
 //  set g = null
   
endfunction


function chargue takes nothing returns nothing

 local integer i= 0
 local trigger tr= CreateTrigger()
 local trigger td= CreateTrigger()
 local trigger tf= CreateTrigger()
    loop
        call TriggerRegisterPlayerUnitEvent(tr, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function btrue))
        call TriggerRegisterPlayerUnitEvent(td, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function btrue))
        call TriggerRegisterPlayerUnitEvent(tf, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function btrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
     call TriggerAddCondition(tr, Condition(function charguec))
     call TriggerAddCondition(td, Condition(function dartc))
     call TriggerAddCondition(tf, Condition(function fastc))
     
     call TriggerAddAction(tr, function moveat)
     call TriggerAddAction(td, function dart)
     call TriggerAddAction(tf, function fast)
     
     
     set tr=null
     set td=null
     set tf=null
endfunction 



