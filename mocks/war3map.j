    set gg_trg_CreateHeroM=CreateTrigger()
    call RegionAddRect(r, gg_rct_Man)
    call TriggerRegisterEnterRegion(gg_trg_CreateHeroM, r, Condition(function herobool))
    call TriggerAddCondition(gg_trg_CreateHeroM, Condition(function Trig_CreateHeroM_Conditions))
    call TriggerAddAction(gg_trg_CreateHeroM, function Trig_CreateHeroM_Actions)
    set r=null
endfunction


