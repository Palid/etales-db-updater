function Trig_dieLeave_Conditions takes nothing returns boolean
    local integer id= GetPlayerId(GetOwningPlayer(GetDyingUnit()))
    return IsUnitType(GetDyingUnit(), UNIT_TYPE_HERO) == true and IsUnitInRegion(incidentTeam, GetDyingUnit()) == true and IsPlayerInForce(Player(id), teamEventForce) == true
endfunction

function dieLeaveBattle takes nothing returns nothing
      call MakeAlly(GetOwningPlayer(GetTriggerUnit()) , GetEnumPlayer())
      call MakeAlly(GetEnumPlayer() , GetOwningPlayer(GetTriggerUnit()))
endfunction

function Trig_dieLeave_Actions takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetDyingUnit()))
  local integer kid= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
           if IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) then
               call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 6, "|cffffcc00" + GetPlayerName(Player(id)) + killmsg[GetRandomInt(0, 5)] + GetPlayerName(Player(kid)) + "|r")
           endif
          
          call GroupAddUnit(diedheroes, GetDyingUnit())
          if IsPlayerInForce(Player(kid), teamEventForce) == true then
           set s__playerkills[kid]= s__playerkills[kid] + 1
           call LeaderboardSetItemValue(clashlb, LeaderboardGetPlayerIndex(clashlb, Player(kid)), s__playerkills[kid])
         endif
           
               if IsPlayerInForce(Player(id), teamA) == true then
                    set teamAp=teamAp - 1
                    if teamAp == 0 then
                      call EndTeamEvent(teamA)
                    endif
               elseif IsPlayerInForce(Player(id), teamB) == true then
                    set teamBp=teamBp - 1
                    if teamBp == 0 then
                     call EndTeamEvent(teamB)
                    endif
               endif
           call UpdateLeaderBoard()
           
endfunction

