function Trig_dressplayer_Actions takes nothing returns nothing
      local integer playerId= GetPlayerId(GetTriggerPlayer())
      local integer i= 0
      local item it= null
      local real x
      local real y
      
     // call DisplayTimedTextToPlayer(Player(playerId),.3,.2,8,"Loading...")
      call TriggerSleepAction(0.5)
      
    if ReadyForDress[playerId] == true then
   
    set ReadyForDress[playerId]=false
    
                 if ( GemVar_A[playerId] > 0 ) then
                     call AddItemToStock(udg_MAVault[playerId], 'I0UH', GemVar_A[playerId], GemVar_A[playerId])
                 endif
             
                 if ( onix[playerId] > 0 ) then
                     call AddItemToStock(udg_MAVault[playerId], 'I0MJ', onix[playerId], onix[playerId])
                 endif
                 
            
                 if ( emerald[playerId] > 0 ) then
                    call AddItemToStock(udg_MAVault[playerId], 'I0MM', emerald[playerId], emerald[playerId])
                 endif

             
                 if ( saphire[playerId] > 0 ) then
                      call AddItemToStock(udg_MAVault[playerId], 'I0MN', saphire[playerId], saphire[playerId])
                 endif

             
                 if ( diamond[playerId] > 0 ) then
                     call AddItemToStock(udg_MAVault[playerId], 'I0ML', diamond[playerId], diamond[playerId])
                 endif

                 
                if ( rubi[playerId] > 0 ) then
                     call AddItemToStock(udg_MAVault[playerId], 'I0MK', rubi[playerId], rubi[playerId])
                 endif
                call TriggerSleepAction(0.02)
    //give jewel box inventory item from saved game
           set i=0
           loop
              exitwhen i > 5
              if s__FrgItemId[(playerId)*(7)+i] > 0 then
                 call UnitAddItemToSlotById(udg_BMaster[playerId], s__FrgItemId[(playerId)*(7)+i], i)
                 call TriggerSleepAction(0.02)
              endif
              set i=i + 1
            endloop
           //allocating item charges on slots with item charges 
          
            set i=0
           loop
              exitwhen i > 5
               if s__FrgItemCh[(playerId)*(7)+i] > 0 then
               call SetItemCharges(UnitItemInSlot(udg_BMaster[playerId], s__FrgItemSl[(playerId)*(7)+i]), s__FrgItemCh[(playerId)*(7)+i])
             
               endif
             set i=i + 1
            endloop
          
          ///if GetItemType(UnitItemInSlot(udg_BMaster[playerId],udg_Slots[0]))==ITEM_TYPE_PURCHASABLE or GetItemType(UnitItemInSlot(udg_BMaster[playerId],udg_Slots[0]))==ITEM_TYPE_CHARGED then
         
         
                    set i=0
                    set x=GetUnitX(loadedUnit[playerId])
                    set y=GetUnitY(loadedUnit[playerId])
                    loop
                    exitwhen i > 5
                      if s__HerItemId[(playerId)*(7)+i] > 0 then
                        set it=CreateItem(s__HerItemId[(playerId)*(7)+i], x, y)
                        call UnitAddItem(loadedUnit[playerId], it)
                        call SaveInteger(nodump, GetHandleId(it), GetHandleId(it), playerId + 10)
                         set s__HerItemId[(playerId)*(7)+i]= 0
                         call TriggerSleepAction(0.02)
                      endif
                    set i=i + 1
                    endloop
           
                    set i=0
                    loop
                    exitwhen i > 5
                       if s__HerItemCh[(playerId)*(7)+i] > 0 then
                        call SetItemCharges(UnitItemInSlot(loadedUnit[playerId], s__HerItemSl[(playerId)*(7)+i]), s__HerItemCh[(playerId)*(7)+i])
                        set s__HerItemSl[(playerId)*(7)+i]= 13
                        set s__HerItemCh[(playerId)*(7)+i]= 0
                       endif
                    set i=i + 1
                    endloop
         //  call SetItemCharges(UnitItemInSlot(udg_BMaster[playerId],udg_Slots[0]),1)
          //  endif
                 set i=0
                    set x=GetUnitX(slave[playerId])
                    set y=GetUnitY(slave[playerId])
                    loop
                    exitwhen i > 5
                      if s__SolItemId[(playerId)*(7)+i] > 0 then
                        set it=CreateItem(s__SolItemId[(playerId)*(7)+i], x, y)
                        call UnitAddItem(slave[playerId], it)
                        
                        call SaveInteger(nodump, GetHandleId(it), GetHandleId(it), playerId + 10)
                         set s__SolItemId[(playerId)*(7)+i]= 0
                         call TriggerSleepAction(0.02)
                      endif
                    set i=i + 1
                    endloop
           
                    set i=0
                    loop
                    exitwhen i > 5
                       if s__SolItemCh[(playerId)*(7)+i] > 0 then
                        call SetItemCharges(UnitItemInSlot(slave[playerId], s__SolItemSl[(playerId)*(7)+i]), s__SolItemCh[(playerId)*(7)+i])
                        set s__SolItemSl[(playerId)*(7)+i]= 13
                        set s__SolItemCh[(playerId)*(7)+i]= 0
                       endif
                    set i=i + 1
                    endloop
 
          
          
          
                   set i=0
                    set x=GetUnitX(udg_ARVault[playerId])
                    set y=GetUnitY(udg_ARVault[playerId])
                    loop
                    exitwhen i > 5
                      if s__TenItemId[(playerId)*(7)+i] > 0 then
                        set it=CreateItem(s__TenItemId[(playerId)*(7)+i], x, y)
                        call UnitAddItem(udg_ARVault[playerId], it)
                        call SaveInteger(nodump, GetHandleId(it), GetHandleId(it), playerId + 10)
                         set s__TenItemId[(playerId)*(7)+i]= 0
                         call TriggerSleepAction(0.02)
                      endif
                    set i=i + 1
                    endloop
           
                    set i=0
                    loop
                    exitwhen i > 5
                       if s__TenItemCh[(playerId)*(7)+i] > 0 then
                        call SetItemCharges(UnitItemInSlot(udg_ARVault[playerId], s__TenItemSl[(playerId)*(7)+i]), s__TenItemCh[(playerId)*(7)+i])
                        set s__TenItemSl[(playerId)*(7)+i]= 13
                        set s__TenItemCh[(playerId)*(7)+i]= 0
                       endif
                    set i=i + 1
                    endloop
 
 
 
                   
          

                
                if ( Lf[playerId] > 0 ) then
                 set fallow[playerId]=true
                endif

                 call UnitAddAbility(loadedUnit[playerId], udg_FSpell[Lf[playerId]])
                 call UnitMakeAbilityPermanent(loadedUnit[playerId], true, udg_FSpell[Lf[playerId]])
                 
                 if Lf[playerId] == 4 or Lf[playerId] == 5 then
                    call UnitAddAbility(loadedUnit[playerId], 'A0EW') //relocation
                    call UnitMakeAbilityPermanent(loadedUnit[playerId], true, 'A0EW')
                 endif
                 
                 if Lf[playerId] == 5 then
                    call UnitAddAbility(loadedUnit[playerId], 'A0IQ') //rEkrom Lord
                    call UnitMakeAbilityPermanent(loadedUnit[playerId], true, 'A0IQ')
                 endif
                 
                set udg_Faction[playerId]=Lf[playerId]

        //give slave inventory item from saved game

                
            //    call TriggerExecute( gg_trg_ALLY )//enabling players alliances
             
             
             if Lfam[playerId] > 0 then
                    set i=0
                    set x=GetUnitX(familiar[playerId])
                    set y=GetUnitY(familiar[playerId])
                    loop
                    exitwhen i > 5
                      if s__FamItemId[(playerId)*(7)+i] > 0 then
                        set it=CreateItem(s__FamItemId[(playerId)*(7)+i], x, y)
                        call UnitAddItem(familiar[playerId], it)
                        call SaveInteger(nodump, GetHandleId(it), GetHandleId(it), playerId + 10)
                         set s__FamItemId[(playerId)*(7)+i]= 0
                         call TriggerSleepAction(0.02)
                      endif
                    set i=i + 1
                    endloop
           
                    set i=0
                    loop
                    exitwhen i > 5
                       if s__FamItemCh[(playerId)*(7)+i] > 0 then
                        call SetItemCharges(UnitItemInSlot(familiar[playerId], s__FamItemSl[(playerId)*(7)+i]), s__FamItemCh[(playerId)*(7)+i])
                        set s__FamItemSl[(playerId)*(7)+i]= 13
                        set s__FamItemCh[(playerId)*(7)+i]= 0
                       endif
                    set i=i + 1
                    endloop
                endif
                
                 call ClearTempLoad(playerId)
                 
               set prevlevel[playerId]=GetHeroLevel(udg_PHero[playerId])
               
               if nightime == true then
                 
                   set lights[playerId]=AddSpecialEffectTarget("Light.mdx", udg_PHero[playerId], "origin")
                 endif
                 
              if GetUnitAbilityLevel(udg_PHero[playerId], 'A075') > 0 or GetUnitAbilityLevel(udg_PHero[playerId], 'A05Z') > 0 then
                call TriggerRegisterUnitStateEvent(deactivateHR[playerId], udg_PHero[playerId], UNIT_STATE_MANA, LESS_THAN, 121.00)
              endif

        if boardCreated[playerId] == false then
            call NewBoard(playerId)
            
        endif
                 
        
     
     
     
     
    endif
    
    
    
    
    
endfunction

