     call TriggerAddCondition(tiveormoves[i], Condition(function Trig_IveorMovement_Conditions))
     call TriggerAddAction(tiveormoves[i], function Trig_IveorMovement_Actions)
  
  set i=i + 1
  endloop

endfunction


