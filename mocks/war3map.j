local real y= LoadReal(AiHash, GetHandleId(t), 2)

local real tx= GetRandomReal(x - 170, x + 170)
local real ty= GetRandomReal(y - 170, y + 170)

     call DestroyEffect(AddSpecialEffect(sffectdusta, tx, ty))
     call DestroyEffect(AddSpecialEffect(terranfx, tx, ty))
     

set t=null

endfunction



