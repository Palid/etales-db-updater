function InitTrig_Slaves takes nothing returns nothing
local integer i= 0
    set gg_trg_Slaves=CreateTrigger()
    loop
    
    call TriggerRegisterPlayerUnitEvent(gg_trg_Slaves, Player(i), EVENT_PLAYER_UNIT_ISSUED_POINT_ORDER, Condition(function bool))
    set i=i + 1
    exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
    call TriggerAddCondition(gg_trg_Slaves, Condition(function Trig_Slaves_Conditions))
    call TriggerAddAction(gg_trg_Slaves, function Trig_Slaves_Actions)
endfunction


//===========================================================================
// Trigger: soulslave
//===========================================================================
function Trig_soulslave_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I01S' )
endfunction

function Trig_soulslave_Actions takes nothing returns nothing
local integer pid= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local unit u= LoadUnitHandle(questtm, GetHandleId(GetManipulatedItem()), 3)
local real x= GetItemX(GetManipulatedItem())
local real y= GetItemY(GetManipulatedItem())
    set pslave[pid]=cslave[pid]
    call ShowUnit(pslave[pid], false)
    set cslave[pid]=null

   // call ReviveHero(u,x,y,false)
    set cslave[pid]=CreateUnit(Player(pid), GetUnitTypeId(u), x, y, 225)
    //call SetUnitOwner(cslave[pid], GetOwningPlayer(GetTriggerUnit()), true )
   // set slave[pid] = u
    call TriggerSleepAction(0.1)
    call UnitAddAbility(cslave[pid], 'A07R') //resurreccion
   // call UnitAddAbility(cslave[pid],'A0CC')//Free Slave
    call UnitAddAbility(cslave[pid], 'A0CT') //Slave inventory
     call UnitAddAbility(cslave[pid], 'A0CU') //hide
     call TriggerSleepAction(0.5)
     if cslave[pid] == null then
      call ShowUnit(pslave[pid], true)
      set cslave[pid]=pslave[pid]
      set pslave[pid]=null
     else
      call RemoveUnit(pslave[pid])
      set pslave[pid]=null
     endif
     
     
     
set u=null
endfunction

//===========================================================================
function InitTrig_soulslave takes nothing returns nothing
    set gg_trg_soulslave=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_soulslave, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_soulslave, Condition(function Trig_soulslave_Conditions))
    call TriggerAddAction(gg_trg_soulslave, function Trig_soulslave_Actions)
endfunction


