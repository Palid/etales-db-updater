function UnitChat takes string s,unit u returns nothing
 local real size= StringLength(s) / 5
    if ( size > 10 ) then
       set size=10
    endif
 
        call CreateTextTagUnitBJ(s, u, 10, 8.5, 90.00, 90.00, 90.00, 0.00)
        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
        call SetTextTagLifespan(GetLastCreatedTextTag(), size)
        call SetTextTagFadepoint(GetLastCreatedTextTag(), 1.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 90)
        
endfunction

function SpellName takes string s,unit u,real sizex returns nothing
 local real size= StringLength(s) / 5
 local real color= 75.00 - ( sizex * 8.33 )
 
        call CreateTextTagUnitBJ(s, u, 12, 8 + sizex, 100.00, color, color, 0.00)
        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
        call SetTextTagLifespan(GetLastCreatedTextTag(), size)
        call SetTextTagFadepoint(GetLastCreatedTextTag(), 1.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 90)
        
endfunction



function RescueQuest takes integer id,integer index returns integer
local integer i= 0
local integer q= 0
loop
 exitwhen i > 10
 
  
  if LoadInteger(questtm, GetHandleId(Player(id)), i) == index then
   //  call DisplayTimedTextToPlayer(Player(id),.1,0,4,I2S(q))
   return index
  endif
 set i=i + 1
 endloop

return 0

endfunction



function ManagePersQuest takes integer id returns integer
local integer i= 0
local integer j= 0
local integer q= 0
loop
 exitwhen i > 10
  set tmpQid[i]=0 //vacio la variable en el buffer temporal
  set q=LoadInteger(questtm, GetHandleId(Player(id)), i) //extraigo las ids de las quests guardadas en el handle del player
  if q > 0 then
   //  call DisplayTimedTextToPlayer(Player(id),.1,0,4,I2S(q))
   set tmpQid[j]=q //como el player tiene 5 posiciones para guardar verifico si hay datos en cada posicion
   set j=j + 1
  endif
 set i=i + 1
 endloop

set i=0
loop
 exitwhen i > 10
   call SaveInteger(questtm, GetHandleId(Player(id)), i, tmpQid[i]) //Desactivo la index de la quest para el jugador cambiandola por 0
 set i=i + 1
 endloop

return j //j+1 //devuelvo el numero de quest activas guardadas , las inactivas devolvieron valor 0

endfunction
    
function AddQuestLog takes integer index,integer id,string log,unit questunit returns nothing
 
 call SaveInteger(udg_cache, GetHandleId(questunit), GetHandleId(udg_PHero[id]), index)

        if index == 1 then
       set questr_1[id]=log
 elseif index == 2 then
       set questr_2[id]=log
 elseif index == 3 then
       set questr_3[id]=log
 elseif index == 4 then
       set questr_4[id]=log
 elseif index == 5 then
       set questr_5[id]=log
 endif

 call UnitChat("New quest registered!" , udg_Slave[id])
 
endfunction

function DisplayUpdatedQuest takes integer playerid,integer QuestIndex returns nothing
local string log= QSid[QuestIndex] + QSidx[QuestIndex] + QSidy[QuestIndex]

   if ( GetLocalPlayer() == Player(playerid) ) then
          call ClearTextMessages()
   endif

   call DisplayTimedTextToPlayer(Player(playerid), 0, 0, 10, "|cffffcc00QUEST UPDATE|r")
   call DisplayTimedTextToPlayer(Player(playerid), .1, 0, 10, log)
set log=null
endfunction

function UpdatePersQuestND takes integer id,integer QuestIndex,integer Data,string log,string var,string total returns nothing
    
    if Data != - 1 then
        set Qdata[QuestIndex]=Data
    endif
    if log != "-" then
        set QSid[QuestIndex]=log
    endif
    if var != "-" then
        set QSidx[QuestIndex]=var
    endif
    if total != "-" then
        set QSidy[QuestIndex]=total
    endif
    call ManagePersQuest(id)
   // call DisplayUpdatedQuest(id,QuestIndex)
       
endfunction



function UpdatePersQuest takes integer id,integer QuestIndex,integer Data,string log,string var,string total returns nothing
    
    if Data != - 1 then
        set Qdata[QuestIndex]=Data
    endif
    if log != "-" then
        set QSid[QuestIndex]=log
    endif
    if var != "-" then
        set QSidx[QuestIndex]=var
    endif
    if total != "-" then
        set QSidy[QuestIndex]=total
    endif
    call ManagePersQuest(id)
    call DisplayUpdatedQuest(id , QuestIndex)
    
    
endfunction

