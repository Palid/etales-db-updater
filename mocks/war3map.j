//===========================================================================
// Trigger: cam4a
//===========================================================================
function Trig_cam4a_Actions takes nothing returns nothing
local integer i= 0
local location p= Location(- 9190, - 3170)

loop
  exitwhen i > 9
    call CameraSetupApplyForPlayer(true, gg_cam_winter, Player(i), 0)
    //call SetCameraTargetController(udg_PHero[0], 0.00, 0.00, true )
    call CameraSetTargetNoiseForPlayer(Player(0), 300, 0.5)
    //call CameraSetSourceNoiseForPlayer( Player(i), 10, 0.1 )
    call CameraSetEQNoiseForPlayer(Player(0), 6)
    set i=i + 1
 endloop

 call IssuePointOrderLoc(udg_PHero[0], "move", p)
 call RemoveLocation(p)
 set p=null
    
endfunction

