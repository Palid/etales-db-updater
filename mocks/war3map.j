//===========================================================================
// Trigger: gatedet
//===========================================================================
function Trig_gatedet_Conditions takes nothing returns boolean
    return s__GateIsOpen[LoadInteger(questtm, GetHandleId(GetTriggeringRegion()), 0)] == false and IsUnitType(GetEnteringUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_gatedet_Actions takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local integer Bid= LoadInteger(questtm, GetHandleId(GetTriggeringRegion()), 0)
   
   set s__nocamp[id]= true
  
    
    if cowardslev[Bid] < GetUnitLevel(u) or s__gatesopened[(id)*(7)+Bid] == true then
        set s__GateIsOpen[Bid]= true
        call ModifyGateBJ(bj_GATEOPERATION_OPEN, taxgates[Bid])
        call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, u)
        call TriggerSleepAction(1.5)
        if cowardslev[Bid] < GetUnitLevel(u) and GetRandomInt(0, 4) == 3 then
        call MakeFaceToUnit(s__taxer[Bid] , u)
        call UnitChat(cowards[GetRandomInt(1, 27)] , s__taxer[Bid])
        endif
        call TriggerSleepAction(8.5)
        set s__GateIsOpen[Bid]= false
        call ModifyGateBJ(bj_GATEOPERATION_CLOSE, taxgates[Bid])
        call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, u)
     endif
        set u=null
endfunction

//===========================================================================
function InitTrig_gatedet takes nothing returns nothing
    set gg_trg_gatedet=CreateTrigger()

    call TriggerAddCondition(gg_trg_gatedet, Condition(function Trig_gatedet_Conditions))
    call TriggerAddAction(gg_trg_gatedet, function Trig_gatedet_Actions)
endfunction


