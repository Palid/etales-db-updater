//===========================================================================
// Trigger: dwarvenfind
//
//  bj_questCompletedSound
//===========================================================================
function Trig_dwarvenfind_Actions takes nothing returns nothing
    local location p= Location(10745, 13832)
//Disabling tina help request
    call DisableTrigger(gg_trg_tinahelp)
    call DisableTrigger(gg_trg_Discoverbrok)
    
    call UnitAddAbility(udg_tina, 'Awan')
    call SetUnitPositionLoc(udg_tina, udg_forgerini)

//---run from here------------------
    call DisableTrigger(GetTriggeringTrigger())
    call ShowUnit(udg_forger, true)
    call SetUnitPathing(udg_forger, false)
    call UnitAddAbility(udg_forger, 'Aloc')
     
    call UnitChat("¡¡H E L P !!" , udg_forger)
    call TriggerSleepAction(2)
    call UnitChat("¿¿Someone here??" , udg_forger)
    call TriggerSleepAction(2)
    call UnitChat("¡Thanks Godness!, I was trapped here..." , udg_forger)
    call TriggerSleepAction(2)
    call UnitChat("My name is Brok, i am a forger..." , udg_forger)
    call IssuePointOrderLoc(udg_forger, "move", p)
    call TriggerSleepAction(2)
    call UnitChat("je,je,je.. I lost myself again." , udg_forger)
    call TriggerSleepAction(1)
    call UnitChat("So, if you want to forge any weapon, visit me at the Scout Post, near to the Silent River.." , udg_forger)
    call TriggerSleepAction(2)
  
    call RemoveLocation(p)
    set p=null
    
    

    
    
endfunction

