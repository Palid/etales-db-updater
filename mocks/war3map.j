    call TriggerRegisterAnyUnitEventBJ(gg_trg_MBT, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_MBT, Condition(function MBTC))
    call TriggerAddAction(gg_trg_MBT, function MBTA)
endfunction


//===========================================================================
// Trigger: MBA
//
// 
//===========================================================================
function displace_action takes nothing returns nothing
    local timer tn= GetExpiredTimer()
    local unit u= LoadUnitHandleBJ(StringHashBJ("caster"), GetHandleIdBJ(tn), udg_cache)
    local real inc= LoadRealBJ(StringHashBJ("inc"), GetHandleIdBJ(tn), udg_cache)
    local real ang= LoadRealBJ(StringHashBJ("angle"), GetHandleIdBJ(tn), udg_cache)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    
  // if (IsTerrainPathableBJ(p1, PATHING_TYPE_WALKABILITY) == true) then 
     // set inc = inc + 1
  //else
     // set inc = 0
  // endif

    set inc=inc - 1

    call SetUnitPositionLoc(u, p1)
    call RemoveLocation(p)
    set p=null
    call RemoveLocation(p1)
    set p1=null
    call SaveRealBJ(inc, StringHashBJ("inc"), GetHandleIdBJ(tn), udg_cache)

    set u=null
    call DisplayTextToForce(GetPlayersAll(), R2S(inc))



      set tn=null
    
   
endfunction

function Ddisplace takes nothing returns nothing
   local unit u= GetTriggerUnit()
   local location p= GetUnitLoc(u)
   local real ang= GetUnitFacing(u) + 180
   local timer tm= (NewTimerEx(0)) // INLINED!!
   local real inc= 15

   
    call SaveUnitHandleBJ(u, StringHashBJ("caster"), GetHandleIdBJ(tm), udg_cache)
    call SaveRealBJ(inc, StringHashBJ("inc"), GetHandleIdBJ(tm), udg_cache)
    call SaveRealBJ(ang, StringHashBJ("angle"), GetHandleIdBJ(tm), udg_cache)


    call TimerStart(tm, 0.01, true, function displace_action)
    call PolledWait(0.1)
    call PauseTimer(tm)
    call ReleaseTimer(tm)
    set tm=null
    //call FlushChildHashtableBJ(GetHandleIdBJ(tm), udg_cache)

    set inc=0
    set ang=0
    call RemoveLocation(p)
    set p=null
    set u=null
endfunction

//===========================================================================
function InitTrig_MBA takes nothing returns nothing
    set gg_trg_MBA=CreateTrigger()
    call TriggerAddAction(gg_trg_MBA, function Ddisplace)
endfunction


