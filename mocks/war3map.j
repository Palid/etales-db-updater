    return ( GetItemTypeId(GetManipulatedItem()) == 'I09H' )
endfunction

function walorcka takes nothing returns nothing
   local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   local integer questid
   call MakeFaceToUnit(gg_unit_h02S_0463 , udg_PHero[id])

   if ( GetUnitTypeId(GetTriggerUnit()) != 'H02A' ) then
    
      call UnitChat("You haven't born from the inner of the Earth (orc), you cannot take this test" , gg_unit_h02S_0463)
      
        
   elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
      call UnitChat("You know what you must do!" , gg_unit_n08D_0232)
        
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
      call UnitChat("You need to be more experienced surviving battles.. |n|cffffcc00Needs 300 kills|r!" , gg_unit_h02S_0463)
          
        else
         call UnitChat("I remember that I saw some orcs climbing on a mountain in the northen orc lands." , gg_unit_n08D_0232)
         call TriggerSleepAction(2)
         call UnitChat("They were called as warlocs and that mountain was an altar." , gg_unit_h02S_0463)
         call TriggerSleepAction(2)
         call UnitChat("They invoked thunders above the summit... ." , gg_unit_h02S_0463)
       
         set s__inwarlock[id]= true
 
         call GroupAddUnit(udg_inTest, udg_PHero[id])
         call TriggerSleepAction(2)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "|cffffcc00MAIN QUEST DISCOVERED|r")
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "          |cffeeee88Calling a thunder|r: Travel to the walorck's mountain in the orc northern lands...")
         set questid=SetupQuest(id , null , "CALLING A THUNDER" , "Travel to the walorcks mountain in the orc northern lands" , "-" , "-" , 0 , s__qty[2])
         call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
        
        
         call StartSound(bj_questDiscoveredSound)
          call TriggerSleepAction(2)
          if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
            call PingMinimap(1045, 19345, 15)
        //call StartSound(bj_pingMinimapSound)
          endif
           
      endif

endfunction



