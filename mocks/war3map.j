 call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "|cffffcc00The Flames of Enthashara:|r The altar of |cffffcc00Winter Keeper's|r is ready, Enable |cffffcc00Forgotten Swamp|r altar|r")
