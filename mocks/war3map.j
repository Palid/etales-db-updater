    set gg_trg_stackscrvit=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_stackscrvit, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_stackscrvit, Condition(function scrcvit))
    call TriggerAddAction(gg_trg_stackscrvit, function scravit)
endfunction


//===========================================================================
// Trigger: stackrubi
//
// I090 diamond fr
// I091 emerald fr
// I096 onyx fr
// I097 rubi fr
// I098 saphire fr
//===========================================================================
//TESH.scrollpos=21
//TESH.alwaysfold=0

function STRUC takes nothing returns boolean
    return GetItemTypeId(GetManipulatedItem()) == 'I0S9'
endfunction

function STRUA takes nothing returns nothing
  local item jw= CreateItem('I097', 0, 0)
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local integer chargues= GetItemCharges(jw)
  
  call DisableTrigger(gg_trg_stackrubi)
 //r call RemoveItem(GetManipulatedItem())
//  call UnitRemoveItem(GetTriggerUnit(),jw)
 
  call UnitAddItem(udg_BMaster[id], jw)
  
   if ( GetItemTypeCount(udg_BMaster[id] , 'I097') > 1 ) then
    call RemoveItem(jw)
    
     set chargues=chargues + GetItemCharges(GetMainJewel(udg_BMaster[id] , 'I097'))
     call SetItemCharges(GetMainJewel(udg_BMaster[id] , 'I097'), chargues)
    endif
    
      if ( GetItemCharges(GetMainJewel(udg_BMaster[id] , 'I097')) > 4 ) then
       call RemoveItem(GetMainJewel(udg_BMaster[id] , 'I097'))
       
       call PlaySoundOnUnitBJ(bj_questSecretSound, 75, udg_PHero[id])
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    |cff00ccffRubi completed and added to vault|r")
     // call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Items\\AIem\\AIemTarget.mdl",udg_PHero[id],"origin"))
     //    call UnitAddItemByIdSwapped( 'I0MK',udg_BMaster[id])
      set rubi[id]=rubi[id] + 1
     call releasejewel(id)
     endif
     

    call EnableTrigger(gg_trg_stackrubi)
    set jw=null
    
endfunction

//===========================================================================
function InitTrig_stackrubi takes nothing returns nothing
    set gg_trg_stackrubi=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_stackrubi, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_stackrubi, Condition(function STRUC))
    call TriggerAddAction(gg_trg_stackrubi, function STRUA)
endfunction


