//===========================================================================
// Trigger: rotation
//===========================================================================
function Trig_rotation_Actions takes nothing returns nothing
 local integer i= 0
 local real x
 local real y
 local real dist= 750
 local real face
 
  loop
    exitwhen i > 8
    if traveling[i] == true then
     set face=GetUnitFacing(udg_zeppelinunit[i])
     call SetCameraFieldForPlayer(Player(i), CAMERA_FIELD_ROTATION, face, 1.5)
     set x=GetUnitX(udg_zeppelinunit[i]) + dist * Cos(face * bj_DEGTORAD)
     set y=GetUnitY(udg_zeppelinunit[i]) + dist * Sin(face * bj_DEGTORAD)
    
      if ( GetLocalPlayer() == Player(i) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call PanCameraToTimed(x, y, 0.04)
      endif
     
    endif
    set i=i + 1
    endloop
endfunction

//===========================================================================
function InitTrig_rotation takes nothing returns nothing
    set gg_trg_rotation=CreateTrigger()
    call TriggerRegisterTimerEventPeriodic(gg_trg_rotation, 0.04)
    call TriggerAddAction(gg_trg_rotation, function Trig_rotation_Actions)
endfunction


//===========================================================================
// Trigger: rotationH
//===========================================================================
function Trig_rotationH_Actions takes nothing returns nothing
 local integer i= 0
 local real x
 local real y
 local real xc
 local real yc
 local real xd
 local real yd
 local real xh
 local real yh
 local real xr
 local real yr
 local real z
 local real z1
 //local real dist = 470
 local real face
 
 set cmcicle=cmcicle + 1
 if cmcicle > 5 then
  set cmcicle=0
 endif
 
  loop
    exitwhen i > 8
    if travel3d[i] == true then
      set xh=GetUnitX(udg_PHero[i])
      set yh=GetUnitY(udg_PHero[i])
      
     set xc=GetUnitX(udg_PHero[i])
     set yc=GetUnitY(udg_PHero[i])
     call MoveLocation(l, xc, yc)
     set z=GetLocationZ(l)
     set xd=xc + 64 * Cos(GetUnitFacing(udg_PHero[i]) * bj_DEGTORAD)
     set yd=yc + 64 * Sin(GetUnitFacing(udg_PHero[i]) * bj_DEGTORAD)
     call MoveLocation(l, xd, yd)
     set z1=GetLocationZ(l)
     
     
     set face=GetUnitFacing(udg_PHero[i])
     set xr=face - prev_f[i]
     set xr=SquareRoot(xr * xr)
     if xh != prev_x[i] and yh != prev_y[i] then
      
       call SetCameraFieldForPlayer(Player(i), CAMERA_FIELD_ROTATION, face, crot)
      // call SetCameraFieldForPlayer( Player(i), CAMERA_FIELD_ANGLE_OF_ATTACK, cangle, 0 )
     
      if GetLocalPlayer() == Player(i) then
       call SetCameraField(CAMERA_FIELD_ANGLE_OF_ATTACK, cangle + ( ( z1 - z ) * 0.5 ), 0.32)
       call SetCameraField(CAMERA_FIELD_ZOFFSET, GetCameraField(CAMERA_FIELD_ZOFFSET) + z - GetCameraTargetPositionZ() + 128, - 0.01)
       call SetCameraField(CAMERA_FIELD_ZOFFSET, GetCameraField(CAMERA_FIELD_ZOFFSET) + z - GetCameraTargetPositionZ() + 128, 0.01)
           
      endif
     
     //  set xr = xh*
      
       set x=GetUnitX(udg_PHero[i]) + cdist * Cos(face * bj_DEGTORAD)
       set y=GetUnitY(udg_PHero[i]) + cdist * Sin(face * bj_DEGTORAD)
      
      
      if ( GetLocalPlayer() == Player(i) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call PanCameraToTimed(x, y, cpan)
      endif
    endif
    
    set prev_x[i]=xh
    set prev_y[i]=yh
    set prev_f[i]=face
    endif
    set i=i + 1
    endloop
endfunction

//===========================================================================
function InitTrig_rotationH takes nothing returns nothing
    set gg_trg_rotationH=CreateTrigger()
   // call DisableTrigger(gg_trg_rotationH)
    call TriggerRegisterTimerEventPeriodic(gg_trg_rotationH, 0.04)
    call TriggerAddAction(gg_trg_rotationH, function Trig_rotationH_Actions)
endfunction


//===========================================================================
// Trigger: startstat
//
//     integer array   TMPstats[9][6]
//     integer array   TMPresiduo[9]
//     boolean array   ISreseting[9]
//===========================================================================
function Trig_startstat_Conditions takes nothing returns boolean
    return GetItemTypeId(GetManipulatedItem()) == 'I0FB'
endfunction

function Trig_startstat_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer i= 0
local integer index= 0

     loop
        if ( UnitItemInSlot(udg_PHero[id], index) != null ) then
            call UnitChat("You mustn't wear any item to take a reassignation" , gg_unit_n08P_0411)
            call AdjustPlayerStateBJ(93021, Player(id), PLAYER_STATE_RESOURCE_GOLD)
            return
        endif

        set index=index + 1
        exitwhen index >= bj_MAX_INVENTORY
    endloop


    if s__ISreseting[id] == true then

      call UnitChat("You already are in a reassignation" , gg_unit_n08P_0411)
      call AdjustPlayerStateBJ(93021, Player(id), PLAYER_STATE_RESOURCE_GOLD)
    elseif s__dstate[id] > 0 then
       call UnitChat("You actual state doesn't allow me to take reassignation" , gg_unit_n08P_0411)
      call AdjustPlayerStateBJ(93021, Player(id), PLAYER_STATE_RESOURCE_GOLD)
      
      
    else
      set s__ISreseting[id]= true
      loop
      exitwhen i > 5
      set s__TMPstats[(id)*(6)+i]= 0
      
      set i=i + 1
      endloop
      
      set s__TMPresiduo[id]= 0
      set s__OriginalAmn[id]= 0
      
      call GetStats(udg_PHero[id] , id)
      
      set s__TMPresiduo[id]= udg_STR[id] + udg_AGI[id] + udg_INT[id] + s__SVFortune[id] + s__SVMstrength[id] + s__SVConstitution[id]
      
      set s__OriginalAmn[id]= s__TMPresiduo[id]
      
      set reassignt[id]=(NewTimerEx(0)) // INLINED!!
      call SaveInteger(questtm, GetHandleId(reassignt[id]), 1, id + 10)
     
      
      
      call UpdateReset(id)
    endif


endfunction

//===========================================================================
function InitTrig_startstat takes nothing returns nothing
    set gg_trg_startstat=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_startstat, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_startstat, Condition(function Trig_startstat_Conditions))
    call TriggerAddAction(gg_trg_startstat, function Trig_startstat_Actions)
endfunction


//===========================================================================
// Trigger: startreset
//===========================================================================
//TESH.scrollpos=147
//TESH.alwaysfold=0
function IsonReset takes nothing returns boolean
  return s__ISreseting[GetPlayerId(GetTriggerPlayer())] == true
endfunction

function AssignStat takes integer amnt,integer id,integer i returns nothing
         if amnt > 0 and amnt < 1201 and amnt <= s__TMPresiduo[id] then
             
             if s__TMPstats[(id)*(6)+i] > 0 then
                 set s__TMPresiduo[id]= s__TMPresiduo[id] + s__TMPstats[(id)*(6)+i]
                 set s__TMPstats[(id)*(6)+i]= amnt
                 set s__TMPresiduo[id]= s__TMPresiduo[id] - amnt
                 else
                 set s__TMPstats[(id)*(6)+i]= amnt
                 set s__TMPresiduo[id]= s__TMPresiduo[id] - amnt
             endif
             
         endif
         
         call UpdateReset(id)

endfunction

function AssignAdvStat takes integer amnt,integer id,integer i returns nothing
         if amnt > 0 and amnt < 901 and amnt <= s__TMPresiduo[id] then
             
             if s__TMPstats[(id)*(6)+i] > 0 then
                 set s__TMPresiduo[id]= s__TMPresiduo[id] + s__TMPstats[(id)*(6)+i]
                 set s__TMPstats[(id)*(6)+i]= amnt
                 set s__TMPresiduo[id]= s__TMPresiduo[id] - amnt
                 else
                 set s__TMPstats[(id)*(6)+i]= amnt
                 set s__TMPresiduo[id]= s__TMPresiduo[id] - amnt
             endif
             
         endif
         
         call UpdateReset(id)

endfunction


function Trig_startreset_Actions takes nothing returns nothing
local integer id=GetPlayerId(GetTriggerPlayer())
local integer i= 0
local string chat= StringCase(GetEventPlayerChatString(), true)
local string cmd= SubString(chat, 5, 8)
local string done= SubString(chat, 5, 9)
local string reset= SubString(chat, 5, 10)
local integer amnt= 0
local integer total= 0




 //if ISreseting[id]== true then

        set amnt=S2I(SubString(chat, 9, 13))

              if cmd == "STR" then
               call AssignStat(amnt , id , 0)
               
         elseif cmd == "AGI" then
                call AssignStat(amnt , id , 1)

          elseif cmd == "INT" then
                call AssignStat(amnt , id , 2)

           elseif cmd == "FRT" then
                call AssignAdvStat(amnt , id , 3)
                 
           elseif cmd == "MSR" then
               call AssignAdvStat(amnt , id , 4)

           elseif cmd == "CNS" then
               call AssignAdvStat(amnt , id , 5)
                 
           elseif done == "DONE" then
           
               call UpdateReset(id)
               
               if UnitInventoryCount(udg_PHero[id]) > 0 then
                 
                  call DisplayTimedTextToPlayer(Player(id), .5, .1, 15, "Please retire all items on your hero to apply the reassignation")
                  
               elseif s__TMPresiduo[id] == 0 then
               
                    set total=s__TMPstats[(id)*(6)+0] + s__TMPstats[(id)*(6)+1] + s__TMPstats[(id)*(6)+2] + s__TMPstats[(id)*(6)+3] + s__TMPstats[(id)*(6)+4] + s__TMPstats[(id)*(6)+5]
                    
                    if s__OriginalAmn[id] == total then
                                
                            set s__TMPstats[(id)*(6)+1]= s__TMPstats[(id)*(6)+1] + 35
                            set s__TMPstats[(id)*(6)+0]= s__TMPstats[(id)*(6)+0] + 35
                            set s__TMPstats[(id)*(6)+2]= s__TMPstats[(id)*(6)+2] + 35
                                
                     call SetHeroAgi(udg_PHero[id], s__TMPstats[(id)*(6)+1], true)
                     call SetHeroStr(udg_PHero[id], s__TMPstats[(id)*(6)+0], true)
                     call SetHeroInt(udg_PHero[id], s__TMPstats[(id)*(6)+2], true)

                     set s__Mstrength[id]= s__TMPstats[(id)*(6)+4]
                     set s__Fortune[id]= s__TMPstats[(id)*(6)+3]
                     set s__Constitution[id]= s__TMPstats[(id)*(6)+5]
                     call StartSound(bj_questHintSound)

                     call DisplayTimedTextToPlayer(Player(id), .5, .1, 15, "|cffffcc00Reassignation Completed. You can take on your clothes|r")

                     call PauseTimer(reassignt[id])
                     call FlushChildHashtable(questtm, GetHandleId(reassignt[id]))
                     call ReleaseTimer(reassignt[id])
                     set reassignt[id]=null
                                         
                      loop
                      exitwhen i > 5
                      set s__TMPstats[(id)*(6)+i]= 0
                      set i=i + 1
                      endloop
                       set s__TMPresiduo[id]= 0
                       set s__OriginalAmn[id]= 0
                       
                       set s__ISreseting[id]= false
                         
                         
                    endif
               
               
               else
                  call UpdateReset(id)
                  call DisplayTimedTextToPlayer(Player(id), .5, .1, 15, "|cffffcc00There are remaining points to be assigned, please assign all your points|r")
         
               
               endif
           
           
           elseif reset == "RESET" then
             loop
              exitwhen i > 5
              set s__TMPstats[(id)*(6)+i]= 0
              set i=i + 1
              endloop
               set s__TMPresiduo[id]= 0
              // call GetStats(udg_PHero[id],id)
               set s__TMPresiduo[id]= s__OriginalAmn[id]
               call UpdateReset(id)
          else
           call DisplayTimedTextToPlayer(Player(id), .5, .1, 15, "|cffffcc00Unknown instruction entered.|r")
         endif
 
 // endif //Isreseting
  
set chat=null
set cmd=null
set amnt=0
   
endfunction

//===========================================================================
function InitTrig_startreset takes nothing returns nothing
local integer i= 0
    set gg_trg_startreset=CreateTrigger()
    loop
    exitwhen i > 8
    call TriggerRegisterPlayerChatEvent(gg_trg_startreset, Player(i), "-set", false)
    set i=i + 1
    endloop
     call TriggerAddCondition(gg_trg_startreset, Condition(function IsonReset))
    
    call TriggerAddAction(gg_trg_startreset, function Trig_startreset_Actions)
endfunction


//===========================================================================
// Trigger: gatelib
//===========================================================================
//===========================================================================
// Trigger: homecast
//===========================================================================
function Trig_homecast_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A0CG'
endfunction

function Trig_homecast_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local effect fx= AddSpecialEffectTarget(masstel, udg_PHero[id], "origin")
 local real x= GetUnitX(udg_PHero[id])
 local real y= GetUnitY(udg_PHero[id])
 
  call TriggerSleepAction(4)
  call DestroyEffect(AddSpecialEffectTarget(seblink, udg_PHero[id], "origin"))
  call DestroyEffect(AddSpecialEffectTarget(seblink, udg_Familiar[id], "origin"))
  call DestroyEffect(AddSpecialEffectTarget(seblink, udg_Slave[id], "origin"))
  if ( cslave[id] != null ) then
        call DestroyEffect(AddSpecialEffectTarget(seblink, cslave[id], "origin"))
  endif
  
  call TriggerSleepAction(0.5)
  call SetUnitPositionLoc(udg_PHero[id], udg_RevivalPoints[id])
  call SetUnitPositionLoc(udg_Slave[id], udg_RevivalPoints[id])
  call SetUnitPositionLoc(udg_Familiar[id], udg_RevivalPoints[id])
  if ( cslave[id] != null ) then
        call SetUnitPositionLoc(cslave[id], udg_RevivalPoints[id])
  endif
  call PanCameraToTimedLocForPlayer(GetOwningPlayer(udg_PHero[id]), udg_RevivalPoints[id], 0)
  call ShowUnit(homeg[id], true)
  call SetUnitPosition(homeg[id], x, y)
  call DestroyEffect(fx)
  
  set fx=null
  call UnitRemoveAbility(udg_Slave[id], 'A0CG')
  call UnitAddAbility(udg_Slave[id], 'A0FP')
  
  call TriggerSleepAction(300)
  call UnitRemoveAbility(udg_Slave[id], 'A0FP')
  call UnitAddAbility(udg_Slave[id], 'A0CG')
  call ShowUnit(homeg[id], false)

endfunction

//===========================================================================
function InitTrig_homecast takes nothing returns nothing
local integer i= 0
    set gg_trg_homecast=CreateTrigger()
    loop
     exitwhen i > 8
      call TriggerRegisterPlayerUnitEvent(gg_trg_homecast, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function istrue))
      set i=i + 1
     endloop
    call TriggerAddCondition(gg_trg_homecast, Condition(function Trig_homecast_Conditions))
    call TriggerAddAction(gg_trg_homecast, function Trig_homecast_Actions)
endfunction


