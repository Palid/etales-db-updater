    call TriggerRegisterAnyUnitEventBJ(gg_trg_hussarapi, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_hussarapi, Condition(function hapic))
    call TriggerAddAction(gg_trg_hussarapi, function hapia)
