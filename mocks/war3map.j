endfunction

function Trig_Discoverbrok_Actions takes nothing returns nothing
   call DisableTrigger(gg_trg_Discoverbrok)


    call IssueImmediateOrder(GetTriggerUnit(), "stop")
    call TriggerSleepAction(1)
    call UnitChat("I am very worried..." , udg_tina)
    call TriggerSleepAction(2)
    call UnitChat("My uncle Brok is lost." , udg_tina)
    call TriggerSleepAction(3)
    call UnitChat("He don´t come back to home from last 4 days." , udg_tina)
    call TriggerSleepAction(3)
    call UnitChat("Please find Him." , udg_tina)
    call TriggerSleepAction(2)
    
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00MAIN QUEST:|r Find Tina's uncle.")
    
    
    call StartSound(bj_questDiscoveredSound)
    
    
   call QuestSetDiscovered(udg_brokQ, true)

   
   
endfunction

