// Trigger: globals
//
// set rewards[0] = "gold coins"
// set rewards[1] = "experience"
// set rewards[2] = "gems"
// set rewards[3] = "equipment"
// weaponlvl[12][21]=972
// weaponsize[0]=4
// call SaveInteger(questtm,GetHandleId(u),StringHash("killer"),id+10)
//    call SaveInteger(questtm,GetHandleId(u),StringHash("quest"),id+10)
//  call UnitChat("I'll pay you with |cffffcc00"+samount+" "+rewards[rwd]+"|r if you kill that "+GetUnitName(u),qgiver)
//===========================================================================
//===========================================================================
// Trigger: lauchPquest
//
// Asid,Aneu
//===========================================================================
//===================launchParent quest =========================0

function LaunchDeliver takes unit qgiver,unit qtaker returns boolean
  local integer id= GetPlayerId(GetOwningPlayer(qtaker))
  local integer dest= GetRandomInt(1, 7)
  local unit parent= null
  local real x
  local real y
  local integer questid
  local integer reward= ( GetUnitLevel(qgiver) * GetUnitLevel(qtaker) ) / 4
  local item packet
  


 loop
    set parent=GroupPickRandomUnit(ghostg)
   exitwhen parent != qgiver and GetUnitUserData(parent) == 0
   endloop
   
   set x=GetUnitX(parent)
   set y=GetUnitY(parent)
  
   call SetUnitUserData(parent, 1320)
   call UnitChat("Can you deliver this packet to my friend |cffffcc00" + GetUnitName(parent) + "|r?, He is on an exploration mission, and needs some aids..." , qgiver)
   call MakeFaceToUnit(qgiver , qtaker)
  
     call TriggerSleepAction(3)
    set packet=CreateItem(delivery, GetUnitX(qtaker), GetUnitY(qtaker))
    call UnitAddItem(qtaker, packet)
    
    call SaveUnitHandle(questtm, GetHandleId(packet), StringHash("rmte"), qgiver)
    call SaveUnitHandle(questtm, GetHandleId(packet), StringHash("to"), parent)
    call SaveUnitHandle(questtm, GetHandleId(packet), StringHash("emailer"), qtaker)
    
    call SaveItemHandle(questtm, GetHandleId(parent), StringHash("delivery"), packet)

    
      call UnitRemoveAbility(qgiver, 'Awan')
      call UnitRemoveAbility(qgiver, newquest)
      call UnitRemoveAbility(qgiver, 'Asid')
      call UnitRemoveAbility(qgiver, 'Aneu')
      call RemoveItemFromStock(qgiver, 'I08O')
      
    //  call SetUnitInvulnerable(qgiver,true)
    //  call PauseUnit(qgiver,true)
      
      call TriggerSleepAction(1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00NEW PERSONAL QUEST|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Deliver the packet to the " + GetUnitName(parent) + ", who is needed for aids.")
      set questid=SetupQuest(id , parent , "MAIL SERVICE" , "Deliver an entrustment to the " + GetUnitName(parent) + " named into packet info" , "-" , "-" , reward , s__qty[0])
      call SaveInteger(questtm, GetHandleId(packet), 1321, questid) //guardo id de quest en el viajero
        if ( GetLocalPlayer() == Player(id) ) then
           call PingMinimapEx(x, y, 7, 255, 255, 50, false)
       endif
    
     call TriggerSleepAction(30)

     call UnitAddAbility(qgiver, 'Awan')
     call UnitAddAbility(qgiver, newquest)
     call UnitAddAbility(qgiver, 'Asid')
     call UnitAddAbility(qgiver, 'Aneu')
     call AddItemToStock(qgiver, 'I08O', 1, 1)
     
     set parent=null
     set packet=null
    
  return true
endfunction




function LaunchTravel takes unit qgiver,unit qtaker returns boolean
  local integer id= GetPlayerId(GetOwningPlayer(qtaker))
  local integer dest= GetRandomInt(1, 7)
  local real x= GetRectCenterX(s__citycenter[dest])
  local real y= GetRectCenterY(s__citycenter[dest])
  local integer questid
  local integer reward= GetUnitLevel(qgiver) * GetUnitLevel(qtaker)


  
   call UnitChat("I'm traveling to |cffffcc00" + s__cities[dest] + "|r, Can you protect me while I get there?, I'll reward you with |cffffcc00$" + I2S(reward) + " G|r" , qgiver)
   call MakeFaceToUnit(qgiver , qtaker)
  
     
    call TriggerSleepAction(3)
   
    
       call AddTraveler(id , qgiver)
        if travelerc[id] > 3 then
          call UnitChat(" You have a lot of people here (+4)" , qgiver)
          call TriggerSleepAction(2)
          call UnitChat(" Please finish your other bussines before" , qgiver)
          call TriggerSleepAction(2)
          call UnitChat("Anyway, I have another things to do" , qgiver)
          return false
        endif
      call UnitRemoveAbility(qgiver, 'Awan')
      call UnitRemoveAbility(qgiver, newquest)
      call UnitRemoveAbility(qgiver, 'Asid')
      call UnitRemoveAbility(qgiver, 'Aneu')
      call UnitRemoveAbility(qgiver, 'Apit')
      
      call RemoveItemFromStock(qgiver, 'I08O')
      call SaveInteger(questtm, GetHandleId(qgiver), 1222, dest)
      call SetUnitUserData(qgiver, 2222)
      call TriggerSleepAction(1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00NEW PERSONAL QUEST|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Protect the " + GetUnitName(qgiver) + " until he reaches to |cffffcc00" + s__cities[dest] + "|r")
      set questid=SetupQuest(id , qgiver , "ENTHASHARA's TRAVELERS" , "Protect the " + GetUnitName(qgiver) + " until he reaches to |cffffcc00" + s__cities[dest] + "|r" , "-" , "-" , reward , s__qty[0])
      call SaveInteger(questtm, GetHandleId(qgiver), 1223, questid) //guardo id de quest en el viajero
        if ( GetLocalPlayer() == Player(id) ) then
           call PingMinimapEx(x, y, 7, 255, 255, 50, false)
       endif
   
    
  return true
endfunction



//==========================SETUP================================
function LaunchPquestC takes nothing returns boolean
    return GetItemTypeId(GetSoldItem()) == 'I08O'
endfunction

function LaunchPquestA takes nothing returns nothing
local unit qu= GetSellingUnit()
local unit u= GetBuyingUnit()
local integer QuestType= GetRandomInt(1, 4)
local integer levelR= GetUnitLevel(qu) - 3

 if IsUnitType(u, UNIT_TYPE_HERO) == true then
 
    if GetHeroLevel(u) < levelR then
          call UnitChat("Sorry, but I prefer assistance from someone more experienced...(Lv " + I2S(levelR) + ")" , qu)
          call MakeFaceToUnit(qu , u)
          call TriggerSleepAction(5)
          call AddItemToStock(qu, 'I08O', 1, 1) //Reseted item bought
    else
           if QuestType == 1 then
                        call LaunchTravel(qu , u)
            elseif QuestType == 2 then
                         call LaunchDeliver(qu , u)
            elseif QuestType == 3 then
                         call qgroupActions(qu , u)
            elseif QuestType == 4 then
                        call singlemonster(qu , u)
            endif
    endif
   
 else
   call AddItemToStock(qu, 'I08O', 1, 1) //Reseted item bought
 endif
 
 set qu=null
 set u=null

endfunction

//===========================================================================
function InitTrig_lauchPquest takes nothing returns nothing
    set gg_trg_lauchPquest=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_lauchPquest, EVENT_PLAYER_UNIT_SELL_ITEM)
    call TriggerAddCondition(gg_trg_lauchPquest, Condition(function LaunchPquestC))
    call TriggerAddAction(gg_trg_lauchPquest, function LaunchPquestA)
endfunction


//===========================================================================
// Trigger: deliverinfo
//===========================================================================
function Trig_deliverinfo_Conditions takes nothing returns boolean
    return GetItemTypeId(GetManipulatedItem()) == 'I08Q'
endfunction

function Trig_deliverinfo_Actions takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local item it= GetManipulatedItem()
  local unit dest= LoadUnitHandle(questtm, GetHandleId(it), StringHash("to"))
  local integer questid= LoadInteger(questtm, GetHandleId(it), 1321)
  
    if GetUnitState(dest, UNIT_STATE_LIFE) > 0.4 then
          if ( GetLocalPlayer() == Player(id) ) then
               call PingMinimapEx(GetUnitX(dest), GetUnitY(dest), 7, 255, 255, 50, false)
           endif
    else
         if ( GetLocalPlayer() == Player(id) ) then
              call ClearTextMessages()
         endif
          call StartSound(bj_questFailedSound)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffff0000PERSONAL QUEST FAILED|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Entrustment's addressee has died...")
         
          call UpdatePersQuestND(id , questid , Qdata[questid] , "-" , "-" , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
          call FlushChildHashtable(questtm, GetHandleId(it))
          call RemoveItem(it)
          set it=null
    endif
  
  set it=null
  set dest=null
endfunction

