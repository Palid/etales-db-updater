//===========================================================================
// Trigger: kknps
//
// kobolds kiddnappers
//===========================================================================
function kknpsc takes nothing returns boolean
    return GetUnitTypeId(GetTriggerUnit()) == 'n016' or GetUnitTypeId(GetTriggerUnit()) == 'n008'
endfunction

function CountKobolds takes nothing returns nothing
 set koboldnumber=koboldnumber + 1
endfunction


function kknpsa takes nothing returns nothing
local integer i= 0
local unit l__victim= GetTriggerUnit()
local effect esnare= null
local boolexpr istru= Condition(function bool)

call DisableTrigger(gg_trg_kknps)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05N', - 17600, 4100, 100))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05N', - 17600, 4100, 100))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05N', - 17600, 4100, 100))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05N', - 17600, 4100, 100))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05P', - 17600, 4100, 100))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05P', - 17600, 4100, 100))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05P', - 17600, 4100, 45))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05O', - 17600, 4100, 45))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05O', - 17600, 4100, 45))
call TriggerSleepAction(0.1)
call GroupAddUnit(koboldk, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n05Q', - 17600, 4100, 45))
call TriggerSleepAction(0.1)
call TriggerRegisterUnitInRange(gg_trg_kidnapped, l__victim, 150, null)
call DestroyBoolExpr(istru)
set istru=null
call SaveUnitHandle(questtm, GetHandleId(koboldk), 0, l__victim)
set koboldvictim=l__victim


loop
  exitwhen childk == true
   call GroupPointOrder(koboldk, "move", GetUnitX(l__victim), GetUnitY(l__victim))
   call TriggerSleepAction(1)
endloop


    set esnare=AddSpecialEffectTarget("Abilities\\Spells\\Orc\\Ensnare\\ensnare_AirTarget.mdl", l__victim, "chest")
    call ForGroup(koboldk, function CountKobolds)
    call EnableTrigger(gg_trg_checkgroup)

    
    
    
loop
exitwhen koboldnumber < 1
    call TriggerSleepAction(1)
endloop
  call DestroyEffect(esnare)
  call DisableTrigger(gg_trg_checkgroup)
  call TriggerSleepAction(1)
  call UnitChat("Thanks for saving me...snif, i wanna go home..." , l__victim)
 
  
  call TriggerSleepAction(2)
  call DisplayTimedTextToForce(GetPlayersAll(), 10.00, "|cffffcc00Velhilmen's News:|r Kobolds's gang has been destroyed")
  call StartSound(bj_questCompletedSound)
 loop
   exitwhen i > 8
         if koboldkiller[i] == true then
          //  call DisplayTimedTextToPlayer(Player(i),0,0,6,"|cffffcc00PERSONAL QUEST FINISHED|r")
            set koboldkiller[i]=false
            call DisplayTimedTextToPlayer(Player(i), .1, 0, 10, "You get +2500 XP [max level 20]")
            call DisplayTimedTextToPlayer(Player(i), .1, 0, 10, "You get +8 Reputation")
            call AddHeroXP(udg_PHero[i], 2500, true)
            set Reputation[i]=Reputation[i] + 8
         endif
 set i=i + 1
 endloop

  call RemoveSavedHandle(questtm, GetHandleId(koboldk), 0)
  
  call IssuePointOrder(koboldvictim, "move", 22250, 3900)
  call TriggerSleepAction(4)
  call SetUnitPosition(koboldvictim, - 17600, 4100)
  call IssuePointOrder(koboldvictim, "move", - 14900, 10670)

    
call TriggerSleepAction(10)
//call RemoveUnit(victim)
set l__victim=null
set childk=false
set vincave=false
set esnare=null
call TriggerSleepAction(150)
call EnableTrigger(gg_trg_kknps)
call EnableTrigger(gg_trg_kidnapped)
endfunction

