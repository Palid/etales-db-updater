function mishagc takes nothing returns boolean
    return IsUnitInGroup(GetTriggerUnit(), MishaGroup) == true and GetUnitState(udg_BOSS[3], UNIT_STATE_LIFE) > 0
endfunction


function mishaga takes nothing returns nothing

  local real x= 0
  local real y= 0
  local unit bear= null
  
  call GroupRemoveUnit(MishaGroup, GetTriggerUnit())
  set bear=FirstOfGroup(MishaGroup)
  
  if bear == null then
    call DisableTrigger(gg_trg_mishagroup)
    call GroupClear(MishaGroup)
    call TriggerSleepAction(24)
    
  //  call GroupAddUnit(MishaGroup,udg_BOSS[3])
  //  call TriggerSleepAction(0.1)
    set x=GetUnitX(udg_BOSS[3])
    set y=GetUnitY(udg_BOSS[3])
    call DestroyEffect(AddSpecialEffectTarget(sffectpunch, udg_BOSS[3], "chest"))
    call GroupAddUnit(MishaGroup, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'e000', x, y, 180))
    call TriggerSleepAction(0.02)
    call GroupAddUnit(MishaGroup, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'e000', x, y, 0))
    call TriggerSleepAction(0.02)
    call GroupAddUnit(MishaGroup, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n003', x, y, 45))
    call TriggerSleepAction(0.02)
    call GroupAddUnit(MishaGroup, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n003', x, y, 45))
    call TriggerSleepAction(0.02)
    call GroupAddUnit(MishaGroup, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n003', x, y, 135))
    call TriggerSleepAction(0.02)
    call GroupAddUnit(MishaGroup, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n003', x, y, 225))
    call TriggerSleepAction(0.02)

    call EnableTrigger(gg_trg_mishagroup)
   else
   set bear=null
   endif

  


  
endfunction

