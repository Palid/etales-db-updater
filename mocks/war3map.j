//TESH.alwaysfold=0
function Trig_healbulb_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0LX' )
endfunction

function Trig_healbulb_Actions takes nothing returns nothing

 if ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'I0LY') == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I0LY')
      
        if ( GetItemCharges(udg_tmpitem) < 50 ) then
           call SetItemCharges(udg_tmpitem, ( GetItemCharges(udg_tmpitem) + 1 ))
        endif
       
        set udg_tmpitem=null
    else
        call UnitAddItemByIdSwapped('I0LY', GetTriggerUnit())
        call DisplayTimedTextToPlayer(GetTriggerPlayer(), 0, 0, bj_TEXT_DELAY_ITEMACQUIRED, "ITEM ACQUIRED")
        call DisplayTimedTextToPlayer(GetTriggerPlayer(), 0, 0, bj_TEXT_DELAY_ITEMACQUIRED, "Received Healer bulb Root")
       call StartSound(bj_questItemAcquiredSound)

        
    endif
 
    
endfunction

