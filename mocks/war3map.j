//===========================================================================
function Trig_drink_Conditions takes nothing returns boolean
    return GetItemType(GetManipulatedItem()) == ITEM_TYPE_POWERUP and GetWidgetLife(GetManipulatedItem()) == 251.00 and s__ISreseting[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == false
endfunction

function Trig_drink_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer lvl= GetItemLevel(GetManipulatedItem())
local integer state= lvl - ( lvl / 10 ) * 10
local integer power= lvl / 10
local integer id= GetPlayerId(GetOwningPlayer(u))
local real x
local real y

call SetAltState(id , state , power , barwomans[udg_Plugar[id]])

call TriggerSleepAction(2)
  if tavernhour == true then
     set x=GetUnitX(u) + GetRandomReal(- 70, 70)
     set y=GetUnitY(u) + GetRandomReal(- 70, 70)
     call CreateItem('I0FC', x, y)
  endif
set u=null

endfunction

