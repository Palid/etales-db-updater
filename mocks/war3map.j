endfunction


//===========================================================================
// Trigger: archernd
//===========================================================================
//TESH.scrollpos=36
//TESH.alwaysfold=0
function ARCDC takes nothing returns boolean
    return ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true )
endfunction

function ARCDA takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local integer i= 1
 local location p=  GetUnitLoc(u)
 local integer exp= GetHeroXP(u)
 local integer level= GetHeroLevel(u)
 local integer questid
     
 if ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'I0M0') == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I0M0')
      
         if ( GetItemCharges(udg_tmpitem) > 9 ) then
           call UnitRemoveItem(GetTriggerUnit(), udg_tmpitem)
           
               loop
               exitwhen i > 6
               call UnitRemoveItemFromSlotSwapped(i, u)
               set i=i + 1
               endloop
           
               
            call UnitChat("Well done sister, take your bow and your arrows. Don't die with arrows in your quiver, throw all of them!" , gg_unit_Hvwd_1037)
          
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "QUEST DONE")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Archer Quest")
            set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
            call UpdatePersQuest(id , questid , 0 , "Reached first class tier" , "-" , "-")
            call RemoveQuestFromPlayer(questid , QPid[questid])
            call StartSound(bj_questCompletedSound)

                        
    set udg_PHero[id]=CreateUnitAtLoc(GetOwningPlayer(u), 'H008', p, 270)
    call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\Orc\\Reincarnation\\ReincarnationTarget.mdl")
    call DestroyEffect(GetLastCreatedEffectBJ())
    call AddProfaner(id) //Trigger registrado
    call SetHeroAgi(udg_PHero[id], GetHeroAgi(u, false) + 24, true)
    call SetHeroStr(udg_PHero[id], GetHeroStr(u, false) + 24, true)
    call SetHeroInt(udg_PHero[id], GetHeroInt(u, false) + 24, true)
    call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
    call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
    call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)

            
            
            call RemoveUnit(u)
            
            call SetHeroXP(udg_PHero[id], exp, false)
            call AdjustPlayerStateBJ(7, GetOwningPlayer(u), PLAYER_STATE_RESOURCE_LUMBER)
            set udg_Hnext[id]=4
           
            call DisableTrigger(gg_trg_growlog)
            call DisableTrigger(gg_trg_bowlog)
            call RemoveAllQuestFromPlayer(id)
         endif
          set udg_tmpitem=null
    endif

    set u=null
    call RemoveLocation(p)
    set p=null
endfunction
//===========================================================================
function InitTrig_archernd takes nothing returns nothing
    set gg_trg_archernd=CreateTrigger()
    call TriggerRegisterEnterRectSimple(gg_trg_archernd, gg_rct_archer)
    call TriggerAddCondition(gg_trg_archernd, Condition(function ARCDC))
    call TriggerAddAction(gg_trg_archernd, function ARCDA)
endfunction


//===========================================================================
// Trigger: aprent
//
// gg_unit_Hvwd_1037
//===========================================================================
//TESH.scrollpos=9
//TESH.alwaysfold=0
function APRTC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0LT' )
endfunction

function APRTA takes nothing returns nothing
local integer questid
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))

   if ( GetUnitTypeId(GetTriggerUnit()) != 'H00H' ) then
        call UnitChat("Only male novices can take this responsability" , gg_unit_Hblm_1043)

        
   elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
        call UnitChat("Ah? where is the book, where are the |cffffcc0010 pages|r?" , gg_unit_Hblm_1043)
 
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
            call UnitChat("You dont have necessary experience to do this quest. |n|cffffcc00Needs 300 kills|r" , gg_unit_Hblm_1043)
        else
            call UnitChat("Ok, if you want be my aprenttice, get back the lost pages of this book |cffffcc00(10 pages)|r" , gg_unit_Hblm_1043)

            call EnableTrigger(gg_trg_bookget)
            call EnableTrigger(gg_trg_growpage)
            call TriggerExecute(gg_trg_bookget)
            call GroupAddUnitSimple(GetTriggerUnit(), udg_inTest)
             call TriggerSleepAction(3)
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00MAIN QUEST DISCOVERED|r: Reading magic words")
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "     Collect 10 wizzard book's pages spreaded on Velhilmen fields")
         
           
            set questid=SetupQuest(id , null , "READING MAGIC WORDS" , "Collect 10 wizzard book's pages spreaded on Velhilmen" , "-" , "-" , 0 , s__qty[2])
            call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
    endif

endfunction



