function InitTrig_zombikill takes nothing returns nothing
    set gg_trg_zombikill=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_zombikill, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_zombikill, Condition(function Trig_zombikill_Conditions))
    call TriggerAddAction(gg_trg_zombikill, function Trig_zombikill_Actions)
endfunction


