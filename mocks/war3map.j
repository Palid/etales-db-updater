//TESH.alwaysfold=0
function Trig_protector_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A097' )
endfunction

function Trig_protector_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local unit a= GetSpellTargetUnit()
 
 call SaveUnitHandle(udg_cache, GetHandleId(a), 777, u)
 call UnitAddAbility(a, 'A098')
 if ( IsUnitInGroup(a, hasprotector) == false ) then
  call GroupAddUnit(hasprotector, a)
  call TriggerRegisterUnitEvent(gg_trg_prosf, a, EVENT_UNIT_DAMAGED)
 endif
 call SetUnitVertexColorBJ(a, 100, 100, 100.00, 25.00)
 call TriggerSleepAction(60)
 call UnitRemoveAbility(a, 'A098')
 call SetUnitVertexColorBJ(a, 100, 100, 100.00, 0.00)
 set u=null
 set a=null
 
endfunction

