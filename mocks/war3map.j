       set i=i + 1
      endloop
   
    call TriggerAddCondition(gg_trg_sfjewel, Condition(function Trig_sfjewel_Conditions))
    call TriggerAddAction(gg_trg_sfjewel, function Trig_sfjewel_Actions)
endfunction


