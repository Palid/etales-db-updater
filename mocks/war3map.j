//===========================================================================
// Trigger: launchbolts
//
// "CHIM"
//===========================================================================
//TESH.scrollpos=26
//TESH.alwaysfold=0
function lightcond takes nothing returns boolean
    return GetUnitAbilityLevel(GetAttacker(), hasbolts) > 0 and IsUnitInGroup(GetAttacker(), linearbolters) == false
endfunction

function launchlightacc takes nothing returns nothing

 local unit u= GetAttacker()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local unit a= GetTriggerUnit()
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real x2= GetUnitX(a)
 local real y2= GetUnitY(a)
 local real xf= x2 - x
 local real yf= y2 - y
 local real angle= bj_RADTODEG * Atan2(yf, xf)
 
 call GroupAddUnit(linearbolters, u)
 set lightningboltT[id]=u
 set light_x[id]=x + 3000 * Cos(angle * bj_DEGTORAD)
 set light_y[id]=y + 3000 * Sin(angle * bj_DEGTORAD)
 
 call SaveInteger(hts, GetHandleId(gg_trg_launchbolts), 1, id)
 
 call TriggerSleepAction(0.3)
 call ExecuteFunc("lightacc")
 call TriggerSleepAction(0.3)
 call ExecuteFunc("lightacc")
  call TriggerSleepAction(0.3)
 call ExecuteFunc("lightacc")
  call TriggerSleepAction(0.3)
 call ExecuteFunc("lightacc")
  call TriggerSleepAction(0.3)
 call ExecuteFunc("lightacc")
  call TriggerSleepAction(1)

  call GroupRemoveUnit(linearbolters, u)
endfunction

//===========================================================================
function InitTrig_launchbolts takes nothing returns nothing
    set gg_trg_launchbolts=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_launchbolts, EVENT_PLAYER_UNIT_ATTACKED)
    call TriggerAddCondition(gg_trg_launchbolts, Condition(function lightcond))
    call TriggerAddAction(gg_trg_launchbolts, function launchlightacc)
endfunction


//===========================================================================
// Trigger: monsoon
//===========================================================================
//TESH.scrollpos=94
//TESH.alwaysfold=0
function Trig_monsoon_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == Amonsoon
endfunction


function monsooncycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer id= GetPlayerId(GetOwningPlayer(u))
local real xc= LoadReal(hts, GetHandleId(t), 2)
local real yc= LoadReal(hts, GetHandleId(t), 3)
local real distance= LoadInteger(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i=  LoadInteger(hts, GetHandleId(t), 7)
local real inc= 12
local real x
local real y
local real xb
local real yb
local real amp
local unit l_a= null
local unit l_b= null
set it=it - 1

set i=i + 9



 set xc=xc + inc * Cos(angle * bj_DEGTORAD)
 set yc=yc + inc * Sin(angle * bj_DEGTORAD)
 
 set amp=Sin(i * bj_DEGTORAD) * 190
 
 set x=xc + amp * Cos(( angle - 90 ) * bj_DEGTORAD)
 set y=yc + amp * Sin(( angle - 90 ) * bj_DEGTORAD)

 set xb=xc + amp * Cos(( angle + 90 ) * bj_DEGTORAD)
 set yb=yc + amp * Sin(( angle + 90 ) * bj_DEGTORAD)
 
 set l_a=CreateUnit(Player(id), ldummyE, x, y, i)
  call UnitApplyTimedLife(l_a, 'BTLF', 0.13)
 set l_b=CreateUnit(Player(id), ldummyE, xb, yb, i)
  call UnitApplyTimedLife(l_b, 'BTLF', 0.13)
 
 call SaveReal(hts, GetHandleId(t), 2, xc)
 call SaveReal(hts, GetHandleId(t), 3, yc)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 
if it < 0 then
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
endif

set t=null
set l_a=null
set l_b=null
set u=null



endfunction



function Trig_monsoon_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local real ux= GetUnitX(u)
 local real uy= GetUnitY(u)
 local real x= GetSpellTargetX()
 local real y= GetSpellTargetY()
 local real dx= x - ux
 local real dy= y - uy
 local real distance= SquareRoot(dx * dx + dy * dy) + 135
 local real it= distance / 12
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local timer t= (NewTimerEx(0)) // INLINED!!
 
 

 set ux=ux - 70 * Cos(angle * bj_DEGTORAD)
 set uy=uy - 70 * Sin(angle * bj_DEGTORAD)
 
 
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, ux)
 call SaveReal(hts, GetHandleId(t), 3, uy)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 

 call TimerStart(t, 0.03, true, function monsooncycle)
 
 set t=null
 set u=null
 

 

endfunction

//===========================================================================
function InitTrig_monsoon takes nothing returns nothing
    set gg_trg_monsoon=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_monsoon, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_monsoon, Condition(function Trig_monsoon_Conditions))
    call TriggerAddAction(gg_trg_monsoon, function Trig_monsoon_Actions)
endfunction


//===========================================================================
// Trigger: lightningstrike
//===========================================================================
//TESH.scrollpos=90
//TESH.alwaysfold=0
function lstrikec takes nothing returns boolean
    return GetSpellAbilityId() == Lstrike
endfunction


function lstrikecycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer id= GetPlayerId(GetOwningPlayer(u))
local real xc= LoadReal(hts, GetHandleId(t), 2)
local real yc= LoadReal(hts, GetHandleId(t), 3)
local real distance= LoadInteger(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i=  LoadInteger(hts, GetHandleId(t), 7)
local lightning ln= LoadLightningHandle(hts, GetHandleId(t), 8)
local integer dec= LoadInteger(hts, GetHandleId(t), 9)
local real inc= 5
local real x
local real y
local real xb= LoadReal(hts, GetHandleId(t), 10)
local real yb= LoadReal(hts, GetHandleId(t), 11)
local real amp
local location p= LoadLocationHandle(hts, GetHandleId(t), 12)
local unit slow= LoadUnitHandle(hts, GetHandleId(t), 13)



set it=it - 1

set i=i + 3



 set xc=xc + inc * Cos(angle * bj_DEGTORAD)
 set yc=yc + inc * Sin(angle * bj_DEGTORAD)
 
 set amp=Sin(i * bj_DEGTORAD) * 180
 
 set x=xc + amp * Cos(( angle - 90 ) * bj_DEGTORAD)
 set y=yc + amp * Sin(( angle - 90 ) * bj_DEGTORAD)

call MoveLocation(p, xb, yb)

set dec=dec - 1
if dec < 1 then
set dec=10
set xb=GetRandomReal(xc - 36, xc + 36)
set yb=GetRandomReal(yc - 36, yc + 36)
 call SaveReal(hts, GetHandleId(t), 10, xb)
 call SaveReal(hts, GetHandleId(t), 11, yb)
endif
call MoveLightningEx(ln, true, xb, yb, GetLocationZ(p), x, y, GetLocationZ(p) + 1700)
call SetUnitPosition(slow, xb, yb)
  call DestroyEffect(AddSpecialEffect(LIGHTBALL, xb, yb))
 
 call SaveReal(hts, GetHandleId(t), 2, xc)
 call SaveReal(hts, GetHandleId(t), 3, yc)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveInteger(hts, GetHandleId(t), 9, dec)
 
if it < 0 then
  call DestroyLightning(ln)
  call DestroyEffect(AddSpecialEffect(THUNDER, xb, yb))
  call RemoveUnit(slow)
  call RemoveLocation(p)
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)

endif

set p=null
set t=null
set ln=null
set u=null
set slow=null


endfunction



function lstrikea takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local location p= GetUnitLoc(u)
 local real ux= GetUnitX(u)
 local real uy= GetUnitY(u)
 local real x= GetSpellTargetX()
 local real y= GetSpellTargetY()
 local real dx= x - ux
 local real dy= y - uy
 local real distance= SquareRoot(dx * dx + dy * dy) + 135
 local real it= distance / 5
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx) - 180
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer dec= 10
 local unit slow= CreateUnit(Player(id), slower, x, y, 270)
 local lightning ln= AddLightningEx(CHAIN, true, x, y, GetLocationZ(p), x, y, GetLocationZ(p) + 700)
 call SetLightningColor(ln, 1, 1, 1, 1)
 


 
 
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, x)
 call SaveReal(hts, GetHandleId(t), 3, y)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveLightningHandle(hts, GetHandleId(t), 8, ln)
 call SaveInteger(hts, GetHandleId(t), 9, dec)
 call SaveReal(hts, GetHandleId(t), 10, x)
 call SaveReal(hts, GetHandleId(t), 11, y)
 call SaveLocationHandle(hts, GetHandleId(t), 12, p)
 call SaveUnitHandle(hts, GetHandleId(t), 13, slow)
 call TimerStart(t, 0.02, true, function lstrikecycle)
 
 set p=null
 set ln=null
 set t=null
 set u=null
 set slow=null

 

endfunction

//===========================================================================
function InitTrig_lightningstrike takes nothing returns nothing
    set gg_trg_lightningstrike=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_lightningstrike, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_lightningstrike, Condition(function lstrikec))
    call TriggerAddAction(gg_trg_lightningstrike, function lstrikea)
endfunction


//===========================================================================
// Trigger: lightningSleash
//===========================================================================
//TESH.scrollpos=60
//TESH.alwaysfold=0
function Trig_lightningSleash_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == Lsleash )
endfunction


function lsleashcycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real dist= LoadReal(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i= LoadInteger(hts, GetHandleId(t), 7)
 
local real xi= LoadReal(hts, GetHandleId(t), 8) + it
local real height= dist / 2.5
local real h= GetParabolaZ(xi , dist , height)

 
 set x=x + it * Cos(angle * bj_DEGTORAD)
 set y=y + it * Sin(angle * bj_DEGTORAD)

 call SetUnitFlyHeight(a, h, 0)
 call SetUnitPosition(a, x, y)

 
 if h < 1 then
  call SetUnitFlyHeight(a, 0, 0)
  call PauseUnit(a, false)
  call SetUnitPathing(a, true)
  // call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl",GetUnitX(a),GetUnitY(a) ))   
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)

  else
  call SaveReal(hts, GetHandleId(t), 2, x)
  call SaveReal(hts, GetHandleId(t), 3, y)
 // call SaveReal(hts,GetHandleId(t),6,inc)  
  //call SaveReal(hts,GetHandleId(t),5,angle_t)  
      call SaveReal(hts, GetHandleId(t), 8, xi)
 endif
set a=null
set t=null

endfunction

function Trig_lightningSleash_Actions takes nothing returns nothing
 local unit u= GetSpellTargetUnit()
 local unit a= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(a))
 local location p= GetUnitLoc(u)
 local location q= GetUnitLoc(a)
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real distance= SquareRoot(dx * dx + dy * dy) - 120
 local real it= distance / 45
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx) - 180
 local timer t= null
 local integer dec= 10
 local lightning ln= AddLightningEx(CHIMA, true, ux, uy, GetLocationZ(q) + 60, x, y, GetLocationZ(p) + 60)
 call RemoveLocation(p)
 call RemoveLocation(q)
 set p=null
 set q=null
 
   if ( GetUnitFlyHeight(u) > 2 ) then
       call CS_Error(Player(id) , "Lightning Sleash failed!...")
       call DestroyLightning(ln)
       set ln=null
   else
      set t=(NewTimerEx(0)) // INLINED!!
     call DestroyEffect(AddSpecialEffect(THUNDER, x, y))
     call DestroyEffect(AddSpecialEffectTarget(STORMBOLT, u, "origin"))
     call SetLightningColor(ln, 1, 1, 1, 1)
     call TriggerSleepAction(0.02)
     call DestroyLightning(ln)
     set ln=null

     call UnitAddAbilityBJ('Amrf', u)
     call UnitRemoveAbilityBJ('Amrf', u)
     call SetUnitPathing(u, false)
     call SaveUnitHandle(hts, GetHandleId(t), 1, u)
     call SaveReal(hts, GetHandleId(t), 2, x)
     call SaveReal(hts, GetHandleId(t), 3, y)
     call SaveReal(hts, GetHandleId(t), 4, distance)
     call SaveReal(hts, GetHandleId(t), 5, it)
     call SaveReal(hts, GetHandleId(t), 6, angle)
     call SaveInteger(hts, GetHandleId(t), 7, i)
     call SaveReal(hts, GetHandleId(t), 8, 0)

     call TimerStart(t, 0.02, true, function lsleashcycle)
 endif
 set u=null
 set a=null
 set t=null
endfunction

//===========================================================================
function InitTrig_lightningSleash takes nothing returns nothing
    set gg_trg_lightningSleash=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_lightningSleash, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_lightningSleash, Condition(function Trig_lightningSleash_Conditions))
    call TriggerAddAction(gg_trg_lightningSleash, function Trig_lightningSleash_Actions)
endfunction


//===========================================================================
// Trigger: warlockthunder
//===========================================================================
//TESH.scrollpos=84
//TESH.alwaysfold=0
function Trig_warlockthunder_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0H9' )
endfunction

function Trig_warlockthunder_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local boolexpr filter= Condition(function bool)
local unit gu
local real inspired= 1
local real dmg
local real fdmg
local integer idmg
local location p
local lightning lnn
local group wlinn= CreateGroup()



 if GetUnitPointValue(u) > 130 then
  set dmg=I2R(GetHeroInt(u, true)) * 6
  else
   set dmg=I2R(GetHeroInt(u, true)) * ( 0.5 * GetUnitAbilityLevel(u, 'A0H9') )
  endif
 

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif
 
 set Thunderfall[id]=CreateGroup()


 call GroupEnumUnitsInRange(Thunderfall[id], GetUnitX(u), GetUnitY(u), 250, filter)
 call DestroyBoolExpr(filter)
 set filter=null

 loop
   set gu=FirstOfGroup(Thunderfall[id])
   exitwhen gu == null
    if IsUnitEnemy(gu, Player(id)) == true and GetUnitState(gu, UNIT_STATE_LIFE) > 0.4 then
      call DisableTrigger(gg_trg_DMG)
     
    
      call GroupAddUnit(wlinn, gu)
      set fdmg=dmg * inspired
      set fdmg=fdmg + fdmg * AddRacialBonus(gu , id)
      set idmg=R2I(fdmg)
      set p=GetUnitLoc(gu)
     
     call EnableTrigger(gg_trg_SPDMG)
     call UnitDamageTarget(u, gu, fdmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
     set lnn=AddLightningEx(CHAIN, true, GetUnitX(gu), GetUnitY(gu), GetLocationZ(p), GetUnitX(gu), GetUnitY(gu), GetLocationZ(p) + 900)
     call SaveLightningHandle(HTcreep, GetHandleId(gu), 308, lnn)
     call DestroyEffect(AddSpecialEffectTarget(sfstatic, u, "chest"))
   
     call DisableTrigger(gg_trg_SPDMG)
     call RemoveLocation(p)
     set p=null
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , gu)
      set spelldmg[id]=0
      call EnableTrigger(gg_trg_DMG)
    
    endif
   call GroupRemoveUnit(Thunderfall[id], gu)

  
endloop
   
set lnn=null
set gu=null
call GroupClear(Thunderfall[id])

call DestroyGroup(Thunderfall[id])
set Thunderfall[id]=null

call TriggerSleepAction(0.04)


 loop
 set gu=FirstOfGroup(wlinn)
 exitwhen gu == null

 // set lnn = LoadLightningHandle(hts,GetHandleId(gu),308)
 call DestroyLightning(LoadLightningHandle(HTcreep, GetHandleId(gu), 308))
 //set lnn = null
 call GroupRemoveUnit(wlinn, gu)

 endloop

 
 
 set u=null
 set lnn=null
 call DestroyGroup(wlinn)
 set wlinn=null
endfunction

//===========================================================================
function InitTrig_warlockthunder takes nothing returns nothing
    set gg_trg_warlockthunder=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_warlockthunder, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_warlockthunder, Condition(function Trig_warlockthunder_Conditions))
    call TriggerAddAction(gg_trg_warlockthunder, function Trig_warlockthunder_Actions)
endfunction


//===========================================================================
// Trigger: fallen library
//===========================================================================

//===========================================================================
// Trigger: hungerforblood
//===========================================================================
function Trig_hungerforblood_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0GK' )
endfunction

function fooders takes nothing returns boolean
    return ( IsPlayerEnemy(GetOwningPlayer(temp_vamp), GetOwningPlayer(GetFilterUnit())) == true and GetUnitState(GetFilterUnit(), UNIT_STATE_LIFE) > 1 )
endfunction

function Trig_hungerforblood_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local unit gu
local real Hx= GetUnitX(u)
local real Hy= GetUnitY(u)
local real x= 0
local real y= 0
local real amount
local real amounth
local real aleft
local integer idmg= 0
local group dlife= CreateGroup()
local group nolight= CreateGroup()
local boolexpr bfilter= Condition(function fooders)
local lightning l__l
local effect sfx= AddSpecialEffectTarget("Abilities\\Spells\\Human\\FlameStrike\\FlameStrikeTarget.mdl", u, "origin")
local real inspired= 1
local location p= null
local location q= GetUnitLoc(u)

set temp_vamp=u

  if ActSpecast(id , GetSpellAbilityId()) == true then
     set inspired=1 + s__castamount[id] * s__casttype[id]
 endif
   
   
   
    
// call PauseUnit(u,true)
 call SetUnitAnimationByIndex(u, 2)
 call GroupEnumUnitsInRange(dlife, Hx, Hy, 400, bfilter)
 call DestroyBoolExpr(bfilter)
 set bfilter=null
 set temp_vamp=null
 call TriggerSleepAction(0.3)

 // call DestroyEffect(AddSpecialEffectTarget(sffectdusta,u,"origin")) 

 loop
  set gu=FirstOfGroup(dlife)
  exitwhen gu == null
   call GroupRemoveUnit(dlife, gu)
   call GroupAddUnit(nolight, gu)
   set amount=GetUnitState(gu, UNIT_STATE_LIFE)
   set amounth=GetUnitState(u, UNIT_STATE_LIFE)
   set x=GetUnitX(gu)
   set y=GetUnitY(gu)
   set p=GetUnitLoc(gu)
   set aleft=amount * 0.16
           if aleft > 9708 then
            set aleft=9708
           endif
   
   set aleft=aleft * inspired
   
   
   
   set amount=amount - aleft
   set amounth=amounth + aleft

   call SetUnitState(gu, UNIT_STATE_LIFE, amount)
   call SetUnitState(u, UNIT_STATE_LIFE, amounth)
   set idmg=R2I(aleft * - 1)
   call SpellDmgText(idmg , gu)
   set l__l=AddLightningEx("DRAL", true, x, y, GetLocationZ(p) + 90, Hx, Hy, GetLocationZ(q) + 160)
   call SaveLightningHandle(hts, GetHandleId(gu), GetHandleId(u), l__l)
   call RemoveLocation(p)
   set p=null
   if UnitIsSleeping(gu) == true then
    call UnitWakeUp(gu)
    call IssueTargetOrder(gu, "attack", u)
   endif
  
 endloop
 set gu=null
 call DestroyGroup(dlife)
 set dlife=null
 
call TriggerSleepAction(0.3)
 loop
  set gu=FirstOfGroup(nolight)
  exitwhen gu == null
   call GroupRemoveUnit(nolight, gu)
   set l__l=LoadLightningHandle(hts, GetHandleId(gu), GetHandleId(u))
   call DestroyLightning(l__l)
   call FlushChildHashtable(hts, GetHandleId(gu))
     
  
 endloop
 
 call DestroyGroup(nolight)
 set nolight=null
 set gu=null
 set l__l=null
 call RemoveLocation(q)
 set q=null
// call PauseUnit(u,false)
 //call TriggerSleepAction(0.4)
 call DestroyEffect(sfx)
 set sfx=null
 
 
set u=null

endfunction

//===========================================================================
function InitTrig_hungerforblood takes nothing returns nothing
    set gg_trg_hungerforblood=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_hungerforblood, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_hungerforblood, Condition(function Trig_hungerforblood_Conditions))
    call TriggerAddAction(gg_trg_hungerforblood, function Trig_hungerforblood_Actions)
endfunction


//===========================================================================
// Trigger: vampires
//
// Nightstalkers
//===========================================================================
function Trig_vampires_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A0GI'
endfunction


function OwnedBats takes nothing returns boolean
    return GetUnitTypeId(GetFilterUnit()) == batdmy and GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(GetSpellAbilityUnit())
endfunction



function Trig_vampires_Actions takes nothing returns nothing
 local unit u= GetSpellAbilityUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 
  set batsON[id]=true
  call TriggerSleepAction(0.1)
  call GroupClear(carrionbats[id])
  set bj_groupEnumTypeId=batdmy
  call GroupEnumUnitsOfPlayer(carrionbats[id], Player(id), filterGetUnitsOfPlayerAndTypeId)

   set carriont_x[id]=x
   set carriont_y[id]=y
   call TriggerSleepAction(30)
   set batsON[id]=false

   set u=null
endfunction

//===========================================================================
function InitTrig_vampires takes nothing returns nothing
   local integer i= 0
    set gg_trg_vampires=CreateTrigger()
    
    loop
       exitwhen i > 15
       call TriggerRegisterPlayerUnitEvent(gg_trg_vampires, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, null)
       set i=i + 1
   
    endloop
    call TriggerAddCondition(gg_trg_vampires, Condition(function Trig_vampires_Conditions))
    call TriggerAddAction(gg_trg_vampires, function Trig_vampires_Actions)
endfunction


//===========================================================================
// Trigger: Impaler Hand
//===========================================================================
//TESH.scrollpos=63
//TESH.alwaysfold=0
function Trig_IH_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == imphand )
endfunction



function Trig_IH_Actions takes nothing returns nothing
local integer i= 1
local integer j= 0
local unit u= GetSpellAbilityUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local real angle

local real x= GetUnitX(u)
local real y= GetUnitY(u)
local unit c
local unit gu
local group g= CreateGroup()
local real dmg= I2R(GetHeroStr(u, true) + GetHeroAgi(u, true)) * 4
local real fdmg
local integer idmg= 0
local boolexpr filter= Condition(function bool)
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif




call GroupClear(impaledvictims)
 set angle=GetUnitFacing(u)
 
 
  loop
 exitwhen j > 8
 
 
 set diam_x[j]=x + incradio[j] * Cos(( angle ) * bj_DEGTORAD)
 set diam_y[j]=y + incradio[j] * Sin(( angle ) * bj_DEGTORAD)
 call GroupClear(g)
 call GroupEnumUnitsInRange(g, diam_x[j], diam_y[j], diameters[j] / 2, filter)
 call DestroyBoolExpr(filter)
 set filter=null
 
 call GroupAddGroup(g, impaledvictims)
 
 set j=j + 1
 endloop
 
 call DestroyGroup(g)
 set g=null
 
  set imp_x[0]=x + 570 * Cos(( angle ) * bj_DEGTORAD)
  set imp_y[0]=y + 570 * Sin(( angle ) * bj_DEGTORAD)
  
 // set c = CreateUnit(Player(id),impaledummy,imp_x[0],imp_y[0],angle)

 call TriggerSleepAction(0.02)
  set imp_x[1]=imp_x[0] - 500 * Cos(( angle ) * bj_DEGTORAD)
  set imp_y[1]=imp_y[0] - 500 * Sin(( angle ) * bj_DEGTORAD)
  set impale[1]=CreateDestructable(impalefxdes, imp_x[1], imp_y[1], angle - 180, 1.4, 0)
  
   loop

   set gu=FirstOfGroup(impaledvictims)
   exitwhen gu == null
  // if IsUnitEnemy(gu,GetOwningPlayer(udg_PHero[id]))==true and GetUnitState(gu,UNIT_STATE_LIFE)>0.5 then
    if IsUnitEnemy(gu, Player(id)) == true and GetUnitState(gu, UNIT_STATE_LIFE) > 0.5 then
    // call CheckIfHasDMG(gu) 
   //  call DisableTrigger(gg_trg_DMG)
    // call EnableTrigger(gg_trg_SPDMG)
     // call UnitDamageTarget(udg_PHero[id], gu, dmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
      
     // call UnitDamageTarget(u, gu, dmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
    
    
    
      call DisableTrigger(gg_trg_DMG)
      set fdmg=dmg * inspired
      set fdmg=fdmg + fdmg * AddRacialBonus(gu , id)
      set idmg=R2I(fdmg)
     
      call EnableTrigger(gg_trg_SPDMG)
      call UnitDamageTarget(u, gu, fdmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
      //call UnitDamageTarget(GetTriggerUnit(),GetSpellTargetUnit(),dmg, true, false, ATTACK_TYPE_MAGIC,DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
      call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , gu)
      set spelldmg[id]=0
      call EnableTrigger(gg_trg_DMG)
    
    
    
      set impale[2]=CreateDestructable(impalefxdes, GetUnitX(gu), GetUnitY(gu), angle - 180, 0.6, 0)
      set c=CreateUnit(Player(id), impaledummy, GetUnitX(gu), GetUnitY(gu), 270)
      call IssueTargetOrder(c, "cripple", gu)
      call UnitApplyTimedLife(c, 'BTLF', 2)
      set c=null
      
    // call DestroyEffect(AddSpecialEffectTarget(holyfx,gu,"chest"))
  //   call DisableTrigger(gg_trg_SPDMG)
   //  call EnableTrigger(gg_trg_DMG)
     // set idmg = R2I(spelldmg[id])
    //  call SpellDmgText(idmg,gu)   
    //  set spelldmg[id] = 0
    
   endif
   call GroupRemoveUnit(impaledvictims, gu)
   //set gu = null
endloop
   
set gu=null
call GroupClear(impaledvictims)
     
  
  call TriggerSleepAction(0.02)
  set impale[0]=CreateDestructable(impaledes, imp_x[0], imp_y[0], angle - 180, 0.8, 0)
 // call TriggerSleepAction(0.02)

 set i=0
    call TriggerSleepAction(0.15)


 call RemoveDestructable(impale[0])
 set impale[0]=null
 call TriggerSleepAction(0.3)
 call RemoveDestructable(impale[1])
 set impale[1]=null
  call RemoveDestructable(impale[2])
 set impale[2]=null
 set c=null
 
endfunction
