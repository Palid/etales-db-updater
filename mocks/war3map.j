function InitTrig_kknps takes nothing returns nothing
    local region rectRegion= CreateRegion()
    set gg_trg_kknps=CreateTrigger()
    call DisableTrigger(gg_trg_kknps)
    call RegionAddRect(rectRegion, gg_rct_Velhilmen)
    call TriggerRegisterLeaveRegion(gg_trg_kknps, rectRegion, Condition(function bool))
   
    call TriggerAddCondition(gg_trg_kknps, Condition(function kknpsc))
    call TriggerAddAction(gg_trg_kknps, function kknpsa)
endfunction


//===========================================================================
// Trigger: checkgroup
//===========================================================================
function pickkobold takes nothing returns nothing
 set koboldnumber=koboldnumber + 1
  if ( GetRandomInt(1, koboldnumber) == 1 ) then
     set pickedkobold=GetEnumUnit()
   endif
endfunction



function Trig_checkgroup_Actions takes nothing returns nothing
    set koboldnumber=0
    call ForGroup(koboldk, function CountKobolds)
    if koboldnumber > 0 then
      call ForGroup(koboldk, function pickkobold)
      if GetUnitState(pickedkobold, UNIT_STATE_LIFE) > 0 then
         call IssuePointOrder(koboldvictim, "move", GetUnitX(pickedkobold), GetUnitY(pickedkobold))
       endif
       set pickedkobold=null
    endif


endfunction

//===========================================================================
