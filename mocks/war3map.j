function sequencer takes integer size returns nothing
 local integer i= 0
 local integer j
 local integer a

 
loop
 exitwhen i > size
 set seq[i]=i
 set i=i + 1
endloop
 
 
 set i=size
 
 loop
 exitwhen i < 1

 set j=GetRandomInt(0, i)
 set a=seq[i]
 set seq[i]=seq[j]
 set seq[j]=a
 set i=i - 1
 endloop
 

endfunction



function CheckIfHasDMG takes unit gu returns nothing

  if IsUnitInGroup(gu, udg_Spelledg) == false then
    call GroupAddUnit(udg_Spelledg, gu)
    call TriggerRegisterUnitEvent(gg_trg_SPDMG, gu, EVENT_UNIT_DAMAGED)
 endif
endfunction

function managetraveler takes integer id returns integer
 local integer i= 0
 local integer j= 0
  loop
   exitwhen i > 4
    set travelerex[i]=null
    set travelerix[i]=null
    set i=i + 1
    endloop
   
 set travelerex[0]=traveler1[id]
 set travelerex[1]=traveler2[id]
 set travelerex[2]=traveler3[id]
 set travelerex[3]=traveler4[id]
 
 set i=0
 loop
 exitwhen i > 3
 if travelerex[i] != null then
  set j=j + 1
  set travelerix[j]=travelerex[i]

 endif
 set i=i + 1
 endloop
 
 
 set traveler1[id]=travelerix[1]
 set traveler2[id]=travelerix[2]
 set traveler3[id]=travelerix[3]
 set traveler4[id]=travelerix[4]


 return j
endfunction


function AddTraveler takes integer id,unit u returns nothing
local integer count= managetraveler(id)

 if count > 3 then
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "   Too many travelers, Please finish your quests before ")
  return
 elseif count == 0 then
   set traveler1[id]=u
  elseif count == 1 then
   set traveler2[id]=u
 elseif count == 2 then
   set traveler3[id]=u
 elseif count == 3 then
   set traveler4[id]=u
 endif
 call UnitAddAbility(u, 'A0CT') //slave inventory
endfunction

function RemoveTraveler takes integer id,unit u returns nothing
local integer i= 0
  if traveler1[id] == u then
    set traveler1[id]=null
  elseif traveler2[id] == u then
    set traveler2[id]=null
  elseif traveler3[id] == u then
    set traveler3[id]=null
  elseif traveler4[id] == u then
    set traveler4[id]=null
  endif
  loop
    exitwhen i > 3
      call RemoveItem(UnitItemInSlot(u, i))
      set i=i + 1
  endloop
  
  call UnitRemoveAbility(u, 'A0CT') //slave inventory 
  
 call managetraveler(id)

endfunction



