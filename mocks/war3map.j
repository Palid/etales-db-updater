 local timer array t
 local integer tc

// local real dx
// local real dy
 //local real dist

 
 local real array inc
 
 // call TriggerSleepAction(0.5) 
 
// call SetUnitAnimationByIndex(u,9)   
 loop
    exitwhen i > 6
    
   set dummy=CreateUnit(Player(id), 'n05Y', x, y, angle)
 
  // call IssueImmediateOrder(dummy, "thunderclap" )
    call UnitApplyTimedLifeBJ(3.00, 'BTLF', dummy)
     //set face[i] = GetUnitFacing(dummy)
 
   set t[i]=(NewTimerEx(0)) // INLINED!!
   set inc[i]=1
 
 //call CreateTextTagLocBJ( I2S(gc), p, 0, 10, 100, 100, 100, 0 )
 
   call SaveUnitHandle(hts, GetHandleId(t[i]), 0, dummy)
   call SaveReal(hts, GetHandleId(t[i]), 1, angle)
  // call SaveReal(hts,GetHandleId(t[gc]),2,dist[gc]) 
   call SaveReal(hts, GetHandleId(t[i]), 4, inc[i])

 // call DestroyEffect(AddSpecialEffectTarget(sffectdusta,gu,"origin")) 

 call TimerStart(t[i], 0.04, true, function BRUTCU)
    
    set angle=angle + 60
    set i=i + 1
  endloop
 
 

      
 // call TriggerSleepAction(0.05)
  call CreateUbersplatBJ(q, "THND", 100, 100, 100, 0, false, false)
  call SetUbersplatRenderAlways(GetLastCreatedUbersplat(), true)
  
  
     

 

 
 call TriggerSleepAction(2.97)
 set tc=6
 loop
 exitwhen tc < 1
   set gu=LoadUnitHandle(hts, GetHandleId(t[tc]), 0)
   call SetUnitPathing(gu, true)
   call FlushChildHashtable(hts, GetHandleId(t[tc]))
   call PauseTimer(t[tc])
   call ReleaseTimer(t[tc])
   set t[tc]=null
 
 set tc=tc - 1
 endloop
 
 if ( GetUnitState(u, UNIT_STATE_LIFE) < 100000 ) then
 call TriggerSleepAction(1.5)
 set i=0
 set angle=30
  loop
    exitwhen i > 6
    
   set dummy=CreateUnit(Player(id), 'n05Y', x, y, angle)
 
  // call IssueImmediateOrder(dummy, "thunderclap" )
    call UnitApplyTimedLifeBJ(3.00, 'BTLF', dummy)
     //set face[i] = GetUnitFacing(dummy)
 
   set t[i]=(NewTimerEx(0)) // INLINED!!
   set inc[i]=1
 
 //call CreateTextTagLocBJ( I2S(gc), p, 0, 10, 100, 100, 100, 0 )
 
   call SaveUnitHandle(hts, GetHandleId(t[i]), 0, dummy)
   call SaveReal(hts, GetHandleId(t[i]), 1, angle)
  // call SaveReal(hts,GetHandleId(t[gc]),2,dist[gc]) 
   call SaveReal(hts, GetHandleId(t[i]), 4, inc[i])

 // call DestroyEffect(AddSpecialEffectTarget(sffectdusta,gu,"origin")) 

 call TimerStart(t[i], 0.04, true, function BRUTCU)
    
    set angle=angle + 60
    set i=i + 1
  endloop
 
 

      
 // call TriggerSleepAction(0.05)
 // call CreateUbersplatBJ(q, "THND", 100, 100, 100, 0, false, false )
  //call SetUbersplatRenderAlways( GetLastCreatedUbersplat(), true )
  
  
     

 

 
 call TriggerSleepAction(2.97)
 set tc=6
 loop
 exitwhen tc < 1
   set gu=LoadUnitHandle(hts, GetHandleId(t[tc]), 0)
   call SetUnitPathing(gu, true)
   call FlushChildHashtable(hts, GetHandleId(t[tc]))
   call PauseTimer(t[tc])
   call ReleaseTimer(t[tc])
   set t[tc]=null
 
 set tc=tc - 1
 endloop
 
 //call RemoveLocation(p)
 //call RemoveLocation(q)
// call DestroyGroup(g)
// set gu = null
 
//call TriggerSleepAction(0.3)
//call SetUnitAnimation(u, "stand" )
//set u = null


 
 endif
 
 
 
 //call RemoveLocation(p)
 call RemoveLocation(q)
 set q=null
 call DestroyGroup(g)
 set g=null
 set gu=null
 
call TriggerSleepAction(0.3)
//call SetUnitAnimation(u, "stand" )
set u=null





endfunction

