        if ivsstageready == true and GetUnitState(gg_unit_E00I_2515, UNIT_STATE_LIFE) < 980000 then
            call ExecuteFunc("laststage")
             
           elseif ivfstageready == true and GetUnitState(gg_unit_E00I_2515, UNIT_STATE_LIFE) < 1480000 then
             call ExecuteFunc("middlestage")
             
           endif

endfunction

