//===========================================================================
// Trigger: initplayer
//
// -_- this code sucks  
//===========================================================================
function bossEnum takes nothing returns boolean
    return ( GetUnitPointValue(GetFilterUnit()) == 300 )
endfunction



function Trig_initplayer_Actions takes nothing returns nothing
 local integer i= 0
 local integer bossBns= 0
 local boolexpr isboss= Condition(function bossEnum)
 local unit boss= null
 
   
    

    set udg_Startpoint=GetRectCenter(gg_rct_Rect_242)
    set udg_VelhimenP=GetRectCenter(gg_rct_Revival)
    set udg_PlayerCont=0
    
    call EnableTrigger(gg_trg_initcommand)
    
    loop
        exitwhen udg_PlayerCont > 7
        if ( GetPlayerSlotState(Player(udg_PlayerCont)) == PLAYER_SLOT_STATE_PLAYING ) then
           
           // call PanCameraToTimedForPlayer(Player(udg_PlayerCont-1), GetLocationX(udg_Startpoint),GetLocationY(udg_Startpoint),0)
            set User[udg_totalPlaying + 1]=udg_PlayerCont
            set udg_Hnext[udg_PlayerCont]=1
            set udg_CHnext[udg_PlayerCont]=200
            set udg_uslot[udg_totalPlaying]=GetPlayerId(Player(udg_PlayerCont))
            set udg_RevivalPoints[GetPlayerId(Player(udg_PlayerCont))]=Location(10300, 16410)
        
        set udg_totalPlaying=udg_totalPlaying + 1
       endif
        set udg_PlayerCont=udg_PlayerCont + 1
    endloop
  loop
   exitwhen i > 8
    call UnitAddAbility(udg_zeppelinunit[i], 'Amrf')
    call UnitRemoveAbility(udg_zeppelinunit[i], 'Amrf')
    call ShowUnit(udg_zeppelinunit[i], false)
   
   set i=i + 1
   endloop
     
    call GroupEnumUnitsInRect(udg_tmpgrop1, GetWorldBounds(), isboss)
    call DestroyBoolExpr(isboss)
    set isboss=null
     
    if udg_totalPlaying > 4 then
       set bossBns=s__bossbonus[5]
    else
       set bossBns=s__bossbonus[udg_totalPlaying]
    endif
    
    loop
     
      exitwhen FirstOfGroup(udg_tmpgrop1) == null
       set boss=FirstOfGroup(udg_tmpgrop1)
       call UnitAddAbility(boss, bossBns)
       call GroupRemoveUnit(udg_tmpgrop1, boss)
      
      endloop
      
      call DestroyGroup(udg_tmpgrop1)
      set udg_tmpgrop1=null
    
   
    set loadingcounter=loadingcounter + 0.01
    set loadingDisplay="Starting dungeons"
  
  call dungeons()
   call InitBMaster()
   call checkdump()
   call initclownlb()
     
     set loadingcounter=loadingcounter + 0.01
     
     set loadingDisplay="Starting quests"
  
  call questinit()

  
  // call CreateDialog() useless for now
   //call InitDialog() useless for now
endfunction

