function SetAltState takes integer id,integer state,integer power,unit barwoman returns nothing
local integer lvl= 0
local real movespd= 0
local real resist= ( s__Mstrength[id] + s__Constitution[id] ) / ( power * 100 )
local integer dlvl= 0
local integer ethyl= 1 + power - R2I(resist)



if GetUnitPointValue(udg_PHero[id]) == 100 then
 call DisableTrigger(gg_trg_drink)
 call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "The barwoman rejects your gold...")
 call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) + drinkvalue[state])
 call TriggerSleepAction(2)
 set novicenodrink[id]=novicenodrink[id] + 1
 call BarwomanAngry(id , barwoman)
return
endif

if ( ethyl < 1 ) then
   set ethyl=1
endif

set s__altstatelvl[(id)*(10)+state]= s__altstatelvl[(id)*(10)+state] + 1

if GetHeroStr(udg_PHero[id], false) < 250 and ( state == LUCK or state == AGI ) then
 if GetHeroStr(udg_PHero[id], false) + ( s__altstate[(id)*(10)+STR] - ( s__altstate[(id)*(10)+state] + s__Slvl[lvl] ) ) < 1 then
 call UnitChat("Take your money back, You're not enough strong to resist this drink.." , barwoman)
 call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) + drinkvalue[state])
 set s__altstatelvl[(id)*(10)+state]= s__altstatelvl[(id)*(10)+state] - 1
 return
 endif
endif

set lvl=s__altstatelvl[(id)*(10)+state]
set s__cups[id]= s__cups[id] + ethyl
set dlvl=s__dstate[id]
set s__dstate[id]= 1 + ( s__cups[id] / 6 )




            //  call DisplayTimedTextToPlayer(Player(id),0,0,5,"State +"+I2S(state))
           //   call DisplayTimedTextToPlayer(Player(id),0,0,5,"dstate -"+I2S(dstate[id]))


    
             
           
    if s__dstate[id] < 6 then
    
                if dlvl < s__dstate[id] then
                  set dlvl=s__dstate[id]
                  
                 if dlvl < 2 then
                 call UnitChat("Uaaa, this is really delicious!" , udg_PHero[id])
                 elseif dlvl < 3 then
                 call UnitChat("Ejjejeje... ejejeje.... ejejeje...HIC!..." , udg_PHero[id])
                 set s__AltStEva[id]= true
                 elseif dlvl < 4 then
                 call UnitChat("UH-h-h-heeeeey! Wheeeere d'ya think yeeeeer goin’?" , udg_PHero[id])
                 set s__AltStMov[id]= true
                 call UnitAddAbility(udg_PHero[id], DRUNKEN)
                 
                 elseif dlvl < 5 then
                 call UnitChat("Hic....  Hic ....AAAAAAHHHH... wheeeeere ish my coup!... ejejeje" , udg_PHero[id])
                 set s__AltStVis[id]= true
                 elseif dlvl < 6 then
                 call UnitChat("Gerroff me!” ... “I’m ash sober ash ’m gonna git. And nothing I - wait wait wait - ...Eeeeeerm." , udg_PHero[id])
                 set s__AltStDmg[id]= true
                 endif
             endif
             
     if lvl < 6 then
     
             set s__altstatedur[(id)*(10)+state]= 3 * 50 * lvl
             
            if state == LUCK then
               
                set s__Fortune[id]= s__Fortune[id] - s__altstate[(id)*(10)+state]
                call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) - s__altstate[(id)*(10)+STR], true)
                
                set s__altstate[(id)*(10)+STR]= s__altstate[(id)*(10)+STR] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
                set s__altstate[(id)*(10)+STR]= s__altstate[(id)*(10)+STR] - s__altstate[(id)*(10)+state]
                
                set s__Fortune[id]= s__Fortune[id] + s__altstate[(id)*(10)+state]
                call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) + s__altstate[(id)*(10)+STR], true)
              
        //      call DisplayTimedTextToPlayer(Player(id),0,0,5,"Luck increased +"+I2S(altstate[id][state]))
        //      call DisplayTimedTextToPlayer(Player(id),0,0,5,"Dec STR "+I2S(altstate[id][STR]))
                //set altstate[id][STR] = 0 - altstate[id][state]
               
           
            elseif state == MSTR then
                set s__Mstrength[id]= s__Mstrength[id] - s__altstate[(id)*(10)+state]
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) - s__altstate[(id)*(10)+AGI], true)
                
                set s__altstate[(id)*(10)+AGI]= s__altstate[(id)*(10)+AGI] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
                set s__altstate[(id)*(10)+AGI]= s__altstate[(id)*(10)+AGI] - s__altstate[(id)*(10)+state]
                 
                set s__Mstrength[id]= s__Mstrength[id] + s__altstate[(id)*(10)+state]
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) + s__altstate[(id)*(10)+AGI], true)
                
         //     call DisplayTimedTextToPlayer(Player(id),0,0,5,"Mental strength +"+I2S(altstate[id][state]))
         //     call DisplayTimedTextToPlayer(Player(id),0,0,5,"Dec AGI "+I2S(altstate[id][AGI]))
                
             elseif state == CONS then
                set s__Constitution[id]= s__Constitution[id] - s__altstate[(id)*(10)+state]
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) - s__altstate[(id)*(10)+INT], true)
                
               set s__altstate[(id)*(10)+INT]= s__altstate[(id)*(10)+INT] + s__altstate[(id)*(10)+state]
               set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
               set s__altstate[(id)*(10)+INT]= s__altstate[(id)*(10)+INT] - s__altstate[(id)*(10)+state]
               
                set s__Constitution[id]= s__Constitution[id] + s__altstate[(id)*(10)+state]
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) + s__altstate[(id)*(10)+INT], true)
              
          //    call DisplayTimedTextToPlayer(Player(id),0,0,5,"Constitution +"+I2S(altstate[id][state]))
          //    call DisplayTimedTextToPlayer(Player(id),0,0,5,"Dec INT "+I2S(altstate[id][INT]))
                
            elseif state == MSPD then
                set movespd=GetUnitMoveSpeed(udg_PHero[id])
                
                  if s__altstatelvl[(id)*(10)+state] < 2 then
                        set s__initspeed[id]= movespd - GetUnitDefaultMoveSpeed(udg_PHero[id])
                    endif
                
                call SetUnitMoveSpeed(udg_PHero[id], movespd - s__altstate[(id)*(10)+state])
                
                if GetUnitAbilityLevel(udg_PHero[id], ARMOR) > 0 then
                  call UnitRemoveAbility(udg_PHero[id], ARMOR)
                endif
                
                set s__altstate[(id)*(10)+DEF]= s__altstate[(id)*(10)+DEF] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + ( s__Slvl[lvl] / 3 )
                set s__altstate[(id)*(10)+DEF]= s__altstate[(id)*(10)+DEF] - s__altstate[(id)*(10)+state]
                
                
                call UnitAddAbility(udg_PHero[id], ARMOR)
                call SetUnitAbilityLevel(udg_PHero[id], ARMOR, 6 - lvl)
                call SetUnitMoveSpeed(udg_PHero[id], movespd + s__altstate[(id)*(10)+state])
              
           //   call DisplayTimedTextToPlayer(Player(id),0,0,5,"Movement speed +"+I2S(altstate[id][state]))
           //   call DisplayTimedTextToPlayer(Player(id),0,0,5,"Dec Armor"+I2S(altstate[id][DEF]))
                
            elseif state == INT then
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) - s__altstate[(id)*(10)+state], true)
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) - s__altstate[(id)*(10)+AGI], true)
                
                set s__altstate[(id)*(10)+AGI]= s__altstate[(id)*(10)+AGI] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
                set s__altstate[(id)*(10)+AGI]= s__altstate[(id)*(10)+AGI] - s__altstate[(id)*(10)+state]
                
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) + s__altstate[(id)*(10)+state], true)
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) + s__altstate[(id)*(10)+AGI], true)
              
           //   call DisplayTimedTextToPlayer(Player(id),0,0,5,"Intelligence +"+I2S(altstate[id][state]))
          //    call DisplayTimedTextToPlayer(Player(id),0,0,5,"Dec AGI"+I2S(altstate[id][AGI]))
            
            elseif state == AGI then
               
               call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) - s__altstate[(id)*(10)+state], true)
               call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) - s__altstate[(id)*(10)+STR], true)
               
                set s__altstate[(id)*(10)+STR]= s__altstate[(id)*(10)+STR] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
                set s__altstate[(id)*(10)+STR]= s__altstate[(id)*(10)+STR] - s__altstate[(id)*(10)+state]
                 
              
               call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) + s__altstate[(id)*(10)+state], true)
               call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) + s__altstate[(id)*(10)+STR], true)
               
            //  call DisplayTimedTextToPlayer(Player(id),0,0,5,"Agility +"+I2S(altstate[id][state]))
            //  call DisplayTimedTextToPlayer(Player(id),0,0,5,"Dec STR "+I2S(altstate[id][STR]))
               
            elseif state == STR then
                call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) - s__altstate[(id)*(10)+state], true)
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) - s__altstate[(id)*(10)+INT], true)
                
                 set s__altstate[(id)*(10)+INT]= s__altstate[(id)*(10)+INT] + s__altstate[(id)*(10)+state]
                 set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
                 set s__altstate[(id)*(10)+INT]= s__altstate[(id)*(10)+INT] - s__altstate[(id)*(10)+state]
                 
                call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) + s__altstate[(id)*(10)+state], true)
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) + s__altstate[(id)*(10)+INT], true)
                
          //    call DisplayTimedTextToPlayer(Player(id),0,0,5,"Strength +"+I2S(altstate[id][state]))
           //   call DisplayTimedTextToPlayer(Player(id),0,0,5,"Dec INT "+I2S(altstate[id][INT]))
            
            elseif state == HITP then
            
               call UnitRemoveAbility(udg_PHero[id], s__HITSP[lvl - 1])
               
                set s__Fortune[id]= s__Fortune[id] - s__altstate[(id)*(10)+LUCK]
                
                set s__altstate[(id)*(10)+LUCK]= s__altstate[(id)*(10)+LUCK] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
                set s__altstate[(id)*(10)+LUCK]= s__altstate[(id)*(10)+LUCK] - s__altstate[(id)*(10)+state]
                
                set s__Fortune[id]= s__Fortune[id] + s__altstate[(id)*(10)+LUCK]
                call UnitAddAbility(udg_PHero[id], s__HITSP[lvl])
               // call SetUnitAbilityLevel(udg_PHero[id],HITSP,lvl)
               
          //    call DisplayTimedTextToPlayer(Player(id),0,0,5,"Hit points +"+I2S(altstate[id][state]))
          //    call DisplayTimedTextToPlayer(Player(id),0,0,5,"Luck "+I2S(altstate[id][LUCK]))
                
            elseif state == DEF then
            
               if GetUnitAbilityLevel(udg_PHero[id], ARMOR) > 0 then
                call UnitRemoveAbility(udg_PHero[id], ARMOR)
               endif
                set s__Mstrength[id]= s__Mstrength[id] - s__altstate[(id)*(10)+MSTR]
                
                set s__altstate[(id)*(10)+MSTR]= s__altstate[(id)*(10)+MSTR] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= s__altstate[(id)*(10)+state] + s__Slvl[lvl]
                set s__altstate[(id)*(10)+MSTR]= s__altstate[(id)*(10)+MSTR] - s__altstate[(id)*(10)+state]
                 
               
                set s__Mstrength[id]= s__Mstrength[id] + s__altstate[(id)*(10)+MSTR]
                call UnitAddAbility(udg_PHero[id], ARMOR)
                call SetUnitAbilityLevel(udg_PHero[id], ARMOR, lvl + 5)
                
             // call DisplayTimedTextToPlayer(Player(id),0,0,5,"Defense +"+I2S(altstate[id][state]))
             // call DisplayTimedTextToPlayer(Player(id),0,0,5,"Mental Strength "+I2S(altstate[id][MSTR]))
            
            endif
        endif //level<6
    else
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffff2222Died by drunken stupor (Ethyl Coma)|r")
     call KillUnit(udg_PHero[id])
     call CleanAllStates(id)
    endif

endfunction


function Createpvpgem takes unit u returns nothing
local real x= GetUnitX(u)
local real y= GetUnitY(u)
local real x1= GetRandomReal(x - 200, x + 200)
local real y1= GetRandomReal(y - 200, y + 200)
 
 call CreateItem('I0UH', x1, y1)

 
endfunction

function DropPvpBoss takes unit u returns nothing
local integer i= GetUnitLevel(u) / 10
local integer j= 0
 loop
 exitwhen j > i
 call Createpvpgem(u)
 set j=j + 1
 endloop


endfunction

function DropPvpMerc takes unit u returns nothing
local integer i= GetUnitLevel(u) / 20
local integer j= 0
 loop
 exitwhen j > i
 call Createpvpgem(u)
 set j=j + 1
 endloop


endfunction

function SetNext takes integer i returns integer
 local integer lev= GetUnitPointValue(udg_PHero[i]) - 100
 if ( lev < 1 ) then
  set udg_Hnext[i]=1
 elseif ( lev < 20 ) then
  set udg_Hnext[i]=3
 elseif ( lev < 40 ) then
  set udg_Hnext[i]=9
 else
  set udg_Hnext[i]=22
 endif
 return udg_Hnext[i]
endfunction


function AddProfaner takes integer id returns nothing
  local integer amnt= GetUnitUserData(udg_PHero[id])

  call TriggerRegisterUnitInRange(trgprofaner[id], udg_PHero[id], 150, Condition(function ctrue))
  call TriggerRegisterUnitInRange(gg_trg_mercinrange, udg_PHero[id], 600, Condition(function ctrue))
  call AdjustPlayerStateBJ(100, Player(id), PLAYER_STATE_RESOURCE_GOLD)
 // call TriggerRegisterUnitEvent( gg_trg_exemass, udg_PHero[id], EVENT_UNIT_DAMAGED )
  set ksquest[id]=SetupQuest(id , null , "BUILDING A HERO" , "Get |cffffcc00" + I2S(SetNext(id) * 300) + "|r kill points to be allowed for next promotion" , I2S(amnt) , "/" + I2S(SetNext(id) * 300) , amnt , s__qty[1])
  call UnitAddAbility(udg_PHero[id], callfamiliar)
  call UnitMakeAbilityPermanent(udg_PHero[id], true, callfamiliar)
 
endfunction    

function RequestLog takes integer id returns nothing
  local integer n= ManagePersQuest(id)
  local integer i= 0
  local integer j
  

          call SetInfoQ(id , 0 , 0 , .3 , "|cff777777¤|r  |cff999999" + questr_Done[id])
          set i=0
          set j=3
          
          
           loop
           exitwhen j > 19
                      
            call SetInfoQ(id , j , 0 , .25 , "  ")
            call SetInfoQ(id , j + 1 , 0 , .3 , "  ")
            call SetInfoQ(id , j , 1 , .05 , "  ")
        
                     
           set j=j + 2
           set i=i + 1
          endloop
          
          set i=0
          set j=3
          
          
          loop
          exitwhen i > n
           if tmpQid[i] > 0 then
         // set Qboard[id][j][0].text = "|cff777777¤|r  |cffffcc00"+QTitle[tmpQid[i]]+"|r"
           call SetInfoQ(id , j , 0 , .25 , "|cff777777¤|r  |cffffcc00" + QTitle[tmpQid[i]] + "|r")
          // set Qboard[id][j+1][0].text = Qtype[tmpQid[i]]+" |cffdddddd"+QSid[tmpQid[i]]+"|r"
           call SetInfoQ(id , j + 1 , 0 , .3 , Qtype[tmpQid[i]] + " |cffdddddd" + QSid[tmpQid[i]] + "|r")
          // set Qboard[id][j+1][1].text = QSidx[tmpQid[i]] + QSidy[tmpQid[i]]
           call SetInfoQ(id , j , 1 , .05 , QSidx[tmpQid[i]] + QSidy[tmpQid[i]])
           
              endif
           set j=j + 2
           set i=i + 1
          endloop

        
 
endfunction


function RequestStats takes integer id returns nothing
local string pname= GetPlayerName(Player(id))
local string hname= GetUnitName(udg_PHero[id])
local string level= I2S(GetUnitLevel(udg_PHero[id]))
local string rpoint= I2S(GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_LUMBER))
local string mspeed="|cff8888ffMSpeed|r = " + I2S(R2I(GetUnitMoveSpeed(udg_PHero[id])))
local string cadd= "Class:|cffbbbbff" + hname + "|r"
local real sp_cast_chance= I2R(s__Fortune[id]) / 30
local real sp_cast_xdmg= I2R(s__Mstrength[id]) / 647
local real lethal_attack_edmg= 1.618 * ( logg(10 , 10 + I2R(s__Constitution[id])) - 1 )
local real lethal_attack_per= ( I2R(s__Fortune[id]) / 1618 ) * 100
local real destr_drop_per= 7 + ( I2R(s__Fortune[id]) / 1618 ) * 100
local integer find_gold_chance= R2I(12 + logg(1.618 , I2R(1 + s__Fortune[id])))
        local real col0= .07
        local real col1= .05
        local real col2= .01
        local real col3= .10
        local real col4= .05
 

        call GetStats(udg_PHero[id] , id)

        call SetInfo(id , 1 , 0 , col0 , cadd)
        call SetInfo(id , 1 , 1 , col1 , "Level:" + level)
        
        call SetInfo(id , 2 , 0 , col0 , mspeed)
        call Setwidth(id , 3 , 0 , col0)
        call SetInfo(id , 4 , 1 , col1 , rpoint)
        call SetInfo(id , 5 , 1 , col1 , "|cffffcc00" + I2S(GetUnitUserData(udg_PHero[id])) + "/" + I2S(SetNext(id) * 300) + "|r") //killer points
        call SetInfo(id , 6 , 1 , col1 , "|cffffcc00" + s__drunkenlvl[s__dstate[id]] + "|r") //state
        call SetInfo(id , 1 , 4 , col4 , I2S(udg_STR[id]))
        call SetInfo(id , 2 , 4 , col4 , I2S(udg_AGI[id]))
        call SetInfo(id , 3 , 4 , col4 , I2S(udg_INT[id]))
        call SetInfo(id , 5 , 4 , col4 , I2S(s__Constitution[id]))
        call SetInfo(id , 6 , 4 , col4 , I2S(s__Mstrength[id]))
        call SetInfo(id , 7 , 4 , col4 , I2S(s__Fortune[id]))
        call SetInfo(id , 7 , 1 , col1 , I2S(find_gold_chance) + "%")
        call SetInfo(id , 8 , 1 , col1 , R2S(destr_drop_per) + "%")
        call SetInfo(id , 9 , 1 , col1 , udg_Factionname[udg_Faction[id]])
       call SetInfo(id , 10 , 1 , col1 , I2S(Reputation[id]))
        call SetInfo(id , 8 , 4 , col4 , ylw + R2S(sp_cast_chance) + "%|r")
        call SetInfo(id , 9 , 4 , col4 , ylw + R2S(sp_cast_xdmg) + "x|r")
       call SetInfo(id , 10 , 4 , col4 , ylw + R2S(lethal_attack_per) + "%|r")
       call SetInfo(id , 11 , 4 , col4 , ylw + R2S(lethal_attack_edmg) + "x|r")
       call SetInfo(id , 12 , 4 , col4 , ylw + R2S(I2R(s__Mstrength[id]) / 23) + "%|r")
       call SetInfo(id , 13 , 4 , col4 , ylw + R2S(I2R(s__Constitution[id]) / 402) + "%|r")
         call Setwidth(id , 11 , 0 , col0)
         call Setwidth(id , 12 , 0 , col0)
         call Setwidth(id , 13 , 0 , col0)
         call Setwidth(id , 11 , 1 , col1)
         call Setwidth(id , 12 , 1 , col1)
         call Setwidth(id , 13 , 1 , col1)
           
           
           set cadd=null
           set rpoint=null
           set pname=null
           set hname=null
           set mspeed=null
           set level=null
        

endfunction

function isherostatue takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

 function NewBoard takes integer id returns nothing
       // local integer id = 0
        local string pname
        local string hname
        local string level
        local string rpoint
        local string mspeed
        local integer n
        local integer i= 0
        local integer j
        local real sp_cast_chance
        local real sp_cast_xdmg
        local real lethal_attack_edmg
        local real lethal_attack_per
        local real destr_drop_per
        local string faction
        local integer find_gold_chance
        local real col0= .07
        local real col1= .05
        local real col2= .01
        local real col3= .10
        local real col4= .05
  
      
        
         
        set Pboard[id]=sc__Board_create()
       // call Pboard[id].setStyle(true, false)
       
        set pname=GetPlayerName(Player(id))
        set hname=GetUnitName(udg_PHero[id])
        set level=I2S(GetUnitLevel(udg_PHero[id]))
        set rpoint=I2S(GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_LUMBER))
        set mspeed="|cff8888ffMSpeed|r = " + I2S(R2I(GetUnitMoveSpeed(udg_PHero[id])))
   
        set sp_cast_chance=I2R(s__Fortune[id]) / 30
        set sp_cast_xdmg=I2R(s__Mstrength[id]) / 647
        set lethal_attack_edmg=1.618 * ( logg(10 , 10 + I2R(s__Constitution[id])) - 1 )
        set lethal_attack_per=( I2R(s__Fortune[id]) / 1618 ) * 100
                   

        set find_gold_chance=R2I(12 + logg(1.618 , I2R(1 + s__Fortune[id])))
        set destr_drop_per=7 + ( I2R(s__Fortune[id]) / 1618 ) * 100
        set faction=udg_Factionname[udg_Faction[id]]

       

        
         call GetStats(udg_PHero[id] , id)
           

                
           call MultiboardSetTitleText(s__Board_Board___bBoard[(Pboard[id])], (pname + "'s Info")) // INLINED!!
           
        //    set Pboard[id].column[0].width = .11
        //    set Pboard[id].column[1].width = .05
        //    set Pboard[id].column[2].width = .01
        //    set Pboard[id].column[3].width = .11
        //    set Pboard[id].column[4].width = .03
           
           call SetInfo(id , 0 , 0 , col0 , "|cffffcc00HERO INFO|r")
           call Setwidth(id , 0 , 1 , col1)
          // call Setwidth(id,1, 1,col1)
         
           //set Pboard[id][0][0].text = "|cffffcc00HERO INFO|r"
           call SetInfo(id , 1 , 0 , col0 , "Class: |cffbbbbff" + hname + "|r")
           call SetInfo(id , 1 , 1 , col1 , "Level:" + level)
          
           
           call SetInfo(id , 2 , 0 , col0 , mspeed)
           call Setwidth(id , 2 , 1 , col1)
           
           
           call Setwidth(id , 3 , 0 , col0)
           call Setwidth(id , 3 , 1 , col1)
           
           call SetInfo(id , 4 , 0 , col0 , "Unused points:")
           call SetInfo(id , 4 , 1 , col1 , rpoint)
            
           call SetInfo(id , 5 , 0 , col0 , "Killer Points:")
