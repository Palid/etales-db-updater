// Trigger: scoutdead
//===========================================================================
function Trig_scoutdead_Actions takes nothing returns nothing
    local integer id= GetUnitUserData(GetTriggerUnit()) - 1
    set scoutdead[id]=true
    set rescuedscout[id]=null
    
    call DisableTrigger(LoadTriggerHandle(questtm, GetHandleId(udg_PHero[id]), StringHash("scouttrg")))
   
endfunction

//===========================================================================
function InitTrig_scoutdead takes nothing returns nothing
    set gg_trg_scoutdead=CreateTrigger()
   
    call TriggerAddAction(gg_trg_scoutdead, function Trig_scoutdead_Actions)
endfunction


//===========================================================================
// Trigger: checkingscout
//===========================================================================
function returnreinhard takes nothing returns boolean
return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_checkingscout_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 
  if scoutON[id] == true then
    if scoutdead[id] == true then
     set scoutON[id]=false
     
     
  elseif rescuedscout[id] != null then
    
      set scoutON[id]=false
      call DestroyEffect(AddSpecialEffectTarget(seblink, rescuedscout[id], "chest"))
      call TriggerSleepAction(2)
      call RemoveUnit(rescuedscout[id])
      call DisableTrigger(LoadTriggerHandle(questtm, GetHandleId(udg_PHero[id]), StringHash("scouttrg")))
      set rescuedscout[id]=null
    endif
  endif
endfunction

//===========================================================================
function InitTrig_checkingscout takes nothing returns nothing
    set gg_trg_checkingscout=CreateTrigger()
    call TriggerRegisterUnitInRange(gg_trg_checkingscout, gg_unit_h019_1129, 170, Condition(function btrue))
    call TriggerAddCondition(gg_trg_checkingscout, Condition(function returnreinhard))
    call TriggerAddAction(gg_trg_checkingscout, function Trig_checkingscout_Actions)
endfunction


//===========================================================================
// Trigger: repscout
//===========================================================================
function Trig_repscout_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0UL' and scoutON[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == false )
endfunction

function Trig_repscout_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))

     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00The Captain says:|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    I been noticed about another scout that has been seen")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    |cffffcc00Go to rescue him before he die|r")
     set scoutON[id]=true
     set scoutdead[id]=false
     set questIndex[id]=questIndex[id] + 1
     call AddQuestLog(questIndex[id] , id , "Rescue Velhilmen scout" , reinhard)
       
    call StartSound(bj_questDiscoveredSound)
   
    call setupscouts(id)



      
      loop
         exitwhen ( scoutON[id] == false )
              call TriggerSleepAction(0.50)
         endloop
      
      
      
       
    call TriggerSleepAction(0.5)
    set scoutON[id]=true
    
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00QUEST DONE|r: Rescue velhilmen Scout")
      call MarkQuestDone(id , reinhard)
      call TriggerSleepAction(1)

      call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00The Captain says:|r")
      if scoutdead[id] == true then
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    What??.. the scout has died!")
        call TriggerSleepAction(4)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "    ...")
        call TriggerSleepAction(3)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    Too bad for his family...")
        call TriggerSleepAction(2)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Anyway, thanks for your services...")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Take this, It can helps you.")
        call TriggerSleepAction(5)
        call StartSound(gg_snd_QuestActivateWhat1)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cffffcc00Got +800 Gold|r")
        call AdjustPlayerStateBJ(800, Player(id), PLAYER_STATE_RESOURCE_GOLD)
    elseif scoutdead[id] == false then
      
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Excelent " + Pnombre[id] + "!, We have true warriors here!")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    keep up the good work")
      call TriggerSleepAction(3)
      call StartSound(gg_snd_QuestActivateWhat1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cff00ccffGot +1000 Experience|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cffffcc00Got +1500 Gold|r")
      call AddHeroXP(udg_PHero[id], 1000, false)
      call AdjustPlayerStateBJ(1500, Player(id), PLAYER_STATE_RESOURCE_GOLD)
   endif
   
      call TriggerSleepAction(3)
      set scoutON[id]=false

endfunction

//===========================================================================
function InitTrig_repscout takes nothing returns nothing
    set gg_trg_repscout=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_repscout, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_repscout, Condition(function Trig_repscout_Conditions))
    call TriggerAddAction(gg_trg_repscout, function Trig_repscout_Actions)
endfunction


//===========================================================================
// Trigger: rescuescouts
//===========================================================================
//===========================================================================
// Trigger: clrscr
//===========================================================================
function Trig_clrscr_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0AS' )
endfunction

function Trig_clrscr_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
endfunction

//===========================================================================
function InitTrig_clrscr takes nothing returns nothing
   local integer i= 0
   set gg_trg_clrscr=CreateTrigger()
    
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_clrscr, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function btrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
   
    
   
    call TriggerAddCondition(gg_trg_clrscr, Condition(function Trig_clrscr_Conditions))
    call TriggerAddAction(gg_trg_clrscr, function Trig_clrscr_Actions)
endfunction


//===========================================================================
// Trigger: sleeptent
//===========================================================================
//TESH.scrollpos=37
//TESH.alwaysfold=0
function SELPTC takes nothing returns boolean
     return ( GetUnitTypeId(GetTransportUnit()) == 'e00F' )
endfunction

function SELPTA takes nothing returns nothing
local integer i= 0

local unit u= GetTriggerUnit()
local unit tr= GetTransportUnit()
local integer id= GetPlayerId(GetOwningPlayer(tr))
local effect sf= AddSpecialEffectTarget("Abilities\\Spells\\Undead\\Sleep\\SleepTarget.mdl", tr, "overhead")

 call UnitRemoveAbility(udg_ARVault[id], 'A05O')
call UnitRemoveAbility(udg_BMaster[id], 'A05O')
call UnitRemoveAbility(udg_MAVault[id], 'A05O')

 call SetUnitInvulnerable(tr, false)
 
  loop
   exitwhen IsUnitLoaded(u) == false
   
    call SetUnitLifeBJ(u, ( GetUnitState(u, UNIT_STATE_LIFE) + ( GetUnitState(u, UNIT_STATE_MAX_LIFE) * 0.04 ) ))
    call SetUnitManaBJ(u, ( GetUnitState(u, UNIT_STATE_MANA) + ( GetUnitState(u, UNIT_STATE_MAX_MANA) * 0.04 ) ))
    call TriggerSleepAction(0.5)
    set i=i + 1
    if i > 28 then
     call IssueTargetOrder(tr, "unload", u)

    endif
   endloop
    call SetUnitLifeBJ(u, ( GetUnitState(u, UNIT_STATE_LIFE) + 4000 ))
    call SetUnitManaBJ(u, ( GetUnitState(u, UNIT_STATE_MANA) + 1000 ))
   

 call DestroyEffect(sf)
 set sf=null
 call SetUnitInvulnerable(tr, true)

 call UnitAddAbility(udg_ARVault[id], 'A05O')
 call UnitAddAbility(udg_BMaster[id], 'A05O')
 call UnitAddAbility(udg_MAVault[id], 'A05O')
  
// call IssueImmediateOrder(tr, "berserk" )
 set u=null
 set tr=null
endfunction

//===========================================================================
function InitTrig_sleeptent takes nothing returns nothing
    set gg_trg_sleeptent=CreateTrigger()
    
    call TriggerRegisterAnyUnitEventBJ(gg_trg_sleeptent, EVENT_PLAYER_UNIT_LOADED)
    
    
    call TriggerAddCondition(gg_trg_sleeptent, Condition(function SELPTC))
    call TriggerAddAction(gg_trg_sleeptent, function SELPTA)
endfunction


//===========================================================================
// Trigger: enabletutorial
//===========================================================================
//TESH.scrollpos=316
//TESH.alwaysfold=0



function Trig_enabletutorial_Conditions takes nothing returns boolean

    return ( GetItemTypeId(GetManipulatedItem()) == 'I0U8' )
endfunction

function Trig_enabletutorial_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local integer level= GetUnitLevel(udg_PHero[id])
 local integer questid= 0
 local item itm
 local integer kills= 0
 local integer killsf= 0
 
 if ( udg_tutorialNO[id] == false and level < 4 ) then
      
      set udg_tutorialNO[id]=true
      
      call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
      call TriggerSleepAction(1)
      
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Hello " + Pnombre[id] + ", I see you are a new adventurer here")
      call TriggerSleepAction(6)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    |cffffcc00Enthashara|r is a beautiful land, but some strange things happens")
      call TriggerSleepAction(6)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    I am looking for helpers to go |cffffcc00Velhilmen village|r. Maybe you can give a hand")
      call TriggerSleepAction(6)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    First we need to check if you has the bravery and the dexterty")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    to deal with those problems")
      call TriggerSleepAction(7)
      call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Ok, let's begin with the tutorial, I will show you all the basics of the game")
      call TriggerSleepAction(6)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    When you learn it, I will give you your first main quest")
      call TriggerSleepAction(8)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "   " + Pnombre[id] + ", the |cffffcc00wisp|r that follow you is your permanently support.")
      call TriggerSleepAction(7)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "     Your wisp, the |cffffcc00soul guardian|r works as pocket where you can:")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "       |cffaaffaa- carry and use items|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "       |cffaaffaa- manage FAMILIAR aspects")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "       |cffaaffaa- manage QUEST registry")
      call TriggerSleepAction(10)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "     |cffffcc00Remember this:|r your wisp is allowed to carry all those items which require higher level than yours")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "     Except those activable items with offensive abilities. Wisp cannot handle them")
      call TriggerSleepAction(6)
      call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
      
      if GetUnitLevel(udg_PHero[id]) < 4 then
          call AdjustPlayerStateBJ(16, Player(id), PLAYER_STATE_RESOURCE_LUMBER)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "|cffffcc00Shayu says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    Ok, now you have |cffffcc0016 stats points|r, check it on your lumber resource.")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    On each new level you will gain 16 new stats point to distribute")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    To set your atributes with these stats points, you must |cffffcc00Press|r the |cffffcc00ESC|r key")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    and select the |cffffcc00Stats Book Master|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    This book allows you to spend your stat points in |cff6666ffInt|r,|cff66ff66Agi|r,|cffff3333Str|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    or in advanced status like |cffffcc00Mstr|r,|cff66ffaaConst|r,|cffffaa33Luck|r")
          call TriggerSleepAction(10)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 35, "    It's strongly recomended to destinate a considerable amount of your point to Strength.")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 35, "    It will keeps you alive while you takes damage in lower levels")
          call TriggerSleepAction(10)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 25, "    |cffffcc00Spend all your stat points now!|r")
              loop
                exitwhen ( GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_LUMBER) == 0 )
                  call TriggerSleepAction(0.10)
                endloop
          
          call TriggerSleepAction(2)
          if ( GetLocalPlayer() == Player(id) ) then
              call ClearTextMessages()
          endif
          call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Well done " + Pnombre[id] + ", take a little reward for doing your first work!")
          call TriggerSleepAction(1)
          call StartSound(gg_snd_QuestActivateWhat1)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    |cff00ccffGot +500 Experience|r")
          call AddHeroXP(udg_PHero[id], 500, false)
      endif
        
      call TriggerSleepAction(7)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    " + Pnombre[id] + " when you press the |cffffcc00ESC|r key, it's like your are deploying a |cffffcc00Personal Camp.|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    In your camp you own a |cffffcc00Stats Book Master|r, a |cffffcc00Jewel Box|r and your |cffffcc00Tent|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    You'll find a lot of |cffffccccGems|r and |cffffffccGem fragments|r dropped from monsters and destructables")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    Gems fragments automatically are moved to the |cffffcc00Book's master|r when you pickup it")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    A |cffffccccGem|r is forged with 5 gem fragments of the same type.")
      call StartSound(gg_snd_QuestActivateWhat1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 45, "    |cffffcc00Go to the fields and find me one gem fragment!|r")
     
      set questid=SetupQuest(id , tutor , "A NEW ADVENTURE - PART I" , "Find a gem Fragment " , "0" , "/1" , 0 , s__qty[1])
      
      
     // set questIndex[id] = questIndex[id] + 1
      //call AddQuestLog(questIndex[id],id,"Find a gem Fragment",tutor) 
      
      
      
       loop
            exitwhen ( GetItemLevel(UnitItemInSlot(udg_BMaster[id], 0)) == 222 )
              call TriggerSleepAction(0.50)
            endloop
      call TriggerSleepAction(1.5)
      
       call SetUnitPositionLoc(udg_PHero[id], tutorialL)
       call SetUnitPositionLoc(udg_Familiar[id], tutorialL)
       call SetUnitPositionLoc(udg_Slave[id], tutorialL)
       call PanCameraToTimedLocForPlayer(Player(id), tutorialL, 0)
       call DestroyEffect(AddSpecialEffectTarget(seblink, udg_PHero[id], "chest"))
       call CheckCurrentCamera(id)
       
    call TriggerSleepAction(1)
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Nice " + Pnombre[id] + "!, you got a new reward!")
      call TriggerSleepAction(1)
      call StartSound(gg_snd_QuestActivateWhat1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    |cff00ccffGot +900 Experience|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    |cff00ccffGot Rubi Gem|r")
      call AddHeroXP(udg_PHero[id], 900, false)
      
   //   call MarkQuestDone(id,tutor)
       call UpdatePersQuestND(id , questid , 1 , "-" , I2S(1) , "-")
       call TriggerSleepAction(0.02)
       call RemoveQuestFromPlayer(questid , id)
      
      
      set itm=CreateItem('I0MK', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])) //rubi
      call UnitAddItem(udg_PHero[id], itm)
      set itm=null
      
      call TriggerSleepAction(6)
      call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    To |cffccccffstore|r gems into your |cffffcc00Jewel Box|r you must click on it")
      call TriggerSleepAction(6)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Remember to |cffffcc00hide|r your camp when you finish your settings.")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Your Stored gems could be |cffffcc00stolen|r by other players if")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    you don't hide your camp. Take care about it")
      call TriggerSleepAction(8)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    It's very important to store any crafted gem into your Jewel Box")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    By this mode you leaves free the slot to start another gem craft")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    |cffffcc00If all the six slots of your Book's Master are loaded, you'll start losing collected gem fragments|r")
      call TriggerSleepAction(14)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    A |cffffcc00deep gem sound|r like |cffff0000this|r advices you when a gem is ready.")
      call TriggerSleepAction(1)
      call PlaySoundOnUnitBJ(bj_questSecretSound, 75, udg_PHero[id])
      call TriggerSleepAction(7)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Ok, the third element of your camp is your |cffffcc00Personal Tent|r.")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    it allows you to restore your Hp and Mana while you are sleeping")
      call TriggerSleepAction(7)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    While you're sleeping, your tent can be destroyed. Take care of it.")
    //  call DisplayTimedTextToPlayer(Player(id),0,0,6,"    |cffccccffStore Scroll Button|r. It will search any scroll into your current inventories.")
      call TriggerSleepAction(8)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    Ok, let'see the |cffffcc00fighting|r experience")
      call TriggerSleepAction(5)
      
      set itm=CreateItem('I005', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])) //rubi
      call SetItemCharges(itm, 20)
      call UnitAddItem(udg_PHero[id], itm)
      set itm=null
      set itm=CreateItem('I005', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])) //rubi
      call SetItemCharges(itm, 20)
      call UnitAddItem(udg_PHero[id], itm)
      set itm=null
      
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Take this meat and go to fields!")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    |cff00ccffGot +2 Meat packs|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    While you practice your combat skills, slay |cffffcc0020 Monsters!|r")
      
      set questid=SetupQuest(id , tutor , "A NEW ADVENTURE - PART II" , "Slay monsters in Emerald Port's field " , "0" , "/20" , 0 , s__qty[1])
     
      call SaveInteger(udg_cache, GetHandleId(tutor), GetHandleId(udg_PHero[id]), questid)
     // set questIndex[id] = questIndex[id] + 1
     // call AddQuestLog(questIndex[id],id,"|cffffcc00Monsters killed:|r 0/20",tutor) 
      call TriggerSleepAction(5)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    When you'll be ready i'll teleport you back!")
      call TriggerSleepAction(8)

      
      
      set kills=GetUnitUserData(udg_PHero[id]) + 20
      set monster_kill_display[id]=true
      set monster_count[id]=0
      set monster_total[id]=20
      set monster_to_kill[id]="Monsters"
      loop
            exitwhen ( GetUnitUserData(udg_PHero[id]) >= kills )
              call TriggerSleepAction(0.50)
      endloop
       set monster_kill_display[id]=false
       call TriggerSleepAction(0.5)
      
       call SetUnitPositionLoc(udg_PHero[id], tutorialL)
       call SetUnitPositionLoc(udg_Familiar[id], tutorialL)
       call SetUnitPositionLoc(udg_Slave[id], tutorialL)
       call PanCameraToTimedLocForPlayer(Player(id), tutorialL, 0)
       call DestroyEffect(AddSpecialEffectTarget(seblink, udg_PHero[id], "chest"))
       call CheckCurrentCamera(id)
       
    call TriggerSleepAction(1)
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Nicely done " + Pnombre[id] + "!, take this reward!")
      
      call UpdatePersQuestND(id , questid , 20 , "-" , I2S(20) , "-")
      call TriggerSleepAction(0.02)
      call RemoveQuestFromPlayer(questid , id)
      
    //  call MarkQuestDone(id,tutor)
      call TriggerSleepAction(1)
      call StartSound(gg_snd_QuestActivateWhat1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cff00ccffGot +1800 Experience|r")
      call AddHeroXP(udg_PHero[id], 1800, false)
      call TriggerSleepAction(5)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "   " + Pnombre[id] + " you can evolute according to the class that you'll chose.")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Each evolution requires a certain amount of |cffffcc00kill points|r.")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    These |cffffcc00kill points|r are count from death monsters by your hand,")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    check your current |cffffcc00kill points|r on your wisp or in the |cffddddffgame info panel|r")
      call TriggerSleepAction(12)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 05, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 05, "    I wanna reward you with 30 kill points if you do a little work for me")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 05, "    into the fields there are some |cff99ff99Gnoll Assasins|r those lead the monsters")
      call TriggerSleepAction(1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 20, "    Go to the forest and kill |cffffcc003 Gnoll Assasins!|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 20, "    When you'll be ready i'll teleport you back!")
      call StartSound(gg_snd_QuestActivateWhat1)
      
      set questid=SetupQuest(id , tutor , "A NEW ADVENTURE - PART III" , "Exterminate Gnoll Leaders " , "0" , "/3" , 0 , s__qty[1])
      call SaveInteger(udg_cache, GetHandleId(tutor), GetHandleId(udg_PHero[id]), questid)
     // set questIndex[id] = questIndex[id] + 1
     // call AddQuestLog(questIndex[id],id,"|cffffcc00Gnoll Assasins killed:|r 0/3",tutor)  
      set GnollAssasinsC[id]=0
      set GnollAssasins[id]=true //to show the counter
      call TriggerSleepAction(1)
      loop
         exitwhen ( GnollAssasinsC[id] >= 3 )
              call TriggerSleepAction(0.50)
         endloop
      set GnollAssasins[id]=false //to show the counter
      call TriggerSleepAction(0.5)
      
       call SetUnitPositionLoc(udg_PHero[id], tutorialL)
       call SetUnitPositionLoc(udg_Familiar[id], tutorialL)
       call SetUnitPositionLoc(udg_Slave[id], tutorialL)
       call PanCameraToTimedLocForPlayer(Player(id), tutorialL, 0)
       call DestroyEffect(AddSpecialEffectTarget(seblink, udg_PHero[id], "chest"))
       call CheckCurrentCamera(id)
       
    call TriggerSleepAction(1)
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call SetUnitFacingToFaceUnitTimed(tutor, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Excelent " + Pnombre[id] + "!, Here is your reward!")
      
      call UpdatePersQuestND(id , questid , 20 , "-" , I2S(20) , "-")
      call TriggerSleepAction(0.02)
      call RemoveQuestFromPlayer(questid , id)
      
     // call MarkQuestDone(id,tutor)
      call TriggerSleepAction(1)
      call StartSound(gg_snd_QuestActivateWhat1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cff00ccffGot +30 Kill Points|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cff00ccffGot +2800 Experience|r")
      call AddHeroXP(udg_PHero[id], 2800, false)
      call SetUnitUserData(udg_PHero[id], ( GetUnitUserData(udg_PHero[id]) + 30 ))
      call TriggerSleepAction(5)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Well done " + Pnombre[id] + ", the tutorial finishes here.")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Don't forget to use your stat points, and take care of your camp")
      call TriggerSleepAction(8)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    I have a gift for you, use it wisely")
      call TriggerSleepAction(1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    |cff00ccffGot 1 Bear Claws|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    |cff00ccffGot 1 Diamond|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    |cff00ccffGot 1 Rare Chest|r")
      set itm=CreateItem('I001', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])) //claws
      call UnitAddItem(udg_PHero[id], itm)
      set itm=null
      set itm=CreateItem('I0ML', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])) //diamond
      call UnitAddItem(udg_PHero[id], itm)
      set itm=null
      set itm=CreateItem('I008', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])) //rare chest
      call UnitAddItem(udg_PHero[id], itm)
      set itm=null
      call TriggerSleepAction(1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Those claws are part of a |cffffcc00Set|r. Complete it " + Pnombre[id])
      call TriggerSleepAction(7)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Shayu says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Now " + Pnombre[id] + ", go to talk with |cffffcc00Reinhard|r on Velhilmen Village")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Good luck...")
      call StartSound(bj_questDiscoveredSound)
      
      set questid=SetupQuest(id , tutor , "BEARS'S ISSUE IN VELHILMEN" , "Find Reinhard on Velhilmen " , " " , " " , 0 , s__qty[1])
     if ( GetLocalPlayer() == Player(id) ) then
           call PingMinimapEx(- 14343, 14286, 16, 255, 255, 50, false)
       endif
      
      call SaveInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[id]), questid)
      //set questIndex[id] = questIndex[id] + 1
     // call AddQuestLog(questIndex[id],id,"|cffffcc00Find Reinhard on Velhilmen|r",reinhard)  
      set reinhardON[id]=true
      
 elseif ( udg_tutorialNO[id] == true and level == 3 ) then
     call UnitChat("Be quiet " + Pnombre[id] + "!" , tutor)
 else
     call UnitChat("Sorry " + Pnombre[id] + ", you can't repeat this tutorial." , tutor)
 endif
 

endfunction

//===========================================================================
function InitTrig_enabletutorial takes nothing returns nothing
    local integer i= 0
    set gg_trg_enabletutorial=CreateTrigger()
    
       loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_enabletutorial, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function btrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
   
    call TriggerAddCondition(gg_trg_enabletutorial, Condition(function Trig_enabletutorial_Conditions))
    call TriggerAddAction(gg_trg_enabletutorial, function Trig_enabletutorial_Actions)
endfunction


//===========================================================================
// Trigger: bearmaskquest
//
// 
//===========================================================================
function Trig_bearmaskquest_Conditions takes nothing returns boolean
     return ( GetItemTypeId(GetManipulatedItem()) == 'I080' )
endfunction

function Trig_bearmaskquest_Actions takes nothing returns nothing
local item itm= GetManipulatedItem()
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local integer itmid= 0
 local integer questid= 0
  
  if ( bearmaskON[id] == true ) then
    call SaveInteger(questtm, GetHandleId(itm), 1, id)
  elseif ( GetTriggerUnit() == reinhard ) then
   set itmid=LoadInteger(questtm, GetHandleId(itm), 1)
   if bearmaskON[itmid] == true then
      
       set bearmask[itmid]=bearmask[itmid] + 1
   
    
      if ( GetLocalPlayer() == Player(itmid) ) then
          call ClearTextMessages()
       endif
      set questid=LoadInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[itmid]))
      call UpdatePersQuestND(itmid , questid , bearmask[itmid] , "-" , I2S(bearmask[itmid]) , "-")
      
      call DisplayTimedTextToPlayer(Player(itmid), 0, 0, 3, "|cffffcc00Collected bear masks|r: " + I2S(bearmask[itmid]) + "/4")
     // call UpdateQuestLog(reinhard,itmid,"|cffffcc00Collected bear masks|r: "+I2S(bearmask[itmid])+"/4")
   endif
   call TriggerSleepAction(0.3)
   call RemoveItem(itm)
  endif
 set itmid=0
endfunction

//===========================================================================
function InitTrig_bearmaskquest takes nothing returns nothing
    local integer i= 0
    set gg_trg_bearmaskquest=CreateTrigger()
     loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_bearmaskquest, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function btrue))
        set i=i + 1
        exitwhen i == 16
    endloop
   
    call TriggerAddCondition(gg_trg_bearmaskquest, Condition(function Trig_bearmaskquest_Conditions))
    call TriggerAddAction(gg_trg_bearmaskquest, function Trig_bearmaskquest_Actions)
endfunction


//===========================================================================
// Trigger: reinhardNovices
//===========================================================================
function reinc takes nothing returns boolean
    return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) and reinhardON[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == true )
endfunction

function reina takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local item itm
  local integer questid= 0
   
  set reinhardON[id]=false
  call UnitChat("Here is Reinhard..." , udg_PHero[id])
  call TriggerSleepAction(1)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "|cffffcc00MAIN QUEST UPDATE|r: Find Reinhard")
  call StartSound(gg_snd_QuestActivateWhat1)
  
     set questid=LoadInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[id]))

     call UpdatePersQuestND(id , questid , 0 , "-" , "-" , "-")
     call TriggerSleepAction(0.02)
     call RemoveQuestFromPlayer(questid , id)
      
  
 // call MarkQuestDone(id,reinhard)
  call TriggerSleepAction(4)
  call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    What!?, |cffffcc00Shayu|r sends you to talk with me?...")
  call TriggerSleepAction(6)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Mmmm, you look too weak!")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Seriously, We have heavy problems here, so... I don't believe that you can help me")
  call TriggerSleepAction(7)
  call UnitChat("trust me... i will be the most powerfull warrior ever!!!" , udg_PHero[id])
  call TriggerSleepAction(4)
  call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "    You!!?")
  call TriggerSleepAction(4)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    UWAAAAAHAHAHJAHAHAHAHAHAHAHHA!!!!.Ha ha haaa haaa..")
  call TriggerSleepAction(4)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 1, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 1, "    *cof  *cof...")
  call UnitChat("@%$##~!!!" , udg_PHero[id])
  call TriggerSleepAction(3)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "    Dammit child, Shayu sent me a joker")
  call TriggerSleepAction(4)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Well... anyway, we need all the help possible, included jokers")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    so, if you can wield a weapon, that's just what we want")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    also you can demonstrate that you are more than a joker... boy")
  call TriggerSleepAction(9)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Let'see... ")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Our first problem are those |cffffcc00bears|r. ")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Three weeks ago, some early morning they appeared in our fields")
  call TriggerSleepAction(7)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    I know that their natural habitat was the South lands ")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    But for some unknown reason they moved here")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    It's look like they are |cffffcc00running away|r for something rare")
  call TriggerSleepAction(8)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    But we are paying this crisis losing our crops")
  call TriggerSleepAction(5)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Reinhard says:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    We started to hunt bears, their hides and claws can be sold")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    and it makes them move away for little times")
  call TriggerSleepAction(7)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00NEW MAIN QUEST|r: Give Reinhard |cffffcc004 Bear masks|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "     Drop |cffffcc004 Bear masks|r in front of Reinhard")
  call StartSound(bj_questDiscoveredSound)
  set bearmaskON[id]=true
  
  set questid=SetupQuest(id , tutor , "BEARS'S ISSUE IN VELHILMEN" , "Drop baby bear heads in front of Reinhard " , "0" , "/4" , 0 , s__qty[1])
  call SaveInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[id]), questid)
 
 // set questIndex[id] = questIndex[id] + 1
 // call AddQuestLog(questIndex[id],id,"|cffffcc00Collected bear masks|r: 0/4",reinhard) 
 
  call UnitChat("Go to hunt bears and drop their heads here" , reinhard)
  call EnableTrigger(trgbmask[id])
  set bearmask[id]=0
  loop
            exitwhen ( bearmask[id] > 3 )
              call TriggerSleepAction(0.50)
  endloop
  set bearmaskON[id]=false
  call DisableTrigger(trgbmask[id])
  call TriggerSleepAction(1)
  call SetUnitPositionLoc(udg_PHero[id], reinhardL)
  call SetUnitPositionLoc(udg_Familiar[id], reinhardL)
  call SetUnitPositionLoc(udg_Slave[id], reinhardL)
  call PanCameraToTimedLocForPlayer(Player(id), reinhardL, 0)
  call DestroyEffect(AddSpecialEffectTarget(seblink, udg_PHero[id], "chest"))
  call CheckCurrentCamera(id)
     call TriggerSleepAction(1)
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00MAIN QUEST DONE|r: Give Reinhard |cffffcc004 Bear masks|r")
      call StartSound(gg_snd_QuestActivateWhat1)
     
      call UpdatePersQuestND(id , questid , 4 , "-" , I2S(4) , "-")
      call TriggerSleepAction(0.02)
      call RemoveQuestFromPlayer(questid , id)
      
     
   //  call MarkQuestDone(id,reinhard)
      call TriggerSleepAction(1)
      call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Reinhard says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    OOOOh boy you make it!!, take this reward!")
      call TriggerSleepAction(1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    |cff00ccffGot +600 Experience|r")
      call AddHeroXP(udg_PHero[id], 600, false)
    
    call TriggerSleepAction(4)
     call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Reinhard says:|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Well done child, you can helpme a lot with those bears.")
    call TriggerSleepAction(6)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Reinhard says:|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    If you want to make stronger, killing bears with more level is the best way")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Seriously, you can do a little work for me with some |cffffcc00ranging bears|r.")
    call TriggerSleepAction(8)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Reinhard says:|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Go to the fields and kill |cffffcc006 Ranging bears!|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    When you'll be ready i'll teleport you back!")
    call StartSound(bj_questDiscoveredSound)
    
    
      set questid=SetupQuest(id , tutor , "BEARS'S ISSUE IN VELHILMEN - PART II" , "Kill Ranging bears " , "0" , "/6" , 0 , s__qty[1])
      call SaveInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[id]), questid)
      
      
      //set questIndex[id] = questIndex[id] + 1
      //call AddQuestLog(questIndex[id],id,"|cffffcc00Ranging bears killed:|r 0/6",reinhard)  
      set rangingbearsC[id]=0
      set rangingbears[id]=true //to show the counter
      call TriggerSleepAction(1)
      loop
         exitwhen ( rangingbearsC[id] >= 6 )
              call TriggerSleepAction(0.50)
         endloop
      set rangingbears[id]=false //to show the counter
      call TriggerSleepAction(0.5)
      
       call SetUnitPositionLoc(udg_PHero[id], reinhardL)
       call SetUnitPositionLoc(udg_Familiar[id], reinhardL)
       call SetUnitPositionLoc(udg_Slave[id], reinhardL)
       call PanCameraToTimedLocForPlayer(Player(id), reinhardL, 0)
       call DestroyEffect(AddSpecialEffectTarget(seblink, udg_PHero[id], "chest"))
       call CheckCurrentCamera(id)
       
    call TriggerSleepAction(1)
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00QUEST DONE|r: Kill Ranging bears")
      
      call UpdatePersQuestND(id , questid , 6 , "-" , I2S(6) , "-")
      call TriggerSleepAction(0.02)
      call RemoveQuestFromPlayer(questid , id)
      
      
     // call MarkQuestDone(id,reinhard)
      call TriggerSleepAction(1)
      call StartSound(gg_snd_QuestActivateWhat1)
      call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Reinhard says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Excelent " + Pnombre[id] + "!, you have been improved your skills!")
      call TriggerSleepAction(3)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cff00ccffGot +1200 Experience|r")
      call AddHeroXP(udg_PHero[id], 1200, false)
      
     call TriggerSleepAction(4)
     call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Reinhard says:|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Ok child, you can do a last thing for me.")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    We sent scouts to check where is the bears's leader.")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    but some of them are lost in the jungle")
    
    call TriggerSleepAction(8)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Reinhard says:|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    I been noticed about a scout that has been seen")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Go to rescue him, before he die")
     
    call StartSound(bj_questDiscoveredSound)
      call setupscouts(id)
      set scoutON[id]=true
      
      
      set questid=SetupQuest(id , tutor , "BEARS'S ISSUE IN VELHILMEN - PART III" , "Rescue Velhilmen scout " , "0" , "/1" , 0 , s__qty[1])
      call SaveInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[id]), questid)
      
     // set questIndex[id] = questIndex[id] + 1
    //  call AddQuestLog(questIndex[id],id,"Rescue Velhilmen scout",reinhard)  

      call TriggerSleepAction(1)
      loop
         exitwhen ( scoutON[id] == false )
              call TriggerSleepAction(0.50)
         endloop
      
     

    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00QUEST DONE|r: Rescue velhilmen Scout")
      
      call UpdatePersQuestND(id , questid , 1 , "-" , I2S(1) , "-")
      call TriggerSleepAction(0.02)
      call RemoveQuestFromPlayer(questid , id)
      
       call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Reinhard says:|r")
      if scoutdead[id] == true then
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    What??.. the scout has died!")
        call TriggerSleepAction(4)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "    ...")
        call TriggerSleepAction(3)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    We are nothing...")
        call TriggerSleepAction(2)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Anyway, thanks for your services...")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Take this, can help you.")
        call TriggerSleepAction(5)
        call StartSound(gg_snd_QuestActivateWhat1)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cffffcc00Got +974 Gold|r")
        call AdjustPlayerStateBJ(974, Player(id), PLAYER_STATE_RESOURCE_GOLD)
    elseif scoutdead[id] == false then
      
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Excelent " + Pnombre[id] + "!, people considers you a HERO!")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    keep the good work")
      call TriggerSleepAction(3)
      call StartSound(gg_snd_QuestActivateWhat1)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cff00ccffGot +2000 Experience|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    |cffffcc00Got +1618 Gold|r")
      call AddHeroXP(udg_PHero[id], 2000, false)
      call AdjustPlayerStateBJ(1618, Player(id), PLAYER_STATE_RESOURCE_GOLD)
   endif
     call TriggerSleepAction(5)
      call SetUnitFacingToFaceUnitTimed(reinhard, udg_PHero[id], 0)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Reinhard says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    That's all for now child.")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    It's time to make yourself stronger.")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    I've heard that in Valdivia stranger things are happening")

      call TriggerSleepAction(5)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "     Reinhard gives you a |cffffcc00Rare Chest|r")
      set itm=CreateItem('I008', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])) //rare chest
      call UnitAddItem(udg_PHero[id], itm)
      call TriggerSleepAction(4)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Reinhard says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    God bye boy...")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "    So, If you want some challenges, you can go to |cffffcc00The Church|r north east from here")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "    and help church's parson with some monsters on his catacombs.")
    
  set itm=null
  
endfunction

