    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
            call UnitChat("You don't have the horde bravery. |n|cffffcc00Needs 300 kills|r" , gg_unit_h01W_0023)

        else
            call UnitChat("The Elder waits for you, go to talk with my brother on Ekrom. He will shows you where the elder is..." , gg_unit_h01W_0023)

            set orcadviced[id]=true
            
         call GroupAddUnitSimple(GetTriggerUnit(), udg_inTest)
         call TriggerSleepAction(4)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00MAIN QUEST DISCOVERED|r: Seeking your own fate")
