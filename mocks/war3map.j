//===========================================================================
// Trigger: archer
//
// gg_unit_Hvwd_1037
//===========================================================================
//TESH.scrollpos=25
//TESH.alwaysfold=0
function ARCR takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0LQ' )
endfunction

function ARAR takes nothing returns nothing
local integer questid
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   
   if ( GetUnitTypeId(GetTriggerUnit()) != 'H00G' ) then
        call UnitChat("Only female novices can take this responsability" , gg_unit_Hvwd_1037)
        
   elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
        call UnitChat("You need |cffffcc0010 Bow logs|r. Where are them? find in the beach" , gg_unit_Hvwd_1037)
 
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
            call UnitChat("You don't have necessary experience to do this quest. |n|cffffcc00Needs 300 kills|r" , gg_unit_Hvwd_1037)

        else
            call UnitChat("Ok, we need archers. If you want to be one, you need arrows and bow. Bring me |cffffcc0010 bow logs|r to make your weapon. Find it on the beach" , gg_unit_Hvwd_1037)

            call EnableTrigger(gg_trg_bowlog)
            call EnableTrigger(gg_trg_growlog)
            call TriggerExecute(gg_trg_bowlog)
            call GroupAddUnitSimple(GetTriggerUnit(), udg_inTest)
           call TriggerSleepAction(3)
           call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00MAIN QUEST DISCOVERED|r: Making your weapon")
           call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "     Collect 10 bow logs spreaded across the beach and return to Archer master with them")
         
           
            set questid=SetupQuest(id , null , "MAKING YOUR WEAPON" , "Collect 10 bow logs spreaded across the beach" , "-" , "-" , 0 , s__qty[2])
            call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
       
    endif
endfunction



