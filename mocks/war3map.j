//===========================================================================

function scrcdmg takes nothing returns boolean
    return GetItemTypeId(GetManipulatedItem()) == 'I0SO'
endfunction

function scradmg takes nothing returns nothing
 local integer chargues= GetItemCharges(GetManipulatedItem())

   if ( GetItemTypeCount(GetTriggerUnit() , 'I0SO') > 1 ) then
     if ( GetItemCharges(GetMainJewel(GetTriggerUnit() , 'I0SO')) < 20 ) then
     call RemoveItem(GetManipulatedItem())
    
     set chargues=chargues + GetItemCharges(GetMainJewel(GetTriggerUnit() , 'I0SO'))
     call SetItemCharges(GetMainJewel(GetTriggerUnit() , 'I0SO'), chargues)
    endif
    
  endif
endfunction

