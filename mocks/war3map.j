  //  call FlushChildHashtableBJ( GetHandleIdBJ(t), udg_MG1Hash )
   // call PanCameraToTimedLocForPlayer( GetOwningPlayer(revive), udg_RevivalPoints[GetPlayerId(GetOwningPlayer(revive))], 0 )
