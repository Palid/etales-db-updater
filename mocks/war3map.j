//===========================================================================
// Trigger: lightuplantern
//===========================================================================
//TESH.scrollpos=61
//TESH.alwaysfold=0
function Trig_lightuplantern_Conditions takes nothing returns boolean
    return GetUnitTypeId(GetTriggerUnit()) == 'h03R'
endfunction

function follownat takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit s= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer id= GetUnitUserData(s) - 10
local real ux= GetUnitX(s)
local real uy= GetUnitY(s)
local real x= GetUnitX(udg_PHero[id])
local real y= GetUnitY(udg_PHero[id])
local real dx= x - ux
local real dy= y - uy
local real distance= SquareRoot(dx * dx + dy * dy)


if distance < 1100 then
  call IssueTargetOrder(s, "smart", udg_PHero[id])
else
  call IssueImmediateOrder(s, "stop")
endif

set t=null
set s=null

endfunction


function appSpirit takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit s= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer i= LoadInteger(hts, GetHandleId(t), 2)

set i=i + 1

call SetUnitVertexColor(s, 255, 255, 255, i)
 call SaveInteger(hts, GetHandleId(t), 2, i)
 
if i > 170 then
   call PauseTimer(t)
   call FlushChildHashtable(hts, GetHandleId(t))
   call ReleaseTimer(t)
   set natready=true
endif

set s=null
set t=null

endfunction

function Trig_lightuplantern_Actions takes nothing returns nothing
   local unit l__l= GetTriggerUnit()
   local item f= GetManipulatedItem()
   local unit s= null
   local integer id
   local real x
   local real y
   local real ang
   local integer xp
   
   if ( GetItemTypeId(f) == 'I0FH' ) then
      set id=LoadInteger(hts, GetHandleId(f), 10) - 7
      call SetUnitAnimation(l__l, "stand")
      call AddSpecialEffect("Light.mdx", GetUnitX(l__l), GetUnitY(l__l))
      call UnitAddAbility(l__l, 'Aloc')
      call TriggerSleepAction(2)
      call StartSound(bj_questUpdatedSound)
      set xp=GetRandomInt(900, 1100)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00ARCANISTS LUMINARIES|r: A new lantern has been activated")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "You get |cffffcc00+12|r Reputation")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "You get |cffaaccff+" + I2S(xp) + "|r XP")
      call AddHeroXP(udg_PHero[id], xp, true)
      set Reputation[id]=Reputation[id] + 12
      call FlushChildHashtable(hts, GetHandleId(f))
      set lanternsp[id]=lanternsp[id] + 1
      
      if lanternsp[id] > 3 and natspirit == false then
      set natspirit=true
        set ang=GetUnitFacing(udg_PHero[id])
        set spiritfollowed=udg_PHero[id]
        set x=GetUnitX(l__l) + 400 * Cos(ang * bj_DEGTORAD)
        set y=GetUnitY(l__l) + 400 * Sin(ang * bj_DEGTORAD)
        set s=CreateUnit(Player(10), 'e010', x, y, ang - 180)
        call SetUnitUserData(s, 10 + id)
        call SetUnitVertexColor(s, 255, 255, 255, 0)
        set natuspirit=s
        set natureTimer=(NewTimerEx(0)) // INLINED!!
        call SaveUnitHandle(hts, GetHandleId(natureTimer), 1, s)
        call SaveInteger(hts, GetHandleId(natureTimer), 2, 1)
        call TimerStart(natureTimer, 0.02, true, function appSpirit)
        call IssueTargetOrder(s, "smart", l__l)
        call TriggerSleepAction(0.3)
       
        loop
          exitwhen natready == true
            call TriggerSleepAction(1)
        endloop
        
        set natureTimer=(NewTimerEx(0)) // INLINED!!
        call SaveUnitHandle(hts, GetHandleId(natureTimer), 1, s)
        call TimerStart(natureTimer, 4, true, function follownat)
      
        
        set s=null
      endif
      
      
      
      
   else
     call UnitRemoveItem(l__l, f)
   endif
   
   set l__l=null
   set f=null

endfunction

//===========================================================================
function InitTrig_lightuplantern takes nothing returns nothing
    set gg_trg_lightuplantern=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_lightuplantern, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_lightuplantern, Condition(function Trig_lightuplantern_Conditions))
    call TriggerAddAction(gg_trg_lightuplantern, function Trig_lightuplantern_Actions)
endfunction


//===========================================================================
// Trigger: endspirit
//===========================================================================
//TESH.scrollpos=21
//TESH.alwaysfold=0
function Trig_endspirit_Conditions takes nothing returns boolean
    return GetEnteringUnit() == spiritfollowed or GetUnitTypeId(GetEnteringUnit()) == 'e010'
endfunction

function Trig_endspirit_Actions takes nothing returns nothing
local unit u= GetEnteringUnit()
local unit s
local integer questid
local integer id= GetPlayerId(GetOwningPlayer(spiritfollowed))
  
  if GetUnitTypeId(u) == 'e010' then
    if not ( natureTimer == null ) then
        call PauseTimer(natureTimer)
    endif
    call IssuePointOrder(u, "smart", GetRectCenterX(gg_rct_mirador), GetRectCenterY(gg_rct_mirador))
    call TriggerSleepAction(1.6)
    call IssueImmediateOrder(u, "stop")
    call UnitChat("Thanks for bringme here, I was a bit lost..." , u)
    call TriggerSleepAction(3)
    call StartSound(bj_questUpdatedSound)
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00ARCANISTS LUMINARIES|r: Spiritual things")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "The nature spirit has reached her destiny.")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "You receive a |cffffcc00Scroll of Hurricane|r")
    set questid=LoadInteger(udg_cache, GetHandleId(Arcanist), GetHandleId(spiritfollowed))
    call UpdatePersQuestND(id , questid , Qrequ[questid] , "-" , I2S(Qrequ[questid]) , "-")
    call TriggerSleepAction(0.02)
    call RemoveQuestFromPlayer(questid , id)
    call UnitAddItem(udg_PHero[id], CreateItem(udg_itmpool[53], GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])))
    set spiritfollowed=null

  
  elseif u == spiritfollowed then
    set s=LoadUnitHandle(hts, GetHandleId(natureTimer), 1)
    call PauseTimer(natureTimer)
    call FlushChildHashtable(hts, GetHandleId(natureTimer))
    call ReleaseTimer(natureTimer)
    call IssuePointOrder(s, "smart", GetRectCenterX(gg_rct_mirador), GetRectCenterY(gg_rct_mirador))
    set s=null
  endif

set u=null

endfunction

//===========================================================================
function InitTrig_endspirit takes nothing returns nothing
    set gg_trg_endspirit=CreateTrigger()
    call TriggerRegisterEnterRectSimple(gg_trg_endspirit, gg_rct_mirador)
    call TriggerAddCondition(gg_trg_endspirit, Condition(function Trig_endspirit_Conditions))
    call TriggerAddAction(gg_trg_endspirit, function Trig_endspirit_Actions)
endfunction


