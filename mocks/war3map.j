function Trig_Noorder_Conditions takes nothing returns boolean
    return ( GetPlayerId(GetOwningPlayer(GetTriggerUnit())) == PLAYER_NEUTRAL_PASSIVE or IsUnitAlly(GetAttacker(), GetOwningPlayer(GetTriggerUnit())) == true )
endfunction

function Trig_Noorder_Actions takes nothing returns nothing
local unit u= GetAttacker()
   if GetPlayerId(GetOwningPlayer(GetTriggerUnit())) != 15 then
        call IssueImmediateOrder(u, "stop")
        call SetUnitPosition(u, GetUnitX(u), GetUnitY(u))
  endif

   set u=null
endfunction

