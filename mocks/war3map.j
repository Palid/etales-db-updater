//===========================================================================

//===========================================================================
// Trigger: Molten Arrow
//
// function GetUnitsInRangeOfLocMatching takes real radius, location whichLocation, boolexpr filter returns group
//     local group g = CreateGroup()
//     call GroupEnumUnitsInRangeOfLoc(g, whichLocation, radius, filter)
//     call DestroyBoolExpr(filter)
//     return g
// endfunction
//===========================================================================
function Trig_Molten_Arrow_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0CE' )
endfunction

function booltrue takes nothing returns boolean
    return true
endfunction


function Trig_Molten_Arrow_Actions takes nothing returns nothing
local integer i= 1
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local real angle
local real x= GetUnitX(u)
local real y= GetUnitY(u)
local unit c
local unit gu
local group g= CreateGroup()
local group array gi
local real dmg= ( GetHeroAgi(u, true) * 3 ) + ( GetHeroInt(u, true) * 1.5 )
local real fdmg
local integer idmg= 0
local boolexpr istru= null
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

  set dmg=dmg * inspired

  set mtn_x[0]=GetUnitX(u)
  set mtn_y[0]=GetUnitY(u)

  call TriggerSleepAction(0.1)
  set angle=GetUnitFacing(u)
  set c=CreateUnit(Player(id), moltendummy, GetUnitX(u), GetUnitY(u), angle)
  call UnitApplyTimedLife(c, 'BTLF', 0.7)
  //call TriggerSleepAction(0.1)
  
loop
 exitwhen i > 12

 
 
  set mtn_x[i]=mtn_x[i - 1] + 90 * Cos(( angle ) * bj_DEGTORAD)
  set mtn_y[i]=mtn_y[i - 1] + 90 * Sin(( angle ) * bj_DEGTORAD)
  set gi[i]=CreateGroup()
  set istru=Condition(function booltrue)
  call GroupEnumUnitsInRange(gi[i], mtn_x[i], mtn_y[i], 175, istru)
  call DestroyBoolExpr(istru)
  set istru=null

  set bj_groupAddGroupDest=g
  call ForGroup(gi[i], function GroupAddGroupEnum)
  call DestroyGroup(gi[i])
  set gi[i]=null
 set i=i + 1
 endloop
 
 
 
  set molten[0]=CreateDestructable('B01F', mtn_x[0], mtn_y[0], angle - 180, 0.5, 0)
  call SetUnitPosition(c, mtn_x[0], mtn_y[0])
  
  //call TriggerSleepAction(0.02)
  set molten[1]=CreateDestructable('B01F', mtn_x[1], mtn_y[1], angle - 180, 0.4, 0)
  call SetUnitPosition(c, mtn_x[1], mtn_y[1])
 //  call TriggerSleepAction(0.02)
  set molten[2]=CreateDestructable('B01F', mtn_x[2], mtn_y[2], angle - 180, 0.8, 0)
  call SetUnitPosition(c, mtn_x[2], mtn_y[2])
 //  call TriggerSleepAction(0.02)
  set molten[3]=CreateDestructable('B01F', mtn_x[3], mtn_y[3], angle - 180, 1.2, 0)
  call SetUnitPosition(c, mtn_x[3], mtn_y[3])
 //  call TriggerSleepAction(0.02)
  set molten[4]=CreateDestructable('B01F', mtn_x[4], mtn_y[4], angle - 180, 1.6, 0)
  call SetUnitPosition(c, mtn_x[4], mtn_y[4])
 //  call TriggerSleepAction(0.02)
  set molten[5]=CreateDestructable('B01F', mtn_x[5], mtn_y[5], angle - 180, 2, 0)
  call SetUnitPosition(c, mtn_x[5], mtn_y[5])
 //  call TriggerSleepAction(0.02)
  set molten[6]=CreateDestructable('B01F', mtn_x[6], mtn_y[6], angle - 180, 2.4, 0)
  call SetUnitPosition(c, mtn_x[6], mtn_y[6])
 //  call TriggerSleepAction(0.02)
  set molten[7]=CreateDestructable('B01F', mtn_x[7], mtn_y[7], angle - 180, 2.8, 0)
  call SetUnitPosition(c, mtn_x[7], mtn_y[7])
  // call TriggerSleepAction(0.02)
  set molten[8]=CreateDestructable('B01F', mtn_x[8], mtn_y[8], angle - 180, 3.2, 0)
  call SetUnitPosition(c, mtn_x[8], mtn_y[8])
 //  call TriggerSleepAction(0.02)
  set molten[9]=CreateDestructable('B01F', mtn_x[9], mtn_y[9], angle - 180, 3.6, 0)
  call SetUnitPosition(c, mtn_x[9], mtn_y[9])
  // call TriggerSleepAction(0.02)
  set molten[10]=CreateDestructable('B01F', mtn_x[10], mtn_y[10], angle - 180, 4, 0)
  call SetUnitPosition(c, mtn_x[10], mtn_y[10])
  // call TriggerSleepAction(0.02)
  set molten[11]=CreateDestructable('B01F', mtn_x[11], mtn_y[11], angle - 180, 3, 0)
  call SetUnitPosition(c, mtn_x[11], mtn_y[11])
  // call TriggerSleepAction(0.02)
  set molten[12]=CreateDestructable('B01F', mtn_x[12], mtn_y[12], angle - 180, 2, 0)
  call SetUnitPosition(c, mtn_x[12], mtn_y[12])
  
  // call TriggerSleepAction(0.03)
  loop
      
      set gu=FirstOfGroup(g)
     exitwhen gu == null
     
    call CheckIfHasDMG(gu)
   
     if ( GetUnitState(gu, UNIT_STATE_LIFE) > 0.5 and IsUnitEnemy(gu, GetOwningPlayer(u)) ) then
      set fdmg=dmg + dmg * AddRacialBonus(gu , id)
      call DestroyEffect(AddSpecialEffectTarget(fulgor, gu, "chest"))
      call EnableTrigger(gg_trg_SPDMG)
      call UnitDamageTarget(u, gu, fdmg, true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
      call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , gu)
      set spelldmg[id]=0
 
   
   endif
   call GroupRemoveUnit(g, gu)

  // set gu = null
     
endloop
 
   call TriggerSleepAction(0.05)
  
 // call ForGroup(f, function showeed)
  
 //  call DestroyGroup(f)
   call DestroyGroup(g)
   set g=null
   
   
   //set c = null
 set i=0
 
 loop
 exitwhen i > 12

 call RemoveDestructable(molten[i])
 set molten[i]=null
 call TriggerSleepAction(0.01)
 set i=i + 1
 endloop
 set c=null
 
endfunction
