        call CreateRat(blackratID , GetRandomReal(minXERR, maxXERR) , GetRandomReal(minYERR, maxYERR))
        call CreateRat(blackratID , GetRandomReal(minXERR, maxXERR) , GetRandomReal(minYERR, maxYERR))
        if extrarats == false then
            call CreateRat(ratID , GetRandomReal(minXERR, maxXERR) , GetRandomReal(minYERR, maxYERR))
            call CreateRat(snapratID , GetRandomReal(minXERR, maxXERR) , GetRandomReal(minYERR, maxYERR))
