//===========================================================================
// Trigger: arcaniststop
//===========================================================================
//TESH.scrollpos=45
//TESH.alwaysfold=0
function arcaintavc takes nothing returns boolean
  return GetEnteringUnit() == Arcanist
endfunction

function arcaintava takes nothing returns nothing
 local effect sf= null
 local real tday= 0
 local boolean wakeup= false
 local boolean timel= false

 call DisableTrigger(gg_trg_arcaniststop)
 call IssueImmediateOrder(Arcanist, "stop")
 call SetUnitFacing(Arcanist, 315)
 set tavernhour=true
 set arcanistgotav=false
 loop
  exitwhen timel == true
     call TriggerSleepAction(10)
     set tday=GetFloatGameState(GAME_STATE_TIME_OF_DAY)
     set timel=tday > 5.0 and tday < 6.0
     
  endloop
  set tavernhour=false
  set arcanistreturning=true
  call UnitAddAbility(Arcanist, DRUNKEN)
  call UnitChat("Uuuwaaa.. Ok guys I'm leaving to sleep..." , Arcanist)
  call TriggerSleepAction(1)
  call IssuePointOrder(Arcanist, "move", GetRectCenterX(gg_rct_veltab2out), GetRectCenterY(gg_rct_veltab2out))
  call TriggerSleepAction(14)
  call SetUnitPosition(Arcanist, GetRectCenterX(gg_rct_veltab2in), GetRectCenterY(gg_rct_veltab2in))
  call TriggerSleepAction(0.3)
  call IssuePointOrder(Arcanist, "move", GetRectCenterX(gg_rct_arcan2out), GetRectCenterY(gg_rct_arcan2out))
  call TriggerSleepAction(9)
  call SetUnitPosition(Arcanist, GetRectCenterX(gg_rct_arcan1out), GetRectCenterY(gg_rct_arcan1out))
  call TriggerSleepAction(0.3)
  call IssuePointOrder(Arcanist, "move", GetRectCenterX(gg_rct_arcslp), GetRectCenterY(gg_rct_arcslp))
  call TriggerSleepAction(11)
  call SetUnitTimeScale(Arcanist, 0.3)
  call UnitRemoveAbility(Arcanist, DRUNKEN)
  set arcanistreturning=false
  set arcanistsleep=true
  call SetUnitPosition(Arcanist, GetUnitX(Arcanist) + 1, GetUnitY(Arcanist) - 1)
  call TriggerSleepAction(0.1)
  call SetUnitAnimation(Arcanist, "death")
  set sf=AddSpecialEffectTarget("Abilities\\Spells\\Undead\\Sleep\\SleepTarget.mdl", Arcanist, "overhead")

  loop
     exitwhen wakeup == true
     call TriggerSleepAction(10)
     set tday=GetFloatGameState(GAME_STATE_TIME_OF_DAY)
     set wakeup=( tday > 12.3 and tday < 13.3 )
     
  endloop
  
  call DestroyEffect(sf)
  set sf=null
  call SetUnitTimeScale(Arcanist, 1)
  call SetUnitAnimation(Arcanist, "stand")
  call IssuePointOrder(Arcanist, "move", GetRectCenterX(gg_rct_arcwrk), GetRectCenterY(gg_rct_arcwrk))
  set arcanistsleep=false
 
endfunction

//===========================================================================
function InitTrig_arcaniststop takes nothing returns nothing
    set gg_trg_arcaniststop=CreateTrigger()
    call DisableTrigger(gg_trg_arcaniststop)
    call TriggerRegisterEnterRectSimple(gg_trg_arcaniststop, gg_rct_bld)
    call TriggerAddCondition(gg_trg_arcaniststop, Condition(function arcaintavc))
    call TriggerAddAction(gg_trg_arcaniststop, function arcaintava)
endfunction


