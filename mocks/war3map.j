function InitTrig_trollpit takes nothing returns nothing
    set gg_trg_trollpit=CreateTrigger()
    call TriggerRegisterEnterRectSimple(gg_trg_trollpit, gg_rct_trolljester)
    call TriggerAddCondition(gg_trg_trollpit, Condition(function Trig_trollpit_Conditions))
    call TriggerAddAction(gg_trg_trollpit, function Trig_trollpit_Actions)
endfunction


