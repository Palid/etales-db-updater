//===========================================================================
// Trigger: weresprp
//===========================================================================
function Trig_werescape_Conditions takes nothing returns boolean
    return GetUnitState(gg_unit_h02P_0761, UNIT_STATE_LIFE) > 1 and GetRandomInt(0, 2) == 1
endfunction

function Trig_werescape_Actions takes nothing returns nothing
local integer rectID= GetRandomInt(4, 52)
local real x= 0
local real y= 0
    call SetUnitPosition(gg_unit_h02P_0761, GetRectCenterX(rects[rectID]), GetRectCenterY(rects[rectID]))
    call TriggerSleepAction(125)
    call ShowUnit(gg_unit_h02P_0761, false) //villager
    call ShowUnit(gg_unit_U00D_0740, true) //werewolf
    call SetUnitPosition(gg_unit_U00D_0740, GetUnitX(gg_unit_h02P_0761), GetUnitY(gg_unit_h02P_0761))
   // call IssueImmediateOrder(gg_unit_h02P_0761, "metamorphosis" )
    call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 8, "|cffffcc00You feel an evil presence far away under the moonlight...|r")
    call TriggerSleepAction(5)
    call PlaySoundBJ(gg_snd_wolf1)
    call TriggerSleepAction(10)
     call PlaySoundBJ(gg_snd_night)
    call TriggerSleepAction(410)
     
     if GetUnitState(gg_unit_U00D_0740, UNIT_STATE_LIFE) > 1 then
      set x=GetUnitX(gg_unit_U00D_0740)
      set y=GetUnitY(gg_unit_U00D_0740)
      call ShowUnit(gg_unit_U00D_0740, false)
      call ShowUnit(gg_unit_h02P_0761, true)
      call SetUnitPosition(gg_unit_U00D_0740, 17200, 16800)
      call TriggerSleepAction(0.05)
      call SetUnitPosition(gg_unit_h02P_0761, x, y)
      
      
     endif

     
   
     
endfunction

