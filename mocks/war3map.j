//Lethal Strike dmg execution
function Dodmg takes unit u,real dmg,real multiply,integer percent returns nothing
   local integer ratio= GetRandomInt(0, 100)
   //local sound s = null
       if ( ratio <= percent ) then
         set udg_Lethalstrikestack=udg_Lethalstrikestack + ( dmg * multiply )
         set ITCB=0
         set ITCG=0
         set ITCR=255
        // set udg_TSC = 21.00
         set udg_TSC=19.00
       //  set s =  gg_snd_stabb
        // call DisableTrigger( GetTriggeringTrigger() )
         call PlaySoundOnUnitBJ(gg_snd_stabb, 60, GetTriggerUnit())
         call EnableTrigger(gg_trg_LSDMG)
          call UnitDamageTarget(u, GetTriggerUnit(), udg_Lethalstrikestack, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
        // call UnitDamageTargetBJ( u, GetTriggerUnit(), udg_Lethalstrikestack, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL )
         call DisableTrigger(gg_trg_LSDMG)
         
       // call EnableTrigger( GetTriggeringTrigger() )
    endif
 // set s = null  
endfunction


function IsClaymoredmg takes unit u,unit v returns integer

 local integer pid= GetPlayerId(GetOwningPlayer(u))
 local real bdmg= ( GetHeroAgi(udg_PHero[pid], true) * 0.5 )
 local real cdmg= ( GetHeroInt(udg_PHero[pid], true) )
 local real lvl= I2R(GetHeroLevel(udg_PHero[pid])) * 0.1
 

 local real perc= ( bdmg + cdmg ) * lvl
 

   if ( perc > 0 ) then
   
   
     call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\Incinerate\\FireLordDeathExplode.mdl", v, "chest"))
     call EnableTrigger(gg_trg_MGDMG)
     call UnitDamageTarget(udg_PHero[pid], v, perc, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
     call DisableTrigger(gg_trg_MGDMG)
 
  
     set ITCB=36
     set ITCG=135
     set ITCR=225
   endif
   return R2I(magicdmg[pid])

endfunction


//checking for bats
function IsDummydmg takes unit u,unit v returns real
local integer pid= GetPlayerId(GetOwningPlayer(u))
local real bdmg= 0
local boolean ray= false
local real inspired
local real bansheedmg= 0
local real akdmg= 0
local real scdmg= 0
local real mana


     if GetUnitTypeId(u) == 'n092' then //scorpon blaster
         
         set bdmg=4 * GetHeroInt(udg_PHero[pid], true)
         
         if bdmg > 0 then
         set ITCB=0
         set ITCG=127
         set ITCR=255
         endif
         call DestroyEffect(AddSpecialEffectTarget(firexplode, v, "origin"))
         
  
    elseif GetUnitTypeId(u) == 'n08Y' then //scorpon blaster
         
         set scdmg=GetUnitState(v, UNIT_STATE_LIFE) * 0.05
         
         if scdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
    elseif GetUnitTypeId(u) == 'n08U' then //akasha sweeping
         
         set akdmg=GetUnitState(v, UNIT_STATE_LIFE) * 0.05
	     call UnitApplyTimedLife(u, 'BTLF', 0.1)
		// call DisplayTimedTextToPlayer(Player(0),0,0,4,GetUnitName(v) + R2S(bansheedmg))
         
         if akdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
    elseif ( GetUnitTypeId(u) == 'n08T' ) then //bomb
         
         set akdmg=644 + GetUnitState(v, UNIT_STATE_LIFE) * 0.25
	
		// call DisplayTimedTextToPlayer(Player(0),0,0,4,GetUnitName(v) + R2S(bansheedmg))
         
         if akdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
      elseif ( GetUnitTypeId(u) == 'n08S' ) then //akasha sweeping
         
         set akdmg=GetUnitState(v, UNIT_STATE_LIFE) * 0.1
	
		// call DisplayTimedTextToPlayer(Player(0),0,0,4,GetUnitName(v) + R2S(bansheedmg))
         
         if akdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
      elseif ( GetUnitTypeId(u) == 'H00M' and AkashaSwp == true ) then //akasha sweeping
         
         set akdmg=GetUnitState(v, UNIT_STATE_LIFE) * 0.08
	
		// call DisplayTimedTextToPlayer(Player(0),0,0,4,GetUnitName(v) + R2S(bansheedmg))
         
         if akdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
    elseif ( GetUnitTypeId(u) == 'n00A' ) then //bansheeD
         
         set bansheedmg=GetUnitState(v, UNIT_STATE_LIFE) * 0.03
		 
	
		
		 set mana=GetUnitState(v, UNIT_STATE_MANA) * 0.99
		 call SetUnitState(v, UNIT_STATE_MANA, mana)
		
		// call DisplayTimedTextToPlayer(Player(0),0,0,4,GetUnitName(v) + R2S(bansheedmg))
         
         if bansheedmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
    elseif ( GetUnitTypeId(u) == 'n07Y' ) then //carrionswarm
         
         set inspired=LoadReal(hts, GetHandleId(u), StringHash("spcast"))
         
         set bdmg=inspired * ( GetHeroStr(udg_PHero[pid], true) * 0.04 )
         
         if bdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
    elseif ( GetUnitTypeId(u) == 'u00I' ) then //bat
  
         set bdmg=( GetHeroInt(udg_PHero[pid], true) * 0.03 ) + ( GetHeroStr(udg_PHero[pid], true) * 0.04 )
         
         if bdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
  
    elseif ( GetUnitTypeId(u) == ldummyA ) then //linear bolt
         
         set bdmg=( GetHeroInt(udg_PHero[pid], true) * 0.24 )
         
         if bdmg > 0 then
         set ITCB=255
         set ITCG=215
         set ITCR=215
         endif
 
        
    
    
    elseif ( GetUnitTypeId(u) == ldummyB ) then //widebolt
         set bdmg=( GetHeroInt(udg_PHero[pid], true) * 0.12 )
         
         if bdmg > 0 then
         set ITCB=255
         set ITCG=215
         set ITCR=215
         endif
    
    elseif ( GetUnitTypeId(u) == ldummyD ) then
         set bdmg=GetHeroInt(udg_PHero[pid], true) * 0.5
         
         if bdmg > 0 then
         set ITCB=0
         set ITCG=0
         set ITCR=255
         endif
        set ray=true
     
    elseif ( GetUnitTypeId(u) == ldummyE ) then
         set bdmg=( GetHeroInt(udg_PHero[pid], true) * 0.25 )
         
         if bdmg > 0 then
         set ITCB=0
         set ITCG=255
         set ITCR=255
         endif
    endif
	
      
     if scdmg > 0 then //scorpion damage
	     call EnableTrigger(gg_trg_BTDMG)
         call UnitDamageTarget(gg_unit_U00O_0266, v, scdmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
         call DisableTrigger(gg_trg_BTDMG)
	 
     elseif akdmg > 0 then
	     
         call EnableTrigger(gg_trg_BTDMG)
         call UnitDamageTarget(udg_BOSS[6], v, akdmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
         call DisableTrigger(gg_trg_BTDMG)
	 
     elseif bansheedmg > 0 then
	     call EnableTrigger(gg_trg_BTDMG)
         call UnitDamageTarget(udg_BOSS[0], v, bansheedmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
         call DisableTrigger(gg_trg_BTDMG)
	 
     elseif bdmg > 0 then
         call EnableTrigger(gg_trg_BTDMG)
         call UnitDamageTarget(udg_PHero[pid], v, bdmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
         call DisableTrigger(gg_trg_BTDMG)
         
         if ray == true then
         set udg_TSC=20.00
         else
         set udg_TSC=13.00
         endif
	
      endif
      
 return 17.00
 
endfunction

function LethalFortune takes unit u returns boolean
local integer id= GetPlayerId(GetOwningPlayer(u))
return ( I2R(s__Fortune[id]) / 1618 ) * 100 > GetRandomReal(1, 100)
endfunction


//Lethal Strike dmg verification
function IsLethalStrike takes unit u,real dmg returns nothing
local integer id
local real inspired
local real constdmg

if ( UnitHasBuffBJ(u, 'B00D') == true ) then
    call Dodmg(u , dmg , 0.6 , 10)
elseif ( UnitHasBuffBJ(u, 'B00E') == true ) then
  call Dodmg(u , dmg , 0.8 , 17)
elseif ( UnitHasBuffBJ(u, 'B00F') == true ) then
 
  call Dodmg(u , dmg , 1 , 24)
elseif ( UnitHasBuffBJ(u, 'B00C') == true ) then
 
  call Dodmg(u , dmg , 1.2 , 31)
elseif ( UnitHasBuffBJ(u, 'B01S') == true ) then
  set inspired=LoadReal(hts, GetHandleId(u), StringHash("spcast"))
  call Dodmg(u , dmg , 1.4 * inspired , 101)
  
elseif ( LethalFortune(u) == true ) then
  set id=GetPlayerId(GetOwningPlayer(u))
  set constdmg=1.618 * ( logg(10 , 10 + I2R(s__Constitution[id])) - 1 )
  //set dmg = dmg + constdmg
  
  call Dodmg(u , dmg , constdmg , 101)
else
  set udg_TSC=17
endif
endfunction


function Deadlyblow takes unit u,unit target,real dmg returns integer
 local integer pid= GetPlayerId(GetOwningPlayer(u))
 local real mdmg= 0
 local real perc1= I2R(GetHeroLevel(u)) * 0.045
 local real perc2= I2R(GetHeroLevel(target)) * 0.060
 local real perc= perc1 + perc2
 
   set mdmg=dmg * perc
   if ( mdmg > 0 ) then
   
     call EnableTrigger(gg_trg_MGDMG)
     call UnitDamageTarget(u, target, mdmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
     call DisableTrigger(gg_trg_MGDMG)
     call DestroyEffect(AddSpecialEffectTarget(sfstatic, target, "chest"))
     set deadlyblow[pid]=false
     call DestroyEffect(deadlyeffect[pid])
     set deadlyeffect[pid]=null
  
     set ITCB=36
     set ITCG=135
     set ITCR=225
   endif
   return R2I(magicdmg[pid])
 
endfunction


function MagicAmplified takes unit u,real dmg,integer t,unit l__victim returns integer
 local integer pid= GetPlayerId(GetOwningPlayer(u))
 local real mdmg= 0

  if ( t == 5 or t == 6 ) then
   set mdmg=dmg * udg_magicBonus[pid]
   if ( mdmg > 0 ) then
    // call DisableTrigger( GetTriggeringTrigger() )
     call EnableTrigger(gg_trg_MGDMG)
     call UnitDamageTarget(u, l__victim, mdmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
     call DisableTrigger(gg_trg_MGDMG)
   //  call EnableTrigger( GetTriggeringTrigger() )
     set ITCB=0
     set ITCG=255
     set ITCR=255
   endif
   return R2I(magicdmg[pid])
  endif
  return 0
endfunction

function PierceAmplified takes unit u,real dmg,integer t,unit l__victim returns integer
 local integer pid= GetPlayerId(GetOwningPlayer(u))
 local real pdmg= 0

  if ( t == 1 or t == 2 ) then
   set pdmg=dmg * piercebonus[pid] * 0.2
   if ( pdmg > 0 ) then
    // call DisableTrigger( GetTriggeringTrigger() )
     call EnableTrigger(gg_trg_PCDMG)
     call UnitDamageTarget(u, l__victim, pdmg, true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
     call DisableTrigger(gg_trg_PCDMG)
   //  call EnableTrigger( GetTriggeringTrigger() )
     set ITCB=242
     set ITCG=132
     set ITCR=132
   endif
   return R2I(piercedmg[pid])
  endif
  return 0
endfunction


function CarrionSwarm takes unit u,real dmg,unit l__victim returns integer
 local integer pid= GetPlayerId(GetOwningPlayer(u))
 local real hdmg= 0
 local integer stat= 0

  if ( GetUnitTypeId(u) == 'n07Y' and s__IsCarrionSwarm[pid] == true ) then
   set hdmg=dmg + ( GetHeroStr(udg_PHero[pid], true) * 2 )
   if ( hdmg > 0 ) then
    // call DisableTrigger( GetTriggeringTrigger() )
     call EnableTrigger(gg_trg_LSDMG)
     call UnitDamageTarget(udg_PHero[pid], l__victim, hdmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
     call DisableTrigger(gg_trg_LSDMG)
   //  call EnableTrigger( GetTriggeringTrigger() )
     set ITCB=132
     set ITCG=255
     set ITCR=255
   endif
   return R2I(lstrikedmg[pid])
  endif
  return 0
endfunction


function movetxt takes nothing returns nothing

local timer t= GetExpiredTimer()
local real angle= LoadReal(hts, GetHandleId(t), 1)
local real scale= LoadReal(hts, GetHandleId(t), 2)
local real vel= LoadReal(hts, GetHandleId(t), 3)
local string dmg= LoadStr(hts, GetHandleId(t), 4)
local texttag dmgtxt= LoadTextTagHandle(hts, GetHandleId(t), 5)
local integer sec= LoadInteger(hts, GetHandleId(t), 6)

    set vel=vel - 2
    
    if sec < 18 then
    
      set scale=scale + 0.001
    else
      set scale=scale - 0.002
    
    endif

    call SetTextTagText(dmgtxt, dmg, scale)
    call SetTextTagVelocityBJ(dmgtxt, vel, angle)

  set sec=sec + 1
  
    if sec > 34 then
     call FlushChildHashtable(hts, GetHandleId(t))
     call PauseTimer(t)
     call ReleaseTimer(t)
    else
     call SaveReal(hts, GetHandleId(t), 2, scale)
     call SaveReal(hts, GetHandleId(t), 3, vel)
     call SaveStr(hts, GetHandleId(t), 4, dmg)
     call SaveInteger(hts, GetHandleId(t), 6, sec)
   
    endif
   
set dmg=null
set dmgtxt=null
set t=null
    
endfunction


function Trig_DMG_Actions takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local unit a= GetEventDamageSource()
    local integer pid= GetPlayerId(GetOwningPlayer(a))
    local integer did= GetPlayerId(GetOwningPlayer(u))
    local real dmg= GetEventDamage()
    local integer d= R2I(dmg)
    local integer t= ModuloInteger(GetUnitPointValue(a), 10)
    local integer r= piercebonus[pid]
   // local texttag tt = CreateTextTag()
    local real xvel= 0
    local real yvel= 0
    local real cmana= 0
    local real dmana= 0
    local integer dpot= 10 * LoadInteger(AiHash, GetHandleId(u), 4)
    local real vel= 180.00
    local real tlife= 1.0
    local real textHeight
    local timer tm= (NewTimerEx(0)) // INLINED!!
    local texttag dmgtxt= null
    local string dmgstr
    local integer sec= 0
    
     
    //local real tscale = 0.0391
    if d < 1 then
    set u=null
    set a=null
    return
    endif
    
    set dmg=dmg + dmg * AddRacialBonus(u , pid)
    
    
  //  local integer ssdmg = LoadInteger(udg_cache,GetHandleId(u),GetHandleId(a))
         call DisableTrigger(gg_trg_DMG)

   call IsDummydmg(a , u)
     
    set d=d + R2I(batsdmg[pid])
    
    call IsLethalStrike(a , dmg)
   // set d = d + ssdmg
    //set d = d + R2I(udg_Lethalstrikestack)
    
  //  set tscale = tscale + udg_TSC
 
    set d=d + R2I(lstrikedmg[pid])
    set d=d + MagicAmplified(a , dmg , t , u) //Checking if attacker has magic bonus
    set d=d + PierceAmplified(a , dmg , r , u) //Checking if attacker has pierce bonus

    

    
    set udg_DmgTextAngle=GetUnitFacing(a)
    

    
 //   set xvel = 0.38828125 * Cos(udg_DmgTextAngle * bj_DEGTORAD)
  //  set yvel = 0.38828125 * Sin(udg_DmgTextAngle * bj_DEGTORAD)
    
        
         if IsUnitType(a, UNIT_TYPE_HERO) == true and deadlyblow[pid] == true then
              set d=d + Deadlyblow(a , u , dmg) //verifico si es un Dk con deadlyblow
              set vel=150.00
              set udg_TSC=19.00
              set tlife=1.10
              set udg_DmgTextAngle=90
         endif
         
        if ( GetUnitTypeId(a) == 'n07Y' ) then
              set d=d + CarrionSwarm(a , dmg , u)
              set vel=150.00
              set udg_TSC=19.00
              set tlife=1.10
              set udg_DmgTextAngle=90
         endif
         
        if ( GetUnitTypeId(a) == 'n04U' ) then
        set d=d + IsClaymoredmg(a , u)
              set vel=150.00
              set udg_TSC=19.00
              set tlife=1.10
              set udg_DmgTextAngle=90
             
       endif
         
    
         if IsUnitType(u, UNIT_TYPE_HERO) == true then
                if mshieldstate[pid] == true then
                   set cmana=GetUnitState(u, UNIT_STATE_MANA)
                   set dmana=10 + dmg / 10
                       if dmana >= cmana then
                          call SetUnitState(u, UNIT_STATE_MANA, 0)
                          set mshieldstate[pid]=false
                       else
                          set cmana=cmana - dmana
                          call SetUnitState(u, UNIT_STATE_MANA, cmana)
                       endif
                 endif
    
                 if dmg > 2000 then
                      //  call shakebattle(did,pid,dmg*0.33,u)
                 endif
          endif
          
     set textHeight=udg_TSC * 0.023 / 10
     
     
     if udg_DmgTextAngle > 90 and udg_DmgTextAngle < 270 then
       set udg_DmgTextAngle=115
     else
       set udg_DmgTextAngle=65
    endif
    
    set dmgstr=I2S(d)
    set dmgtxt=CreateTextTag()
    call SetTextTagText(dmgtxt, dmgstr, textHeight)
    call SetTextTagPosUnit(dmgtxt, u, - 100)
    call SetTextTagColor(dmgtxt, ITCR, ITCG, ITCB, 255)
    call SetTextTagPermanent(dmgtxt, false)
    call SetTextTagLifespan(dmgtxt, tlife)
    call SetTextTagFadepoint(dmgtxt, 0.5)
    call SetTextTagVelocityBJ(dmgtxt, vel, udg_DmgTextAngle)
    
    
     call SaveReal(hts, GetHandleId(tm), 1, udg_DmgTextAngle)
     call SaveReal(hts, GetHandleId(tm), 2, textHeight)
     call SaveReal(hts, GetHandleId(tm), 3, vel)
     call SaveStr(hts, GetHandleId(tm), 4, dmgstr)
     call SaveTextTagHandle(hts, GetHandleId(tm), 5, dmgtxt)
     call SaveInteger(hts, GetHandleId(tm), 6, sec)
    
     
    
     call TimerStart(tm, 0.03, true, function movetxt)
    
    // call CreateTextTagUnitBJ(I2S(d), u, -150, udg_TSC, ITCR, ITCG, ITCB, 0 )
    // set bj_lastCreatedTextTag = CreateTextTag()
    // call SetTextTagText(bj_lastCreatedTextTag, I2S(d), textHeight)
     //call SetTextTagPosUnit(bj_lastCreatedTextTag, u, -100)
     //call SetTextTagColor(bj_lastCreatedTextTag, ITCR, ITCG,  ITCB, 255)
     //call SetTextTagPermanent(bj_lastCreatedTextTag, false )
     //call SetTextTagLifespan(bj_lastCreatedTextTag, tlife )
     //call SetTextTagFadepoint(bj_lastCreatedTextTag, 0.5 )
     //call SetTextTagVelocityBJ(bj_lastCreatedTextTag, vel, udg_DmgTextAngle )
          
          
   // call TriggerSleepAction(0.1)
    call EnableTrigger(gg_trg_DMG)
  set dmgtxt=null
  set dmgstr=null
  set d=0
  set udg_Lethalstrikestack=0.00
  set ITCR=191
  set ITCG=191
  set ITCB=191
  set udg_TSC=17.00
  set batsdmg[pid]=0
  set lstrikedmg[pid]=0
  set piercedmg[pid]=0
  set magicdmg[pid]=0
  set u=null
  set a=null
  set tm=null

endfunction

//===========================================================================
function InitTrig_DMG takes nothing returns nothing
         
    set gg_trg_DMG=CreateTrigger()
    call DisableTrigger(gg_trg_DMG)
    call TriggerAddCondition(gg_trg_DMG, Condition(function hawkOff))
    call TriggerAddAction(gg_trg_DMG, function Trig_DMG_Actions)
endfunction


//===========================================================================
// Trigger: UTD
//===========================================================================
function Trig_UTD_Conditions takes nothing returns boolean
       return ( IsUnitInGroup(GetTriggerUnit(), udg_HasDMGevent) == false )
endfunction

function Trig_UTD_Actions takes nothing returns nothing
    call GroupAddUnit(udg_HasDMGevent, GetTriggerUnit())
    call TriggerRegisterUnitEvent(gg_trg_DMG, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_LSDMG, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_BTDMG, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_MGDMG, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_PCDMG, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhawk, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhawkb, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhater, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhaterb, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
endfunction

//===========================================================================
function InitTrig_UTD takes nothing returns nothing
     local integer index
    set gg_trg_UTD=CreateTrigger()


    set index=0
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_UTD, Player(index), EVENT_PLAYER_UNIT_ATTACKED, Condition(function bool))

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop

   // call TriggerRegisterAnyUnitEventBJ( gg_trg_UTD, EVENT_PLAYER_UNIT_ATTACKED )
    call TriggerAddCondition(gg_trg_UTD, Condition(function Trig_UTD_Conditions))
    call TriggerAddAction(gg_trg_UTD, function Trig_UTD_Actions)
endfunction


//===========================================================================
// Trigger: spelledg
//===========================================================================
function Trig_spelledg_Conditions takes nothing returns boolean
    return ( IsUnitInGroup(GetSpellTargetUnit(), udg_Spelledg) == false )
endfunction

function Trig_spelledg_Actions takes nothing returns nothing
   call GroupAddUnit(udg_Spelledg, GetSpellTargetUnit())
   call TriggerRegisterUnitEvent(gg_trg_SPDMG, GetSpellTargetUnit(), EVENT_UNIT_DAMAGED)
  // call TriggerRegisterUnitEvent( gg_trg_SDMG, GetSpellTargetUnit(), EVENT_UNIT_DAMAGED )
   
endfunction

//===========================================================================
function InitTrig_spelledg takes nothing returns nothing
    set gg_trg_spelledg=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_spelledg, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_spelledg, Condition(function Trig_spelledg_Conditions))
    call TriggerAddAction(gg_trg_spelledg, function Trig_spelledg_Actions)
endfunction


