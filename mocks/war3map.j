function mercscape takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(questtm, GetHandleId(t), 0)
local integer id= LoadInteger(questtm, GetHandleId(u), 1)
local integer si= LoadInteger(questtm, GetHandleId(t), 1)
local real face= GetUnitFacing(u)
local real x= GetUnitX(u) + 100 * Cos(face * bj_DEGTORAD)
local real y= GetUnitY(u) + 100 * Sin(face * bj_DEGTORAD)
local real xt
local real yt
local real horizonti= face - 90
local real horizonte= face + 90
local real horizont

   if GetUnitState(u, UNIT_STATE_LIFE) < 0.5 then
     call PauseTimer(t)
     call ReleaseTimer(t)
     call FlushChildHashtable(questtm, GetHandleId(t))
     call FlushChildHashtable(questtm, GetHandleId(u))
     call TriggerSleepAction(0.02)
     set t=null
     set u=null
     return
   endif

    if IsTerrainWalkable(x , y) then
      call IssuePointOrder(u, "move", mercx[si], mercy[si])
    else
   // set face = GetUnitFacing(u)
  //  set xt = x + 800 * Cos(face * bj_DEGTORAD)
  //  set yt = y + 800 * Sin(face * bj_DEGTORAD)
        
        set horizont=GetRandomReal(horizonti, horizonte)
        set xt=x + 800 * Cos(horizont * bj_DEGTORAD)
        set yt=y + 800 * Sin(horizont * bj_DEGTORAD)
           
    call IssuePointOrder(u, "blink", xt, yt)
    call TriggerSleepAction(2)
    call IssuePointOrder(u, "move", mercx[si], mercy[si])
    //call IssueTargetOrder(u,"attack",udg_PHero[id])
     call TriggerSleepAction(0.05)
   endif
    if ( GetLocalPlayer() == Player(id) ) then
        call PingMinimap(x, y, 3)
     endif
 
set t=null
set u=null

endfunction



function Trig_endduel_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local unit a= GetKillingUnit()
local integer id= GetPlayerId(GetOwningPlayer(a))
local integer vid= GetPlayerId(GetOwningPlayer(u))
local integer questid
local timer t= null
local item it= null
local integer scapeindex= GetRandomInt(5, 7)

   if GetOwningPlayer(u) == Player(PLAYER_DARK_LORD) then
    set questid=GetUnitUserData(u)
        if u == QUid[questid] then
                set t=LoadTimerHandle(questtm, GetHandleId(udg_PHero[QPid[questid]]), GetHandleId(u))
                 call FlushChildHashtable(questtm, GetHandleId(t))
                 call FlushChildHashtable(questtm, GetHandleId(u))
                 call TriggerSleepAction(0.02)
                call PauseTimer(t)
                call ReleaseTimer(t)
                call StartSound(bj_questCompletedSound)
                call DisplayTimedTextToPlayer(Player(QPid[questid]), .1, 0, 10, "|cffffcc00SURVIVOR QUEST FINISHED!!|r")
                call DisplayTimedTextToPlayer(Player(QPid[questid]), .1, 0, 10, "   The slayer has been killed")
   
    
                if id == QPid[questid] then
    
                    call UpdatePersQuest(QPid[questid] , questid , Qdata[questid] , "   Success!!! You killed that bastard... [" , "1" , "-")
     
                    call DisplayTimedTextToPlayer(Player(id), .1, 0, 10, "   you got +15 Reputation ")
                    set Reputation[id]=Reputation[id] + 15
                    call DropPvpMerc(u)
    
                else
                    call UpdatePersQuest(QPid[questid] , questid , Qdata[questid] , "A mercenary who wanted kills you has been destroyed.. [" , "1" , "-")
                    call DisplayTimedTextToPlayer(Player(id), .1, 0, 10, "   you got +6 Reputation ")
                    set Reputation[id]=Reputation[id] + 6
                endif
                call TriggerSleepAction(0.02)
                call RemoveQuestFromPlayer(questid , QPid[questid])
                set hasbounty[QPid[questid]]=false
                set it=LoadItemHandle(herohash, GetHandleId(u), 2)
                    if it != null then
                        call UnitRemoveItem(u, it)
                        call ItemName(GetItemName(it) , GetItemX(it) , GetItemY(it))
                    endif
                call TriggerSleepAction(1)
                call RemoveUnit(u)
                set u=null
        endif //is the merc u == QUid[questid]
   
   elseif IsUnitType(a, UNIT_TYPE_HERO) == true and GetOwningPlayer(a) == Player(PLAYER_DARK_LORD) then
    set questid=GetUnitUserData(a)
        if a == QUid[questid] then
             set t=LoadTimerHandle(questtm, GetHandleId(udg_PHero[QPid[questid]]), GetHandleId(a))
             if LoadInteger(questtm, GetHandleId(t), 1) < 5 then //checking is hero already scaping
                call PauseTimer(t)
                call ReleaseTimer(t)
                call TriggerSleepAction(0.1)
                call StartSound(bj_questUpdatedSound)
                call DisplayTimedTextToPlayer(Player(QPid[questid]), .1, 0, 10, "|cffffcc00SURVIVOR QUEST UPDATE!|r")
                set it=UnitRemoveItemFromSlot(u, GetRandomInt(0, 5))
                
                call DisableTrigger(pickset)
                call DisableTrigger(gg_trg_IR)
                call DisableTrigger(gg_trg_PA)
                call DisableTrigger(gg_trg_PW)
                call UnitAddItem(a, it)
                call EnableTrigger(pickset)
                call EnableTrigger(gg_trg_IR)
                call EnableTrigger(gg_trg_PA)
                call EnableTrigger(gg_trg_PW)
                
                call SaveItemHandle(herohash, GetHandleId(a), 2, it)
                set t=(NewTimerEx(0)) // INLINED!!
                call SaveUnitHandle(questtm, GetHandleId(t), 0, a)
                call SaveInteger(questtm, GetHandleId(t), 1, scapeindex)
                call SaveTimerHandle(questtm, GetHandleId(udg_PHero[QPid[questid]]), GetHandleId(a), t)
                call TimerStart(t, 10, true, function mercscape)
            
                call StartSound(bj_questDiscoveredSound)
                call UpdatePersQuest(QPid[questid] , questid , Qdata[questid] , "   Cath the thief before he reach to any Big Cavern's Entrance " , "0" , "-")
                call DisplayTimedTextToPlayer(Player(QPid[questid]), .1, 0, 10, "   The slayer has taken your |cffffcc00" + GetItemName(it) + "|r")
              
              
              endif //checking is hero already is scaping
        endif
    
   endif //hero owned by dark lord

set u=null
set a=null
set t=null
set it=null
endfunction
//===========================================================================
function InitTrig_endduel takes nothing returns nothing
 local integer i= 0
    set gg_trg_endduel=CreateTrigger()
    loop
    call TriggerRegisterPlayerUnitEvent(gg_trg_endduel, Player(i), EVENT_PLAYER_UNIT_DEATH, Condition(function istrue))
    set i=i + 1
    exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
    call TriggerAddCondition(gg_trg_endduel, Condition(function Trig_endduel_Conditions))
    call TriggerAddAction(gg_trg_endduel, function Trig_endduel_Actions)
endfunction


