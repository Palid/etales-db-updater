function Trig_left_Actions takes nothing returns nothing
 local string s= GetPlayerName(GetTriggerPlayer())
     call DisplayTimedTextToForce(GetPlayersAll(), 5.00, "|cffff0000" + s + "|r has left the game")
     
 call RemoveUnit(udg_PHero[GetPlayerId(GetTriggerPlayer())])
 call RemoveUnit(udg_Slave[GetPlayerId(GetTriggerPlayer())])
 call RemoveUnit(cslave[GetPlayerId(GetTriggerPlayer())])
 call RemoveUnit(udg_Familiar[GetPlayerId(GetTriggerPlayer())])
 call RemoveUnit(udg_MAVault[GetPlayerId(GetTriggerPlayer())])
 call RemoveUnit(udg_ARVault[GetPlayerId(GetTriggerPlayer())])
 
 
 call SetPlayerName(GetTriggerPlayer(), "|cff888888Left|r")
 call ForceRemovePlayer(udg_pvp, GetTriggerPlayer())
 set s=null
endfunction

//===========================================================================
function InitTrig_left takes nothing returns nothing
    local integer i= 0
    set gg_trg_left=CreateTrigger()
    loop
     exitwhen i > 12
     call TriggerRegisterPlayerEventLeave(gg_trg_left, Player(i))
     set i=i + 1
     endloop
     
    call TriggerAddAction(gg_trg_left, function Trig_left_Actions)
endfunction


//===========================================================================
// Trigger: pvpout
//===========================================================================
function Trig_pvpout_Conditions takes nothing returns boolean
     return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and inpvp[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == true )
endfunction

function settingpvpout takes nothing returns nothing
    call MakeAlly(GetOwningPlayer(GetTriggerUnit()) , GetEnumPlayer())
    call MakeAlly(GetEnumPlayer() , GetOwningPlayer(GetTriggerUnit()))
endfunction

function Trig_pvpout_Actions takes nothing returns nothing
   local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))

   if GemVar_A[id] > 0 then
      set GemVar_A[id]=GemVar_A[id] - 1
      call CreateItem('I0UH', GetUnitX(GetTriggerUnit()), GetUnitY(GetTriggerUnit()))
   endif
   
    call ForceRemovePlayer(udg_pvp, GetOwningPlayer(GetTriggerUnit()))
    call ForForce(udg_pvp, function settingpvpout)
    set inpvp[id]=false
    call UnitAddAbility(udg_PHero[id], callfamiliar)
    call EnableTrigger(natkp[id])
    call IssueImmediateOrder(udg_Familiar[id], "stop")
    if udg_Faction[id] == 4 or udg_Faction[id] == 5 then
     call UnitAddAbility(udg_PHero[id], 'A0EW')
    endif
    
endfunction

//===========================================================================
function InitTrig_pvpout takes nothing returns nothing
    local integer index= 0
    set gg_trg_pvpout=CreateTrigger()
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_pvpout, Player(index), EVENT_PLAYER_UNIT_DEATH, null)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    //call TriggerRegisterLeaveRectSimple( gg_trg_pvpout, gg_rct_pvp )
    call TriggerAddCondition(gg_trg_pvpout, Condition(function Trig_pvpout_Conditions))
    call TriggerAddAction(gg_trg_pvpout, function Trig_pvpout_Actions)
endfunction


//===========================================================================
// Trigger: pvp
//
// bj_questHintSound 
//===========================================================================
//TESH.scrollpos=44
//TESH.alwaysfold=0
function PVPC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0T4' )
endfunction

function settingpvp takes nothing returns nothing
    call MakeEnemy(GetOwningPlayer(GetTriggerUnit()) , GetEnumPlayer())
    call MakeEnemy(GetEnumPlayer() , GetOwningPlayer(GetTriggerUnit()))
endfunction

function PVPA takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local unit u= udg_PHero[id]
local location p
local string pname= GetPlayerName(GetOwningPlayer(u))
local string hname= GetUnitName(udg_PHero[id])
local boolean ok= false
   //if (pvpof == true ) then
  if ( on_event == true ) then
    call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 3, "PVP is closed while there are conflicts, come back later")
   //call UnitChat("PVP is closed while there are conflicts, come back later", GetSellingUnit())
   else
        call ForceAddPlayer(udg_pvp, Player(id))
        call ForForce(udg_pvp, function settingpvp)
         set inpvp[id]=true
        call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 3, "You will be teleported to the arena...")
       // call UnitChat("You'll be moved into the PvP Arena", GetSellingUnit())
        call StartSound(bj_questDiscoveredSound)
        call TriggerSleepAction(2)

        set p=udg_pvploc[GetRandomInt(0, 7)]
             if udg_Faction[id] == 4 or udg_Faction[id] == 5 then
               call UnitRemoveAbility(udg_PHero[id], 'A0EW')
               call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 3, "Blink disabled for PvP...")
            endif
        call SetUnitPositionLoc(u, p)
      //  call SetUnitPositionLoc(udg_Slave[id] ,p)
       // call SetUnitPositionLoc(udg_Familiar[id] ,p)
       call UnitRemoveAbility(udg_PHero[id], callfamiliar)
       call ShowUnit(udg_Familiar[id], false)
       call ShowUnit(cslave[id], false)
        
        call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
        call DisplayTimedTextToForce(GetPlayersAll(), 6.00, "|cffffcc00" + pname + "|r, the " + hname + " has entered into the PvP Arena")
        call StartSound(bj_questHintSound)

        call DisableTrigger(natkp[id])
            
   endif

set p=null

set u=null
set pname=null
set hname=null

endfunction

//===========================================================================
function InitTrig_pvp takes nothing returns nothing
    set gg_trg_pvp=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_pvp, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_pvp, Condition(function PVPC))
    call TriggerAddAction(gg_trg_pvp, function PVPA)
endfunction


//===========================================================================
// Trigger: lpvp
//===========================================================================
//TESH.scrollpos=18
//TESH.alwaysfold=0
function lpvpc takes nothing returns boolean
    return ( inpvp[GetPlayerId(GetTriggerPlayer())] == true and GetUnitState(udg_PHero[GetPlayerId(GetTriggerPlayer())], UNIT_STATE_LIFE) > 0.4 )
endfunction

function lpvpa takes nothing returns nothing
local integer id= GetPlayerId(GetTriggerPlayer())
local unit h= udg_PHero[GetPlayerId(GetTriggerPlayer())]
local location r= udg_RevivalPoints[id]
 
  if ( CountPlayersInForceBJ(udg_pvp) == 1 ) then
   call ForceRemovePlayer(udg_pvp, GetTriggerPlayer())
   call EnableTrigger(natkp[id])
   set inpvp[id]=false
   call UnitAddAbility(udg_PHero[id], callfamiliar)
    if udg_Faction[id] == 4 or udg_Faction[id] == 5 then
      call UnitAddAbility(udg_PHero[id], 'A0EW')
    endif
   call SetUnitPositionLoc(h, r)
   call SetUnitPositionLoc(udg_Slave[id], r)
   call SetUnitPositionLoc(udg_Familiar[id], r)
 elseif ( CountPlayersInForceBJ(udg_pvp) > 1 ) then
   call DisplayTimedTextToPlayer(GetOwningPlayer(h), 0, 0, 6, "There are another players in the arena.")
   call DisplayTimedTextToPlayer(GetOwningPlayer(h), 0, 0, 6, "You cannot leave here until you die or defeat them...")
 endif
 

set r=null
call RemoveLocation(r)
set h=null

endfunction

//===========================================================================
function InitTrig_lpvp takes nothing returns nothing
    local integer i= 0
    set gg_trg_lpvp=CreateTrigger()
     
    loop
    exitwhen i > 8
        call TriggerRegisterPlayerChatEvent(gg_trg_lpvp, Player(i), "-leavepvp", true)
    set i=i + 1
    endloop
    
    
    call TriggerAddCondition(gg_trg_lpvp, Condition(function lpvpc))
    call TriggerAddAction(gg_trg_lpvp, function lpvpa)
endfunction


