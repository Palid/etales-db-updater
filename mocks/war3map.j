function explosions takes nothing returns nothing

local integer tipo= GetRandomInt(0, 4)
 set exploder=CreateUnit(Player(12), explosion[tipo], GetUnitX(gg_unit_E00I_2515), GetUnitY(gg_unit_E00I_2515), GetRandomReal(0, 359))
 call UnitApplyTimedLife(exploder, 'BTLF', 3)
 call SetUnitTimeScale(exploder, GetRandomReal(.9, 2.7))
 set exploder=null
 

 
endfunction

function shaker takes nothing returns nothing
local integer i= 0
 loop
 exitwhen i > 7
     call shakebattle(i , 12 , 2678 , gg_unit_E00I_2515)
  set i=i + 1
 endloop
endfunction


function Trig_iveortruedie_Actions takes nothing returns nothing
local integer i= 0
local real d= 2678 * 0.6
call SetUnitTimeScale(gg_unit_E00I_2515, 0.05)
 set inveorfa=(NewTimerEx(0)) // INLINED!!
 set inveorfb=(NewTimerEx(0)) // INLINED!!
 
      
 call TimerStart(inveorfa, 0.2, true, function explosions)
  call TimerStart(inveorfb, 1, true, function shaker)
 call DisplayTimedTextToForce(GetPlayersAll(), 7, "|cffffcc00I V E O R   S C R E A M S !|r")
 call DisplayTimedTextToForce(GetPlayersAll(), 7, "N N O O O O O O O O O O O O O O O O O O O O O O...")
 
  call TriggerSleepAction(8)
 call DisplayTimedTextToForce(GetPlayersAll(), 7, "A A A A A A A A R R R G G H H H H H H H H...")
 
 call CinematicFadeBJ(bj_CINEFADETYPE_FADEIN, 0.5, "ReplaceableTextures\\CameraMasks\\White_mask.blp", 100.00, 90.00, 60, 60.00)

 call TriggerSleepAction(4)
 call CinematicFadeBJ(bj_CINEFADETYPE_FADEIN, 0.20, "ReplaceableTextures\\CameraMasks\\White_mask.blp", 100.00, 90.00, 60, 60.00)



 call SetUnitTimeScale(gg_unit_E00I_2515, 1)


call TriggerSleepAction(7)
call CinematicFadeBJ(bj_CINEFADETYPE_FADEIN, 4, "ReplaceableTextures\\CameraMasks\\White_mask.blp", 100.00, 90.00, 60, 60.00)

  call TriggerSleepAction(7)
 call PauseTimer(inveorfa)
 call ReleaseTimer(inveorfa)
 call PauseTimer(inveorfb)
 call ReleaseTimer(inveorfb)
     
call DropPvpBoss(GetTriggerUnit())
call DropPvpBoss(GetTriggerUnit())
call CreateFixed(GetTriggerUnit() , 79) // Divine chest

call CreateFixed(GetTriggerUnit() , 1020) // 'I0CM' //elite helmet
call CreateFixed(GetTriggerUnit() , 1046) // 'I0BT' //Legendary Excalibur light blade 
call CreateFixed(GetTriggerUnit() , 1013) //INTELOGO Avahor 

  call TriggerSleepAction(5)
 call EnableTrigger(gg_trg_Godspech)

    call ShowUnit(gg_unit_H03N_0386, true) //Sattan
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Resurrect\\ResurrectCaster.mdl", gg_unit_H03N_0386, "origin"))
    
    call ShowUnit(gg_unit_H03M_0385, true) //Sun
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Resurrect\\ResurrectCaster.mdl", gg_unit_H03M_0385, "origin"))
call TriggerSleepAction(12)
     
    if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) == true ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
     
      endif
      
     call StartSound(bj_questCompletedSound)
     call FlashQuestDialogButton()
   
     call QuestItemSetCompleted(iveordia, true)
     call QuestItemSetCompleted(iveordib, true)
    // call QuestItemSetCompleted(iveordic,true)
     call QuestItemSetCompleted(iveordid, true)
     call QuestSetDiscovered(iveordq, true)
     call QuestSetCompleted(iveordq, true)
     call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffcccc00WORLD QUEST COMPLETED:|r Iveor's Destiny")
     call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "All players got +123606 |cff6666ffXP|r, +81803 |cffffcc00gold|r")
  loop
    exitwhen i > 7
      
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[79], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
      call AddHeroXP(udg_PHero[i], 123606, false)
      call AdjustPlayerStateBJ(81803, Player(i), PLAYER_STATE_RESOURCE_GOLD)
     set i=i + 1
    
    endloop
      
      
endfunction

