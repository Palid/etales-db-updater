//===========================================================================
// Trigger: warlockend
//===========================================================================
//TESH.scrollpos=96
//TESH.alwaysfold=0
function warlockec takes nothing returns boolean
 local integer id= GetPlayerId(GetOwningPlayer(GetEnteringUnit()))
     return IsUnitType(GetEnteringUnit(), UNIT_TYPE_HERO) == true and s__inwarlock[id] == true
endfunction




function walockt takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 0)
local integer attch= LoadInteger(hts, GetHandleId(t), 3)
local integer id= GetPlayerId(GetOwningPlayer(a))

set attch=attch + 1
if attch > 5 then
set attch=0

endif
   call SaveInteger(hts, GetHandleId(t), 3, attch)
   call SetUnitAnimationByIndex(a, GetRandomInt(0, 9))
   call DestroyEffect(AddSpecialEffectTarget(STATIC, a, electrocuteattch[attch]))
  

set a=null
set t=null
endfunction


function warlockea takes nothing returns nothing
     local integer id= GetPlayerId(GetOwningPlayer(GetEnteringUnit()))
     local integer i= 1
     local integer attch= 0
     local unit u= GetEnteringUnit()
     local integer exp= GetHeroXP(u)
     local timer t= (NewTimerEx(0)) // INLINED!!
     local location p
     local integer agi= GetHeroAgi(u, false) + 24
     local integer str= GetHeroStr(u, false) + 24
     local integer int= GetHeroInt(u, false) + 24
     local integer questid
     
      
       call IssueImmediateOrder(u, "stop")
       set s__inwarlock[id]= false
       call UnitAddAbility(u, 'Avul')
       
  
        call UnitChat("The hermit told me here thuders fall over the mountain..." , u)
        call TriggerSleepAction(3)
        call UnitChat("could it be true?." , u)
        call TriggerSleepAction(2)
        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\Monsoon\\MonsoonBoltTarget.mdl", u, "chest"))
        call TriggerSleepAction(0.1)
        call DestroyEffect(AddSpecialEffectTarget(seffectclap, u, "origin"))
        call SaveUnitHandle(hts, GetHandleId(t), 0, u)
        call SaveInteger(hts, GetHandleId(t), 3, attch)
       
        call TimerStart(t, 0.2, true, function walockt)
       
        call TriggerSleepAction(0.7)
        call DestroyEffect(AddSpecialEffectTarget(seffectclap, u, "origin"))
        call TriggerSleepAction(0.7)
        call DestroyEffect(AddSpecialEffectTarget(seffectclap, u, "origin"))
        call TriggerSleepAction(0.7)
        call DestroyEffect(AddSpecialEffectTarget(seffectclap, u, "origin"))
        call TriggerSleepAction(0.7)
        call DestroyEffect(AddSpecialEffectTarget(seffectclap, u, "origin"))
        call TriggerSleepAction(0.7)
       
         call PauseTimer(t)
         call FlushChildHashtable(hts, GetHandleId(t))
         call ReleaseTimer(t)
         set t=null
  
  
           
            call GroupRemoveUnit(udg_inTest, u)
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "MAIN QUEST DONE")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Warlock test...")
            call StartSound(bj_questCompletedSound)
            
            set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
            call UpdatePersQuest(QPid[questid] , questid , Qdata[questid] , "The thunder has chosen you... " , "-" , "-")
            call RemoveQuestFromPlayer(questid , QPid[questid])

            
            
            set p=GetUnitLoc(u)
                   loop
                   exitwhen i > 6
                   call UnitRemoveItemFromSlot(u, i)
                   set i=i + 1
                   endloop
                   
            
            call RemoveUnit(u)
            
           set udg_PHero[id]=CreateUnitAtLoc(Player(id), 'O00I', p, 270)
           call DestroyEffect(AddSpecialEffectTarget(seffectclap, udg_PHero[id], "origin"))
           
           call AddProfaner(id) //Trigger registrado
       
           
            call SetHeroAgi(udg_PHero[id], agi, true)
            call SetHeroStr(udg_PHero[id], str, true)
            call SetHeroInt(udg_PHero[id], int, true)
            
            call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
            call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
            call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
       
            
            call SetHeroXP(udg_PHero[id], exp, false)
            call AdjustPlayerStateBJ(7, Player(id), PLAYER_STATE_RESOURCE_LUMBER)
           
            set udg_Hnext[id]=4
            call UnitChat("WUUUAAAAAJOJOJOOOOOOOOOOOOOooo... what the hell was that!!" , udg_PHero[id])
            set u=null
            set t=null
            call RemoveLocation(p)
            set p=null

endfunction

