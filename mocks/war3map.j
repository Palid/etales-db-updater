function Trig_checkcentaurs_Conditions takes nothing returns boolean
    return GetUnitUserData(GetDyingUnit()) == 1123
endfunction

function Trig_checkcentaurs_Actions takes nothing returns nothing
local unit u= GetDyingUnit()
local integer id= LoadInteger(questtm, GetHandleId(u), 1123)
local integer idk= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
    call GroupRemoveUnit(s__centaurs[id], u)
    call FlushChildHashtable(questtm, GetHandleId(u))
    
    if id == idk then
     set s__centaurkiller[id]= s__centaurkiller[id] + 1
    endif
    
    set u=null
endfunction

