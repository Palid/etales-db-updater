//===========================================================================
// Trigger: katherinneMeting
//
// quest katherinneq
// questitem katherinneia
//===========================================================================
//TESH.scrollpos=146
//TESH.alwaysfold=0
function Trig_katherinneMeting_Conditions takes nothing returns boolean
    return s__KatherineAdvice[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == true and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_katherinneMeting_Actions takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local real x= GetRectCenterX(Salida[9])
  local real y= GetRectCenterY(Salida[9])
  local real xk= GetUnitX(kathy)
  local real yk= GetUnitY(kathy)
  local real duration= 8
  
  call DisableTrigger(gg_trg_katherinneMeting)

  call TriggerSleepAction(3)

  call ShowUnit(kathy, true)
  call SetUnitPosition(kathy, x, y)
  call SetUnitInvulnerable(kathy, true)
  call SetUnitOwner(kathy, Player(10), false) //Enthashara
  call IssuePointOrder(kathy, "move", GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id]))
  call TriggerSleepAction(4)
  call PauseUnit(udg_PHero[id], true)
  
  
  
   call UnitChat("Lady katherinne!... Pleased to see you here!" , henry)
   call MakeFaceToUnit(henry , kathy)
   call TriggerSleepAction(3)
   call IssuePointOrder(udg_Slave[id], "move", GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id]))
   call UnitChat("My Lords...!" , kathy)
   call MakeFaceToUnit(kathy , udg_PHero[id])
   call TriggerSleepAction(3)
   call UnitChat("My lady, How is working your safe way system?" , elrus)
   call MakeFaceToUnit(elrus , kathy)
   call TriggerSleepAction(3)
   call UnitChat("My dear Elrus, all is going fine just some little issues with unexpected <<warriors>>..." , kathy)
   call MakeFaceToUnit(kathy , elrus)
   call TriggerSleepAction(5)
   call UnitChat("Issues? What kind of issues are you talking about my lady?." , bernard)
   call MakeFaceToUnit(bernard , kathy)
   call TriggerSleepAction(4)
   call UnitChat("In fact there are some people that don't appreciate the value of our gates..." , kathy)
   call MakeFaceToUnit(kathy , udg_PHero[id])
   call TriggerSleepAction(4)
   call UnitChat("They started to attack my people and destroy my gates..." , kathy)
   call MakeFaceToUnit(kathy , henry)
   call TriggerSleepAction(3)
   call UnitChat("WHAT!!?. Who are those rebels? why nobody noticed us about that insurgency..." , henry)
   call MakeFaceToUnit(henry , kathy)
   call TriggerSleepAction(4)
   call UnitChat("Because I requested to keep these events in secret." , kathy)
   call MakeFaceToUnit(kathy , elrus)
   call TriggerSleepAction(3)
   call UnitChat("I'm not interested to alert citizen about this act." , kathy)
   call MakeFaceToUnit(kathy , elrus)
   call TriggerSleepAction(3)
   call UnitChat("I've chosen to hunt personally all those renegades." , kathy)
   call MakeFaceToUnit(kathy , bernard)
   call TriggerSleepAction(3)
   call UnitChat("Are you sure dear Katherinne? Maybe these people is in disagree with your methods" , elrus)
   call MakeFaceToUnit(elrus , kathy)
   call TriggerSleepAction(5)
   call UnitChat("Are you questioning Katherinne's gestion Elrus?." , henry)
   call MakeFaceToUnit(henry , elrus)
   call MakeFaceToUnit(bernard , elrus)
   call TriggerSleepAction(3)
   call UnitChat("Surely not... Henry, I just have some doubts about how the citizens received these indications..." , elrus)
   call MakeFaceToUnit(elrus , henry)
   call TriggerSleepAction(5)
   call UnitChat("Be sure... dear Elrus, that they are in better state than your Colddream's villagers in terms of security" , kathy)
   call MakeFaceToUnit(kathy , elrus)
   call MakeFaceToUnit(bernard , kathy)
   call TriggerSleepAction(6)
   call UnitChat("What are you trying to say my lady?" , elrus)
   call MakeFaceToUnit(elrus , kathy)
   call TriggerSleepAction(3)
   call UnitChat("Well... It's known that you are sieged by various enemies, I can help you, but you chose to reject my offers..." , kathy)
   call MakeFaceToUnit(kathy , elrus)
   call TriggerSleepAction(6)
   call UnitChat("It's simple my lady. We can defend ourselves. I don't like to see our ways kept by bandits" , elrus)
   call MakeFaceToUnit(elrus , kathy)
   call TriggerSleepAction(4)
   call UnitChat("You don't need to be insolent Elrus!!!" , bernard)
   call MakeFaceToUnit(bernard , elrus)
   call TriggerSleepAction(3)
   call UnitChat("Calm down my friend!!" , kathy)
   call MakeFaceToUnit(kathy , bernard)
   call TriggerSleepAction(3)
   call UnitChat("Let our dear Elrus handle his problems alone" , kathy)
   call MakeFaceToUnit(kathy , udg_PHero[id])
   call TriggerSleepAction(4)
   call UnitChat("if you'll excuse me, I have to speak a word with my friend |cffffcc00" + GetPlayerName(Player(id)) + "|r here" , kathy)
   call MakeFaceToUnit(kathy , henry)
   call TriggerSleepAction(4)
   call UnitChat("Sure..." , henry)
   call TriggerSleepAction(1)
   call UnitChat("See you later dear..." , bernard)
   call TriggerSleepAction(2)
   call UnitChat("...... " , elrus)
   call PauseUnit(udg_PHero[id], false)
   call UnitChat("Please follow me..." , kathy)
   call MakeFaceToUnit(kathy , udg_PHero[id])
   call TriggerSleepAction(2)
   call IssuePointOrder(kathy, "move", - 14940, - 11740)
   call TriggerSleepAction(1)
   call IssuePointOrder(udg_PHero[id], "move", - 14940, - 11740)
   call TriggerSleepAction(5)
   call UnitChat("Listen me...." , kathy)
   call TriggerSleepAction(2)
        call MakeFaceToUnit(kathy , udg_PHero[id])
        call DisplayTimedTextToPlayer(Player(id), 0, 0, duration, "|cffffcc00Lady Katherinne says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "I do not know who you think you are")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "I do not know who are your friends...")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "but make sure you commited a big mistake")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "when you started to kill my men")
   call TriggerSleepAction(9)
        call MakeFaceToUnit(kathy , udg_PHero[id])
        call IssuePointOrder(kathy, "move", GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id]))
        call DisplayTimedTextToPlayer(Player(id), 0, 0, duration, "|cffffcc00Lady Katherinne says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "Nobody enter into my bussiness")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "without my permission.")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "but you directly try to embarras me")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "I cannot allow that")
   call TriggerSleepAction(9)
        call MakeFaceToUnit(kathy , udg_PHero[id])
        call IssuePointOrder(kathy, "move", GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id]))
        call DisplayTimedTextToPlayer(Player(id), 0, 0, duration, "|cffffcc00Lady Katherinne says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "Be ready, I'll fall over you")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "I'll find you, I'll will hunt you and all your friends")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "I'll cut your hands and your foots, I'll impale you")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "then I'll show your bloody chest to the people as my flag.")
        call DisplayTimedTextToPlayer(Player(id), 0.1, 0, duration, "to teach them what happens to those heroes who try to deal with me.")
   call TriggerSleepAction(11)
   call StartSound(bj_questDiscoveredSound)
     if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "|cffffcc00NEW GLOBAL QUEST FOUND|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, duration, "Lady Katherinne, Leader of bandits syndicate has declared war to you")
               
      endif
      
 
   call QuestSetDiscovered(katherinneq, true)
   set KatherineAngry=true
  // set katherinet = NewTimer()
   
   
    call TriggerSleepAction(5)
    call IssuePointOrder(kathy, "move", x, y)
    call TriggerSleepAction(7)
    
    
  //call ShowUnit(kathy,false)
  call SetUnitPosition(kathy, xk, yk)
  call SetUnitInvulnerable(kathy, false)
  call SetUnitOwner(kathy, Player(8), false) //Player_Bandits Syndicate
 // call EnableTrigger(gg_trg_katherinneMeting)
   set s__KatherineAdvice[id]= false
   call EnableTrigger(gg_trg_kathprvnt)
endfunction

