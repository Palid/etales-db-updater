 call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "All players got +64400 XP, +1 Divine Chest")
  loop
    exitwhen i > 8
      
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[79], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
      call AddHeroXP(udg_PHero[i], 64400, false)
     set i=i + 1
    
    endloop
  
 call shakecam(2)

  call TriggerSleepAction(4)
  call ShowDestructable(gg_dest_OTsp_13905, true) //black hand hate
  call DisplayTimedTextToForce(GetPlayersAll(), 8, "|cff999999An underground gate has been activated|r")
