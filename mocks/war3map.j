function ctrue takes nothing returns boolean
 return true
endfunction

function clownvictimc takes nothing returns boolean
 return ( IsUnitInGroup(GetTriggerUnit(), clownvictim) == false )
endfunction

function addclownvictim takes nothing returns nothing
local unit u= GetTriggerUnit()

 call GroupAddUnit(clownvictim, u)
 call TriggerRegisterUnitEvent(gg_trg_clownmadnesssfx, u, EVENT_UNIT_DAMAGED)
  call TriggerRegisterUnitEvent(gg_trg_clownlefthand, u, EVENT_UNIT_DAMAGED)
  
  set u=null
 
endfunction



function initclownlb takes nothing returns nothing
local integer i= 0
 set adclw=CreateTrigger()
 
     loop
        call TriggerRegisterPlayerUnitEvent(adclw, Player(i), EVENT_PLAYER_UNIT_ATTACKED, Condition(function ctrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
 call TriggerAddCondition(adclw, Condition(function clownvictimc))
 call TriggerAddAction(adclw, function addclownvictim)
 
 set orders[0]="chest"
 set orders[1]="head"
 set orders[2]="origin"
 set orders[3]="weapon"
 set orders[5]="hand"

 
 
endfunction


