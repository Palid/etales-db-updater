//===========================================================================
// Trigger: death gift
//===========================================================================
function Trig_death_gift_Conditions takes nothing returns boolean
    return ( GetWidgetLife(GetManipulatedItem()) == 555.0 and IsUnitType(GetManipulatingUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_death_gift_Actions takes nothing returns nothing
   local integer n
   local integer j= 0
   local integer select
   local real r
   local unit u= GetManipulatingUnit()
   local integer id= GetPlayerId(GetOwningPlayer(u))
   local real x= GetUnitX(u)
   local real y= GetUnitY(u)
   local item it= GetManipulatedItem()
   local item mit= null
   local integer str= GetHeroStr(u, false) - 4
 

 
        if GetItemTypeId(it) == 'I04Z' then //gems
         set n=GetRandomInt(5, 15)
         
         loop
          exitwhen j > n
           set mit=CreateItem(udg_itmpool[GetRandomInt(30, 35)], GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120), GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120))
         //  call ItemName(GetItemName(mit),GetItemX(mit),GetItemY(mit))
           set mit=null
           call TriggerSleepAction(0.01)
          set j=j + 1
         endloop
        
    elseif GetItemTypeId(it) == 'I050' then //fragment
         set n=GetRandomInt(10, 25)
         loop
          exitwhen j > n
           set mit=CreateItem(udg_itmpool[GetRandomInt(37, 41)], GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120), GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120))
         //  call ItemName(GetItemName(mit),GetItemX(mit),GetItemY(mit))
           set mit=null
           call TriggerSleepAction(0.01)
          set j=j + 1
         endloop
    
    elseif GetItemTypeId(it) == 'I051' then //chest
    
           set mit=CreateItem(udg_itmpool[GetRandomInt(80, 86)], GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120), GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120))
    
    elseif GetItemTypeId(it) == 'I056' then //scrolls
         set n=GetRandomInt(2, 4)
         
         loop
          exitwhen j > n
           set mit=CreateItem(udg_itmpool[GetRandomInt(49, 57)], GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120), GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120))
           call ItemName(GetItemName(mit) , GetItemX(mit) , GetItemY(mit))
           set mit=null
           call TriggerSleepAction(0.01)
          set j=j + 1
         endloop
    
    elseif GetItemTypeId(it) == 'I057' then //xp
         set n=GetRandomInt(20, 60) * 809
         call AddHeroXP(udg_PHero[id], n, false)
         
         call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, " The Guard of Death gives you +|cffffcc00" + I2S(n) + "|r Experience!")
       
        
     elseif GetItemTypeId(it) == 'I058' then //gold
         set n=GetRandomInt(53, 117) * 485
         call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) + n)
     
         call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, " The Guard of Death gives you +|cffffcc00" + I2S(n) + "|r Gold!")
        
     endif
       
         call UnitChat("I'll take 4 of your STR points" , death)
         call SetHeroStr(udg_PHero[id], str, true)
         
     set deathwait=61
     set u=null
     set it=null
     set mit=null
endfunction

//===========================================================================
function InitTrig_death_gift takes nothing returns nothing
local integer i= 0
    set gg_trg_death_gift=CreateTrigger()
    
     
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_death_gift, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function istrue))
       set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
 
    call TriggerAddCondition(gg_trg_death_gift, Condition(function Trig_death_gift_Conditions))
    call TriggerAddAction(gg_trg_death_gift, function Trig_death_gift_Actions)
endfunction


//===========================================================================
// Trigger: setupghost
//===========================================================================
function trggc takes nothing returns boolean
 if GetTriggerUnit() == LoadUnitHandle(questtm, GetHandleId(GetTriggeringTrigger()), 0) then
 //call DisableTrigger(GetTriggeringTrigger())
 call ExecuteFunc("trgga")
 endif
 
 return false
endfunction


function trggcb takes nothing returns boolean
 return GetTriggerUnit() == LoadUnitHandle(questtm, GetHandleId(GetTriggeringTrigger()), 0)
 

endfunction

function trgga takes nothing returns nothing
local unit u= LoadUnitHandle(questtm, GetHandleId(GetTriggeringTrigger()), 1)
local integer questid= GetUnitUserData(u)
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer xp= LoadInteger(questtm, GetHandleId(u), 14)
local real x= GetUnitX(u)
local real y= GetUnitY(u)
local integer alpha= 0
local trigger trg= GetTriggeringTrigger()
local integer iter= 0
local integer i= 0



if Qdata[questid] >= Qrequ[questid] then
   call DisableTrigger(trg)
    call UnitChat("You killed all of them!. Take your reward!" , u)
    call TriggerSleepAction(2)
    
    set ghostavenger[id]=ghostavenger[id] - 1
    
   // call UnitAddItemById(udg_PHero[id],udg_itmpool[57])//manual
    call AddHeroXP(udg_PHero[id], xp, false)
    
    call StartSound(bj_questCompletedSound)
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "   you get |cffbbbbff+" + I2S(xp) + "|r experience!")
    
 //   call DisplayTimedTextToPlayer(Player(id),0,0,6,"   you get |cffffcc00Profanator's Manual|r!")
    
     call UpdatePersQuestND(id , questid , Qrequ[questid] , "-" , I2S(Qrequ[questid]) , "-")
     call TriggerSleepAction(0.02)
     call RemoveQuestFromPlayer(questid , id)
     call TriggerSleepAction(3.5)
     
     loop
     exitwhen deathready == true
         call TriggerSleepAction(0.5)
     endloop
     
     set deathready=false
     call SetUnitPosition(death, GetRandomReal(x - 300, x + 300), GetRandomReal(y - 300, y + 300))
     call ShowUnit(death, true)
     call SetUnitFacingToFaceUnitTimed(death, u, 0)
     loop
      exitwhen alpha > 255
        call SetUnitVertexColor(death, 255, 255, 255, alpha)
        call TriggerSleepAction(0.03)
        set alpha=alpha + 17
     endloop
     
     call UnitChat("I come for your soul" , death)
     call TriggerSleepAction(3)
     call UnitChat("Are you ready?" , death)
     call TriggerSleepAction(1.5)
     call SetUnitFacingToFaceUnitTimed(u, udg_PHero[id], 0)
     call TriggerSleepAction(1)
     call UnitChat("..." , u)
     call TriggerSleepAction(3)
     call UnitChat("yes... I am" , u)
     call TriggerSleepAction(3)
     call UnitChat("I have nothing to do here..." , u)
     call DestroyEffect(AddSpecialEffectTarget(soulfx, u, "origin"))
     call TriggerSleepAction(2)
     call UnitChat("Good bye ..." , u)
     call FlushChildHashtable(questtm, GetHandleId(u))

     call TriggerSleepAction(0.7)
     
    
     call RemoveUnit(u)
     
     set u=null
     
      call SetUnitFacingToFaceUnitTimed(death, udg_PHero[id], 0)
      call TriggerSleepAction(1.5)
      
     set dfavor[id]=dfavor[id] + 1
     
     if ModuloInteger(dfavor[id], 4) == 0 then
      if dfavor[id] == 4 then
       call UnitChat("Do you know that you are doing a very good job here?" , death)
       call TriggerSleepAction(3)
       call UnitChat("me...?" , udg_PHero[id])
       call TriggerSleepAction(2)
       call UnitChat("Yes, you... Please don't act as surprised..." , death)
       call TriggerSleepAction(3)
       call UnitChat("You and me know that those people die because you let them die..." , death)
       call TriggerSleepAction(3)
       call UnitChat("That's not the truth..." , udg_PHero[id])
       call TriggerSleepAction(2)
       call UnitChat("Truth or not truth, I like people as you, |cffffcc00<Revenguers>|r of the death...ja ja ja" , death)
       call TriggerSleepAction(4)
       endif
       call UnitChat("I have a gift for you, please don't be afraid and choose any choice..." , death)
       call TriggerSleepAction(1)
      
      
       call UnitAddAbility(death, 'Asid') //select item
       call UnitAddAbility(death, 'Aneu') //select hero
       call UnitAddAbility(death, 'A0ED') //quest
       call sequencer(5)
       
       
            loop
                exitwhen i > 5
                call AddItemToStock(death, DeathItems[seq[i]], 1, 1)
                call TriggerSleepAction(0.03)
                set i=i + 1
                endloop
           
           set deathwait=0
           loop
           exitwhen deathwait > 60
           call TriggerSleepAction(0.35)
           set deathwait=deathwait + 1
           endloop
          
           set i=0
           loop
           exitwhen i > 5
            call RemoveItemFromStock(death, DeathItems[i])
            call TriggerSleepAction(0.03)
           set i=i + 1
           endloop
           call UnitRemoveAbility(death, 'Asid') //select item
           call UnitRemoveAbility(death, 'Aneu') //select hero
           call UnitRemoveAbility(death, 'A0ED') //quest
           
            call TriggerSleepAction(3)
           call UnitChat("I have to leave you, There's another soul that is waiting for me..." , death)
           call TriggerSleepAction(3)
           call UnitChat("See you later" , death)
      else
          call UnitChat("... :)" , death)
      endif
    // call UnitChat("Do you know that?... You are doing a very good job. je je je...",death)
     set alpha=255
        loop
      exitwhen alpha < 19
        call SetUnitVertexColor(death, 255, 255, 255, alpha)
        call TriggerSleepAction(0.03)
        set alpha=alpha - 17
     endloop
     
     call ShowUnit(death, false)
     set deathready=true
     
     call FlushChildHashtable(questtm, GetHandleId(trg))
     call DestroyTrigger(trg)
     set trg=null
     
  endif

set u=null
endfunction



function Trig_setupghost_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetSoldItem()) == 'I04T' )
endfunction



function Trig_setupghost_Actions takes nothing returns nothing
local unit s= GetSellingUnit()
//local integer id = GetPlayerId(GetOwningPlayer(GetManipulatingUnit()))
local integer id= GetPlayerId(GetTriggerPlayer())
local integer fid= id + 1

local integer target= GetUnitUserData(s)
local string name= LoadStr(questtm, GetHandleId(s), 12)
local integer diaga= 19
local integer diagb= 19
local integer tnumber= GetRandomInt(6, 14)
local integer level= GetUnitLevel(s)
local integer klevel= LoadInteger(questtm, GetHandleId(s), 13)
local integer rewardA= level * klevel * tnumber
local integer culpable= LoadInteger(questtm, GetHandleId(s), 15)
local integer asesinatos= LoadInteger(questtm, StringHash(name), culpable)
local integer tittle= GetRandomInt(1, 15)
local integer qdiagi= GetRandomInt(1, 10)
local integer qdiage= GetRandomInt(1, 8)
local integer questid

local trigger trg= CreateTrigger()


local string diagc= "A |cffffcc00" + name + "|r killed me, please consider my revenge killing |cffff4444" + I2S(tnumber) + "|r of them"
local string diagd= "If you succeed I will give you my last experience: (|cff5555ff+" + I2S(rewardA) + "|r) XP"


call TriggerSleepAction(0.2)

if udg_PHero[id] == null then
 set id=GetPlayerId(GetOwningPlayer(gclient))
 set fid=id + 1
 set gclient=null
endif
call RemoveItemFromStock(s, 'I04T')
call UnitRemoveAbility(s, 'A0ED')
set gquestindex=gquestindex + 1

 if asesinatos < 1 then
  set asesinatos=1
 else
  set asesinatos=asesinatos + 1
 endif
 call SaveInteger(questtm, StringHash(name), culpable, asesinatos)

 set ghostavenger[id]=ghostavenger[id] + 1
loop
exitwhen diaga != diagb

 set diagb=GetRandomInt(1, 19)
 set diaga=GetRandomInt(1, 19)
 call TriggerSleepAction(0.02)
 
endloop
call TriggerSleepAction(0.7)

call UnitChat(ghostlog[diaga] , s)
call TriggerSleepAction(3.5)
call UnitChat(ghostlog[diagb] , s)
call TriggerSleepAction(3.5)
call UnitChat(diagc , s)
call TriggerSleepAction(3.5)
call UnitChat(diagd , s)
call TriggerSleepAction(2)

 call StartSound(bj_questDiscoveredSound)
 set questid=SetupQuest(id , s , ghosttitle[tittle] , ghostqlog[qdiagi] + I2S(tnumber) + " " + name + ghostqblog[qdiage] + " " , "0" , "/" + I2S(tnumber) , 0 , s__qty[0])
 call SetUnitUserData(s, questid)
 call SaveInteger(questtm, GetHandleId(s), 14, rewardA)
 call SaveUnitHandle(questtm, GetHandleId(trg), 0, udg_PHero[id])
 call SaveUnitHandle(questtm, GetHandleId(trg), 1, s)
 
 call SaveInteger(questtm, StringHash(name), questid, fid) //asocio unidad, con quest y con player (sumo 1 porque puede generar error con player(0)
 //call SaveInteger(hts,StringHash(name),asesinatos,questid)
 //set ghostquest[gquestindex] = questid
// call SaveInteger(questtm,GetHandleId(udg_PHero(id),GetHandleId,id)
 
 
 set Qrequ[questid]=tnumber
 
   call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "|cffffcc00NEW QUEST DISCOVERED|r")
   call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "       |cff999999-" + ghostqlog[qdiagi] + I2S(tnumber) + " " + name + ghostqblog[qdiage] + "|r")
  
   
    call TriggerRegisterUnitInRange(trg, s, 255, Condition(function istrue))
    call TriggerAddCondition(trg, Condition(function trggc))
  //  call TriggerAddAction(trg,function trgga)

set s=null
set trg=null
set diagc=null
set diagd=null
endfunction

