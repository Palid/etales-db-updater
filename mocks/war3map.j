//===========================================================================
function InitTrig_setitemtype takes nothing returns nothing
    set gg_trg_setitemtype=CreateTrigger()
    call TriggerRegisterTimerEventSingle(gg_trg_setitemtype, 2.5)
    call TriggerAddAction(gg_trg_setitemtype, function Trig_setitemtype_Actions)
endfunction


