function Trig_Ogrepitfinal_Conditions takes nothing returns boolean
    return ( GetTriggerUnit() == udg_Ogre )
endfunction

function FinishedOgre takes integer id returns nothing
local location p= GetRectCenter(gg_rct_factionfinal2)
local unit u= udg_PHero[id]
           set udg_Ogre_pit_ocu=false
           set udg_unit_hunt_ogre=null
           call SetUnitPositionLoc(u, p)
           call SetUnitPositionLoc(udg_Slave[id], p)
           call SetUnitPositionLoc(udg_Familiar[id], p)
           call SetUnitPositionLoc(cslave[id], p)
           
           if PlayerInTest[id] == true then
           call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
           call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "QUEST DONE")
           call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Wolf's Fang Examn")
           call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Welcome to the Wolf's Fang Brotherhood.")
           call StartSound(bj_questCompletedSound)
           call RemoveAllQuestFromPlayer(id)
           call TriggerSleepAction(2)
           call UnitAddAbility(NextClass(id , u), 'A02L')
           call UnitMakeAbilityPermanent(udg_PHero[id], true, 'A02L')
           
           set udg_Faction[id]=2
           set PlayerInTest[id]=false
           endif
            
            call RemoveLocation(p)
            set p=null
          //  call TriggerExecute( gg_trg_ALLY )
endfunction


function Trig_Ogrepitfinal_Actions takes nothing returns nothing
 local unit Ogre= GetTriggerUnit()
