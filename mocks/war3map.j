// Trigger: kula Dream
//
// gg_unit_Eevi_0669
//===========================================================================
function Trig_kula_Dream_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A083' )
endfunction

function kend takes nothing returns nothing
local timer t= GetExpiredTimer()
local integer i= LoadInteger(udg_cache, GetHandleId(t), 3)
local destructable d= LoadDestructableHandle(udg_cache, GetHandleId(t), i + 5)
 local location p= Location(GetDestructableX(d), GetDestructableY(d))
 

  call RemoveDestructable(d)
   set i=i + 1
   call SaveInteger(udg_cache, GetHandleId(t), 3, i)
   if ( i == 61 ) then
    call PauseTimer(t)

    endif

set t=null
set d=null
call RemoveLocation(p)
set p=null
endfunction


function bucle takes nothing returns nothing
local timer t= GetExpiredTimer()
local destructable dt= null
local unit u= LoadUnitHandle(udg_cache, GetHandleId(t), 0)
local unit gu= null
local unit frz= null
local location p= LoadLocationHandle(udg_cache, GetHandleId(t), 1)
local location pt= null
local location pq= null
local group fg= LoadGroupHandle(udg_cache, GetHandleId(t), 6)
local group g= CreateGroup()
local integer id= GetPlayerId(GetOwningPlayer(u))
local real dist= 16
local real face= LoadReal(udg_cache, GetHandleId(t), 4)
local real scale= LoadReal(udg_cache, GetHandleId(t), 5)
local real x
local real y
local real bns= I2R(GetHeroInt(u, true))
local real dmg
local integer counter= LoadInteger(udg_cache, GetHandleId(t), 3)
local boolexpr istru= null
local real inspired= LoadReal(udg_cache, GetHandleId(t), 7)


set bns=bns * inspired + ( bns * udg_magicBonus[id] )
set counter=counter + 1
set scale=scale + 0.022
set dist=dist * counter
set x=GetLocationX(p) + dist * Cos(face * bj_DEGTORAD)
set y=GetLocationY(p) + dist * Sin(face * bj_DEGTORAD)

set pt=Location(x, y)

set x=GetLocationX(p) + ( dist + 40 + counter ) * Cos(face * bj_DEGTORAD)
set y=GetLocationY(p) + ( dist + 40 + counter ) * Sin(face * bj_DEGTORAD)

set pq=Location(x, y)


set dt=CreateDestructable('B015', GetLocationX(pt), GetLocationY(pt), GetRandomReal(0, 360), GetRandomReal(0.02, scale), 0)
 
//call CreateDestructableLoc( , pt, GetRandomDirectionDeg(),GetRandomReal(0.02,scale), 0 )
call SaveDestructableHandle(udg_cache, GetHandleId(t), counter + 5, dt)

set dt=null



if ( ModuloInteger(counter, 12) == 0 ) then

set bj_lastCreatedUbersplat=CreateUbersplat(GetLocationX(pq), GetLocationY(pq), "THND", 255, 255, 255, 255, false, false)
  // call CreateUbersplatBJ(pq, "THND", 100, 100, 100, 0, false, false )
 call SetUbersplatRenderAlways(bj_lastCreatedUbersplat, true)
//call DestroyEffect(AddSpecialEffectLoc("Abilities\\Spells\\Other\\Volcano\\VolcanoDeath.mdl",pq))

endif

if ( ModuloInteger(counter, 15) == 0 ) then
set istru=Condition(function bool)
 call GroupEnumUnitsInRangeOfLoc(g, pt, 200, istru)
 call DestroyBoolExpr(istru)
 set istru=null
//set g = GetUnitsInRangeOfLocMatching(300.00, pt,Condition(function bool))
loop

   set gu=FirstOfGroup(g)
   exitwhen gu == null
   if ( IsUnitEnemy(gu, GetOwningPlayer(u)) == true ) then
     
      set dmg=bns + bns * AddRacialBonus(gu , id)
     call DestroyEffect(AddSpecialEffectTarget("Abilities\\Weapons\\FrostWyrmMissile\\FrostWyrmMissile.mdl", gu, "chest"))
    // call UnitDamageTargetBJ(u, gu, 10, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL ) 
     call UnitDamageTarget(u, gu, dmg, true, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
     set frz=CreateUnitAtLoc(GetOwningPlayer(u), 'n03U', pq, 0)
    // call UnitRemoveAbility(frz,'Aloc') 
       call IssueTargetOrder(frz, "attack", gu)
    // call IssueTargetOrder( frz, "creepthunderbolt", gu )
    // call UnitAddAbility(frz,'Aloc') 
     call UnitApplyTimedLife(frz, 'BTLF', 3)
     
   // call SetUnitTimeScalePercent( gu, 0.00 )
    call SetUnitTimeScale(gu, 0.00)
    call GroupAddUnit(fg, gu)
   endif
   call GroupRemoveUnit(g, gu)
  // set gu = null
set frz=null
endloop

call DestroyGroup(g)
set g=null

endif


if ( counter == 60 ) then
call PauseTimer(t)
set counter=1
call SaveInteger(udg_cache, GetHandleId(t), 3, counter)
call TimerStart(t, 0.1, true, function kend)

else
  call SaveInteger(udg_cache, GetHandleId(t), 3, counter)
  call SaveReal(udg_cache, GetHandleId(t), 5, scale)
endif



set t=null
call RemoveLocation(pt)
set pt=null
call RemoveLocation(pq)
set pq=null

set p=null

set fg=null
set gu=null
call DestroyGroup(g)
set g=null
endfunction


function Trig_kula_Dream_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local location p= GetUnitLoc(u)
 local location target= GetSpellTargetLoc()
 local real face= GetUnitFacing(u)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer counter= 1
 local real scale= 0.8
 local integer i= 1
 local group fg= CreateGroup()
 local unit gu= null
 local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

 
  call TriggerSleepAction(0.5)
  set face=GetUnitFacing(u)
   call SaveUnitHandle(udg_cache, GetHandleId(t), 0, u)
   call SaveLocationHandle(udg_cache, GetHandleId(t), 1, p)
   call SaveInteger(udg_cache, GetHandleId(t), 3, counter)
   call SaveReal(udg_cache, GetHandleId(t), 4, face)
   call SaveReal(udg_cache, GetHandleId(t), 5, scale)
   call SaveGroupHandle(udg_cache, GetHandleId(t), 6, fg)
   call SaveReal(udg_cache, GetHandleId(t), 7, inspired)
   call PlaySoundOnUnitBJ(gg_snd_Frez, 100, GetTriggerUnit())
   call TimerStart(t, 0.01, true, function bucle)

   
  call TriggerSleepAction(7)
  call RemoveLocation(target)
  set target=null
  call RemoveLocation(p)
  set p=null

  
//set fg = LoadGroupHandle(udg_cache,GetHandleId(t),6) 
 
loop

   set gu=FirstOfGroup(fg)
   exitwhen gu == null
    call SetUnitTimeScale(gu, 1)
     if ( GetUnitState(gu, UNIT_STATE_LIFE) > 0.5 ) then
       call SetUnitAnimation(gu, "stand")
     endif
    call GroupRemoveUnit(fg, gu)
  // set gu = null
endloop
  
  
 call DestroyGroup(fg)
 set fg=null
 
 set gu=null
 
 call FlushChildHashtable(udg_cache, GetHandleId(t))
 
 call ReleaseTimer(t)
 set t=null

endfunction

//===========================================================================
function InitTrig_kula_Dream takes nothing returns nothing
    set gg_trg_kula_Dream=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_kula_Dream, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_kula_Dream, Condition(function Trig_kula_Dream_Conditions))
    call TriggerAddAction(gg_trg_kula_Dream, function Trig_kula_Dream_Actions)
endfunction
//===========================================================================
// Trigger: STL
//===========================================================================
function Trig_STL_Conditions takes nothing returns boolean
    return ( UnitHasBuffBJ(GetAttacker(), 'B011') == true )
endfunction

  function GetkeyS takes integer id returns integer
  if ( id == 1 or id == 23 or id == 45 or id == 68 or id == 91 or id == 114 or id == 137 or id == 158 or id == 181 or id == 204 or id == 227 or id == 250 or id == 273 or id == 296 or id == 319 or id == 342 or id == 365 or id == 388 or id == 411 or id == 434 or id == 457 or id == 480 or id == 502 or id == 525 or id == 547 or id == 570 or id == 593 or id == 616 or id == 639 or id == 662 ) then
    return GetRandomInt(id, id + 22)
endif
    return id
   endfunction
    
function IsNeutralS takes unit u returns boolean
    return ( GetOwningPlayer(u) == Player(PLAYER_IRNT_CULT) or GetOwningPlayer(u) == Player(PLAYER_NEUTRAL_AGGRESSIVE) or GetOwningPlayer(u) == Player(PLAYER_DARK_LORD) )
endfunction

function CreateDropS takes boolean rate,unit u,integer drop returns nothing
local real x= GetUnitX(u)
local real y= GetUnitY(u)

if ( rate ) then
 call CreateItem(udg_itmpool[GetkeyS(LoadInteger(HTcreep, GetUnitTypeId(u), drop))], GetRandomReal(x - 170, x + 170), GetRandomReal(y - 170, y + 170))
endif
endfunction


function DropsS takes unit u returns nothing
call CreateDropS(( GetRandomInt(0, 1000) < 500 ) , u , MEDIO_DROP)
call CreateDropS(( GetRandomInt(0, 1000) < 250 ) , u , TERCIO_DROP)
call CreateDropS(( GetRandomInt(0, 1000) < 125 ) , u , CUARTO_DROP)
call CreateDropS(( GetRandomInt(0, 1000) < 68 ) , u , QUINTO_DROP)
call CreateDropS(( GetRandomInt(0, 1000) < 34 ) , u , DECIMO_DROP)
call CreateDropS(( GetRandomInt(0, 1000) < 17 ) , u , CINCO_DROP)
call CreateDropS(( GetRandomInt(0, 1000) < 8 ) , u , UNO_DROP)



set u=null

endfunction


function Trig_STL_Actions takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local unit a= GetAttacker()
    local real level= 1
    local integer umb= 1
    local integer ran= GetRandomInt(1, 100)
    
    if ( GetUnitTypeId(GetAttacker()) == 'E004' ) then
    
     set level=11.5
    else
     set level=GetUnitAbilityLevel(GetAttacker(), 'A067')
    endif
    
    set umb=1 + R2I(3.5 * level)
    
    if ( ran < umb ) then
    
      if ( IsNeutralS(u) ) then
            call DropsS(u)
            call CreateTextTagUnitBJ("STEALTH ATTACK", a, 30, 9, 100, 100, 0, 0)
            call SetTextTagPermanent(GetLastCreatedTextTag(), false)
            call SetTextTagLifespan(GetLastCreatedTextTag(), 1.3)
            call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 100, 90)
            
     endif
    endif
    set u=null
    set a=null
endfunction

//===========================================================================
function InitTrig_STL takes nothing returns nothing
    set gg_trg_STL=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_STL, EVENT_PLAYER_UNIT_ATTACKED)
    call TriggerAddCondition(gg_trg_STL, Condition(function Trig_STL_Conditions))
    call TriggerAddAction(gg_trg_STL, function Trig_STL_Actions)
endfunction

