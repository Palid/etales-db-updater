//===========================================================================
// Trigger: IDR
//
// Dropped item remove
//===========================================================================
function Timeleft takes nothing returns nothing
 local item it= GetEnumItem()
 //local location p = Location(GetItemX(it), GetItemY(it)) 
 
  if ( GetItemTypeId(it) != 'I0F4' and GetItemTypeId(it) != 'I0L4' and it != Item ) then
    call SetItemUserData(it, ( GetItemUserData(it) + 1 ))
 
    
     if ( GetItemUserData(it) == 90 ) then
        call FlushChildHashtable(nodump, GetHandleId(it))
        call RemoveItem(it)
        set it=null
     endif
   endif

   set it=null

endfunction


function Trig_IDR_Actions takes nothing returns nothing
local boolexpr istru= Condition(function bool)
    call EnumItemsInRect(bj_mapInitialPlayableArea, istru, function Timeleft)
  call DestroyBoolExpr(istru)
  set istru=null
 endfunction

