//===========================================================================
// Trigger: bowlog
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function BLOC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0LZ' )
endfunction

function BLOG takes nothing returns nothing

 if ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'I0M0') == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I0M0')
      
        if ( GetItemCharges(udg_tmpitem) < 50 ) then
           call SetItemCharges(udg_tmpitem, ( GetItemCharges(udg_tmpitem) + 1 ))
        endif
       
        set udg_tmpitem=null
    else
        call UnitAddItemByIdSwapped('I0M0', GetTriggerUnit())
        call DisplayTimedTextToPlayer(GetTriggerPlayer(), 0, 0, bj_TEXT_DELAY_ITEMACQUIRED, "|cffffcc00ITEM ACQUIRED")
        call DisplayTimedTextToPlayer(GetTriggerPlayer(), 0, 0, bj_TEXT_DELAY_ITEMACQUIRED, "Received Bows Wood log")
       call StartSound(bj_questItemAcquiredSound)

        
    endif
 
    
endfunction

//===========================================================================
function InitTrig_bowlog takes nothing returns nothing
    set gg_trg_bowlog=CreateTrigger()
    call DisableTrigger(gg_trg_bowlog)
