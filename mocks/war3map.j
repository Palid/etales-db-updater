//===========================================================================
// Trigger: activeghost
//===========================================================================
//TESH.scrollpos=24
//TESH.alwaysfold=0
function activeghost takes nothing returns nothing
local unit l__died= GetDyingUnit()
local integer utype= GetUnitTypeId(l__died)
local real x= GetUnitX(l__died)
local real y= GetUnitY(l__died)
local unit u= null
local unit k= GetKillingUnit()
local integer vpoint= GetUnitPointValue(k)
local integer ktype= GetUnitTypeId(k)
local string name= GetUnitName(k)
local integer klevel= GetUnitLevel(k)
local integer pkid= GetPlayerId(GetOwningPlayer(k))

    call UnitRemoveAbility(l__died, newquest) //visuals

if GetUnitUserData(l__died) == 2222 then
    call TravelerKilled(l__died)
   endif
set l__died=null
//call TriggerSleepAction(120)
call TriggerSleepAction(90)
set u=CreateUnit(Player(10), utype, x, y, GetRandomReal(0, 355))
if vpoint < 201 then

call SetUnitUserData(u, ktype)

call SaveStr(questtm, GetHandleId(u), 12, name)
call SaveInteger(questtm, GetHandleId(u), 13, klevel)
call SaveInteger(questtm, GetHandleId(u), 15, pkid)

call UnitAddAbility(u, 'A0EF') //select hero
call UnitAddAbility(u, 'Asid') //sell items
call UnitAddAbility(u, 'A0ED') //quest
call UnitAddAbility(u, 'Avul') //invulnerable
call UnitAddAbility(u, 'Agho') //ghost
call UnitAddType(u, UNIT_TYPE_PEON)
call SetUnitAcquireRange(u, 20)

call TriggerSleepAction(0.03)

 call AddItemToStock(u, 'I04T', 1, 1) //avengue me
 call SetUnitVertexColor(u, 255, 255, 255, 90) // old 255,255,255,90
 call TriggerSleepAction(0.03)
 endif
 set u=null
 set k=null
 set name=null
 set utype=0
 set ktype=0
 
endfunction

//===========================================================================
function InitTrig_activeghost takes nothing returns nothing
    set gg_trg_activeghost=CreateTrigger()
    call TriggerAddAction(gg_trg_activeghost, function activeghost)
endfunction


//===========================================================================
// Trigger: initquest
//===========================================================================
function tquestc takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I04R' ) //profanator
endfunction

function tquesta takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  if isprofanator[id] == false then
   set isprofanator[id]=true
   set tombreq[id]=( GetPlayerTechCount(Player(id), 'R009', true) * 5 ) + 5
   call UnitChat("You have chosen a beatifull way, take care of undead monsters" , gg_unit_n06T_0260)
   call TriggerSleepAction(3)
   call UnitChat("They can appear from those opened tombs" , gg_unit_n06T_0260)
   call TriggerSleepAction(3)
   call UnitChat("Come back here when you be ready" , gg_unit_n06T_0260)
   
   call StartSound(bj_questDiscoveredSound)
   set tombqid[id]=SetupQuest(id , gg_unit_n06T_0260 , "TOMB PROFANATORS" , "Find and open tombs around Enthashara " , "0" , "/" + I2S(tombreq[id]) , 0 , s__qty[0])
     
   call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "|cffffcc00NEW QUEST DISCOVERED|r")
   call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "   Find and open |cffffcc00" + I2S(tombreq[id]) + " sarcophagus|r around Enthashara")
   call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "   |cffffccbbRemember that, tomb activated by another player doesn't count for you|r")
   elseif Qdata[tombqid[id]] < tombreq[id] then
    call UnitChat("Hey man, you have job undone. Finish your quest!" , gg_unit_n06T_0260)
   endif
endfunction

//===========================================================================
function InitTrig_initquest takes nothing returns nothing
    set gg_trg_initquest=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_initquest, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_initquest, Condition(function tquestc))
    call TriggerAddAction(gg_trg_initquest, function tquesta)
endfunction


//===========================================================================
// Trigger: finishquest
//===========================================================================
function Trig_finishquest_Conditions takes nothing returns boolean
    return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and isprofanator[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == true )
endfunction

function Trig_finishquest_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer xp

 if Qdata[tombqid[id]] >= tombreq[id] then
    call UnitChat("God job man. Take your reward!" , gg_unit_n06T_0260)
    call TriggerSleepAction(1)
    
    set isprofanator[id]=false
    set xp=( GetPlayerTechCount(Player(id), 'R009', true) + 1 ) * 2000
    
    call UnitAddItemById(udg_PHero[id], udg_itmpool[57]) //manual
    call AddHeroXP(udg_PHero[id], xp, false)
    
    call StartSound(bj_questCompletedSound)
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: TOMB PROFANATOR|r")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "   Opened all tombs required for your profanator's level!")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "   you get |cffbbbbff+" + I2S(xp) + "|r experience!")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "   you get |cffffcc00Profanator's Manual|r!")
    
     call UpdatePersQuestND(id , tombqid[id] , Qdata[tombqid[id]] , "-" , I2S(Qdata[tombqid[id]]) , "-")
     call TriggerSleepAction(0.02)
     call RemoveQuestFromPlayer(tombqid[id] , id)
     set tombreq[id]=0
     set tombqid[id]=0
     
     
  endif

endfunction

//===========================================================================
function InitTrig_finishquest takes nothing returns nothing
    set gg_trg_finishquest=CreateTrigger()
    call TriggerRegisterUnitInRangeSimple(gg_trg_finishquest, 256, gg_unit_n06T_0260)
    call TriggerAddCondition(gg_trg_finishquest, Condition(function Trig_finishquest_Conditions))
    call TriggerAddAction(gg_trg_finishquest, function Trig_finishquest_Actions)
endfunction


//===========================================================================
// Trigger: enablezombi
//===========================================================================
function Trig_enablezombi_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and Player(10) != GetOwningPlayer(GetTriggerUnit())
endfunction

function orderzombi takes nothing returns nothing
call ShowUnit(GetEnumUnit(), true)
call SaveGroupHandle(questtm, GetHandleId(GetEnumUnit()), 10, zombieg[11])
call IssueTargetOrder(GetEnumUnit(), "attack", gg_unit_h02W_0595)
endfunction


function Trig_enablezombi_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 
  call DisableTrigger(gg_trg_enablezombi)
  call ForGroup(zombieg[11], function orderzombi)
  call TriggerSleepAction(0.5)
  
  if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call PanCameraToTimed(- 10980, 3540, 1)
  endif
    
  loop
   exitwhen CountUnitsInGroup(zombieg[11]) < 1
   call TriggerSleepAction(1)
  endloop
  call TriggerSleepAction(1)
  call UnitChat("Those damn monsters..." , gg_unit_h02W_0595)
  call TriggerSleepAction(3)
  call UnitChat("Someone is playing with their damned souls..." , gg_unit_h02W_0595)
  call UnitAddAbility(gg_unit_h02W_0595, newquest)
  call AddItemToStock(gg_unit_h02W_0595, 'I04N', 1, 1) //zombi quests
  
  call DestroyGroup(zombieg[11])
  
endfunction

//===========================================================================
function InitTrig_enablezombi takes nothing returns nothing
    set gg_trg_enablezombi=CreateTrigger()
   
    call TriggerRegisterUnitInRangeSimple(gg_trg_enablezombi, 1500.00, gg_unit_h02W_0595)
    call TriggerAddCondition(gg_trg_enablezombi, Condition(function Trig_enablezombi_Conditions))
    call TriggerAddAction(gg_trg_enablezombi, function Trig_enablezombi_Actions)
endfunction


//===========================================================================
// Trigger: newzgroup
//===========================================================================
function Trig_newzgroup_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I04N' )
endfunction

function setupzomb takes nothing returns nothing

call SaveGroupHandle(questtm, GetHandleId(GetEnumUnit()), 10, zombieg[tmpid])
call SaveInteger(questtm, GetHandleId(GetEnumUnit()), 11, tmpid)
endfunction



function Trig_newzgroup_Actions takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetManipulatingUnit()))
  local integer rz= GetRandomInt(1, 6)
  local real x= GetRectCenterX(zrect[rz])
  local real y= GetRectCenterY(zrect[rz])
  local integer questid
  
  
   //zombie rect id
  
   if haszombi[id] == true then
   
       if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
       endif
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Velhilmen's Lietunant says:|r")
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " Those zombies are alive... kill them all!!")
       return
   elseif GetUnitLevel(udg_PHero[id]) > 32 then
       if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
       endif
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Velhilmen's Lietunant says:|r")
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " We don't need your help. (Max level = 32)")
       return
   
   else
    
   
   
    
    set zleader[id]=CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), zlead, x, y, 270)
    
    call GroupAddUnit(zombieg[id], zleader[id])
    call TriggerSleepAction(0.1)
    call GroupAddUnit(zombieg[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), zretu, x, y, 180))
    call TriggerSleepAction(0.1)
    call GroupAddUnit(zombieg[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), zretu, x, y, 0))
    call TriggerSleepAction(0.1)
    call GroupAddUnit(zombieg[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), zzomb, x, y, 45))
    call TriggerSleepAction(0.1)
    call GroupAddUnit(zombieg[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), zzomb, x, y, 135))
    call TriggerSleepAction(0.1)
    call GroupAddUnit(zombieg[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), zzomb, x, y, 225))
    call TriggerSleepAction(0.1)
    call GroupAddUnit(zombieg[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), zzomb, x, y, 315))
    call TriggerSleepAction(0.1)
    
    set haszombi[id]=true
    set tmpid=id
    call ForGroup(zombieg[id], function setupzomb)
    
       if ( GetLocalPlayer() == Player(id) ) then
         
          call PingMinimapEx(x, y, 7, 255, 255, 50, false)
       endif
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Velhilmen's Lietunant says:|r")
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " A new zombie group has been seen, kill them all!!")
       set questid=SetupQuest(id , gg_unit_h02W_0595 , "THOSE WALKING DEADS" , "Exterminate the group of zombies " , "0" , "/7" , 0 , s__qty[0])
       call SaveInteger(questtm, GetHandleId(zombieg[id]), 1, questid) //guardo id de quest en el grupo
    
   endif
  
  loop
   exitwhen CountUnitsInGroup(zombieg[id]) < 1
   call TriggerSleepAction(2)
  endloop
  set haszombi[id]=false
  
  if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
          
  endif
  call StartSound(bj_questCompletedSound)
   
  if zkilled[id] > 6 then
  
       
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Message from Velhilmen's Lietunant:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " Well done hero, take your reward: |cffaaaaff+5000 XP|r!!")
  call AddHeroXP(udg_PHero[id], 5000, false)
  else
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Message from Velhilmen's Lietunant:|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " Good job hero, you cleaned it!!")
  endif
  
  call UpdatePersQuestND(id , questid , zkilled[id] , "-" , I2S(zkilled[id]) , "-")
  call TriggerSleepAction(0.02)
  call RemoveQuestFromPlayer(questid , id)
 // call UpdatePersQuestND(id,questid,zkilled[id],"-",I2S(zkilled[id]),"-")
  
  set zkilled[id]=0
 // set zombieg[id] = null
  set zleader[id]=null
  set tmpid=20 //no player id
  
endfunction

