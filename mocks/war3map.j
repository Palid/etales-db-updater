        //  call SetInfo(id, 8, 1,col1,R2S(destr_drop_per)+"%")
       
           call SetInfo(id , 9 , 0 , col0 , "Faction:")
           call SetInfo(id , 9 , 1 , col1 , udg_Factionname[udg_Faction[id]])
  
