 local real x= 19840
 local real y= 15930
 

 call FinishedOgre(id)
 call TriggerSleepAction(2)

 set udg_Ogre=CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), GetUnitTypeId(Ogre), x, y, 270)
 set Ogre=null
 
endfunction

