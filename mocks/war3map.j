//===========================================================================
function bmaskc takes nothing returns boolean
    return ( RectContainsUnit(gg_rct_reinhard, GetTriggerUnit()) == true and GetItemTypeId(GetManipulatedItem()) == 'I080' )
endfunction

function bmaska takes nothing returns nothing
 local item bmask= GetManipulatedItem()
 
 call TriggerSleepAction(0.2)
 
  call IssueTargetItemOrder(reinhard, "smart", bmask)
 call TriggerSleepAction(1)
  set bmask=null
endfunction

//===========================================================================
function InitTrig_collectbmask takes nothing returns nothing
    local integer i= 0
    
     loop
        set trgbmask[i]=CreateTrigger()
        call DisableTrigger(trgbmask[i])
        
        call TriggerRegisterPlayerUnitEvent(trgbmask[i], Player(i), EVENT_PLAYER_UNIT_DROP_ITEM, Condition(function btrue))
     
        call TriggerAddCondition(trgbmask[i], Condition(function bmaskc))
        call TriggerAddAction(trgbmask[i], function bmaska)
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
     endloop
    
endfunction


