// Trigger: mercinrange
//===========================================================================
function merc_in_range takes nothing returns boolean
  local integer questid
  local unit target
  local real dx
  local real dy
  local integer i= GetRandomInt(0, 9)
  
  if GetOwningPlayer(GetTriggerUnit()) == Player(PLAYER_NEUTRAL_PASSIVE) and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetTriggerUnit() != death then
    
  set questid=GetUnitUserData(GetTriggerUnit())
  
  set target=udg_PHero[QPid[questid]]
  set dx=GetUnitX(target) - GetUnitX(GetTriggerUnit())
  set dy=GetUnitY(target) - GetUnitY(GetTriggerUnit())
     if SquareRoot(dx * dx + dy * dy) < 950 then
   //  call SaveUnitHandle(questtm,GetHandleId(gg_trg_mercinrange),questid,null)
        call SetUnitOwner(GetTriggerUnit(), Player(PLAYER_DARK_LORD), true)
        call StartSound(bj_questUpdatedSound)
        call UnitChat(mercdiag[i] , GetTriggerUnit())
        //call DisplayTimedTextToPlayer(Player(QPid[questid]),.1,0,6,"|cffffcc00BEWARE!!!  A slayer is close to you|r" )
     endif
 endif
    set target=null
    return false
    
    endfunction


