//===========================================================================
// Trigger: intimidator
//===========================================================================
//TESH.scrollpos=15
//TESH.alwaysfold=0
function trcc takes nothing returns boolean
 return GetUnitTypeId(GetTriggerUnit()) == 'O003' or GetUnitAbilityLevel(GetTriggerUnit(), 'A0C3') > 2
   // return (IsUnitAlly(GetAttacker(), GetOwningPlayer(GetTriggerUnit())) == true)
endfunction

function trac takes nothing returns nothing
local unit a= GetAttacker()
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer r= 1000 / GetUnitLevel(a)
local integer t= GetRandomInt(1, 100)


 local real face= GetUnitFacing(a) - 180
 local real x= GetUnitX(a)
 local real y= GetUnitY(a)
 local real x2= x + 450 * Cos(face * bj_DEGTORAD)
 local real y2= y + 450 * Sin(face * bj_DEGTORAD)


call DisableTrigger(trint[id])

if t < r then
 
  
 
  //  call IssueImmediateOrder( GetAttacker(), "stop" )
    call IssuePointOrder(a, "move", x2, y2)
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\TalkToMe\\TalkToMe.mdl", a, "head"))

endif




    set a=null

call TriggerSleepAction(0.5)
call EnableTrigger(trint[id])

endfunction

//===========================================================================
function InitTrig_intimidator takes nothing returns nothing
  //  local trigger tr = CreateTrigger()
    local integer index
    set index=0
    loop
        set trint[index]=CreateTrigger()
        call TriggerRegisterPlayerUnitEvent(trint[index], Player(index), EVENT_PLAYER_UNIT_ATTACKED, Condition(function bool))
        call TriggerAddCondition(trint[index], Condition(function trcc))
        call TriggerAddAction(trint[index], function trac)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    //    call TriggerRegisterAnyUnitEventBJ( gg_trg_intimidator, EVENT_PLAYER_UNIT_ATTACKED )
 
endfunction


//===========================================================================
// Trigger: Berserk
//
// IBerserk impulse
//===========================================================================


function GetXY takes location p returns boolean
 local real x= GetLocationX(p)
 local real y= GetLocationY(p)


return ( ( x > GetRectMaxX(bj_mapInitialPlayableArea) ) or ( x < GetRectMinX(bj_mapInitialPlayableArea) ) or ( y > GetRectMaxY(bj_mapInitialPlayableArea) ) or ( y < GetRectMaxY(bj_mapInitialPlayableArea) ) )

endfunction



function FCC takes nothing returns boolean
    return GetSpellAbilityId() == 'A0BL' or GetSpellAbilityId() == 'A0C6'
endfunction


function IB_BUCLE takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 4)
    local real dist= LoadReal(hts, GetHandleId(t), 5)
    local boolean s= LoadBoolean(hts, GetHandleId(t), 2)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    local real xi= LoadReal(hts, GetHandleId(t), 3) + inc
    local real inspired= LoadReal(hts, GetHandleId(t), 11)
    local real h= GetParabolaZ(xi , dist , 500)
    //local real h = GetParabolaZ(xi,dist,330)
    local integer id= GetPlayerId(GetOwningPlayer(u))
  // local unit dummy
    local group g= null
    local unit gu= null
    local real dmg= ( ( I2R(GetHeroAgi(u, true)) * 1.3 + I2R(GetHeroStr(u, true)) * 0.7 ) * berserkdmgbonus[id] )
    local real fdmg
    local boolexpr istru= Condition(function bool)
    set inc=( inc - 1 )
  
    call SetUnitPathing(u, false)
    call SetUnitFlyHeight(u, h, 0)
    
  //  if GetXY(p1) then
 //   set p1 = p
  //  endif
    set dmg=dmg * inspired
  
if ( IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) == false ) then
 set p1=p
endif

    call SetUnitPositionLoc(u, p1)

    if ( h < 0 and s == false ) then
     set s=true
     call DestroyEffect(AddSpecialEffectLocBJ(p1, "Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl"))
     
     
set g=GetUnitsInRangeOfLocMatching(300.00, p1, istru)
call DestroyBoolExpr(istru)
set istru=null
loop

   set gu=FirstOfGroup(g)
   exitwhen gu == null
   if IsUnitEnemy(gu, GetOwningPlayer(u)) then
     
     set fdmg=dmg + dmg * AddRacialBonus(gu , id)
     
     call UnitDamageTarget(u, gu, fdmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
     set bj_lastCreatedUnit=CreateUnitAtLoc(GetOwningPlayer(u), 'n059', p1, 0)
     call IssueTargetOrder(bj_lastCreatedUnit, "creepthunderbolt", gu)
     call UnitApplyTimedLife(bj_lastCreatedUnit, 'BTLF', 3)
     
   // call SetUnitTimeScalePercent( gu, 0.00 )
    
   endif
   call GroupRemoveUnit(g, gu)
   set gu=null
endloop

call DestroyGroup(g)
    set g=null
     
      //set dummy = CreateUnit(Player(id),'n059',GetUnitX(u),GetUnitY(u),90)

     //call IssueImmediateOrder(dummy, "stomp" )
     //call UnitApplyTimedLifeBJ( 1.00, 'BTLF', dummy )
  
    //set dummy = null
      
      
    endif
 
    call RemoveLocation(p)
    set p=null
    call RemoveLocation(p1)
    set p1=null
    call SaveBoolean(hts, GetHandleId(t), 2, s)
    call SaveReal(hts, GetHandleId(t), 4, inc)
    call SaveReal(hts, GetHandleId(t), 3, xi)

    set u=null
    //set dist = 0
    set xi=0
    set h=0


   set t=null
  // call ReleaseTimer(t)
 endfunction


function FCA takes nothing returns nothing
   
 local unit u= GetTriggerUnit()
 local location p= GetSpellTargetLoc()
 local location q= GetUnitLoc(u)
 local real face= bj_RADTODEG * Atan2(GetLocationY(p) - GetLocationY(q), GetLocationX(p) - GetLocationX(q))
 local real dx=  GetLocationX(p) - GetLocationX(q)
 local real dy= GetLocationY(p) - GetLocationY(q)
 local real dist= SquareRoot(dx * dx + dy * dy)
  
 local timer t= (NewTimerEx(0)) // INLINED!!
 
 local real inc
 local real xi= 1
 local integer id= GetPlayerId(GetOwningPlayer(u))

 local boolean s= false
 local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
  endif

 
 
 
 if dist < 480 then
 set dist=480
 endif
 
 //set inc = (dist/60)+ 31
 set inc=( dist / 30 ) + 14.5

   call DestroyEffect(AddSpecialEffectLoc(seffectjump, q))
   call SaveUnitHandle(hts, GetHandleId(t), 0, u)
   call SaveReal(hts, GetHandleId(t), 1, face)
   call SaveBoolean(hts, GetHandleId(t), 2, s)
   call SaveReal(hts, GetHandleId(t), 3, xi)
   call SaveReal(hts, GetHandleId(t), 4, inc)
   call SaveReal(hts, GetHandleId(t), 5, dist)
   call SaveReal(hts, GetHandleId(t), 11, inspired)
   
   //call SetUnitVertexColor(u,55,55,55,70)

   
   call SetUnitPathing(u, false)
 //   call CreateUbersplatBJ(q, "THND", 100, 100, 100, 0, false, false )
 //   call SetUbersplatRenderAlways( GetLastCreatedUbersplat(), true )
  
  //  call SetUnitFacing(u, face + 90)
  
  call UnitAddAbilityBJ('Amrf', u)
  call UnitRemoveAbilityBJ('Amrf', u)
 // call SetCameraTargetControllerNoZForPlayer( GetOwningPlayer(u), u, 0, 0, false )
   
  call TimerStart(t, 0.02, true, function IB_BUCLE)
  call SetUnitAnimationByIndex(u, 2)

   call TriggerSleepAction(0.6)

   call SetUnitFacing(u, face)
   call FlushChildHashtable(hts, GetHandleId(t))
   call PauseTimer(t)
   call ReleaseTimer(t)
   set t=null
   call SetUnitFlyHeight(u, 0, 0)
   
    if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call CameraSetTargetNoiseEx(30 * 2.0, 60 * Pow(10, 4), true)
         call CameraSetSourceNoiseEx(30 * 2.0, 60 * Pow(10, 4), true)
    endif
      
    call TriggerSleepAction(0.05)
   if ( GetLocalPlayer() == Player(id) ) then
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
    endif

call TriggerSleepAction(0.1)
 call SetUnitPathing(u, true)
  call RemoveLocation(p)
  set p=null
  call RemoveLocation(q)
  set q=null
  set u=null
endfunction


//===========================================================================
function InitTrig_Berserk takes nothing returns nothing
    set gg_trg_Berserk=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Berserk, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Berserk, Condition(function FCC))
    call TriggerAddAction(gg_trg_Berserk, function FCA)
endfunction


//===========================================================================
// Trigger: Bcombo
//===========================================================================
//TESH.scrollpos=16
//TESH.alwaysfold=0

function CheckCombo takes integer id returns nothing

if ( berserkcombo[id] == true ) then
  if ( ( berserkcomboA[id] - berserkcomboB[id] ) > 1 ) then
  set berserkcomboB[id]=berserkcomboA[id]
  else

  set berserkcomboB[id]=0
  set berserkcomboA[id]=0
  set berserkdmgbonus[id]=1
  set berserkcombo[id]=false
  endif
endif
endfunction


function Trig_Bcombo_Actions takes nothing returns nothing
local integer i= 0

loop
 exitwhen i > 14
  call CheckCombo(i)
 set i=i + 1
 endloop



endfunction

//===========================================================================
function InitTrig_Bcombo takes nothing returns nothing
    set gg_trg_Bcombo=CreateTrigger()
    call TriggerRegisterTimerEventPeriodic(gg_trg_Bcombo, 2.0)
    call TriggerAddAction(gg_trg_Bcombo, function Trig_Bcombo_Actions)
endfunction


//===========================================================================
// Trigger: Bcombost
//===========================================================================
//TESH.scrollpos=45
//TESH.alwaysfold=0
function Trig_Bcombost_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == 'O003' )
endfunction

function CheckSpell takes nothing returns boolean
local boolean iscombo= false

if GetSpellAbilityId() == 'A0BK' then //tacle
 return true
elseif GetSpellAbilityId() == 'A0BJ' then //sword dance
 return true
elseif GetSpellAbilityId() == 'A0BI' then //wolf bite
 return true
elseif GetSpellAbilityId() == 'A0BM' then //wolf claw
 return true
elseif GetSpellAbilityId() == 'A0C6' then //berserk impulse
 return true
elseif GetSpellAbilityId() == 'A0BH' then //bruta break
 return true

 endif
return false
endfunction

 function ShowCombo takes integer id returns nothing
 
  //local integer id = GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  if berserkcomboA[id] > 2 then

    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
     call DisplayTimedTextToPlayer(Player(id), .95, 1, 1.5, "|cffffcc00" + I2S(berserkcomboA[id]) + "x|r |cffffa005KOMBO |cffffa005+" + I2S(R2I(berserkdmgbonus[id] * 100) - 99) + "% OVERKILL|r")
    endif
 endfunction


function Trig_Bcombost_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
if CheckSpell() == true then
 set berserkcombo[id]=true
 set berserkcomboA[id]=berserkcomboA[id] + 1
endif

 if ( berserkcomboA[id] > 2 ) then
 set berserkdmgbonus[id]=berserkdmgbonus[id] + 0.05
 endif
 call ShowCombo(id)
endfunction

//===========================================================================
function InitTrig_Bcombost takes nothing returns nothing
local integer i= 0
    set gg_trg_Bcombost=CreateTrigger()
        loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_Bcombost, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function bool))
       
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
 //   call TriggerRegisterAnyUnitEventBJ( gg_trg_Bcombost, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition(gg_trg_Bcombost, Condition(function Trig_Bcombost_Conditions))
    call TriggerAddAction(gg_trg_Bcombost, function Trig_Bcombost_Actions)
endfunction


//===========================================================================
// Trigger: Wolf bite
//
// Impact bolt
//===========================================================================
//TESH.scrollpos=124
//TESH.alwaysfold=0


function GetXXY takes location p returns boolean
 local real x= GetLocationX(p)
 local real y= GetLocationY(p)


return ( ( x > GetRectMaxX(bj_mapInitialPlayableArea) ) or ( x < GetRectMinX(bj_mapInitialPlayableArea) ) or ( y > GetRectMaxY(bj_mapInitialPlayableArea) ) or ( y < GetRectMaxY(bj_mapInitialPlayableArea) ) )

endfunction



function wolfb takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 4)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    
    
    set inc=inc / 1.1
  
    call SetUnitPathing(u, false)
 
   if IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) then
    call SetUnitPositionLoc(u, p1)
    endif

    //call SetUnitPositionLoc( u, p1 )
   

    
    call RemoveLocation(p)
    call RemoveLocation(p1)
    call SaveReal(hts, GetHandleId(t), 4, inc)
    
    set u=null
    set t=null
  
 endfunction



function SSC takes nothing returns boolean
    return GetSpellAbilityId() == 'A0BM'
endfunction


function SSB takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
    local unit wolf= LoadUnitHandle(hts, GetHandleId(t), 6)
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 4)
    local boolean s= LoadBoolean(hts, GetHandleId(t), 2)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    local real xi= LoadReal(hts, GetHandleId(t), 3) + inc
    local integer prc= LoadInteger(hts, GetHandleId(t), 5) + 12
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local unit dummy= null

    
    set inc=inc / 1.2
  
    call SetUnitPathing(u, false)
   
    
  //  if GetXY(p1) then
 //   set p1 = p
  //  endif
    //call SetUnitVertexColor(u,prc,prc,prc,prc)
    if IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) then
    call SetUnitPositionLoc(u, p1)
    endif

    call SetUnitVertexColor(wolf, prc, prc, prc, prc)
    
    if IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) then
    call SetUnitPositionLoc(wolf, p1)
    endif
    //call SetUnitPositionLoc(wolf, p1 )
   
   

    if ( inc < 0 and s == false ) then
    
     call IssueImmediateOrder(dummy, "stomp")
     call UnitApplyTimedLifeBJ(1.00, 'BTLF', dummy)
  
   set dummy=null
      
      
    endif
 
    call RemoveLocation(p)
    call RemoveLocation(p1)
    call SaveBoolean(hts, GetHandleId(t), 2, s)
    call SaveInteger(hts, GetHandleId(t), 5, prc)
    call SaveReal(hts, GetHandleId(t), 4, inc)
    call SaveReal(hts, GetHandleId(t), 3, xi)
    set u=null
    set wolf=null
    //set dist = 0
    set xi=0
 


   set t=null
  // call ReleaseTimer(t)
 endfunction


function SSA takes nothing returns nothing
   
 local unit u= GetTriggerUnit()
 local unit a= GetSpellTargetUnit()

 local integer id= GetPlayerId(GetOwningPlayer(u))
 local location p= GetSpellTargetLoc()
 local location q= GetUnitLoc(u)
 local real face= bj_RADTODEG * Atan2(GetLocationY(p) - GetLocationY(q), GetLocationX(p) - GetLocationX(q))
 local timer t= (NewTimerEx(0)) // INLINED!!
 local timer tc= (NewTimerEx(0)) // INLINED!!
 local integer dist= 9000
 local real inc= 40
 local real xi= 1
 local integer prc= 1
 local boolean s= false
 local unit wolf
 local real fdmg= ( I2R(GetHeroStr(u, true)) * 3 ) * berserkdmgbonus[id]
 local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
  endif
   
   set fdmg=fdmg * inspired
   set fdmg=fdmg + fdmg * AddRacialBonus(a , id)

    call SetUnitVertexColor(u, 0, 0, 0, 0)


   set wolf=CreateUnit(Player(id), 'o00A', GetUnitX(u), GetUnitY(u), face)
   call SetUnitVertexColor(wolf, 255, 255, 255, 0)
   call SetUnitAnimationByIndex(wolf, 2)
   call SetUnitPathing(u, false)

   call SaveUnitHandle(hts, GetHandleId(t), 0, u)
   call SaveReal(hts, GetHandleId(t), 1, face)
   call SaveBoolean(hts, GetHandleId(t), 2, s)
   call SaveReal(hts, GetHandleId(t), 3, xi)
   call SaveReal(hts, GetHandleId(t), 4, inc)
   call SaveInteger(hts, GetHandleId(t), 5, prc)
   call SaveUnitHandle(hts, GetHandleId(t), 6, wolf)
   
   call SaveUnitHandle(hts, GetHandleId(tc), 0, a)
   call SaveReal(hts, GetHandleId(tc), 1, face)
   call SaveReal(hts, GetHandleId(tc), 4, 20)
   
  call TimerStart(t, 0.02, true, function SSB)
 call DisableTrigger(gg_trg_DMG)
  
 //  call TriggerSleepAction(0.02)
   call TimerStart(tc, 0.02, true, function wolfb)
  call TriggerSleepAction(0.06)
  call DestroyEffect(AddSpecialEffectTarget(sffectpunch, a, "origin"))
  call EnableTrigger(gg_trg_DMG)
  call UnitDamageTarget(u, a, fdmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
        if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call CameraSetTargetNoiseEx(20 * 2.0, 20 * Pow(10, 4), true)
         call CameraSetSourceNoiseEx(20 * 2.0, 20 * Pow(10, 4), true)
    endif
  call TriggerSleepAction(0.05)
      if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
    endif
     call TriggerSleepAction(0.19)
   
   
  call RemoveUnit(wolf)
  set wolf=null
   call SetUnitFacing(u, face)
  call FlushChildHashtable(hts, GetHandleId(t))
   call PauseTimer(t)
   call ReleaseTimer(t)
   set t=null
   call TriggerSleepAction(0.02)
   call FlushChildHashtable(hts, GetHandleId(tc))
   call PauseTimer(tc)
   call ReleaseTimer(tc)
   set tc=null
   
    call RemoveLocation(p)
    set p=null
 call RemoveLocation(q)
 set q=null
 call SetUnitVertexColor(u, 255, 255, 255, 255)
call SetUnitPathing(u, true)
call SetUnitPathing(a, true)

set u=null
set a=null
 
endfunction


//===========================================================================
function InitTrig_Wolf_bite takes nothing returns nothing
    set gg_trg_Wolf_bite=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Wolf_bite, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Wolf_bite, Condition(function SSC))
    call TriggerAddAction(gg_trg_Wolf_bite, function SSA)
endfunction


//===========================================================================
// Trigger: tacle
//
// Impact bolt
//===========================================================================


function GetXXYY takes location p returns boolean
 local real x= GetLocationX(p)
 local real y= GetLocationY(p)


return ( ( x > GetRectMaxX(bj_mapInitialPlayableArea) ) or ( x < GetRectMinX(bj_mapInitialPlayableArea) ) or ( y > GetRectMaxY(bj_mapInitialPlayableArea) ) or ( y < GetRectMaxY(bj_mapInitialPlayableArea) ) )

endfunction




function TACC takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0BK' or GetSpellAbilityId() == 'A0BY' or GetSpellAbilityId() == 'A0C8' )
endfunction

function TACU takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 4)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    
    
    set inc=inc - 1
  
    call SetUnitPathing(u, false)
 
  
      
if IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) then
    call SetUnitPositionLoc(u, p1)
endif
    

   

    
    call RemoveLocation(p)
    set p=null
    call RemoveLocation(p1)
    set p1=null
    call SaveReal(hts, GetHandleId(t), 4, inc)
    
    set u=null
    set t=null
  
 endfunction



function TACB takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 4)
    local boolean s= LoadBoolean(hts, GetHandleId(t), 2)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    local real xi= LoadReal(hts, GetHandleId(t), 3) + inc
    local integer prc= LoadInteger(hts, GetHandleId(t), 5) + 17
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local unit dummy= null

    
    set inc=inc - 2
  
    call SetUnitPathing(u, false)
   
    
  //  if GetXY(p1) then
 //   set p1 = p
  //  endif
    call SetUnitVertexColor(u, prc, prc, prc, prc)
    
      
if IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) then
    call SetUnitPositionLoc(u, p1)
endif
    

   

    if ( inc < 0 and s == false ) then
    
     call IssueImmediateOrder(dummy, "stomp")
     call UnitApplyTimedLifeBJ(1.00, 'BTLF', dummy)
  
   set dummy=null
      
      
    endif
 
    call RemoveLocation(p)
    set p=null
    call RemoveLocation(p1)
    set p1=null
    call SaveBoolean(hts, GetHandleId(t), 2, s)
    call SaveInteger(hts, GetHandleId(t), 5, prc)
    call SaveReal(hts, GetHandleId(t), 4, inc)
    call SaveReal(hts, GetHandleId(t), 3, xi)
    set u=null
    //set dist = 0
    set xi=0
 


   set t=null
  // call ReleaseTimer(t)
 endfunction


function TACA takes nothing returns nothing
   
 local unit u= GetTriggerUnit()
 local unit a= GetSpellTargetUnit()
 local location p= GetSpellTargetLoc()
 local location q= GetUnitLoc(u)
 local real face= bj_RADTODEG * Atan2(GetLocationY(p) - GetLocationY(q), GetLocationX(p) - GetLocationX(q))
 local timer t= (NewTimerEx(0)) // INLINED!!
 local timer tc= (NewTimerEx(0)) // INLINED!!

 local real dx=  GetLocationX(p) - GetLocationX(q)
 local real dy= GetLocationY(p) - GetLocationY(q)
 local real dist= SquareRoot(dx * dx + dy * dy)

 local real dmg= 0
 local real inc
 local real xi= 1
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local integer prc= 1
 local boolean s= false
 local effect sfx
 local destructable dest
 local real inspired= 1
 local real l__cdist= GetCameraField(CAMERA_FIELD_TARGET_DISTANCE)

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
  endif
 

if dist < 150 then
 set dist=150
 endif
 
 //if (GetSpellAbilityId()=='A0BY') then
 // set dmg = I2R(GetHeroAgi(u,true)) * (dist/400 -(20*GetUnitAbilityLevel(u,'A0BY')))
 //else
  set dmg=( I2R(GetHeroAgi(u, true)) * ( dist / 150 ) * berserkdmgbonus[id] ) * inspired
 //endif
 
  
 set inc=( dist / 15 ) + 8
 

   call SaveUnitHandle(hts, GetHandleId(t), 0, u)
   call SaveReal(hts, GetHandleId(t), 1, face)
   call SaveBoolean(hts, GetHandleId(t), 2, s)
   call SaveReal(hts, GetHandleId(t), 3, xi)
   call SaveReal(hts, GetHandleId(t), 4, inc)
      call SaveInteger(hts, GetHandleId(t), 5, prc)
   //apara el segundo timer
   call SaveUnitHandle(hts, GetHandleId(tc), 0, a)
   call SaveReal(hts, GetHandleId(tc), 1, face)
   call SaveReal(hts, GetHandleId(tc), 4, 20)
   
   //call SetUnitVertexColor(u,55,55,55,70)
  
   set sfx=AddSpecialEffectTarget(sffectfire, u, "weapon")
  // call SetUnitAnimationByIndex(u,2)
 
  // call SetUnitFacing(u, face - 90)
 call DestroyEffect(AddSpecialEffectLoc(seffectjump, q))
   call SetUnitVertexColor(u, 0, 0, 0, 0)
    call SetUnitPathing(u, false)
 // call SetCameraTargetControllerNoZForPlayer( GetOwningPlayer(u), u, 0, 0, false )
   
  call TimerStart(t, 0.02, true, function TACB)
 

   call TriggerSleepAction(0.26)
   if udg_rpgc[GetPlayerId(GetOwningPlayer(u))] == false then
    // call ResetToGameCameraForPlayer(GetOwningPlayer(u), 0 )
    // call SetCameraFieldForPlayer(GetOwningPlayer(u),CAMERA_FIELD_TARGET_DISTANCE,cdist,0)
  endif
  
  
  
  
   //call DestroyEffect(AddSpecialEffectLocBJ(GetUnitLoc(u), "Abilities\\Spells\\Orc\\MirrorImage\\MirrorImageCaster.mdl" ))  
   set dmg=dmg + dmg * AddRacialBonus(a , id)
   
   set dest=CreateDestructable('B01G', GetUnitX(u), GetUnitY(u), face - 180, 0.5, 0)
   call UnitDamageTarget(u, a, dmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)

   call SetUnitAnimation(a, "death")
   call DestroyEffect(AddSpecialEffectTarget(seffectb, a, "chest"))
   call TimerStart(tc, 0.02, true, function TACU)
   call TriggerSleepAction(0.04)
   call SetUnitFacing(u, face)
   call FlushChildHashtable(hts, GetHandleId(t))
   call PauseTimer(t)
   call ReleaseTimer(t)
   set t=null
 call TriggerSleepAction(0.1)
call FlushChildHashtable(hts, GetHandleId(tc))
 call PauseTimer(tc)
 call ReleaseTimer(tc)
 set tc=null
 call SetUnitPathing(a, true)
   
 call SetUnitPathing(u, true)
 call RemoveLocation(p)
 set p=null
 call RemoveLocation(q)
 set q=null
 call TriggerSleepAction(0.5)
 if ( GetUnitState(a, UNIT_STATE_LIFE) > 1 ) then
   call SetUnitAnimation(a, "stand")
 endif
 call RemoveDestructable(dest)
 set dest=null
 call DestroyEffect(sfx)
 set sfx=null
 
 call TriggerSleepAction(0.1)
 
 
 call SetUnitVertexColor(u, 255, 255, 255, 255)
 set u=null
 set a=null
endfunction


//===========================================================================
function InitTrig_tacle takes nothing returns nothing
    set gg_trg_tacle=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_tacle, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_tacle, Condition(function TACC))
    call TriggerAddAction(gg_trg_tacle, function TACA)
endfunction


//===========================================================================
// Trigger: Sabredance
//===========================================================================
function Trig_drt_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0BJ' )
endfunction


function sdfilters takes nothing returns boolean
    return ( IsPlayerEnemy(GetOwningPlayer(GetTriggerUnit()), GetOwningPlayer(GetFilterUnit())) == true )
endfunction

function Trig_drt_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local real x= GetUnitX(u)
local real y= GetUnitY(u)

local group g= CreateGroup()
local integer gc
local unit gu
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer Sdmg= ( GetHeroStr(u, true) * 120 ) / 40
local integer Admg= ( GetHeroAgi(u, true) * 80 ) / 30
local integer tdmg= Sdmg + Admg
local real fdmg= I2R(tdmg) * berserkdmgbonus[id]
local real ffdmg
local boolexpr istru= Condition(function sdfilters)
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
  endif

  set fdmg=fdmg * inspired
  
 call SetUnitAnimationByIndex(u, 9)
 call GroupEnumUnitsInRange(g, x, y, 250, istru)
 call DestroyBoolExpr(istru)
 set istru=null

 
 

 loop

 
 set gu=FirstOfGroup(g)
  exitwhen gu == null
  set ffdmg=fdmg + fdmg * AddRacialBonus(gu , id)
  call DestroyEffect(AddSpecialEffectTarget(seffect, gu, "chest"))
  call UnitDamageTarget(u, gu, ffdmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
 
  call GroupRemoveUnit(g, gu)

 endloop
  
   
 
 call SetUnitAnimationByIndex(u, 11)
 call TriggerSleepAction(0.3)
 call SetUnitAnimation(u, "stand")
   
   call DestroyGroup(g)
   set g=null
   set u=null
   set gu=null

endfunction

//===========================================================================
function InitTrig_Sabredance takes nothing returns nothing
    set gg_trg_Sabredance=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Sabredance, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Sabredance, Condition(function Trig_drt_Conditions))
    call TriggerAddAction(gg_trg_Sabredance, function Trig_drt_Actions)
endfunction


//===========================================================================
// Trigger: Shadowclaw
//===========================================================================
function SCCC takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0BI' or GetSpellAbilityId() == 'A0C2' )
endfunction

function settr takes nothing returns nothing
  local timer t= GetExpiredTimer()
  local integer tr= LoadInteger(hts, GetHandleId(t), 0) + 12
  local unit dummy= LoadUnitHandle(hts, GetHandleId(t), 1)

  call SetUnitVertexColor(dummy, 255, 255, 255, tr)
  
  call SaveInteger(hts, GetHandleId(t), 0, tr)
  
  set t=null
  set dummy=null
  
endfunction



function SCCA takes nothing returns nothing
local unit u= GetTriggerUnit()
local unit gu= GetSpellTargetUnit()
local real face= GetUnitFacing(u)
local integer id= GetPlayerId(GetOwningPlayer(u))
local unit dummy
local timer t= (NewTimerEx(0)) // INLINED!!
local real Sdmg= GetHeroStr(u, true) * 3
local real Admg= GetHeroAgi(u, true) * 4.5
local real tdmg= Sdmg + Admg
local real fdmg= tdmg * berserkdmgbonus[id]
local integer tr= 0
local integer idmg
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
  endif

  set fdmg=fdmg * inspired

  

call SaveInteger(hts, GetHandleId(t), 0, tr)

call SetUnitVertexColor(u, 255, 255, 255, tr)
call SetUnitPathing(u, false)
//call TimerStart(t,0.02, true, function settr) 

set dummy=CreateUnit(Player(id), 'o00A', GetUnitX(u), GetUnitY(u), face)
call SetUnitVertexColor(dummy, 255, 255, 255, 0)
call SetUnitAnimationByIndex(dummy, 8)
call SaveUnitHandle(hts, GetHandleId(t), 1, dummy)

call TimerStart(t, 0.02, true, function settr)
call TriggerSleepAction(0.1)



  set fdmg=fdmg + fdmg * AddRacialBonus(gu , id)

call DestroyEffect(AddSpecialEffectTarget(seffect, gu, "head"))
      call DisableTrigger(gg_trg_DMG)
      call EnableTrigger(gg_trg_SPDMG)
      call UnitDamageTarget(u, gu, fdmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)

      call DisableTrigger(gg_trg_SPDMG)
      call EnableTrigger(gg_trg_DMG)
      set idmg=R2I(spelldmg[id])
     

call SetUnitFacing(gu, face + 140)
call TriggerSleepAction(0.15)
call DestroyEffect(AddSpecialEffectTarget(seffect, gu, "chest"))

    call DisableTrigger(gg_trg_DMG)
    call EnableTrigger(gg_trg_SPDMG)
call UnitDamageTarget(u, gu, fdmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
      call DisableTrigger(gg_trg_SPDMG)
      call EnableTrigger(gg_trg_DMG)
      set idmg=idmg + R2I(spelldmg[id])

     call SpellDmgText(idmg , gu)
     set spelldmg[id]=0
 
 
call SetUnitFacing(gu, face + 220)
call TriggerSleepAction(0.2)
call RemoveUnit(dummy)
set dummy=null
call FlushChildHashtable(hts, GetHandleId(t))
call ReleaseTimer(t)
set t=null

//call TriggerSleepAction(0.1)  
call SetUnitVertexColor(u, 255, 255, 255, 255)
call SetUnitPathing(u, true)

set u=null
set gu=null

endfunction

//===========================================================================
function InitTrig_Shadowclaw takes nothing returns nothing
    set gg_trg_Shadowclaw=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Shadowclaw, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Shadowclaw, Condition(function SCCC))
    call TriggerAddAction(gg_trg_Shadowclaw, function SCCA)
endfunction


//===========================================================================
// Trigger: BrutalBreak
//===========================================================================
function Trig_BrutalBreak_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0BH' )
endfunction

function BRUTU takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
  
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 4)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    
    
    set inc=inc - 1.5
  
    call SetUnitPathing(u, false)
 
  if IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) then
    call SetUnitPositionLoc(u, p1)
endif
    
   // call SetUnitPositionLoc( u, p1 )
   

    
    call RemoveLocation(p)
    call RemoveLocation(p1)
    call SaveReal(hts, GetHandleId(t), 4, inc)
    
    set u=null
    set t=null
  
 endfunction


function filters takes nothing returns boolean
    return ( IsPlayerEnemy(GetOwningPlayer(GetTriggerUnit()), GetOwningPlayer(GetFilterUnit())) == true and GetUnitState(GetFilterUnit(), UNIT_STATE_LIFE) > 0 )
endfunction

function Trig_BrutalBreak_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local group g= CreateGroup()
 local integer gc
 local unit gu
 local location q= GetUnitLoc(u)
 local location p
 local real array face
 local timer array t
 local integer tc

 local real dx
 local real dy
 local real dist

 
 local real array inc
 //local boolexpr bfilter = Condition( function filters)
 
 
 call SetUnitAnimationByIndex(u, 9)
 call GroupEnumUnitsInRange(g, x, y, 300, Condition(function filters))
// call DestroyBoolExpr(bfilter)
//set bfilter = null
 
 
 
 
 set bj_groupCountUnits=0
  call ForGroup(g, function CountUnitsInGroupEnum)
 set gc=bj_groupCountUnits
 set tc=gc
 

      
  call TriggerSleepAction(0.05)
  call CreateUbersplatBJ(q, "THND", 100, 100, 100, 0, false, false)
  call SetUbersplatRenderAlways(GetLastCreatedUbersplat(), true)
  
  
      if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
       //  call CameraSetTargetNoiseEx(50*2.0, 60*Pow(10,4),true)
        // call CameraSetSourceNoiseEx(50*2.0, 60*Pow(10,4),true)
    endif
 loop
 exitwhen gc < 1
 
 set gu=FirstOfGroup(g)
 set p=GetUnitLoc(gu)
 set dx=GetLocationX(p) - GetLocationX(q)
 set dy=GetLocationY(p) - GetLocationY(q)
 set dist=575 - SquareRoot(dx * dx + dy * dy)
 set face[gc]=bj_RADTODEG * Atan2(dy, dx)
 
 set t[gc]=(NewTimerEx(0)) // INLINED!!
 set inc[gc]=( dist / 15 ) + 8
 
 //call CreateTextTagLocBJ( I2S(gc), p, 0, 10, 100, 100, 100, 0 )
 
   call SaveUnitHandle(hts, GetHandleId(t[gc]), 0, gu)
   call SaveReal(hts, GetHandleId(t[gc]), 1, face[gc])
  // call SaveReal(hts,GetHandleId(t[gc]),2,dist[gc]) 
   call SaveReal(hts, GetHandleId(t[gc]), 4, inc[gc])

  call DestroyEffect(AddSpecialEffectTarget(sffectdusta, gu, "origin"))

 call TimerStart(t[gc], 0.02, true, function BRUTU)
 call SetUnitAnimation(gu, "death")
 call GroupRemoveUnit(g, gu)
 set gc=gc - 1
 endloop
 
 call TriggerSleepAction(0.1)
 
  if ( GetLocalPlayer() == Player(id) ) then
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
    endif
 
 
 call TriggerSleepAction(0.15)
 
 loop
 exitwhen tc < 1
   set gu=LoadUnitHandle(hts, GetHandleId(t[tc]), 0)
   call SetUnitPathing(gu, true)
   call FlushChildHashtable(hts, GetHandleId(t[tc]))
   call PauseTimer(t[tc])
   call ReleaseTimer(t[tc])
   set t[tc]=null
 
 set tc=tc - 1
 endloop
 
 call RemoveLocation(p)
 set p=null
 call RemoveLocation(q)
 set q=null
 call DestroyGroup(g)
 set g=null
 set gu=null
 
call TriggerSleepAction(0.3)
//call SetUnitAnimation(u, "stand" )
set u=null
endfunction

