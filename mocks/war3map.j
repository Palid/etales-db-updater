            call RemoveItemFromStock(udg_MAVault[id], 'I0MJ')
            call AddItemToStock(udg_MAVault[id], 'I0MJ', onix[id], onix[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
            call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I07P' then //santas hat//70r//70d//70pvp
            if ( rubi[id] >= 70 and GemVar_A[id] >= 70 and diamond[id] >= 70 ) then
            set itm=CreateItem('I06N', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
            set rubi[id]=rubi[id] - 70
            set GemVar_A[id]=GemVar_A[id] - 70
            set diamond[id]=diamond[id] - 70
            call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
            call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0MK')
            call AddItemToStock(udg_MAVault[id], 'I0MK', rubi[id], rubi[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
            call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I07N' then //mighty helm executioner//100pvp//150d
            if ( GemVar_A[id] >= 100 and diamond[id] >= 150 ) then
            set itm=CreateItem('I06H', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
           
            set GemVar_A[id]=GemVar_A[id] - 100
            set diamond[id]=diamond[id] - 150
            call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
            call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
            call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
            call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
            else
                call notjewels(id)
             endif
 elseif GetItemTypeId(it) == 'I07M' then //headbands//25s//25e
            if ( emerald[id] >= 15 and saphire[id] >= 15 ) then
            set itm=CreateItem('I06F', x, y) //rare chest
            call UnitAddItem(GetTriggerUnit(), itm)
  
            set saphire[id]=saphire[id] - 15
            set emerald[id]=emerald[id] - 15
            call RemoveItemFromStock(udg_MAVault[id], 'I0MM')
