//===========================================================================
// Trigger: valdiviatsetup
//
// call RegionAddRect(mainculver,
//===========================================================================
//===========================================================================
// Trigger: activeincident
//
//   call TriggerSleepAction(2) 
//   call UnitChat("Well, I'm not allowed to talk about it, Lieutenant Ankit is in charge...",scoutguard)
//   call MakeFaceToUnit(scoutguard,u)
//===========================================================================
function Trig_activeincident_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetPlayerController(GetOwningPlayer(GetTriggerUnit())) == MAP_CONTROL_USER
endfunction

function movescouts takes nothing returns nothing
call IssuePointOrder(GetEnumUnit(), "move", GetUnitX(scoutguard), GetUnitY(scoutguard))
endfunction


function Trig_activeincident_Actions takes nothing returns nothing
  local unit u= GetTriggerUnit()
  local integer id= GetPlayerId(GetOwningPlayer(u))
   call DisableTrigger(gg_trg_activeincident)

 
  call UnitChat("Hey you, take care of yourself, there are some rare things happening in these fields" , scoutguard)
  call MakeFaceToUnit(scoutguard , u)
  call TriggerSleepAction(3)
   call UnitChat("What happened here?" , u)
  call MakeFaceToUnit(u , scoutguard)
 
 if GetHeroLevel(u) < 39 then
  call TriggerSleepAction(3)
  call UnitChat("Well, I'm not allowed to talk about it, Please follow your way..." , scoutguard)
  call MakeFaceToUnit(scoutguard , u)
  call TriggerSleepAction(4)
  call SetUnitFacing(scoutguard, 270)
  call TriggerSleepAction(15)
  call EnableTrigger(gg_trg_activeincident)
 else
  
          call TriggerSleepAction(3)
          call UnitChat("Well, I'm not allowed to talk about it, Lieutenant Ankit is in charge..." , scoutguard)
          call MakeFaceToUnit(scoutguard , u)
          call TriggerSleepAction(3)

          set vguard=CreateGroup()
          call GroupEnumUnitsOfType(vguard, UnitId2String('h037'), Condition(function gtrue)) //raider
          call GroupAddUnit(vguard, ankit)
          call GroupRemoveUnit(vguard, scoutguard)
          call ForGroup(vguard, function movescouts)
          
          
          call UnitChat("Buf if you told me to take care, I need to know about what..." , u)
          call MakeFaceToUnit(u , scoutguard)
          call TriggerSleepAction(4)
          call UnitChat("Uhm, people says that the centaurs come in the night, their home is in north of here.." , scoutguard)
          call MakeFaceToUnit(scoutguard , u)
          call TriggerSleepAction(4)
          call UnitChat("Well I can defend myself if I'm involved in problems....." , u)
          call MakeFaceToUnit(u , scoutguard)
          call TriggerSleepAction(3)
          call UnitChat("Lieutenant Ankit is coming here, maybe he has work for you, if you want.." , scoutguard)
          call MakeFaceToUnit(scoutguard , u)
  endif
  
  set u=null
 endfunction

