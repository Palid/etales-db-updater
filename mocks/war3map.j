function RemoveQuestFromPlayer takes integer index,integer id returns nothing
local integer i= 0
local integer q= 0

loop
 exitwhen i > 10
  set q=LoadInteger(questtm, GetHandleId(Player(id)), i) //extraigo las ids de las quests guardadas en el handle del player
  // call DisplayTimedTextToPlayer(Player(id),.1,0,4,I2S(q))
 if q == index then
   call SaveInteger(questtm, GetHandleId(Player(id)), i, 0) //Desactivo la index de la quest para el jugador cambiandola por 0
   set questr_Buffer[id]=QTitle[q] //guardo el valor de la quest[index] en el buffer para mostrarla como terminada

  endif
 set i=i + 1
 endloop

//call ManagePersQuest(id) 
set questr_Done[id]=questr_Buffer[id] + "|r  |cff00ccff[Finished]|r" //marcada como finalizada

endfunction


function RemoveAllQuestFromPlayer takes integer id returns nothing
local integer i= 0
local integer q= 0

loop
 exitwhen i > 10
  set q=LoadInteger(questtm, GetHandleId(Player(id)), i) //extraigo las ids de las quests guardadas en el handle del player
  // call DisplayTimedTextToPlayer(Player(id),.1,0,4,I2S(q))
 call SaveInteger(questtm, GetHandleId(Player(id)), i, 0) //Desactivo la index de la quest para el jugador cambiandola por 0
 set questr_Buffer[id]=QTitle[q] //guardo el valor de la quest[index] en el buffer para mostrarla como terminada
 
 set i=i + 1
 endloop

call ManagePersQuest(id)
set questr_Done[id]=questr_Buffer[id] + "|r  |cff00ccff[Complete]|r" //marcada como finalizada

endfunction


function EraseIndexQuest takes integer index,integer id returns string

if index == 1 then
       set questr_Buffer[id]=null
       set questr_1[id]=null
 elseif index == 2 then
       set questr_Buffer[id]=questr_2[id]
       set questr_2[id]=null
 elseif index == 3 then
       set questr_Buffer[id]=questr_3[id]
       set questr_3[id]=null
 elseif index == 4 then
       set questr_Buffer[id]=questr_4[id]
       set questr_4[id]=null
 elseif index == 5 then
       set questr_Buffer[id]=questr_5[id]
       set questr_5[id]=null
endif

set questIndex[id]=questIndex[id] - 1
return questr_Buffer[id]

endfunction


//it asummes that the quest unit only has one quest for a hero at the same time.
function MarkQuestDone takes integer id,unit questunit returns nothing

local integer index= LoadInteger(udg_cache, GetHandleId(questunit), GetHandleId(udg_PHero[id]))
local string donequest= null

if index == 1 then
       set donequest=questr_1[id]
       set questr_1[id]=EraseIndexQuest(questIndex[id] , id)
           
 elseif index == 2 then
       set donequest=questr_2[id]
       set questr_2[id]=EraseIndexQuest(questIndex[id] , id)
 elseif index == 3 then
       set donequest=questr_3[id]
       set questr_3[id]=EraseIndexQuest(questIndex[id] , id)
 elseif index == 4 then
       set donequest=questr_4[id]
       set questr_4[id]=EraseIndexQuest(questIndex[id] , id)
 elseif index == 5 then
       set donequest=questr_5[id]
       set questr_5[id]=EraseIndexQuest(questIndex[id] , id)
 endif

 set questr_Done[id]="         |cff00ccffDone|r -" + donequest
 

endfunction

function SetupQuest takes integer id,unit u,string title,string log,string currentreq,string Totalreq,integer data,string qtype returns integer
local integer slot= 0
 set Qindex=Qindex + 1
 set QPid[Qindex]=id
 set QUid[Qindex]=u
 set QTitle[Qindex]=title
 set QSid[Qindex]=log
 set QSidx[Qindex]=currentreq
 set QSidy[Qindex]=Totalreq
 set Qdata[Qindex]=data
 set Qtype[Qindex]=qtype
 set Qreward[Qindex]=" "
 
 set slot=ManagePersQuest(id)
 call SaveInteger(questtm, GetHandleId(Player(id)), slot, Qindex)
 call ManagePersQuest(id)
 
 call UnitChat("New quest registered!" , udg_Slave[id])
 return Qindex
endfunction


function AddRacialBonus takes unit u,integer id returns real
local real bonus= 0
   //racial [1]0000  2: human  3:undead 4:orc 5:hero 6:Elite 7:Ancient 8: boss
   if GetUnitRace(u) == RACE_ORC and s__PlayerRacial[(id)*(10)+4] == true then
       set bonus=bonus + 0.2
   elseif GetUnitRace(u) == RACE_HUMAN and s__PlayerRacial[(id)*(10)+2] == true then
       set bonus=bonus + 0.2
   endif
   
   if IsUnitType(u, UNIT_TYPE_ANCIENT) == true and s__PlayerRacial[(id)*(10)+7] == true then
      set bonus=bonus + 0.2
   elseif IsUnitType(u, UNIT_TYPE_HERO) == true and s__PlayerRacial[(id)*(10)+5] == true then
       set bonus=bonus + 0.2
   elseif IsUnitType(u, UNIT_TYPE_UNDEAD) == true and s__PlayerRacial[(id)*(10)+3] == true then
       set bonus=bonus + 0.2
   endif

   
   if GetUnitPointValue(u) == 300 and s__PlayerRacial[(id)*(10)+8] == true then //boss
      set bonus=bonus + 0.2
   elseif GetUnitPointValue(u) == 200 and s__PlayerRacial[(id)*(10)+6] == true then //Elite
      set bonus=bonus + 0.2
  endif
  
  return bonus
   
endfunction

function GetRacial takes integer itid returns integer
   return LoadInteger(udg_itempoolhash, itid, 2) / 10000
endfunction

function GetAdvanced takes integer itid returns integer
   return ModuloInteger(LoadInteger(udg_itempoolhash, itid, 2), 10)
endfunction

function NoRacialLeft takes integer id,integer racial returns boolean

  set s__PlayerRacialCount[(id)*(10)+racial]= s__PlayerRacialCount[(id)*(10)+racial] - 1
  if s__PlayerRacialCount[(id)*(10)+racial] < 1 then
     return true
  endif
  
  return false
  
endfunction


function NoAdvancedLeft takes integer id,integer adv returns boolean

  set s__AdvancedBonuscount[(id)*(4)+adv]= s__AdvancedBonuscount[(id)*(4)+adv] - 1
  if s__AdvancedBonuscount[(id)*(4)+adv] < 1 then
     return true
  endif
  
  return false
  
endfunction


function MiscAct takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local item it= GetManipulatedItem()
 local integer unitlevel= GetUnitLevel(u)
 local integer misclevel= GetItemLevel(it)
 local integer reqLevel= misclevel / 1000
 local integer level= ModuloInteger(misclevel, 1000)

 local integer i= 1
 local integer mset= level / 10
 local integer count= LoadInteger(HTsets, GetHandleId(u), level)
 local integer racial= 0
 local integer advanced= 0
 
 if IsUnitType(u, UNIT_TYPE_HERO) == true then
        if unitlevel < reqLevel then
            call UnitChat("|cffffcc00My level isn't enought for this item|r" , u)
            call UnitRemoveItem(u, GetManipulatedItem())
            set u=null
            set it=null
            return
        endif
        
        if level > 160 then
        
              set racial=(LoadInteger(udg_itempoolhash, (GetItemTypeId(it)), 2) / 10000) // INLINED!!
              
             if racial > 1 then
               set s__PlayerRacial[(id)*(10)+racial]= true
               set s__PlayerRacialCount[(id)*(10)+racial]= s__PlayerRacialCount[(id)*(10)+racial] + 1
              endif
             
              set advanced=(ModuloInteger(LoadInteger(udg_itempoolhash, (GetItemTypeId(it)), 2), 10)) // INLINED!!
              
              if advanced == 1 then
              
                set s__AdvancedBonuscount[(id)*(4)+1]= s__AdvancedBonuscount[(id)*(4)+1] + 1 //sumo un articulo con el mismo bono 
             
                if s__AdvancedBonus[(id)*(4)+1] == false then // me aseguro de que el bono solo se asgina una vez
                    set s__Mstrength[id]= s__Mstrength[id] + 322
                    set s__AdvancedBonus[(id)*(4)+1]= true
                endif
                
              elseif advanced == 2 then
                 set s__AdvancedBonuscount[(id)*(4)+2]= s__AdvancedBonuscount[(id)*(4)+2] + 1
                   if s__AdvancedBonus[(id)*(4)+2] == false then
                    set s__Fortune[id]= s__Fortune[id] + 322
                    set s__AdvancedBonus[(id)*(4)+2]= true
                   endif
              elseif advanced == 3 then
               set s__AdvancedBonuscount[(id)*(4)+3]= s__AdvancedBonuscount[(id)*(4)+3] + 1
              
                   if s__AdvancedBonus[(id)*(4)+3] == false then
                        set s__Constitution[id]= s__Constitution[id] + 322
                        set s__AdvancedBonus[(id)*(4)+3]= true
                    endif
              elseif advanced == 4 then
               set s__AdvancedBonuscount[(id)*(4)+4]= s__AdvancedBonuscount[(id)*(4)+4] + 1
              
                   if s__AdvancedBonus[(id)*(4)+4] == false then
                        set s__Constitution[id]= s__Constitution[id] + 322
                        set s__Fortune[id]= s__Fortune[id] + 322
                        set s__Mstrength[id]= s__Mstrength[id] + 322
                        set s__AdvancedBonus[(id)*(4)+4]= true
                    endif
              endif
         
         
        endif
        
        
        
        
 elseif GetUnitPointValue(u) == 334 and GetHeroLevel(udg_PHero[id]) < reqLevel then
 
        call UnitChat("|cffffcc00low level...|r" , u)
        call UnitRemoveItem(u, GetManipulatedItem())
        set u=null
        set it=null
        return
  endif

        set count=count + 1
        call SaveInteger(HTsets, GetHandleId(u), level, count) //guardo el nivel para reconocerlo luego
        call SaveItemHandle(HTsets, GetHandleId(u), level + 400, it) //reservo 200 posiciones y luego guardo los handles
        set mset=mset * 10
 
  loop
      exitwhen i > 5
          set miscset___st[i]=LoadInteger(HTsets, GetHandleId(u), mset + i)
      set i=i + 1
 endloop

 // call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"it level " + I2S(level) + " mset" + I2S(mset) + " count" + I2S(count)) 
   
  if ( miscset___st[1] > 0 and miscset___st[2] > 0 and miscset___st[3] > 0 and miscset___st[4] > 0 and miscset___st[5] < 1 ) then
  
  
      call RemoveItem(LoadItemHandle(HTsets, GetHandleId(u), mset + 401))
      call RemoveItem(LoadItemHandle(HTsets, GetHandleId(u), mset + 402))
      call RemoveItem(LoadItemHandle(HTsets, GetHandleId(u), mset + 403))
      call RemoveItem(LoadItemHandle(HTsets, GetHandleId(u), mset + 404))
  
    set miscset___st[1]=0
    set miscset___st[2]=0
    set miscset___st[3]=0
    set miscset___st[4]=0
    set miscset___st[5]=0
   call SaveInteger(HTsets, GetHandleId(u), mset + 1, 0)
   call SaveInteger(HTsets, GetHandleId(u), mset + 2, 0)
   call SaveInteger(HTsets, GetHandleId(u), mset + 3, 0)
   call SaveInteger(HTsets, GetHandleId(u), mset + 4, 0)
   call SaveInteger(HTsets, GetHandleId(u), mset + 5, 0)
  
 //call UnitRemoveItem(u,LoadItemHandle(HTsets,GetHandleId(u),mset+201))
 //call UnitRemoveItem(u,LoadItemHandle(HTsets,GetHandleId(u),mset+202))
 // call UnitRemoveItem(u,LoadItemHandle(HTsets,GetHandleId(u),mset+203))
 // call UnitRemoveItem(u,LoadItemHandle(HTsets,GetHandleId(u),mset+204))

        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Items\\AIem\\AIemTarget.mdl", u, "origin"))
        call UnitAddItemById(u, udg_Sets[mset + 5]) //creo el set
  endif

    set u=null
    set it=null
 endfunction
   
 function MiscDrop takes nothing returns nothing
  local unit u= GetTriggerUnit()
  local integer unitlevel= GetUnitLevel(u)
  local integer id= GetPlayerId(GetOwningPlayer(u))
  local item it= GetManipulatedItem()
  local integer level= ModuloInteger(GetItemLevel(it), 1000)
  local integer misclevel= GetItemLevel(it)
  local integer reqLevel= misclevel / 1000
  local integer count= LoadInteger(HTsets, GetHandleId(u), level)
  local integer racial= 0
  local integer advanced= 0
  
  
  if unitlevel < reqLevel then
       set u=null
       set it=null
       return
  endif
  
  
 if ( count > 0 ) then
  set count=count - 1
 else
  set count=0
 endif
  
  call SaveInteger(HTsets, GetHandleId(u), level, count)
  call RemoveSavedHandle(HTsets, GetHandleId(u), level + 400) //reservo 200 posiciones y luego guardo los handles
       
 
 
    if IsUnitType(u, UNIT_TYPE_HERO) == true and level > 160 then

  
        
              set racial=(LoadInteger(udg_itempoolhash, (GetItemTypeId(it)), 2) / 10000) // INLINED!!
              
              if NoRacialLeft(id , racial) == true then
                set s__PlayerRacial[(id)*(10)+racial]= false
              endif
             
              set advanced=(ModuloInteger(LoadInteger(udg_itempoolhash, (GetItemTypeId(it)), 2), 10)) // INLINED!!
              
              if advanced > 0 then
              
                  if NoAdvancedLeft(id , advanced) == true then
                  
                      if advanced == 1 then
                        set s__Mstrength[id]= s__Mstrength[id] - 322
                        set s__AdvancedBonus[(id)*(4)+1]= false
                  
                    
                      elseif advanced == 2 then
                    
                        set s__Fortune[id]= s__Fortune[id] - 322
                        set s__AdvancedBonus[(id)*(4)+2]= false
                      
                      elseif advanced == 3 then
                 
                        set s__Constitution[id]= s__Constitution[id] - 322
                        set s__AdvancedBonus[(id)*(4)+3]= false
                        
                      elseif advanced == 4 then
                 
                        set s__Constitution[id]= s__Constitution[id] - 322
                        set s__Fortune[id]= s__Fortune[id] - 322
                        set s__Mstrength[id]= s__Mstrength[id] - 322
                        
                        set s__AdvancedBonus[(id)*(4)+4]= false
                  
                      endif
                  
                  endif
                  
              endif
               
       endif //level>160
 
 
  set u=null
  set it=null
 endfunction
 
 
   
 function IsMisc takes nothing returns boolean
  //    return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_MISCELLANEOUS)
   return ( GetWidgetLife(GetManipulatedItem()) == 73 or GetWidgetLife(GetManipulatedItem()) == 56 )
 
 endfunction
 


 function InitSets takes nothing returns nothing
    local integer index= 0
   
       
     set HTsets=InitHashtable()
          
//call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"Initiliazed") 
    
    call TriggerAddCondition(dropset, Condition(function IsMisc))
    call TriggerAddCondition(pickset, Condition(function IsMisc))
 
 
  loop
        call TriggerRegisterPlayerUnitEvent(pickset, Player(index), EVENT_PLAYER_UNIT_PICKUP_ITEM, null)
        call TriggerRegisterPlayerUnitEvent(dropset, Player(index), EVENT_PLAYER_UNIT_DROP_ITEM, null)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
    call TriggerAddAction(pickset, function MiscAct)
    call TriggerAddAction(dropset, function MiscDrop)

    
    


    set s__qty[0]= "|cffffcc00[Misc]|r"
    set s__qty[1]= "|cff7fff00[Main]|r"
    set s__qty[2]= "|cffff7f50[Char]|r"
    set s__qty[3]= "|cffe6e6fa[Stry]|r"
    endfunction
    

function GetItemTypeCount takes unit whichUnit,integer itemId returns integer
    local integer index
    local item indexItem
    local integer ic= 0

    set index=0
    loop
        exitwhen ic >= bj_MAX_INVENTORY
        set indexItem=UnitItemInSlot(whichUnit, ic)
        if ( indexItem != null ) and ( GetItemTypeId(indexItem) == itemId ) then
            set index=index + 1
        endif
        set ic=ic + 1
        
    endloop
    set indexItem=null
    return index
endfunction

function GetMainJewel takes unit whichUnit,integer itemId returns item
    local integer index
    local item indexItem

    set index=0
    loop
        set indexItem=UnitItemInSlot(whichUnit, index)
        if ( indexItem != null ) and ( GetItemTypeId(indexItem) == itemId ) then
            return indexItem
        endif

        set index=index + 1
        exitwhen index >= bj_MAX_INVENTORY
    endloop
    set indexItem=null
    return indexItem
endfunction



function ItemName takes string s,real x,real y returns nothing
    local integer len= StringLength(s) * 3
    local real life= len / 7.5
    local texttag txt= CreateTextTag()
        call SetTextTagTextBJ(txt, s, 8)
        call SetTextTagPos(txt, x - len, y, 100)
        call SetTextTagColor(txt, 255, 255, 255, 220)
        call SetTextTagPermanent(txt, false)
        call SetTextTagLifespan(txt, life)
        call SetTextTagFadepoint(txt, 3.00)
        call SetTextTagVelocityBJ(txt, 0, 90)
    set txt=null
        
endfunction



function ItemSoulName takes string s,real x,real y returns nothing
    local integer len= StringLength(s) * 3
    local real life= len / 4
    local texttag txt= CreateTextTag()
        call SetTextTagTextBJ(txt, s, 8)
        call SetTextTagPos(txt, x - len, y, 100)
        call SetTextTagColor(txt, 255, 255, 255, 220)
        call SetTextTagPermanent(txt, false)
        call SetTextTagLifespan(txt, life)
        call SetTextTagFadepoint(txt, 3.00)
        call SetTextTagVelocityBJ(txt, 0, 90)
    set txt=null
        
endfunction



