//===========================================================================
// Trigger: orcelder
//===========================================================================
//TESH.scrollpos=46
//TESH.alwaysfold=0
function Trig_orcelder_Conditions takes nothing returns boolean
   return ( broadviced[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == true and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_orcelder_Actions takes nothing returns nothing
local integer i= 1
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local unit u= GetTriggerUnit()
local integer exp= GetHeroXP(u)
local location p= GetUnitLoc(u)
local integer questid

    set broadviced[id]=false

    call UnitChat("Welcome to my home, son of the mother land" , gg_unit_o00B_0036)
    call TriggerSleepAction(3)
    call UnitChat("Are you the Elder" , u)
    call TriggerSleepAction(4)
    call SetUnitFacingToFaceUnitTimed(gg_unit_o00B_0036, u, 0)
    call UnitChat("Yes I am" , gg_unit_o00B_0036)
    call TriggerSleepAction(4)
    call UnitChat("I want to be a grunt" , u)
    call TriggerSleepAction(4)
    call UnitChat("I know..." , gg_unit_o00B_0036)
    call TriggerSleepAction(2)
    call UnitChat("I can feel a great power.." , gg_unit_o00B_0036)
    call TriggerSleepAction(3)
    call UnitChat("Into your spirit..." , gg_unit_o00B_0036)
    call TriggerSleepAction(5)
    call UnitChat("Say what must I do" , u)
    call TriggerSleepAction(4)
    call SetUnitFacingToFaceUnitTimed(gg_unit_o00B_0036, u, 0)
    call UnitChat("You must make yourself a sign of bravery..." , gg_unit_o00B_0036)
    call TriggerSleepAction(4)
    
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "MAIN QUEST DONE")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Grunt Quest")
            set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
            call UpdatePersQuest(id , questid , 0 , "you have been sealed with the Elder bless" , "-" , "-")
            call RemoveQuestFromPlayer(questid , QPid[questid])
            
            call StartSound(bj_questCompletedSound)
                        
           set udg_PHero[id]=CreateUnitAtLoc(GetOwningPlayer(u), 'H02B', p, 270)
           call AddProfaner(id) //Trigger registrado
       
            call AddSpecialEffectTargetUnitBJ("origin", udg_PHero[id], "Abilities\\Spells\\Orc\\Reincarnation\\ReincarnationTarget.mdl")
            call DestroyEffect(GetLastCreatedEffectBJ())
    call SetHeroAgi(udg_PHero[id], GetHeroAgi(u, false) + 24, true)
    call SetHeroStr(udg_PHero[id], GetHeroStr(u, false) + 24, true)
    call SetHeroInt(udg_PHero[id], GetHeroInt(u, false) + 24, true)
    
    call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
    call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
    call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
             loop
               exitwhen i > 6
               call UnitRemoveItemFromSlot(u, i)
               set i=i + 1
               endloop
           
            
            
            call RemoveUnit(u)
            
            call SetHeroXP(udg_PHero[id], exp, false)
            call AdjustPlayerStateBJ(7, GetOwningPlayer(u), PLAYER_STATE_RESOURCE_LUMBER)
            set udg_Hnext[id]=4
   call TriggerSleepAction(4)
   call SetUnitFacingToFaceUnitTimed(gg_unit_o00B_0036, u, 0)
    call UnitChat("I believe in that." , gg_unit_o00B_0036)
    call TriggerSleepAction(3)
    call UnitChat("One day, you will lead us" , gg_unit_o00B_0036)
    call TriggerSleepAction(3)

    call UnitChat("To fight against the Darkness" , gg_unit_o00B_0036)
    call SetUnitFacingToFaceUnitTimed(gg_unit_o00B_0036, u, 0)
    call TriggerSleepAction(5)
    call UnitChat("Now go back to Velhilmen" , gg_unit_o00B_0036)
    call RemoveAllQuestFromPlayer(id)
    call TriggerSleepAction(3)
    call UnitChat("and make yourself a true Berserk" , gg_unit_o00B_0036)
    call RemoveLocation(p)
    set p=null
    set u=null

endfunction

