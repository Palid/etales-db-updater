function Trig_firststage_Conditions takes nothing returns boolean
    return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_firststage_Actions takes nothing returns nothing
 call DisableTrigger(gg_trg_firststage)
 call EnableTrigger(gg_trg_Iveorfights)
 
call UnitChat("WHY YOU HAVE COME HERE...?" , gg_unit_E00I_2515)
call TriggerSleepAction(3)
call UnitChat("DO YOU REALLY BELIEVE YOU CAN CHALLENGE ME...?" , gg_unit_E00I_2515)
call TriggerSleepAction(5)
call UnitChat("DO YOU REALLY THINK YOU CAN STAY IN FRONT OF A GOD...?" , gg_unit_E00I_2515)
call TriggerSleepAction(4)
 call PlaySoundBJ(gg_snd_IveorBegin)

call TriggerSleepAction(4)
call UnitChat("Y O U   S T U P I D   M O R T A L      I ' M   I V E O R   T H E   A L L M I G H T Y . . ." , gg_unit_E00I_2515)
call TriggerSleepAction(2)
call PauseUnit(gg_unit_E00I_2515, false)
call SetUnitInvulnerable(gg_unit_E00I_2515, false)
call TriggerSleepAction(5)
call UnitChat("I  ' M   T H E   A B B A D O N   O F   T E R R A . . ." , gg_unit_E00I_2515)
