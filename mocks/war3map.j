    //set udg_tmpit = GetDestructableLoc(GetOrderTargetDestructable())
    call SaveInteger(udg_cache, GetHandleId(GetOrderTargetDestructable()), 2, GetPlayerId(GetOwningPlayer(GetTriggerUnit())))
