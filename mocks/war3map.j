   // call IssuePointOrder(gg_unit_h02T_0468,"breathoffire",GetUnitX(u),GetUnitY(u))
    
    call TriggerSleepAction(8)
    call EnableTrigger(gg_trg_exelaunch)
    set u=null
endfunction

