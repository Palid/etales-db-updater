function InitTrig_Noorder takes nothing returns nothing
    local integer index
    set index=0
    loop
        set natkp[index]=CreateTrigger()
        call TriggerRegisterPlayerUnitEvent(natkp[index], Player(index), EVENT_PLAYER_UNIT_ATTACKED, null)
        call TriggerAddCondition(natkp[index], Condition(function Trig_Noorder_Conditions))
        call TriggerAddAction(natkp[index], function Trig_Noorder_Actions)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    //    call TriggerRegisterAnyUnitEventBJ( gg_trg_Noorder, EVENT_PLAYER_UNIT_ATTACKED )
 
endfunction


