function settingfallies takes nothing returns nothing
local integer i= 0

    call MakeEnemy(GetEnumPlayer() , Player(11))
    call MakeEnemy(Player(11) , GetEnumPlayer())

loop
exitwhen i > 10
if ( fallow[i] == true ) then
 if ( IsPlayerInForce(Player(i), udg_pgblackhand) == false and GetEnumPlayer() != Player(11) ) then
 
    call MakeAlly(Player(i) , GetEnumPlayer())
