function Trig_mercvanish_Conditions takes nothing returns boolean
    return GetOwningPlayer(GetTriggerUnit()) == Player(PLAYER_DARK_LORD) and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_mercvanish_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer questid= GetUnitUserData(u)
local timer t
local integer scapeindex
  
 
  set t=LoadTimerHandle(questtm, GetHandleId(udg_PHero[QPid[questid]]), GetHandleId(u))
 if t != null then
     call IssueImmediateOrder(GetTriggerUnit(), "stop")
    if GetTriggeringRegion() == mercregion[0] then
        set scapeindex=9
    elseif GetTriggeringRegion() == mercregion[1] then
        set scapeindex=13
    elseif GetTriggeringRegion() == mercregion[3] then
        set scapeindex=8
    elseif GetTriggeringRegion() == mercregion[7] then
        set scapeindex=12
    elseif GetTriggeringRegion() == mercregion[2] or GetTriggeringRegion() == mercregion[6] then
        set scapeindex=10
    elseif GetTriggeringRegion() == mercregion[4] or GetTriggeringRegion() == mercregion[5] then
        set scapeindex=11
    elseif GetTriggeringRegion() == mercregion[8] then
       call PauseTimer(t)
       call ReleaseTimer(t)
       call StartSound(bj_questUpdatedSound)
       call DisplayTimedTextToPlayer(Player(QPid[questid]), .1, 0, 10, "|cffffcc00SURVIVOR QUEST UPDATE!|r")
       call UpdatePersQuest(QPid[questid] , questid , Qdata[questid] , "   The thief vanishes... " , "0" , "-")
       call IssueImmediateOrder(QUid[questid], "stop")
       call TriggerSleepAction(0.02)
       call RemoveQuestFromPlayer(questid , QPid[questid])
       set hasbounty[QPid[questid]]=false
    endif
     call SaveInteger(questtm, GetHandleId(t), 1, scapeindex)
    
  endif
  
  set u=null
  set t=null
endfunction

//===========================================================================
function InitTrig_mercvanish takes nothing returns nothing
local integer i= 0
    set gg_trg_mercvanish=CreateTrigger()
    
    call RegionAddRect(mercregion[0], gg_rct_bcave10i)
    call RegionAddRect(mercregion[1], gg_rct_bandit1i)
    call RegionAddRect(mercregion[2], gg_rct_bcave1i)
    call RegionAddRect(mercregion[3], gg_rct_trollin)
    call RegionAddRect(mercregion[4], gg_rct_bcave8i)
    call RegionAddRect(mercregion[5], gg_rct_bcave4i)
    call RegionAddRect(mercregion[6], gg_rct_bcave6i)
    call RegionAddRect(mercregion[7], gg_rct_dungeonB_out)
    call RegionAddRect(mercregion[8], gg_rct_ruinasoutC)
    loop
        call TriggerRegisterEnterRegion(gg_trg_mercvanish, mercregion[i], Condition(function istrue))
        set i=i + 1
        exitwhen i == 9
    endloop
    
    call TriggerAddCondition(gg_trg_mercvanish, Condition(function Trig_mercvanish_Conditions))
    call TriggerAddAction(gg_trg_mercvanish, function Trig_mercvanish_Actions)
endfunction


//===========================================================================
// Trigger: noabusemerc
//===========================================================================
function Trig_noabusemerc_Conditions takes nothing returns boolean
local real x
local real y
local real face= GetUnitFacing(GetAttacker())
    
    if ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and safer[GetPlayerId(GetOwningPlayer(GetAttacker()))] == true ) then
        set x=GetUnitX(GetTriggerUnit()) + 800 * Cos(face * bj_DEGTORAD)
        set y=GetUnitY(GetTriggerUnit()) + 800 * Sin(face * bj_DEGTORAD)
        call IssuePointOrder(GetTriggerUnit(), "blink", x, y)
    endif
    return false
endfunction


