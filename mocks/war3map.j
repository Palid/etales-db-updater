//===========================================================================
// Trigger: checkundead
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_checkundead_Actions takes nothing returns nothing
local integer i= 0
 if FirstOfGroup(sundeads) == null then
  call DisableTrigger(gg_trg_checkundead)
  call PauseTimer(suta)
  call ReleaseTimer(suta)
  call DestroyTrigger(gg_trg_removeundead)
  call TriggerSleepAction(2)
  call DestroyGroup(sundeads)
  call DestroyGroup(ekromforces)
  call DestroyGroup(coldreamforces)
  call QuestSetDiscovered(undeadq, true)
  call QuestSetCompleted(undeadq, true)
  call QuestItemSetCompleted(undeadqib, true)
  call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffffcc00Undeads Siege:|r The undead army has been destroyed!, the way to Colddream is safe now!")
  call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "All players get |cffffcc00+48700 XP|r, 3 |cffffcc00Kings chest|r")
 loop
    exitwhen i > 8
      
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[82], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[82], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
     // call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[82], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])) )
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[82], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
         
      call AddHeroXP(udg_PHero[i], 48700, false)
     // call AdjustPlayerStateBJ( 14440, Player(i), PLAYER_STATE_RESOURCE_GOLD )
     set i=i + 1
    
    endloop
  
 endif
 
 
  
endfunction

