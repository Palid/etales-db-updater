//TESH.alwaysfold=0
function Trig_warning_Conditions takes nothing returns boolean
  return ( GetItemTypeId(GetManipulatedItem()) == 'I022' and GetUnitLevel(GetTriggerUnit()) > 49 )
endfunction

function Trig_warning_Actions takes nothing returns nothing

local unit c= GetTriggerUnit()

call DisableTrigger(gg_trg_warning)

//if GetTriggerExecCount(gg_trg_warning) < 2 then
  call GroupAddUnit(spidersman, c)
//endif

//call EnableTrigger(gg_trg_warning)
call TriggerSleepAction(1)
call UnitChat("What the hell is wrong with that girl!!!.." , c)


//if GetTriggerExecCount(gg_trg_warning) < 2 then
 call TriggerSleepAction(3)
 call UnitChat("Maybe on Valdivia's tavern someone can tell me about her..." , c)
//endif

set c=null

endfunction

//===========================================================================
function InitTrig_warning takes nothing returns nothing
 local integer i= 0
    set gg_trg_warning=CreateTrigger()
 //  call TriggerRegisterUnitInRange(gg_trg_warning, gg_unit_n05C_0662, 255, Condition(function rescok))
        loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_warning, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function btrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
   call TriggerAddCondition(gg_trg_warning, Condition(function Trig_warning_Conditions))
   call TriggerAddAction(gg_trg_warning, function Trig_warning_Actions)
endfunction


//===========================================================================
// Trigger: girlbehaviour
//===========================================================================
//TESH.scrollpos=50
//TESH.alwaysfold=0
function bhvc takes nothing returns boolean
 return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction


function SpawnSpider takes string spefx,unit c returns nothing

local integer j= 0
local real face= GetUnitFacing(c)
    local real x= GetUnitX(cursedlady) + 650 * Cos(face * bj_DEGTORAD)
    local real y= GetUnitY(cursedlady) + 650 * Sin(face * bj_DEGTORAD)



 call IssuePointOrder(cursedlady, "move", x, y)
   loop
    exitwhen j > 5
    set x=GetUnitX(cursedlady)
    set y=GetUnitY(cursedlady)
    call TriggerSleepAction(0.3)
    call CreateUnit(Player(12), udg_CreepType[36], x, y, face)
    call PlaySoundOnUnitBJ(gg_snd_hurts, 80, cursedlady)
    call DestroyEffect(AddSpecialEffect(spefx, x, y))
    set j=j + 1
    endloop
endfunction



function Trig_girlbehaviour_Actions takes nothing returns nothing
  local unit c= GetTriggerUnit()
  local integer i= GetRandomInt(1, 5)
  local string spefx= "Objects\\Spawnmodels\\Undead\\CryptFiendEggsack\\CryptFiendEggsack.mdl"

call DisableTrigger(gg_trg_girlbehaviour)

 if i == 1 then
   call UnitChat("Get away from me..." , cursedlady)
   call SpawnSpider(spefx , c)
    
elseif i == 2 then
   call UnitChat("¡leave me alone!..." , cursedlady)
     call SpawnSpider(spefx , c)
elseif i == 3 then
   call UnitChat("¡It hurts!!!..." , cursedlady)
     call SpawnSpider(spefx , c)
elseif i == 4 then
   call UnitChat("¡¡Dont touch me!!!..." , cursedlady)
     call SpawnSpider(spefx , c)
elseif i == 5 then
   call UnitChat("!Arrrrgh!!!.." , cursedlady)
     call SpawnSpider(spefx , c)
     
     call TriggerSleepAction(3)
     
  call EnableTrigger(gg_trg_girlbehaviour)
endif
set spefx=null

endfunction

//===========================================================================
function InitTrig_girlbehaviour takes nothing returns nothing
    set gg_trg_girlbehaviour=CreateTrigger()
    call TriggerRegisterUnitInRange(gg_trg_girlbehaviour, gg_unit_n05C_0662, 255, Condition(function rescok))
    call TriggerAddCondition(gg_trg_girlbehaviour, Condition(function bhvc))
    call TriggerAddAction(gg_trg_girlbehaviour, function Trig_girlbehaviour_Actions)
endfunction


