//===========================================================================
// Trigger: warriorend
//===========================================================================
//TESH.scrollpos=48
//TESH.alwaysfold=0
function WARRTC takes nothing returns boolean
    return ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true )
endfunction

function WARRTA takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local integer i= 1
 local location p=  GetUnitLoc(u)
 local integer exp= GetHeroXP(u)
 local integer level= GetHeroLevel(u)
 local integer questid
     
 if ( UnitHasItemOfTypeBJ(u, 'I0LK') == true and s__warriorReq[id] == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(u, 'I0LK')
      
       set s__warriorReq[id]= false
          call GroupRemoveUnit(udg_inTest, u)
          call UnitRemoveItem(u, udg_tmpitem)
           
               loop
               exitwhen i > 6
               call UnitRemoveItemFromSlotSwapped(i, u)
               set i=i + 1
               endloop
           
               
            call UnitChat("Very well!. Now i declare you a great warrior. Good luck in your quests" , gg_unit_Harf_1456)

            call TriggerSleepAction(1)
            call UnitChat("¡SNIFF!, What do you want with my bear set??!" , u)
            call TriggerSleepAction(2)
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "QUEST DONE")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Warrior Quest")
             set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
            call UpdatePersQuest(id , questid , 0 , "Reached first class tier" , "-" , "-")
            call RemoveQuestFromPlayer(questid , QPid[questid])
            
            call StartSound(bj_questCompletedSound)
                        
           set udg_PHero[id]=CreateUnitAtLoc(GetOwningPlayer(u), 'H00W', p, 270)
       
            call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\Orc\\Reincarnation\\ReincarnationTarget.mdl")
            call DestroyEffect(GetLastCreatedEffectBJ())
    call SetHeroAgi(udg_PHero[id], GetHeroAgi(u, false) + 24, true)
    call SetHeroStr(udg_PHero[id], GetHeroStr(u, false) + 24, true)
    call SetHeroInt(udg_PHero[id], GetHeroInt(u, false) + 24, true)
    
    call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
    call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
  call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
    
    call AddProfaner(id) //Trigger registrado
            
            
            call RemoveUnit(u)
            
            call SetHeroXP(udg_PHero[id], exp, false)
            call AdjustPlayerStateBJ(7, GetOwningPlayer(u), PLAYER_STATE_RESOURCE_LUMBER)
            set udg_Hnext[id]=4
           
         call RemoveAllQuestFromPlayer(id)
   
          set udg_tmpitem=null
    endif

    set u=null
    call RemoveLocation(p)
    set p=null
endfunction
