function GetClassReq takes integer c returns boolean
 local boolean canaxe= ( c == 0 or c == 2 or c == 3 or c == 4 or c == 7 or c == 8 or c == 9 or c == 11 )
 local boolean canbow= ( c == 1 )
 local boolean cansword=( c == 3 or c == 4 or c == 7 or c == 9 )
 local boolean canstaff= ( c == 5 or c == 6 or c == 11 or c == 12 )
 local boolean canshield= ( c != 1 and c != 8 )
 
     if ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and canaxe == true ) then // INLINED!!
          return true
    elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 2) and canbow == true ) then // INLINED!!
          return true
    elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 4) and canstaff == true ) then // INLINED!!
          return true
    elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and cansword == true ) then // INLINED!!
          return true
    elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and canshield == true ) then // INLINED!!
          return true
    elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) ) then // INLINED!!
          return true
    endif
 return false
endfunction


function GetLevelReq takes integer unitlevel returns boolean
local integer itlevel= GetItemLevel(GetManipulatedItem())
local integer levelreq= ModuloInteger(itlevel, 100) * 8

 if ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) then // INLINED!!
    set levelreq=levelreq + 3
 elseif ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 2) then // INLINED!!
   set levelreq=levelreq + 4
 elseif ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) then // INLINED!!
   set levelreq=levelreq + 4
 endif
   return ( unitlevel >= levelreq )
 endfunction
 
function Nocarry takes nothing returns nothing
 local unit u= GetTriggerUnit()
       // call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"|cffffcc00You cannot carry more of those items.|r")
       call UnitChat("|cffffcc00I cannot load more of these items.|r" , u)
        call UnitRemoveItem(u, GetManipulatedItem())
set u=null
endfunction 



function NoMoreThan2 takes unit u returns boolean
  local integer hS= 0
  local integer hZ= 0
  local integer hB= 0
  local integer hT= 0
  local integer hD= 0
  local integer hA= 0
  local integer hF= 0
  local integer itmcount= 0
  local integer current= 0
  local item itslot= null
  
 // call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"here")
  set udg_invslot=0

  loop
     exitwhen udg_invslot > 5
      set itslot=UnitItemInSlot(u, udg_invslot)
      set current=ModuloInteger(GetItemLevel(itslot), 1000) / 100
      set itmcount=ModuloInteger(GetItemLevel(itslot), 10000) / 1000
           
  
            if ( current == 1 ) then
                    set hD=( hD + 1 )
            elseif ( current == 2 ) then
                    set hB=( hB + 1 )
            elseif ( current == 3 ) then
                    set hA=( hA + 1 )
                    if ( itmcount == 6 ) then
                    set hT=( hT + 1 )
                    endif
                     
            elseif ( current == 4 ) then
                    set hF=( hF + 1 )
            elseif ( current == 5 ) then
                    set hZ=( hZ + 1 )
                    if ( itmcount == 6 ) then
                    set hT=( hT + 1 )
                    endif
            elseif ( current == 6 ) then
                    set hS=( hS + 1 )
            endif
           
           // call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,I2S(hD))
           // call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,I2S(hB))
          //  call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,I2S(hA))
           // call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,I2S(hT)) 
           // call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,I2S(hS))
           // call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,I2S(hZ))
           //call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,I2S(hF))
           
         set udg_invslot=udg_invslot + 1
     endloop
  
 
 

  if ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 2) and hB > 1 ) then // INLINED!!
     call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and hS > 1 ) then // INLINED!!
 call Nocarry()
  elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and hZ > 1 ) then // INLINED!!
 call Nocarry()
  elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and hD > 1 ) then // INLINED!!
 call Nocarry()
  elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and hA > 1 ) then // INLINED!!
 call Nocarry()
  elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and hA > 0 and hD > 0 ) then // INLINED!!
 call Nocarry()
  elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and hZ > 0 and hD > 0 ) then // INLINED!!
 call Nocarry()
  elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6) and hA > 0 and hZ > 0 ) then // INLINED!!
 call Nocarry()
  elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 4) and hF > 1 ) then // INLINED!!
 call Nocarry()
 
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hT > 1 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hA > 2 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hA > 1 and hS > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hA > 1 and hD > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hA > 1 and hZ > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hZ > 0 and hD > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hZ > 0 and hS > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 3) and hS > 0 and hD > 0 ) then // INLINED!!
 call Nocarry()
   
 
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hT > 1 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hZ > 2 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hZ > 1 and hS > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hZ > 1 and hD > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hZ > 1 and hA > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hS > 0 and hA > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hD > 0 and hA > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5) and hS > 0 and hD > 0 ) then // INLINED!!
 call Nocarry()

  
 
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hT > 1 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hD > 2 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hD > 1 and hS > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hD > 1 and hZ > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hD > 1 and hA > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hD > 1 and hB > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hD > 1 and hF > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hA > 0 and hS > 0 ) then // INLINED!!
 call Nocarry()
elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hA > 0 and hZ > 0 ) then // INLINED!!
call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hS > 0 and hZ > 0 ) then // INLINED!!
 call Nocarry()
 elseif ( ((ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1) and hS > 0 and hF > 0 ) then // INLINED!!
 call Nocarry()
 
 
 elseif ( (ModuloInteger(GetItemLevel(GetManipulatedItem()), 10000) / 1000 == 6) and hT > 1 ) then // INLINED!!
      if ( hS > 0 or hA > 1 or hD > 0 or hZ > 1 ) then
        //call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"|cffffcc00You need free hands to pick up that weapon.|r")
        call UnitChat("|cffffcc00I need a free hand to pickup that...|r" , GetTriggerUnit())
        call UnitRemoveItem(u, GetManipulatedItem())
      endif

  set itslot=null
endif

 set itslot=null
 return false
endfunction


function PickWeapon takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local integer unitlevel= GetHeroLevel(u)
    local integer unitclass= ModuloInteger(GetUnitPointValue(u) - 100, 20)
    local integer itemclas= ModuloInteger(GetItemLevel(GetManipulatedItem()), 10000) / 1000
    local real me= GetWidgetLife(GetManipulatedItem())
    local integer slotused= UnitInventoryCount(GetTriggerUnit())
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local integer piercebns= ModuloInteger(GetItemLevel(GetManipulatedItem()), 4200)
    local integer dmp= LoadInteger(nodump, GetHandleId(GetManipulatedItem()), GetHandleId(GetManipulatedItem()))
    local boolean owner= dmp - 10 == id
    
    
     if u == udg_forger then
         set u=null
         return
        endif
    
    if ( dmp > 9 and owner == false ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, GetManipulatedItem())

     set u=null
     return
   endif
  //  call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()),.75,.2,2,I2S(unitclass))
  //  call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()),.75,.2,2,I2S(itemclas))
    if ( GetLevelReq(unitlevel) == false ) then
        //call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"|cffffcc00You don't have the required level for that item.|r")
        call UnitChat("|cffffcc00I don't have the required level for this weapon.|r" , GetTriggerUnit())
        call UnitRemoveItem(u, GetManipulatedItem())
        return
    elseif ( GetClassReq(unitclass) == false ) then
        //call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"|cffffcc00You don't have the required class for that item.|r")
        call UnitChat("|cffffcc00I cannot fight with this.|r" , GetTriggerUnit())
        call UnitRemoveItem(u, GetManipulatedItem())
        return
    endif
    
    if ( ModuloReal(me, 8) == 0 ) then
     set udg_magicBonus[id]=udg_magicBonus[id] + ( me / 100 )
     //call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"Magic Bonus: "+R2S(1 + udg_magicBonus[id]) )
    endif
 
    if ( piercebns < 13 ) then
    
      set piercebonus[id]=piercebonus[id] + piercebns
     //call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"Magic Bonus: "+R2S(1 + udg_magicBonus[id]) )
    endif
 
    call NoMoreThan2(u)

    
  //  if (itemclas==6 and slotused >3 ) then         
   //       call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"|cffffcc00You need two slots to pick up that item.|r")
   //       call UnitRemoveItem( u, GetManipulatedItem())
    //    endif
 
 set u=null
endfunction

//===========================================================================
function InitTrig_PA takes nothing returns nothing
         local integer index= 0
    set gg_trg_PA=CreateTrigger()
    
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_PA, Player(index), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function bool))

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    //call TriggerRegisterAnyUnitEventBJ( gg_trg_PA, EVENT_PLAYER_UNIT_PICKUP_ITEM )
    call TriggerAddCondition(gg_trg_PA, Condition(function PAXEC))
    call TriggerAddAction(gg_trg_PA, function PickWeapon)
endfunction


//===========================================================================
// Trigger: FAMPA
//
// Pick Weapon Advance
//             
//          
//===========================================================================
function FAMPAC takes nothing returns boolean
    return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_PERMANENT and GetUnitPointValue(GetManipulatingUnit()) == 334 )
endfunction



function FAMPACA takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local integer unitlevel= GetHeroLevel(udg_PHero[id])
    local integer dmp= LoadInteger(nodump, GetHandleId(GetManipulatedItem()), GetHandleId(GetManipulatedItem()))
    local boolean owner= dmp - 10 == id
 if ( dmp > 9 and owner == false ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, GetManipulatedItem())

     set u=null
     return
   endif
     if ( GetLevelReq(unitlevel) == false ) then
        //call DisplayTimedTextToPlayer(GetOwningPlayer(u),.75,.2,2,"|cffffcc00You don't have the required level for that item.|r")
        call UnitChat("|cffffcc00Low level...|r" , GetTriggerUnit())
        call UnitRemoveItem(u, GetManipulatedItem())
   endif
 
 set u=null
endfunction

//===========================================================================
function InitTrig_FAMPA takes nothing returns nothing
         local integer index= 0
    set gg_trg_FAMPA=CreateTrigger()
    
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_FAMPA, Player(index), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function bool))

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    //call TriggerRegisterAnyUnitEventBJ( gg_trg_FAMPA, EVENT_PLAYER_UNIT_PICKUP_ITEM )
    call TriggerAddCondition(gg_trg_FAMPA, Condition(function FAMPAC))
    call TriggerAddAction(gg_trg_FAMPA, function FAMPACA)
endfunction


//===========================================================================
// Trigger: PW
//
// pick wings
//===========================================================================
function Trig_PW_Conditions takes nothing returns boolean
    return ( GetItemLevel(GetManipulatedItem()) == 483 )
endfunction

function Trig_PW_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer i= 0
local integer hw= 0
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer dmp= LoadInteger(nodump, GetHandleId(GetManipulatedItem()), GetHandleId(GetManipulatedItem()))
local boolean owner= dmp - 10 == id
 if ( dmp > 9 and owner == false ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, GetManipulatedItem())

     set u=null
     return
   endif


   loop
     exitwhen i > 5
      
        if ( GetItemLevel(UnitItemInSlot(u, i)) == 483 ) then
         set hw=hw + 1
        endif
        
     set i=i + 1
   endloop
   
   if ( hw > 2 ) then
     call UnitChat("|cffffcc00I cannot equip more of this kind of item|r" , GetTriggerUnit())
     call UnitRemoveItem(u, GetManipulatedItem())
   
   endif

set u=null

endfunction

//===========================================================================
function InitTrig_PW takes nothing returns nothing
    set gg_trg_PW=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_PW, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_PW, Condition(function Trig_PW_Conditions))
    call TriggerAddAction(gg_trg_PW, function Trig_PW_Actions)
endfunction


//===========================================================================
// Trigger: NJ
//
// no jewel rare items
//===========================================================================
function Trig_NJ_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetManipulatingUnit()) == 'e009' )
endfunction

function Trig_NJ_Actions takes nothing returns nothing
local unit u= GetManipulatingUnit()
local item it= GetManipulatedItem()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer dmp= LoadInteger(nodump, GetHandleId(GetManipulatedItem()), GetHandleId(GetManipulatedItem()))

 local boolean owner= dmp - 10 == id
 if ( dmp > 9 and owner == false and not ( GetItemLevel(it) == 222 ) ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, it)

     set u=null
     return
   endif
   
   if ( GetItemLevel(it) != 222 ) then
     call UnitChat("|cffffcc00This Item is to huge for Book's masters slot|r" , u)
     call UnitRemoveItem(u, it)
   
   endif

set u=null
set it=null

endfunction

//===========================================================================
function InitTrig_NJ takes nothing returns nothing
    set gg_trg_NJ=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_NJ, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_NJ, Condition(function Trig_NJ_Conditions))
    call TriggerAddAction(gg_trg_NJ, function Trig_NJ_Actions)
endfunction


//===========================================================================
// Trigger: PS
//===========================================================================
function Trig_PS_Conditions takes nothing returns boolean
local integer id= GetPlayerId(GetOwningPlayer(GetManipulatingUnit()))
     return GetUnitTypeId(GetManipulatingUnit()) == 'n011' or GetManipulatingUnit() == cslave[id] or GetManipulatingUnit() == udg_ARVault[id]
endfunction

function Trig_PS_Actions takes nothing returns nothing
local unit u= GetManipulatingUnit()
local item it= GetManipulatedItem()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer dmp= LoadInteger(nodump, GetHandleId(GetManipulatedItem()), GetHandleId(GetManipulatedItem()))
local boolean owner= dmp - 10 == id
 if ( dmp > 9 and owner == false and not ( GetItemLevel(it) == 222 ) ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, it)

     set u=null
     set it=null
     return
elseif (LoadInteger(udg_itempoolhash, (GetItemTypeId(GetManipulatedItem())), 3) == 1161) and GetUnitTypeId(u) == 'n011' then // INLINED!!

     call UnitChat("I cannot chargue this item!" , u)
     call UnitRemoveItem(u, it)

     set u=null
     set it=null
     return

endif
endfunction

