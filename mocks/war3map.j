//library SaveXP:
    
    function SaveXP__GetMaxXP takes integer level returns integer
        local integer xp
        
        call SetHeroLevel(SaveXP__dummyUnit, level + 1, false)
        set xp=GetHeroXP(SaveXP__dummyUnit) - 1
        call UnitStripHeroLevel(SaveXP__dummyUnit, level + 2)
        
        return xp
    endfunction
    function SaveXP__GetMinXP takes integer level returns integer
        local integer xp
        
        if ( 1 == level ) then
            return 0
        endif
        
        call SetHeroLevel(SaveXP__dummyUnit, level, false)
        set xp=GetHeroXP(SaveXP__dummyUnit)
        call UnitStripHeroLevel(SaveXP__dummyUnit, level + 1)
        
        return xp
    endfunction
    
    function SaveXP__SaveXP takes integer stack,unit whichUnit,integer accuracy returns nothing
        local integer level= GetHeroLevel(whichUnit)
        local real max= Pow(10, accuracy)
        local integer maxi= R2I(max + .5)
        local integer minXp= SaveXP__GetMinXP(level)
        local integer maxXp= SaveXP__GetMaxXP(level) - minXp
        local integer xp= GetHeroXP(whichUnit) - minXp
        local integer percentXp= R2I(( xp * max ) / maxXp)
        
        call s__NumberStack_push(stack,percentXp , maxi)
    endfunction
    
    function SaveXP__LoadXP takes integer stack,unit whichUnit,integer accuracy returns nothing
        local integer level= GetHeroLevel(whichUnit)
        local real max= Pow(10, accuracy)
        local integer maxi= R2I(max + .5)
        local integer minXp= SaveXP__GetMinXP(level)
        local integer maxXp= SaveXP__GetMaxXP(level) - minXp
        local integer percentXp= (s__BigInt_divide(((stack)),(maxi) + 1)) // INLINED!!
        local integer xp= R2I(percentXp * maxXp / max)
        
        call AddHeroXP(whichUnit, xp, false)
    endfunction
    
    function SaveHeroXP takes integer stack,unit whichUnit,integer accuracy returns nothing
        if ( GetHeroLevel(whichUnit) != SaveXP__maxLevel and 0 < accuracy ) then
            call SaveXP__SaveXP(stack , whichUnit , accuracy)
        endif
        call s__NumberStack_push(stack,GetHeroLevel(whichUnit) - 1 , SaveXP__maxLevel - 1)
    endfunction
    
    function LoadHeroXP takes integer stack,unit whichUnit,integer accuracy returns nothing
        local integer level= (s__BigInt_divide(((stack)),(SaveXP__maxLevel - 1) + 1)) + 1 // INLINED!!
        
        if ( level != 1 ) then
        
            call DisableTrigger(gg_trg_Lvup)
            call SetHeroLevel(whichUnit, level, false)
            call EnableTrigger(gg_trg_Lvup)
            
        endif
        
        if ( level != SaveXP__maxLevel and 0 < accuracy ) then
            call SaveXP__LoadXP(stack , whichUnit , accuracy)
        endif
    endfunction
    
//Implemented from module SaveXP__InitMod:
        function s__SaveXP__Init_SaveXP__InitMod___onInit takes nothing returns nothing
          
            set SaveXP__dummyUnit=CreateUnit(Player(15), 'Hpal', 0, 0, 270)
            call UnitAddAbility(SaveXP__dummyUnit, 'Aloc')
            call SetUnitPosition(SaveXP__dummyUnit, - 10360, - 17900)
       
            
            call SetHeroLevel(SaveXP__dummyUnit, 100, false)
            set SaveXP__maxLevel=GetHeroLevel(SaveXP__dummyUnit)
            
            call UnitStripHeroLevel(SaveXP__dummyUnit, 101)
        endfunction

