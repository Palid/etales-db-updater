//===========================================================================
function SeekCoalStone takes nothing returns nothing
  if GetItemTypeId(GetEnumItem()) == 'I006' then
     set Coalfound=1
  endif
endfunction

function ProduceCoal takes nothing returns nothing
call CreateItem('I006', GetRectCenterX(CoalRect), GetRectCenterY(CoalRect))
call TriggerSleepAction(0.2)

endfunction


function Createrock takes nothing returns nothing
   local integer i= 1

   loop
      exitwhen i > 58
          set Coalfound=0
          call EnumItemsInRect(Canteras[i], null, function SeekCoalStone)
           
          if Coalfound == 0 then
              set CoalRect=Canteras[i]
              call ExecuteFunc("ProduceCoal")
          endif
          
        set i=i + 1
      
   endloop
   set CoalRect=null
endfunction

