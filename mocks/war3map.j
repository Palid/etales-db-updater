//===========================================================================


function Trig_BGD_Actions takes nothing returns nothing
 local integer i= 1
 local integer currwthr= 0
 local integer r= 0

   // call CinematicFadeBJ( bj_CINEFADETYPE_FADEOUT, 30.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 80.00 )
    call SetAmbientNightSound("nightsound")
    call TriggerSleepAction(5.00)
   // call SetUnitAnimation( gg_unit_n00Z_0008, "stand" )
    call PlayThematicMusic("war3mapImported\\night.mp3")
    call TriggerExecute(gg_trg_Setranditem)
  
   
    
    
    if ( KatherineAngry == true ) then
      
      call SetUnitPosition(kathy, GetRectCenterX(gg_rct_alcaout), GetRectCenterY(gg_rct_alcaout))
      set r=GetRandomInt(0, 6)
      call IssuePointOrder(kathy, "move", GetRectCenterX(bandrect[r]), GetRectCenterY(bandrect[r]))
      
    endif
  //  call TriggerSleepAction(20)
  //  set currwthr=GetRandomInt(0,3)
  //  call EnableWeatherEffect(weathers[0][currentweather[0]],false)
  //  call EnableWeatherEffect(weathers[0][currwthr],true)
 //   set currentweather[0]=currwthr
  //   call TriggerSleepAction(1)
 ///   set currwthr=GetRandomInt(0,3)
  //  call EnableWeatherEffect(weathers[1][currentweather[1]],false)
  //  call EnableWeatherEffect(weathers[1][currwthr],true)
  //  set currentweather[1]=currwthr 
 //    call TriggerSleepAction(1)
 //   set currwthr=GetRandomInt(0,3)
 //   call EnableWeatherEffect(weathers[2][currentweather[2]],false)
 //   call EnableWeatherEffect(weathers[2][currwthr],true)
 //   set currentweather[2]=currwthr     
   call TriggerSleepAction(120.00)

   call ShowUnit(gg_unit_n08D_0232, true) //show vampire test
   call DestroyEffect(AddSpecialEffectTarget(seffectclap, gg_unit_n08D_0232, "origin"))
   call PlaySoundOnUnitBJ(gg_snd_nightsigth, 100, gg_unit_n08D_0232)
   
endfunction

