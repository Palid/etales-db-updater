function InitTrig_dwarvenfind takes nothing returns nothing
    set gg_trg_dwarvenfind=CreateTrigger()
    call TriggerRegisterDeathEvent(gg_trg_dwarvenfind, gg_dest_DTrc_14881)
    call TriggerRegisterDeathEvent(gg_trg_dwarvenfind, gg_dest_DTrc_14897)
    call TriggerRegisterDeathEvent(gg_trg_dwarvenfind, gg_dest_DTrc_14894)
    call TriggerAddAction(gg_trg_dwarvenfind, function Trig_dwarvenfind_Actions)
endfunction


//===========================================================================
// Trigger: dwarwenteleport
//===========================================================================
//TESH.scrollpos=18
//TESH.alwaysfold=0
function Trig_dwarwenteleport_Conditions takes nothing returns boolean
    return ( GetTriggerUnit() == udg_forger )
endfunction

function Trig_dwarwenteleport_Actions takes nothing returns nothing
 local integer i= 0
       call SetUnitPositionLoc(GetTriggerUnit(), udg_forgerini)
       call TriggerSleepAction(0.5)
       call ShowUnit(udg_forger, false)
       call UnitRemoveAbility(udg_forger, 'Aloc')
       call ShowUnit(udg_forger, true)
       call UnitAddAbility(udg_forger, 'Abrf')
       call IssueImmediateOrder(udg_forger, "bearform")
       call UnitRemoveAbility(udg_forger, 'Abrf')

    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00MAIN QUEST COMPLETED:|r Found Brok, the Dwarven Forger. All Players got |cffff8c00-Lord's Chest-|r")
    
    call StartSound(bj_questCompletedSound)
    call QuestSetDiscovered(udg_brokQ, true)
    call QuestItemSetCompleted(udg_brokQR, true)
    call QuestSetCompleted(udg_brokQ, true)
    call DisableTrigger(gg_trg_tinahelp)
        
    loop
    exitwhen i > 8
      
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[86], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
     
    set i=i + 1
    
    endloop
    
    

endfunction

