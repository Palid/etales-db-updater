local integer i= 0
    set gg_trg_setuphelp=CreateTrigger()
    
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_setuphelp, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function istrue))
       set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
    
    call TriggerAddCondition(gg_trg_setuphelp, Condition(function Trig_setuphelp_Conditions))
    call TriggerAddAction(gg_trg_setuphelp, function Trig_setuphelp_Actions)
endfunction


