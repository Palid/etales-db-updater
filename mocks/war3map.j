function classinfoc takes nothing returns boolean
    return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_POWERUP and ModuloReal(GetWidgetLife(GetManipulatedItem()), 710) > 0 and ModuloReal(GetWidgetLife(GetManipulatedItem()), 710) < 12 )
endfunction

function classinfoca takes nothing returns nothing
    local integer idi= R2I(ModuloReal(GetWidgetLife(GetManipulatedItem()), 710))
    set udg_tmp1=GetUnitLoc(classloc[idi])
    call PingMinimapLocForForce(GetPlayersAll(), udg_tmp1, 1)
    call RemoveLocation(udg_tmp1)
    set udg_tmp1=null
endfunction

