function InitTrig_SCR takes nothing returns nothing
    set gg_trg_SCR=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_SCR, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_SCR, Condition(function Trig_SCR_Conditions))
    call TriggerAddAction(gg_trg_SCR, function Trig_SCR_Actions)
endfunction


//===========================================================================
// Trigger: HAT
//
// Hawk attack trigger
// GetUnitFacing(u)
//===========================================================================
function HATC takes nothing returns boolean
local integer l__rand= ( 450 / GetHeroInt(GetAttacker(), true) )
    return ( ( GetRandomInt(1, l__rand) == 1 ) and ( udg_Hashawk[GetPlayerId(GetOwningPlayer(GetAttacker()))] == true ) )
endfunction


function HATM takes nothing returns nothing

    local timer ti= GetExpiredTimer()
    local unit u= LoadUnitHandleBJ(StringHashBJ("caster"), GetHandleIdBJ(ti), udg_cache)
    local real inc= LoadRealBJ(StringHashBJ("inc"), GetHandleIdBJ(ti), udg_cache)
    local real ang= LoadRealBJ(StringHashBJ("angle"), GetHandleIdBJ(ti), udg_cache)
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    
        call RemoveLocation(p)
        set p=null
    set inc=( inc - 1 )
    set p=GetUnitLoc(u)
    call SetUnitPositionLoc(u, p1)
    call RemoveLocation(p)
        set p=null
    call RemoveLocation(p1)
        set p1=null
    call SaveRealBJ(inc, StringHashBJ("inc"), GetHandleIdBJ(ti), udg_cache)
    if inc < 1 then
    set hawkspeed[id]=1
    else
    set hawkspeed[id]=inc
    endif
    
    set u=null
    set ti=null


endfunction


function HATA takes nothing returns nothing
    local integer id= GetPlayerId(GetOwningPlayer(GetAttacker()))
    local unit u= udg_Hawkarray[id]
    
    local unit v= GetTriggerUnit()
    local timer te= (NewTimerEx(0)) // INLINED!!
    local location p= GetUnitLoc(u)
    local location q= GetUnitLoc(v)
    local real inc= DistanceBetweenPoints(p, q) / 15
    local location p1= GetUnitLoc(GetAttacker())
    local real ang= 0

  call DisableTrigger(GetTriggeringTrigger())


         call IssueImmediateOrder(u, "stop")
         call SetUnitFacingToFaceLocTimed(u, q, 0)
         call TriggerSleepAction(0.6)
         set ang=GetUnitFacing(u)

   if ( inc < 20 ) then
      set inc=20
   endif

   if ( inc > 70 ) then
      set inc=70
   endif

  call SetUnitFlyHeight(u, 20.00, 300)
    call SaveUnitHandleBJ(u, StringHashBJ("caster"), GetHandleIdBJ(te), udg_cache)
    call SaveRealBJ(inc, StringHashBJ("inc"), GetHandleIdBJ(te), udg_cache)
    call SaveRealBJ(ang, StringHashBJ("angle"), GetHandleIdBJ(te), udg_cache)
    call SaveLocationHandleBJ(p, StringHashBJ("p"), GetHandleIdBJ(te), udg_cache)


 
    call UnitAddAbility(u, 'A00M')
    call SetUnitAbilityLevel(u, 'A00M', 1)
    call SetUnitAnimationWithRarity(u, "walk", RARITY_RARE)

    call TimerStart(te, 0.02, true, function HATM)
    call TriggerSleepAction(0.6)
    call SetUnitFlyHeight(u, 240.00, 300)

    call UnitRemoveAbility(u, 'A00M')
    call IssuePointOrderLoc(u, "move", p1)
    call FlushChildHashtable(udg_cache, GetHandleIdBJ(te))
    call ReleaseTimer(te)
    set u=null
    set v=null
    set inc=0
    set ang=0
    call RemoveLocation(p)
    set p=null
    call RemoveLocation(q)
    set q=null
    call RemoveLocation(p1)
    set p1=null
    set te=null
    set hawkspeed[id]=1
    call EnableTrigger(GetTriggeringTrigger())

endfunction

//===========================================================================
function InitTrig_HAT takes nothing returns nothing
    set gg_trg_HAT=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_HAT, EVENT_PLAYER_UNIT_ATTACKED)
    call TriggerAddCondition(gg_trg_HAT, Condition(function HATC))
    call TriggerAddAction(gg_trg_HAT, function HATA)
endfunction


