// Trigger: Acquire
//
//   if IsUnitType(u, UNIT_TYPE_RANGED_ATTACKER) == true  then
//   //  call IssueTargetOrder(u,"smart",udg_PHero[id])
//   elseif IsUnitType(u, UNIT_TYPE_MELEE_ATTACKER) == true then
//   elseif IsUnitType(u, UNIT_TYPE_UNDEAD) == true then
//   elseif IsUnitType(u, UNIT_TYPE_ANCIENT) == true then
//   elseif IsUnitType(u, UNIT_TYPE_SLEEPING) == true then
//    
//   endif
//   
//   
//===========================================================================
function acquireCond takes nothing returns boolean
 local unit u= GetTriggerUnit()
 local boolean nobos= not ( GetUnitPointValue(u) == 300 )
 local boolean nohur= IsUnitInGroup(u, huracans) == false
 local boolean notax= IsUnitInGroup(u, taxbandits) == false
 local boolean nonov= GetUnitLevel(u) > 25
 local boolean nousr= not ( GetPlayerController(GetOwningPlayer(u)) == MAP_CONTROL_USER )
 local boolean noall= not ( GetOwningPlayer(u) == Player(10) )
 local boolean nomch= IsUnitType(u, UNIT_TYPE_MECHANICAL) == false

  
  set u=null
  return ( nohur and notax and nobos and nonov and nousr and noall and nomch )
endfunction

   
    
    
function GiantStomp takes unit u returns nothing
 local group g= CreateGroup()
 local boolexpr istru= Condition(function bool)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local unit gu
    

 call DestroyEffect(AddSpecialEffect(warstompfx, x, y))
    
 call GroupClear(g)
 call GroupEnumUnitsInRange(g, x, y, 250, istru)

call DestroyBoolExpr(istru)
set istru=null
loop

   set gu=FirstOfGroup(g)
   exitwhen gu == null
   if IsUnitEnemy(gu, GetOwningPlayer(u)) then
     
         
      set bj_lastCreatedUnit=CreateUnit(GetOwningPlayer(u), 'n059', x, y, 0)
     call IssueTargetOrder(bj_lastCreatedUnit, "creepthunderbolt", gu)
     call UnitApplyTimedLife(bj_lastCreatedUnit, 'BTLF', 3)
     
   // call SetUnitTimeScalePercent( gu, 0.00 )
    
   endif
   call GroupRemoveUnit(g, gu)
   set gu=null
endloop

call DestroyGroup(g)
set g=null

endfunction

function madbeast takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real dist= LoadReal(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i= LoadInteger(hts, GetHandleId(t), 7)
 
local real xi= LoadReal(hts, GetHandleId(t), 8) + it
local real height= dist / 2.5
local real h= GetParabolaZ(xi , dist , height)

 
 set x=x + it * Cos(angle * bj_DEGTORAD)
 set y=y + it * Sin(angle * bj_DEGTORAD)

 call SetUnitFlyHeight(a, h, 0)
 //call SetUnitPosition(a,x,y)
 call SetUnitX(a, x)
 call SetUnitY(a, y)

 
 if h < 1 then
  call SetUnitFlyHeight(a, 0, 1)
  call PauseUnit(a, false)
  call SetUnitPathing(a, true)
  call SetUnitTimeScale(a, 1)

   call PauseTimer(t)
  //call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\OrbOfDeath\\OrbOfDeathMissile.mdl",a,"origin"))
  // call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl",GetUnitX(a),GetUnitY(a) ))   
   if IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) then //false
     loop
       exitwhen IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) == false
          call TriggerSleepAction(0.3)
          set x=x + 32 * Cos(angle * bj_DEGTORAD)
          set y=y + 32 * Sin(angle * bj_DEGTORAD)

     endloop
    call SetUnitX(a, x)
    call SetUnitY(a, y)
     
  endif
 
 
 call FlushChildHashtable(hts, GetHandleId(t))
 call ReleaseTimer(t)
  
      if IsUnitInGroup(a, giantbeast) == true then
       call GiantStomp(a)
       call TriggerSleepAction(1)
       call DestroyEffect(AddSpecialEffectTarget(roarfx, a, "chest"))
      else
       call DestroyEffect(AddSpecialEffect(flakfx, x, y))
      endif

  else
  call SaveReal(hts, GetHandleId(t), 2, x)
  call SaveReal(hts, GetHandleId(t), 3, y)
 // call SaveReal(hts,GetHandleId(t),6,inc)  
  //call SaveReal(hts,GetHandleId(t),5,angle_t)  
      call SaveReal(hts, GetHandleId(t), 8, xi)
 endif
set a=null
set t=null

endfunction


function MadSetup takes unit u,unit a returns nothing
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real acuracy= GetRandomReal(150, 450)
 local real distance= SquareRoot(dx * dx + dy * dy) - acuracy
 local real it= distance / 45
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx) - 180
 local timer t= null
 local integer dec= 10

  if distance > 2048 or distance < 0 then
 return
endif
 
 set t=(NewTimerEx(0)) // INLINED!!
 
 if IsUnitType(u, UNIT_TYPE_GIANT) == true then
   set distance=distance + acuracy / 2
 endif
// call DestroyEffect(AddSpecialEffect(THUNDER,x,y))
 call DestroyEffect(AddSpecialEffect(seffectjump, x, y))
 call SetUnitFacing(u, angle)
// call SetUnitAnimation(u,"Attack")
 call SetUnitTimeScale(u, 0.6)


 call UnitAddAbilityBJ('Amrf', u)
 call UnitRemoveAbilityBJ('Amrf', u)
   
 call SetUnitPathing(u, false)
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, x)
 call SaveReal(hts, GetHandleId(t), 3, y)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveReal(hts, GetHandleId(t), 8, 0)

 call TimerStart(t, 0.02, true, function madbeast)


 set t=null
call TriggerSleepAction(7)
 if IsUnitType(u, UNIT_TYPE_GIANT) == true then
   call GroupRemoveUnit(giantbeast, u)
 else
  call GroupRemoveUnit(crazybeast, u)
 endif
 
endfunction

//==================================================0sneakers functions========================================



function bsnkcicle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real dist= LoadReal(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i= LoadInteger(hts, GetHandleId(t), 7)
 
local real xi= LoadReal(hts, GetHandleId(t), 8) + it
local real height= dist / 3
local real h= GetParabolaZ(xi , dist , height)

 
 set x=x + it * Cos(angle * bj_DEGTORAD)
 set y=y + it * Sin(angle * bj_DEGTORAD)

 call SetUnitFlyHeight(a, h, 0)
 //call SetUnitPosition(a,x,y)
 if IsTerrainWalkable(x , y) then
    call SetUnitX(a, x)
    call SetUnitY(a, y)
endif
 

 
 
 if h < 1 or GetUnitState(a, UNIT_STATE_LIFE) < 0.4 then
  call SetUnitFlyHeight(a, 0, 1)
  //call PauseUnit(a,false)
  call SetUnitPathing(a, true)
  call SetUnitTimeScale(a, 1)

  call UnitRemoveAbility(a, 'A0HQ') //evasion 
  //call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\OrbOfDeath\\OrbOfDeathMissile.mdl",a,"origin"))
  // call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl",GetUnitX(a),GetUnitY(a) ))   
  call DestroyEffect(AddSpecialEffect(flakfx, x, y))
  call GroupAddUnit(aggresiveUnits, a)
  call IssueImmediateOrder(a, "stop")
  call PauseTimer(t)
 
    if IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) then //false
     loop
       exitwhen IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) == false
          call TriggerSleepAction(0.3)
          set x=x + 32 * Cos(angle * bj_DEGTORAD)
          set y=y + 32 * Sin(angle * bj_DEGTORAD)

     endloop
    call SetUnitX(a, x)
    call SetUnitY(a, y)
     
  endif
 
 call FlushChildHashtable(hts, GetHandleId(t))
 call ReleaseTimer(t)


  else
  call SaveReal(hts, GetHandleId(t), 2, x)
  call SaveReal(hts, GetHandleId(t), 3, y)
 // call SaveReal(hts,GetHandleId(t),6,inc)  
  //call SaveReal(hts,GetHandleId(t),5,angle_t)  
      call SaveReal(hts, GetHandleId(t), 8, xi)
 endif
set a=null
set t=null

endfunction


function bsnkSetup takes unit u,unit a returns nothing
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real acuracy= GetRandomReal(150, 250)
 local real distance= SquareRoot(dx * dx + dy * dy) + acuracy
 local real it= distance / 35
 local integer i= 0
 local real rangle= bj_RADTODEG * Atan2(dy, dx)
 local real angle= GetRandomReal(rangle - 60, rangle + 60)
 local timer t= null
 local integer dec= 10

 
 // call DestroyEffect(AddSpecialEffect(THUNDER,x,y))

// call SetUnitAnimation(u,"Attack")
 call UnitAddAbility(u, 'A0HQ') //evasion 
 
 call SetUnitFacing(u, angle)
 call SetUnitAnimation(u, "stand")
 call TriggerSleepAction(0.5)
 
 set ux=GetUnitX(a)
 set uy=GetUnitY(a)
 set x=GetUnitX(u)
 set y=GetUnitY(u)
 set dx=x - ux
 set dy=y - uy
 set acuracy=GetRandomReal(150, 250)
 set distance=SquareRoot(dx * dx + dy * dy) + acuracy
 set it=distance / 35 //inc = 20

 
 if distance > 2048 or distance < 0 then
 return
endif
 
 call SetUnitPathing(u, false)

 
 // call UnitChat("I'm vanoshing",u)
 call DestroyEffect(AddSpecialEffect(seffectjump, x, y))
 
 set t=(NewTimerEx(0)) // INLINED!!
 
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, x)
 call SaveReal(hts, GetHandleId(t), 3, y)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveReal(hts, GetHandleId(t), 8, 0)

 call TimerStart(t, 0.02, true, function bsnkcicle)


 set t=null


endfunction



function Ambushcicle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real dist= LoadReal(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i= LoadInteger(hts, GetHandleId(t), 7)
 
local real xi= LoadReal(hts, GetHandleId(t), 8) + it
local real height= dist / 2.5
local real h= GetParabolaZ(xi , dist , height)

 
 set x=x + it * Cos(angle * bj_DEGTORAD)
 set y=y + it * Sin(angle * bj_DEGTORAD)

 call SetUnitFlyHeight(a, h, 0)
 //call SetUnitPosition(a,x,y)
 call SetUnitX(a, x)
 call SetUnitY(a, y)

 
 if h < 1 then
  call SetUnitFlyHeight(a, 0, 0)
  call SetUnitPathing(a, true)
  call SetUnitTimeScale(a, 1)
 // call UnitChat("I'm a ambusher",a)
 
 
  
  
  call DestroyEffect(AddSpecialEffect(flakfx, x, y))

  call PauseTimer(t)

  
   if IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) then //false
     loop
       exitwhen IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) == false
          call TriggerSleepAction(0.3)
          set x=x + 32 * Cos(angle * bj_DEGTORAD)
          set y=y + 32 * Sin(angle * bj_DEGTORAD)

     endloop
    call SetUnitX(a, x)
    call SetUnitY(a, y)
     
  endif

  call FlushChildHashtable(hts, GetHandleId(t))
  call ReleaseTimer(t)

  else
  call SaveReal(hts, GetHandleId(t), 2, x)
  call SaveReal(hts, GetHandleId(t), 3, y)
  call SaveReal(hts, GetHandleId(t), 8, xi)
 endif
set a=null
set u=null
set t=null

endfunction


function AmbushStp takes unit u,unit a returns nothing
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real acuracy= GetRandomReal(150, 450)
 local real distance= SquareRoot(dx * dx + dy * dy) - acuracy
 local real it= distance / 45
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx) - 180
 local timer t= null
 local integer dec= 10
 local real time= I2R(GetRandomInt(2, 6))

 
// call DestroyEffect(AddSpecialEffect(THUNDER,x,y))
// call DestroyEffect(AddSpecialEffect(toonfx,x,y)) 

if distance > 2048 or distance < 0 then
 return
endif

// call SetUnitAnimation(u,"Attack")
 call SetUnitTimeScale(u, 0.6)


 call UnitAddAbilityBJ('Amrf', u)
 call UnitRemoveAbilityBJ('Amrf', u)
  call UnitAddAbility(u, 'A0IU') //Healt points   
  call UnitAddAbility(u, 'A026') //magic reduction
  call UnitAddAbility(u, 'A0BA') //speed 100
  call UnitAddAbility(u, 'A03J') //atk bonus 250
  call UnitAddAbility(u, 'A049') //armor 216  
 set t=(NewTimerEx(0)) // INLINED!!
  
 call SetUnitPathing(u, false)
 call SaveUnitHandle(hts, GetHandleId(t), 0, a)
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, x)
 call SaveReal(hts, GetHandleId(t), 3, y)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveReal(hts, GetHandleId(t), 8, 0)

 call TimerStart(t, 0.02, true, function Ambushcicle)


 set t=null
 

  call TriggerSleepAction(time)
  
  set ux=GetUnitX(a)
  set uy=GetUnitY(a)
  set x=GetUnitX(u)
  set y=GetUnitY(u)
  set dx=x - ux
  set dy=y - uy
 
  set distance=SquareRoot(dx * dx + dy * dy)
 
  
  
           if GetUnitState(u, UNIT_STATE_LIFE) > 0.4 and distance < 1100 then
               call bsnkSetup(u , a)
           endif

//call TriggerSleepAction(8)
//call GroupRemoveUnit(Ambushgroup,u)
endfunction

//=========================sneakers setup========================================================

function Sneaker takes nothing returns nothing

 local timer t= GetExpiredTimer()
 local unit u= LoadUnitHandle(AiHash, GetHandleId(t), 1)
 local integer id= LoadInteger(AiHash, GetHandleId(t), 2)
 local boolean atk= LoadBoolean(AiHash, GetHandleId(t), 3)
 local boolean run= LoadBoolean(AiHash, GetHandleId(t), 4)
 local integer smart=6 * LoadInteger(AiHash, GetHandleId(u), 6)
 local real x1
 local real y1
 local real x2
 local real y2
 local real dx
 local real dy
 local real distance
 local real angle
 local real atspd
 local real saferange
 local real snkangle
 local real x
 local real y
 local real fov
 local real msp= GetUnitMoveSpeed(u) + 2
 
 
  if GetUnitStatePercent(udg_PHero[id], UNIT_STATE_LIFE, UNIT_STATE_MAX_LIFE) < 55.0 and GetUnitState(udg_PHero[id], UNIT_STATE_LIFE) > 0.4 and IsUnitInvisible(udg_PHero[id], GetOwningPlayer(u)) == false then
       
      call SetUnitMoveSpeed(u, msp)
      call IssueTargetOrder(u, "attack", udg_PHero[id])
      set atk=true
    else
    set atk=false
    endif
 
 if atk == false and run == false then
     set x1=GetUnitX(u)
     set y1=GetUnitY(u)
     set x2=GetUnitX(udg_PHero[id])
     set y2=GetUnitY(udg_PHero[id])
     set dx=x2 - x1
     set dy=y2 - y1
     set distance=SquareRoot(dx * dx + dy * dy)
     set angle=180 + bj_RADTODEG * Atan2(dy, dx)
     set atspd=GetUnitMoveSpeed(udg_PHero[id])
     set saferange=GetUnitAcquireRange(udg_PHero[id]) + atspd
     set fov=100 - ( distance * 100 ) / saferange
     
 
     
                 if fov < 0 then
                   set fov=0
                 endif
     
     set fov=( 90 * fov ) / 100
     set snkangle=GetRandomReal(angle - fov, angle + fov)
     set x=x2 + saferange * Cos(snkangle * bj_DEGTORAD)
     set y=y2 + saferange * Sin(snkangle * bj_DEGTORAD)
     call IssuePointOrder(u, "smart", x, y)
    
               if distance > ( 1.6 * saferange ) then
               
                call IssueImmediateOrder(u, "stop")
                call UnitRemoveAbility(u, 'A0IT')
                call FlushChildHashtable(AiHash, GetHandleId(t))
                //call RemoveSavedHandle(AiHash,GetHandleId(u),GetHandleId(sneakers))
                call FlushChildHashtable(AiHash, GetHandleId(u))
                set sneakerscnt[id]=sneakerscnt[id] - 1
                call PauseTimer(t)
                call ReleaseTimer(t)
                call GroupRemoveUnit(sneakers, u)
                call SetUnitMoveSpeed(u, GetUnitDefaultMoveSpeed(u))
                set t=null
                set u=null
                return
             endif
     
 endif
 call SaveBoolean(AiHash, GetHandleId(t), 3, atk)
 
 set t=null
 set u=null
 
 
endfunction


//===================stingers============================================

function Stingercl takes nothing returns nothing

 local timer t= GetExpiredTimer()
 local unit u= LoadUnitHandle(AiHash, GetHandleId(t), 1)
 local integer id= LoadInteger(AiHash, GetHandleId(t), 2)
 local boolean atk= LoadBoolean(AiHash, GetHandleId(t), 3)
 local boolean run= LoadBoolean(AiHash, GetHandleId(t), 4)
 local real x1
 local real y1
 local real x2
 local real y2
 local real dx
 local real dy
 local real distance
 local real angle
 local real atspd
 local real saferange
 local real snkangle
 local real x
 local real y
 local real fov
 local real msp= GetUnitMoveSpeed(u) + 25
 
 
  if GetUnitStatePercent(udg_PHero[id], UNIT_STATE_LIFE, UNIT_STATE_MAX_LIFE) < 55.0 and GetUnitState(udg_PHero[id], UNIT_STATE_LIFE) > 0.4 then
       
      call SetUnitMoveSpeed(u, msp)
      call IssueTargetOrder(u, "attack", udg_PHero[id])
      set atk=true
    else
    set atk=false
    endif
 
 if atk == false and run == false then
     set x1=GetUnitX(u)
     set y1=GetUnitY(u)
     set x2=GetUnitX(udg_PHero[id])
     set y2=GetUnitY(udg_PHero[id])
     set dx=x2 - x1
     set dy=y2 - y1
     set distance=SquareRoot(dx * dx + dy * dy)
     
     set saferange=GetUnitAcquireRange(u)

     
                 if distance / saferange < 0.65 then
                 
                         set angle=180 + bj_RADTODEG * Atan2(dy, dx)
                         set atspd=GetUnitMoveSpeed(udg_PHero[id])
                         set fov=100 - ( distance * 100 ) / saferange
                              
                                     if fov < 0 then
                                       set fov=0
                                     endif
                         
                         set fov=( 90 * fov ) / 100
                         set snkangle=GetRandomReal(angle - fov, angle + fov)
                         set x=x2 + saferange * Cos(snkangle * bj_DEGTORAD)
                         set y=y2 + saferange * Sin(snkangle * bj_DEGTORAD)
                         call IssuePointOrder(u, "smart", x, y)
                 
                 endif
    
               if distance > ( 2.3 * saferange ) then
               
                call IssueImmediateOrder(u, "stop")
                call UnitRemoveAbility(u, 'A0IT')
                call FlushChildHashtable(AiHash, GetHandleId(t))
                call FlushChildHashtable(AiHash, GetHandleId(u))
                 call PauseTimer(t)
                call ReleaseTimer(t)
                call GroupRemoveUnit(stingers, u)
                call SetUnitMoveSpeed(u, GetUnitDefaultMoveSpeed(u))
                set t=null
                set u=null
                return
             endif
     
 endif
 call SaveBoolean(AiHash, GetHandleId(t), 3, atk)
 
 set t=null
 set u=null
 
 
endfunction


function acquireAct takes nothing returns nothing
local trigger trg= GetTriggeringTrigger()
 local integer id= LoadInteger(HTsets, GetHandleId(trg), 1) - 7
 local unit u= GetTriggerUnit()
 local real face= GetUnitFacing(u)
 local real hface= GetUnitFacing(udg_PHero[id])

 local integer fear= 3 * LoadInteger(AiHash, GetHandleId(u), 2)
 local integer smart=6 * LoadInteger(AiHash, GetHandleId(u), 6)
 local integer aggre=6 * LoadInteger(AiHash, GetHandleId(u), 1)
 local integer rage= 5 * ( 10 - LoadInteger(AiHash, GetHandleId(u), 2) )
 local integer idiot=3 * ( 10 - LoadInteger(AiHash, GetHandleId(u), 6) )
 local integer sneak= fear + smart
 local integer crazy= GetUnitLevel(u) - ( GetUnitLevel(udg_PHero[id]) / 2 ) + rage + idiot
 local integer giant= rage + smart
 local integer stinger= aggre + smart
 local timer snkt
 local timer stgt
 local boolean atk= false
 local boolean run= false
 local real nspd= GetUnitMoveSpeed(udg_PHero[id]) - 10
 
  if sneakerscnt[id] < 3 and IsUnitInGroup(u, sneakers) == false and GetRandomInt(0, SNEAK_LIMIT) < sneak then
   
   set sneakerscnt[id]=sneakerscnt[id] + 1
   call GroupRemoveUnit(aggresiveUnits, u)
   call GroupAddUnit(sneakers, u)
   call UnitAddAbility(u, 'A0IT')
   call SetUnitMoveSpeed(u, nspd)
   set snkt=(NewTimerEx(0)) // INLINED!!
   call SaveUnitHandle(AiHash, GetHandleId(snkt), 1, u)
   call SaveInteger(AiHash, GetHandleId(snkt), 2, id)
   call SaveBoolean(AiHash, GetHandleId(snkt), 3, atk)
   call SaveBoolean(AiHash, GetHandleId(snkt), 4, run)
   call SaveTimerHandle(AiHash, GetHandleId(u), GetHandleId(sneakers), snkt)
   call TimerStart(snkt, 0.6, true, function Sneaker)
  elseif GetUnitDefaultAcquireRange(u) != 616.00 and IsUnitInGroup(u, aggresiveUnits) == false and IsUnitInGroup(u, crazybeast) == false and IsUnitInGroup(u, sneakers) == false and IsUnitType(u, UNIT_TYPE_ANCIENT) == false and GetRandomInt(0, CRAZY_LIMIT) < crazy then
  
     if IsUnitType(u, UNIT_TYPE_SLEEPING) == true then
        call UnitWakeUp(u)
     endif
  
   call GroupAddUnit(crazybeast, u)
   call UnitAddAbility(u, 'A0IT')
   call IssueTargetOrder(u, "attack", udg_PHero[id])
   call TriggerSleepAction(1)
   call MadSetup(u , udg_PHero[id])
   
  elseif IsUnitType(u, UNIT_TYPE_GIANT) == true and GetUnitDefaultAcquireRange(u) != 616.00 and IsUnitInGroup(u, aggresiveUnits) == false and IsUnitInGroup(u, giantbeast) == false and IsUnitInGroup(u, sneakers) == false and IsUnitInGroup(u, crazybeast) == false and GetRandomInt(0, GIANT_LIMIT) < giant then
 
     if IsUnitType(u, UNIT_TYPE_SLEEPING) == true then
        call UnitWakeUp(u)
     endif
 
   call GroupAddUnit(giantbeast, u)
   call IssueTargetOrder(u, "attack", udg_PHero[id])
   call TriggerSleepAction(1)
   call MadSetup(u , udg_PHero[id])
   
  elseif IsUnitType(u, UNIT_TYPE_RANGED_ATTACKER) == true and GetUnitDefaultAcquireRange(u) != 616.00 and IsUnitInGroup(u, sneakers) == false and IsUnitInGroup(u, crazybeast) == false and IsUnitInGroup(u, aggresiveUnits) == false and IsUnitInGroup(u, stingers) == false and IsUnitInGroup(u, giantbeast) == false and GetRandomInt(0, STING_LIMIT) < stinger then
 
     if IsUnitType(u, UNIT_TYPE_SLEEPING) == true then
        call UnitWakeUp(u)
     endif
 
   call GroupAddUnit(stingers, u)
   call UnitAddAbility(u, 'A0IT')
   call SetUnitMoveSpeed(u, nspd)
   set stgt=(NewTimerEx(0)) // INLINED!!
   call SaveUnitHandle(AiHash, GetHandleId(stgt), 1, u)
   call SaveInteger(AiHash, GetHandleId(stgt), 2, id)
   call SaveBoolean(AiHash, GetHandleId(stgt), 3, atk)
   call SaveBoolean(AiHash, GetHandleId(stgt), 4, run)
   call SaveTimerHandle(AiHash, GetHandleId(u), GetHandleId(stingers), stgt)
   call TimerStart(stgt, 0.6, true, function Stingercl)
   

  elseif IsUnitInGroup(u, aggresiveUnits) == false and IsUnitInGroup(u, Ambushgroup) == false and IsUnitInGroup(u, giantbeast) == false and IsUnitInGroup(u, sneakers) == false and IsUnitInGroup(u, crazybeast) == false and GetRandomInt(0, AGGRE_LIMIT) < aggre then
     
     if IsUnitType(u, UNIT_TYPE_SLEEPING) == true then
        call UnitWakeUp(u)
     endif
     
     call GroupAddUnit(Ambushgroup, u)
     call IssueTargetOrder(u, "attack", udg_PHero[id])
     call TriggerSleepAction(1)
     call AmbushStp(u , udg_PHero[id])
     call SetUnitMoveSpeed(u, nspd)

 endif
   
 // call DisplayTimedTextToPlayer(Player(id),0,0,3,"Triggered")

  set u=null
  set trg=null
  set snkt=null
  set stgt=null

endfunction

//===========================================================================
function InitTrig_Acquire takes nothing returns nothing
local integer i= 0

 loop
 exitwhen i > 7
    set s__enemyAcquire[i]= CreateTrigger()
    
    call SaveInteger(HTsets, GetHandleId(s__enemyAcquire[i]), 1, i + 7)
    
    call TriggerAddCondition(s__enemyAcquire[i], Condition(function acquireCond))
    call TriggerAddAction(s__enemyAcquire[i], function acquireAct)
    set i=i + 1
    endloop
endfunction


//===========================================================================
// Trigger: rangedPrevent
//===========================================================================
function Trig_rangedPrevent_Conditions takes nothing returns boolean
   local unit u= GetTriggerUnit()
   local boolean isranged= IsUnitType(u, UNIT_TYPE_RANGED_ATTACKER) == true and IsUnitInGroup(u, rangedUnits) == false and IsUnitInGroup(u, sneakers) == false
   set u=null
   return isranged
endfunction

  
 
function backcicle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real dist= LoadReal(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i= LoadInteger(hts, GetHandleId(t), 7)
 
local real xi= LoadReal(hts, GetHandleId(t), 8) + it
local real height= dist / 3
local real h= GetParabolaZ(xi , dist , height)

 
 set x=x + it * Cos(angle * bj_DEGTORAD)
 set y=y + it * Sin(angle * bj_DEGTORAD)

call SetUnitFlyHeight(a, h, 0)
 //call SetUnitPosition(a,x,y)
 if IsTerrainWalkable(x , y) then
    call SetUnitX(a, x)
    call SetUnitY(a, y)
endif
 //call DestroyEffect(AddSpecialEffect(seffectjump,x,y))
 
 if it < 1 or h < 1 or GetUnitState(a, UNIT_STATE_LIFE) < 0.4 then

  call SetUnitFlyHeight(a, 0, 0)
  //call PauseUnit(a,false)
  call SetUnitPathing(a, true)
  call SetUnitTimeScale(a, 1)
  call UnitRemoveAbility(a, 'A0HQ') //evasion 
  
  call PauseTimer(t)
  call DestroyEffect(AddSpecialEffect(flakfx, x, y))
  
  //call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\OrbOfDeath\\OrbOfDeathMissile.mdl",a,"origin"))
  // call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl",GetUnitX(a),GetUnitY(a) ))   
      
         if IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) then //false
         loop
           exitwhen IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) == false
              call TriggerSleepAction(0.3)
              set x=x + 32 * Cos(angle * bj_DEGTORAD)
              set y=y + 32 * Sin(angle * bj_DEGTORAD)

         endloop
        call SetUnitX(a, x)
        call SetUnitY(a, y)
         
      endif
  
  call FlushChildHashtable(hts, GetHandleId(t))
  call ReleaseTimer(t)



  else
  call SaveReal(hts, GetHandleId(t), 2, x)
  call SaveReal(hts, GetHandleId(t), 3, y)
  
  set it=it - 1
  call SaveReal(hts, GetHandleId(t), 5, it)
 // call SaveReal(hts,GetHandleId(t),6,inc)  
  //call SaveReal(hts,GetHandleId(t),5,angle_t)  
      call SaveReal(hts, GetHandleId(t), 8, xi)
 endif
set a=null
set t=null

endfunction


function backSetup takes unit u,unit a returns nothing
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real acuracy= GetRandomReal(150, 250)
 local real distance= SquareRoot(dx * dx + dy * dy) / 3 + acuracy
 local real it= distance / 20
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer dec= 10

 call UnitAddAbilityBJ('Amrf', u)
 call UnitRemoveAbilityBJ('Amrf', u)
   
 call SetUnitPathing(u, false)
 

 
   call UnitAddAbility(u, 'A0HQ') //evasion 
  //  call UnitRemoveAbility(u,'A0HQ') //evasion 
    
 call SetUnitPathing(u, false)
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, x)
 call SaveReal(hts, GetHandleId(t), 3, y)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveReal(hts, GetHandleId(t), 8, 0)

 call TimerStart(t, 0.02, true, function backcicle)


 set t=null
 call TriggerSleepAction(7)
 call GroupRemoveUnit(backing, u)

endfunction




function Trig_rangedPrevent_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local unit a= GetAttacker()
 local real x1= GetUnitX(u)
 local real y1= GetUnitY(u)
 local real x2= GetUnitX(a)
 local real y2= GetUnitY(a)
 local real dx= x2 - x1
 local real dy= y2 - y1
 local real distance= SquareRoot(dx * dx + dy * dy)
 local real angle=180 + bj_RADTODEG * Atan2(dy, dx)
 local real x
 local real y
 local real spd= GetUnitMoveSpeed(u)
 local real atspd= GetUnitMoveSpeed(a)
 local real erange= GetUnitAcquireRange(a) + atspd + 50
 local real safereq= erange - distance
 local real rtime= 0.3 + safereq / ( spd + 1 )
 local real nangle= GetRandomReal(angle - 45, angle + 45)
 local integer fear= 7 * LoadInteger(AiHash, GetHandleId(u), 2)
 local integer smart=6 * LoadInteger(AiHash, GetHandleId(u), 6)
 
  if IsUnitInGroup(u, Ambushgroup) == true then
   set fear=fear * 3
 endif
 
 
 
 if GetRandomInt(0, 99) < fear and GetUnitState(a, UNIT_STATE_LIFE) > GetUnitState(u, UNIT_STATE_LIFE) then
 
 call GroupAddUnit(rangedUnits, u)
 
 if distance < 500 then
 
  if GetRandomInt(0, 119) < smart and IsUnitInGroup(u, backing) == false and IsUnitType(u, UNIT_TYPE_ANCIENT) == false then
  
   call GroupAddUnit(backing, u)
  // call TriggerSleepAction(0.2)
   call backSetup(u , a)
   else
   call IssueTargetOrder(u, "attack", a)
   endif
 
 elseif spd > atspd then
  set x=x2 + erange * Cos(angle * bj_DEGTORAD)
  set y=y2 + erange * Sin(angle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(rtime)
  call IssueTargetOrder(u, "attack", a)

 elseif ( distance * 2 ) > erange then
  set x=x1 + safereq * Cos(angle * bj_DEGTORAD)
  set y=y1 + safereq * Sin(angle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(rtime)
  call IssueTargetOrder(u, "attack", a)
 else
  set x=x1 + erange * Cos(nangle * bj_DEGTORAD)
  set y=y1 + erange * Sin(nangle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(1 + rtime)
  call IssueTargetOrder(u, "attack", a)
 endif
 
   call TriggerSleepAction(0.6)
   call GroupRemoveUnit(rangedUnits, u)
 endif
 
set a=null
set u=null


endfunction

//===========================================================================
function InitTrig_rangedPrevent takes nothing returns nothing
    local integer index= 8
    set gg_trg_rangedPrevent=CreateTrigger()
    
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_rangedPrevent, Player(index), EVENT_PLAYER_UNIT_ATTACKED, null)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
    call TriggerAddCondition(gg_trg_rangedPrevent, Condition(function Trig_rangedPrevent_Conditions))
    call TriggerAddAction(gg_trg_rangedPrevent, function Trig_rangedPrevent_Actions)
 
endfunction


