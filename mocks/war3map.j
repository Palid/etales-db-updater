function mmove takes nothing returns nothing
local real x
local real y


 if GetUnitState(udg_BOSS[3], UNIT_STATE_LIFE) > 0.305 then
  set x=GetUnitX(udg_BOSS[3])
  set y=GetUnitY(udg_BOSS[3])
  set zombx=GetRandomReal(x - 600, x + 600)
  set zomby=GetRandomReal(y - 600, y + 600)
  
  if not ( IsPointInRegion(misha_area, zombx, zomby) ) then
  set zombx=- 10300
  set zomby=13670
 endif
  

  
  call IssuePointOrder(udg_BOSS[3], "attack", zombx + GetRandomReal(- 150, 150), zomby + GetRandomReal(- 150, 150))
  
  call ForGroup(MishaGroup, function mishamover)

 endif


endfunction

