    set gg_trg_initplayer=CreateTrigger()
    call TriggerRegisterTimerEvent(gg_trg_initplayer, 20.00, false)
    call TriggerAddAction(gg_trg_initplayer, function Trig_initplayer_Actions)
endfunction


//===========================================================================
// Trigger: CreateHeroM
//===========================================================================
function Trig_CreateHeroM_Conditions takes nothing returns boolean
    return GetUnitTypeId(GetTriggerUnit()) == 'e00K'
endfunction

function herobool takes nothing returns boolean
return true
endfunction

function Trig_CreateHeroM_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetEnteringUnit()))
 local unit u= CreateUnitAtLoc(GetOwningPlayer(GetEnteringUnit()), 'H00H', udg_RevivalPoints[id], 90.00)
 local unit v= CreateUnitAtLoc(GetOwningPlayer(GetEnteringUnit()), 'n011', udg_RevivalPoints[id], 90.00)
    call UnitAddItemById(u, 'I0H3')
    set udg_PHero[id]=u
     call SetHeroLevel(udg_PHero[id], 3, false)
    call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
    call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
    call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
    call AddProfaner(id) //Trigger registrado
    
    set prevlevel[id]=GetHeroLevel(udg_PHero[id])
    
    set udg_Slave[id]=v
    call RemoveUnit(GetEnteringUnit())
    call ResetToGameCameraForPlayer(GetOwningPlayer(GetEnteringUnit()), 0)
    call PanCameraToTimedLocForPlayer(GetOwningPlayer(GetEnteringUnit()), udg_encyp, 0)
      if nightime == true then
      // call DestroyEffect(lights[id])
       set lights[id]=AddSpecialEffectTarget("Light.mdx", udg_PHero[id], "origin")
      endif
    
    if boardCreated[id] == false then
        call NewBoard(id)
        endif
    
    // set ksquest[id] = SetupQuest(id,null,"BUILDING A HERO","Get 300 kill points to be allowed for next promotion","0","/"+I2S(SetNext(id)*300),0,qty[1])

set u=null
set v=null
endfunction

