  function BuildAiPerfil takes unit u returns nothing
   local integer level= GetUnitLevel(u) / 10
   local integer aggr= GetRandomInt(0, 9) + level
   local integer fear= GetRandomInt(0, 9)
   local integer dgold= GetRandomInt(0, 9) + level
   local integer dpoth= GetRandomInt(0, 9) + level
   local integer dweap= GetRandomInt(0, 9) + level
   local integer smart= GetRandomInt(0, 9) + level
   local integer dtres= GetRandomInt(0, 9) + level
   local integer misc= GetRandomInt(0, 9) + level
   

   
   
   call UnitAddAbility(u, 'A0CT') //unitinventory
   call SaveInteger(AiHash, GetHandleId(u), 1, aggr)
   call SaveInteger(AiHash, GetHandleId(u), 2, fear)
   call SaveInteger(AiHash, GetHandleId(u), 3, dgold)
   call SaveInteger(AiHash, GetHandleId(u), 4, dpoth)
   call SaveInteger(AiHash, GetHandleId(u), 5, dweap)
   call SaveInteger(AiHash, GetHandleId(u), 6, smart)
   call SaveInteger(AiHash, GetHandleId(u), 7, dtres)
   call SaveInteger(AiHash, GetHandleId(u), 8, misc)
  
  endfunction
   
   
   
    function enabledmg takes unit u returns nothing
    call GroupAddUnit(udg_HasDMGevent, u)
    call GroupAddUnit(udg_Spelledg, u)
    call TriggerRegisterUnitEvent(gg_trg_SPDMG, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMG, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_LSDMG, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_BTDMG, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_MGDMG, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_PCDMG, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhawk, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhawkb, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhater, u, EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(gg_trg_DMGhaterb, u, EVENT_UNIT_DAMAGED)
    
    call BuildAiPerfil(u)
    
    endfunction
    
    function frag takes nothing returns integer
    local integer i= GetRandomInt(37, 41)
    return i
    endfunction

    function gema takes nothing returns integer
    local integer r= GetRandomInt(1, 4)
    local integer i= GetRandomInt(30, 34)
    if r == 3 then
    return i
    endif
    return 1500 //nothing
    endfunction
//for export functions
    function IsEasy takes unit u returns boolean
         return ( GetUnitTypeId(u) == EASY_UNIT )
    endfunction
    
    function IsNormal takes unit u returns boolean
         return ( GetUnitTypeId(u) == NORM_UNIT )
    endfunction
    
    function IsHard takes unit u returns boolean
         return ( GetUnitTypeId(u) == HARD_UNIT )
    endfunction
    
    function IsVHard takes unit u returns boolean
         return ( GetUnitTypeId(u) == VHRD_UNIT )
    endfunction
  
  //for setupfunctions
  
      function IsEEasy takes integer ID returns boolean
         return ( CreepT[ID] == 1 )
    endfunction
    
    function IsNNormal takes integer ID returns boolean
         return ( CreepT[ID] == 2 )
    endfunction
    
    function IsHHard takes integer ID returns boolean
         return ( CreepT[ID] == 3 )
    endfunction
    
    function IsVVHard takes integer ID returns boolean
         return ( CreepT[ID] == 4 )
    endfunction
    ///////
  
  
     function SetRespawnLoc takes integer nrect returns nothing
     //local region r = CreateRegion()
     local integer c_easyloc= EASY_SLOT
     local integer c_normloc= NORM_SLOT
     local integer c_hardloc= HARD_SLOT
     local integer c_vhrdloc= VHRD_SLOT
     
     local integer i= CreepIni[nrect] + 1
     local integer maxloc= CreepFin[nrect]
     
    
     //call RegionAddRect(r,rects[nrect])
     
    
     
     loop
     exitwhen i > maxloc
     
       
        
         if (CreepT[(i)] == 1) then // INLINED!!
            set c_easyloc=c_easyloc + 1
            call SaveLocationHandle(HTcreep, GetHandleId(rects[nrect]), c_easyloc, Location(CreepX[i], CreepY[i]))
          
        
        elseif (CreepT[(i)] == 2) then // INLINED!!
            set c_normloc=c_normloc + 1
            call SaveLocationHandle(HTcreep, GetHandleId(rects[nrect]), c_normloc, Location(CreepX[i], CreepY[i]))
         
        
        elseif (CreepT[(i)] == 3) then // INLINED!!
            set c_hardloc=c_hardloc + 1
            call SaveLocationHandle(HTcreep, GetHandleId(rects[nrect]), c_hardloc, Location(CreepX[i], CreepY[i]))
            
       
       elseif (CreepT[(i)] == 4) then // INLINED!!
            set c_vhrdloc=c_vhrdloc + 1
            call SaveLocationHandle(HTcreep, GetHandleId(rects[nrect]), c_vhrdloc, Location(CreepX[i], CreepY[i]))
            
            
       endif
        
       set i=i + 1
     endloop
     
     
  
     call SaveInteger(HTcreep, GetHandleId(rects[nrect]), EASY_SLOT, c_easyloc)
     call SaveInteger(HTcreep, GetHandleId(rects[nrect]), NORM_SLOT, c_normloc)
     call SaveInteger(HTcreep, GetHandleId(rects[nrect]), HARD_SLOT, c_hardloc)
     call SaveInteger(HTcreep, GetHandleId(rects[nrect]), VHRD_SLOT, c_vhrdloc)
      
    endfunction
    
    
 function InitializeSlot takes integer rectId returns nothing
        call SaveInteger(HTcreep, GetHandleId(rects[rectId]), EASY_UNIT_SLOT, EASY_UNIT_SLOT)
        call SaveInteger(HTcreep, GetHandleId(rects[rectId]), NORM_UNIT_SLOT, NORM_UNIT_SLOT)
        call SaveInteger(HTcreep, GetHandleId(rects[rectId]), HARD_UNIT_SLOT, HARD_UNIT_SLOT)
        call SaveInteger(HTcreep, GetHandleId(rects[rectId]), VHRD_UNIT_SLOT, VHRD_UNIT_SLOT)
 endfunction
 //=================================Set spawn unit  ==================== 
    function AddEasyCreep takes integer unitId,integer rectId returns nothing
     local integer slot=LoadInteger(HTcreep, GetHandleId(rects[rectId]), EASY_UNIT_SLOT) + 1
   //  call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"Current Easy unit slot in rect " + I2S(rectId) + " :" + I2S(slot))
     if ( slot < NORM_UNIT_SLOT ) then
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), slot, unitId)
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), EASY_UNIT_SLOT, slot)
     endif
    endfunction 
    
    function AddNormalCreep takes integer unitId,integer rectId returns nothing
     local integer slot= LoadInteger(HTcreep, GetHandleId(rects[rectId]), NORM_UNIT_SLOT) + 1
     if ( slot < HARD_UNIT_SLOT ) then
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), slot, unitId)
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), NORM_UNIT_SLOT, slot)
     endif
    endfunction
    
   function AddHardCreep takes integer unitId,integer rectId returns nothing
     local integer slot= LoadInteger(HTcreep, GetHandleId(rects[rectId]), HARD_UNIT_SLOT) + 1
     if ( slot < VHRD_UNIT_SLOT ) then
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), slot, unitId)
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), HARD_UNIT_SLOT, slot)
     endif
    endfunction
    
   function AddVHardCreep takes integer unitId,integer rectId returns nothing
     local integer slot= LoadInteger(HTcreep, GetHandleId(rects[rectId]), VHRD_UNIT_SLOT) + 1
     if ( slot < 120 ) then
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), slot, unitId)
       call SaveInteger(HTcreep, GetHandleId(rects[rectId]), VHRD_UNIT_SLOT, slot)
     endif
    endfunction

