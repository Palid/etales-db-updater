function Trig_ghosts_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()

    call SetUnitVertexColorBJ(u, 100, 100, 100.00, 65.00)
    call GroupAddUnit(cathedralunits, u)
    
    if GetUnitLevel(u) > 43 and GetRandomInt(0, 20) < 7 and EventRunning == true and TeamBonusUnit == null and Bnscnt < totalbns then
      call UnitAddAbility(u, 'A0JN') //team bonus ability true shot
      call UnitAddAbility(u, 'A0HZ') //health bonus
      call SetUnitVertexColorBJ(u, 100, 100, 10, 0) //no trasparente
      set TeamBonusUnit=u
      set Bnscnt=Bnscnt + 1
      call DisplayTimedTextToForce(teamEventForce, 10.00, "A new |cffffcc00Team Unit Bonus|r has been released!")
      call PlaySoundBJ(gg_snd_Bonus)
  
   
    endif
  set u=null
    
endfunction

