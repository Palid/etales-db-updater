        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
   // call TriggerRegisterAnyUnitEventBJ( gg_trg_promoteMinorFortune, EVENT_PLAYER_UNIT_PICKUP_ITEM )
    call TriggerAddCondition(gg_trg_promoteMinorFortune, Condition(function minforc))
    call TriggerAddAction(gg_trg_promoteMinorFortune, function minfora)
endfunction


