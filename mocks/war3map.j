function InitTrig_gd7 takes nothing returns nothing
    set gg_trg_gd7=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_gd7, gg_unit_u002_0545, EVENT_UNIT_DEATH)
    call TriggerAddAction(gg_trg_gd7, function Trig_gd7_Actions)
endfunction


