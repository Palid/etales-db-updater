    call TriggerAddAction(gg_trg_StaffeffectOFF, function Trig_StaffeffectOFF_Actions)
endfunction


//===========================================================================
// Trigger: bowoff
//===========================================================================
function bowc takes nothing returns boolean
     return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_PERMANENT )
endfunction

function bowa takes nothing returns nothing
    local integer prc= ModuloInteger(GetItemLevel(GetManipulatedItem()), 4200)

    local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))

    if ( prc < 13 ) then
     set piercebonus[id]=piercebonus[id] - prc
     
         if ( piercebonus[id] < 0 ) then
            set piercebonus[id]=0
         endif
   //  call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()),.75,.2,2,"Magic Bonus: "+R2S(1 + udg_magicBonus[id]) )
    endif
endfunction

