endfunction

function Trig_kend_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
local integer level= GetHeroLevel(udg_PHero[id])
if level < 21 then
  set koboldkiller[id]=true
endif
 call GroupRemoveUnit(koboldk, GetDyingUnit())
endfunction

