//===========================================================================
// Trigger: setuphelp
//===========================================================================
function Trig_setuphelp_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I05C' and IsUnitType(GetManipulatingUnit(), UNIT_TYPE_HERO) == true )
endfunction

function mdemonscape takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(questtm, GetHandleId(t), 0)
local unit d
local integer id= LoadInteger(questtm, GetHandleId(u), 1)
local integer questid= LoadInteger(questtm, GetHandleId(u), 2)
local real face= GetUnitFacing(u)
local real x= GetUnitX(u)
local real y= GetUnitY(u)

   if GetUnitState(u, UNIT_STATE_LIFE) < 0.3 then

     call PauseTimer(t)
     call ReleaseTimer(t)
     call FlushChildHashtable(questtm, GetHandleId(t))
     call FlushChildHashtable(questtm, GetHandleId(u))
     call TriggerSleepAction(0.02)
     call RemoveUnit(u)
     set t=null
     set u=null
   
     return
   else
    call IssuePointOrder(u, "move", minidemonx[id], minidemony[id])
    if ( GetLocalPlayer() == Player(id) ) then
        call PingMinimap(x, y, 1.5)
     endif

   endif


 
set t=null
set u=null
set d=null

endfunction


function Trig_setuphelp_Actions takes nothing returns nothing
local integer i= 0
local integer id= GetPlayerId(GetOwningPlayer(GetManipulatingUnit()))
local integer questid= 0
local unit wt= null
local unit wr= null
local unit md= null
local timer t


  call UnitChat("I want to help you!" , udg_PHero[id])
  call TriggerSleepAction(1.5)
    if ( GetUnitLevel(udg_PHero[id]) < 30 ) then
        call UnitChat("Sorry boy, you are too weak to do this work" , valdkeeper)
    elseif ( GetUnitLevel(udg_PHero[id]) > 60 ) then
        call UnitChat("Thanks for your offer, but we have enough helpers here." , valdkeeper)
    elseif valdsurvivors[id] == true then
        call UnitChat("You already have this work, If you want more work find another place that needs you" , valdkeeper)
    else
        set valdsurvivors[id]=true
        call SetUnitFacingToFaceUnitTimed(valdkeeper, udg_PHero[id], 0)
        call TriggerSleepAction(1)
        call UnitChat("Thanks man, we appreciate that you have come to give a hand" , valdkeeper)
        call TriggerSleepAction(2)
        
        
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Valdivia's Keeper says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Our problems grow fast any new day...")
        call TriggerSleepAction(5)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    As you know, |cffffcc00undeads|r have blocked the way to reach Colddream")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    negating the contact with our main supplies providers")
        call TriggerSleepAction(6)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Valdivia's Keeper says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Colddream's Merchants tried to manage it sending |cffffcc00ships|r across the Southern Sea")
        call TriggerSleepAction(5)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    But when they were close to our coasts, a surprising storm forces them to aground and sunk all the ships")
        
        if ( GetLocalPlayer() == Player(id) ) then
            call PingMinimap(- 10850, 720, 7)
        endif
        call TriggerSleepAction(6)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Atleast the survivors reached the beach, but there were wild ogres, waiting to devour them ")
        call TriggerSleepAction(6)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Aided by some perverse power, ogres have |cffffcc00watchtowers|r that warn of new survivors")
        call TriggerSleepAction(6)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Valdivia's Keeper says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    A few hours ago we detected a new watchtower location. If you can destroy it, we could get a chance of rescue other survivors.")
        call TriggerSleepAction(7)
        set wt=CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'h02X', wtowerx[id], wtowery[id], 270)
        if ( GetLocalPlayer() == Player(id) ) then
           call PingMinimapEx(wtowerx[id], wtowery[id], 7, 255, 255, 50, false)
        endif
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00NEW QUEST ENABLED|r: |cffffcc00OGRES AND THE SUNKEN SHIPS - PART I|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "     Destroy the Renegade's Tower")
        call StartSound(bj_questDiscoveredSound)
        set findwtower[id]=true
  
        set questid=SetupQuest(id , valdkeeper , "OGRES AND THE SUNKEN SHIPS - PART I" , "Destroy the Renegade's Tower " , "0" , "/1" , 0 , s__qty[3])
        call SetUnitUserData(wt, questid)
      //  call SaveInteger(udg_cache,GetHandleId(valdkeeper),GetHandleId(udg_PHero[id]),questid)
        set Qrequ[questid]=1
       
       loop
        exitwhen findwtower[id] == false
          call TriggerSleepAction(1)
        endloop
        
         call StartSound(bj_questCompletedSound)
          call UpdatePersQuestND(id , questid , 1 , "-" , I2S(1) , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
          call TriggerSleepAction(4)
           call SetUnitFacingToFaceUnitTimed(valdkeeper, udg_PHero[id], 0)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    We got some advantaje taking that tower down...")
          call TriggerSleepAction(5)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    But this hour is very precious to let it go...")
          call TriggerSleepAction(5)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    We must take their places to make a secure way to the sunken ships.")
          call TriggerSleepAction(6)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    It's time to aniquilate some ogres.")
          call TriggerSleepAction(6)
          set questid=SetupQuest(id , valdkeeper , "OGRES AND THE SUNKEN SHIPS PART II" , "Exterminate 30 ogre warrior to get a clean way to the ships " , "0" , "/30" , 0 , s__qty[3])
          call SaveInteger(udg_cache, GetHandleId(valdkeeper), GetHandleId(udg_PHero[id]), questid)
          set Qrequ[questid]=30
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00NEW QUEST ENABLED|r: |cffffcc00OGRES AND THE SUNKEN SHIPS - PART II|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Assault the Ogre Encampment and exterminate 30 ogre warrior, We need to erradicate them to make a secure way to the sunken ships")
          call StartSound(bj_questDiscoveredSound)
        set killingogres[id]=true
          
           loop
        exitwhen killingogres[id] == false
          call TriggerSleepAction(1)
        endloop
          call StartSound(bj_questCompletedSound)
          call UpdatePersQuestND(id , questid , 1 , "-" , I2S(1) , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
          call TriggerSleepAction(4)
           call SetUnitFacingToFaceUnitTimed(valdkeeper, udg_PHero[id], 0)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    There's no choice. Our people can't wait...")
          call TriggerSleepAction(5)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    You have promised us your help, now is time to make it real")
          call TriggerSleepAction(5)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    We need to bring the city at least 20 of the lost reserves.")
          call TriggerSleepAction(2)
          set workers[id]=CreateGroup()
          set wt=CreateUnit(Player(10), 'h030', - 4565, - 2390, 270)
          call SetUnitUserData(wt, id)
          call IssuePointOrder(wt, "move", - 4300, - 1465)
          call GroupAddUnit(workers[id], wt)
          call TriggerSleepAction(0.9)
          set wt=CreateUnit(Player(10), 'h030', - 4565, - 2390, 270)
          call SetUnitUserData(wt, id)
          call IssuePointOrder(wt, "move", - 4300, - 1465)
          call GroupAddUnit(workers[id], wt)
          call TriggerSleepAction(0.9)
          set wt=CreateUnit(Player(10), 'h030', - 4565, - 2390, 270)
          call SetUnitUserData(wt, id)
          call IssuePointOrder(wt, "move", - 4300, - 1465)
          call GroupAddUnit(workers[id], wt)
          call TriggerSleepAction(0.9)
          set wt=CreateUnit(Player(10), 'h030', - 4565, - 2390, 270)
          call SetUnitUserData(wt, id)
          call IssuePointOrder(wt, "move", - 4300, - 1465)
          call GroupAddUnit(workers[id], wt)
          call TriggerSleepAction(1)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Here are some workers. They will carry the supplies to the city")
          call TriggerSleepAction(6)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Your mission is Protect them")
          call TriggerSleepAction(6)
          set questid=SetupQuest(id , valdkeeper , "OGRES AND THE SUNKEN SHIPS - PART III" , "Keep at least 1 worker alive while them bring 20 supplies " , "0" , "/20" , 0 , s__qty[3])
          call SaveInteger(udg_cache, GetHandleId(valdkeeper), GetHandleId(udg_PHero[id]), questid)
          set Qrequ[questid]=20
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00NEW QUEST ENABLED|r: |cffffcc00OGRES AND THE SUNKEN SHIPS - PART III|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Our workers will rescue supplies from sunkens ships. Keep at least one worker alive while they bring 20 reserves to the city.")
          call StartSound(bj_questDiscoveredSound)
          call GroupPointOrder(workers[id], "move", - 10850, 720)

          set workingonsuplies[id]=true
          set workerstoship[id]=CreateGroup()
          set workerstogrocery[id]=CreateGroup()
          call GroupAddGroup(workers[id], workerstoship[id])
        loop
        exitwhen workingonsuplies[id] == false
          call TriggerSleepAction(1)
        endloop
         call StartSound(bj_questCompletedSound)
          call UpdatePersQuestND(id , questid , 20 , "-" , I2S(20) , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
               
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
         
         
         set md=CreateUnit(Player(PLAYER_NEUTRAL_PASSIVE), 'h031', - 8400, 1170, 270)
         call IssuePointOrder(md, "move", - 4213, - 1160)
         call SetUnitUserData(md, id)
          
          loop
          exitwhen minidemonq[id] == true
          call TriggerSleepAction(1)
          endloop
          
          set questid=SetupQuest(id , valdkeeper , "OGRES AND THE SUNKEN SHIPS - FINAL" , "Destroy the supplies stealer and bring back the reserves" , "0" , "/1" , 0 , s__qty[3])
          call SaveInteger(udg_cache, GetHandleId(valdkeeper), GetHandleId(Player(id)), questid)
          set Qrequ[questid]=1
          set t=(NewTimerEx(0)) // INLINED!!
          
          call SaveUnitHandle(questtm, GetHandleId(t), 0, md)
          call SaveInteger(questtm, GetHandleId(md), 1, id)
          call SaveInteger(questtm, GetHandleId(md), 2, questid)
          call TimerStart(t, 4, true, function mdemonscape)
          
          call StartSound(bj_questUpdatedSound)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Valdivia's Keeper says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "   Beware!! a thief is stealing the supplies!!!!")
          call TriggerSleepAction(4)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00NEW QUEST ENABLED|r: |cffffcc00OGRES AND THE SUNKEN SHIPS - FINAL|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Our supplies are vanishing, Destroy the thief... Recover the supplies!!!!")
          call StartSound(bj_questDiscoveredSound)
          
           loop
            exitwhen valdiviafinal[id] == true
                call TriggerSleepAction(1)
            endloop
          
          call StartSound(bj_questCompletedSound)
          call UpdatePersQuestND(id , questid , 20 , "-" , I2S(20) , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
               
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
          call TriggerSleepAction(1)
          call UnitChat("My gratitude to you is eternal, You saved us!!!" , valdkeeper)
          call TriggerSleepAction(3)
          call UnitChat("take this present for your service!" , valdkeeper)
          call TriggerSleepAction(2)
          call AddHeroXP(udg_PHero[id], 16000, false)
          call UnitAddItem(udg_PHero[id], CreateItem('I05G', GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])))
          call DisplayTimedTextToPlayer(Player(id), .1, 0, 7, " You get |cffffcc00+16000|r Experience!")
          call DisplayTimedTextToPlayer(Player(id), .1, 0, 7, " You get |cffffcc00City Keeper Shield|r")
          call TriggerSleepAction(3)
          call UnitChat("Your work here is done. There are another people that needs you help. You're welcome here." , valdkeeper)
         
        endif
set wt=null
set wr=null
set md=null
endfunction

