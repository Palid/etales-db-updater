//===========================================================================
// Trigger: gd1
//
// 
//      set udg_portal[0]= Location(-16959,4865)//Velhilmen
//      set udg_portal[1]= Location(-10561,6914)//lasthope
//      set udg_portal[2]= Location(446,-2816)//VAldivia
//      set udg_portal[3]= Location(-4351,-16191)//Undeadvalley
//      set udg_portal[4]= Location(4861,4676)//ekrom
//      set udg_portal[5]= Location(4285,-14143)//Colddream
//      set udg_portal[6]= Location(14720,-1800)//Hiddenlands
//     
//===========================================================================
function Trig_gd1_Actions takes nothing returns nothing
    call CreateDeadDestructableLocBJ('OTsp', udg_portal[0], 270.00, 1, 0)
    call DestructableRestoreLife(GetLastCreatedDestructable(), GetDestructableMaxLife(GetLastCreatedDestructable()), true)
    call SetDestructableInvulnerableBJ(GetLastCreatedDestructable(), true)
    call TriggerSleepAction(1.00)
    call CreateDestructableLoc('OTsp', udg_tunnel[7], 0, 1, 0)
    call SetDestructableInvulnerableBJ(GetLastCreatedDestructable(), true)
    call TriggerSleepAction(8.00)
    call EnableTrigger(gg_trg_pvi)
    call EnableTrigger(gg_trg_pvo)
    call ShowUnit(gg_unit_n021_0544, true)
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "|cffffcc00- THE WAY TO THE ORACLE -|r")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "|cffcccc00Quest Update|r: Defeat The Portal's Guard of Valdivia ")
    call StartSound(bj_questUpdatedSound)
    call TriggerSleepAction(1)
    call PingMinimapLocForForce(GetPlayersAll(), udg_portal[2], 4)
    
endfunction

