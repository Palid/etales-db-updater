    set gg_trg_agedman=CreateTrigger()
    call TriggerRegisterUnitInRangeSimple(gg_trg_agedman, 256, gg_unit_n08J_0382)
    call TriggerAddCondition(gg_trg_agedman, Condition(function Trig_agedman_Conditions))
    call TriggerAddAction(gg_trg_agedman, function Trig_agedman_Actions)
endfunction


//===========================================================================
// Trigger: librarian
//
//     call DisableTrigger( gg_trg_ankitfound)
//===========================================================================
function Trig_librarian_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and s__libfinished[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == false
endfunction



function Trig_librarian_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer questid= 0
local integer amount= 0
local boolean nothng= false
local real x= 0
local real y= 0
local real face= 0
call DisableTrigger(gg_trg_librarian)

 if findfarmer[id] == true or findpages[id] == true then
  call UnitChat(" Hey, Do you have any new for me?" , gg_unit_n08I_0090)
  call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
  call TriggerSleepAction(3)
  call UnitChat("Hi...." , udg_PHero[id])
  call IssueImmediateOrder(udg_PHero[id], "stop")
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call TriggerSleepAction(2)
  call UnitChat("Still nothing but I'll have soon..." , udg_PHero[id])
  
 elseif SylvanOk[id] == true then
  set SylvanOk[id]=false
  call UnitChat(" Hey, How's everything?" , gg_unit_n08I_0090)
  call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
  call TriggerSleepAction(3)
  call UnitChat("Hi..." , udg_PHero[id])
  call IssueImmediateOrder(udg_PHero[id], "stop")
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call TriggerSleepAction(2)
  call UnitChat("Finally I recovered some pages to complete this tome..." , udg_PHero[id])
  call TriggerSleepAction(3)
  call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
  call UnitChat("Really?? that's a great new!!!." , gg_unit_n08I_0090)
  call TriggerSleepAction(3)
    if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
    endif
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    The librarian takes the improvised tome from your hands and start reading it effusively")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    After a brief period of time He returns the rotten pages to you...")
    call TriggerSleepAction(8)
    call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
    call UnitChat("I have nothing to do with this... My studies are lost" , gg_unit_n08I_0090)
    call TriggerSleepAction(3)
    call UnitChat("Anyway these pages could be usefull for your quest, If you listen me..." , gg_unit_n08I_0090)
    call TriggerSleepAction(2)
    call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
    call TriggerSleepAction(3)
    call UnitChat("You can understand Sylvan languaje simply following these rules..." , gg_unit_n08I_0090)
    call TriggerSleepAction(3)
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    The librarian indicates some marks into the pages to you...")
    call TriggerSleepAction(3)
    call UnitChat("jooo nice!!..." , udg_PHero[id])
          call TriggerSleepAction(2)
          call StartSound(bj_questCompletedSound)
          set questid=LoadInteger(udg_cache, GetHandleId(gg_unit_n08I_0090), GetHandleId(udg_PHero[id]))
          call UpdatePersQuestND(id , questid , 1 , "-" , I2S(1) , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    You have learned sylvan languaje...")
          set amount=GetHeroLevel(udg_PHero[id]) * 225
          call DisplayTimedTextToPlayer(Player(id), .1, 0, 6, " Got +|cffffcc00" + I2S(amount) + "|r Experience!")
          call AddHeroXP(udg_PHero[id], amount, false)
          set s__SylvanLang[id]= 1
		  set s__libfinished[id]= true
         
          call TriggerSleepAction(6)
        
    call UnitChat("I hope this knowledge helps you on your way..." , gg_unit_n08I_0090)
    call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
    call TriggerSleepAction(3)
    call UnitChat("Yes... I'll return to Valdivia, to help guards on their deals with those centaurs..." , udg_PHero[id])
    call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
    
    if ankitrevealed == false then
     set ankitrevealed=true
     call GroupRemoveUnit(vguard, ankit)
    call IssueImmediateOrder(ankit, "stop")
    set x=GetUnitX(ankit)
    set y=GetUnitY(ankit)
    set face=GetUnitFacing(ankit)
   
    call SetUnitPosition(ankit, 6850, 17850)

    
    set ankitsnare=AddSpecialEffectTarget("Abilities\\Spells\\Orc\\Ensnare\\ensnare_AirTarget.mdl", ankit, "chest")
    
    call SetUnitTimeScale(ankit, 0)
    call PauseUnit(ankit, true)
    set ankitlord=CreateUnit(Player(10), 'h036', x, y, face)
    call EnableTrigger(gg_trg_CentaursIncursion)
    call TriggerRegisterUnitInRange(gg_trg_CentaursIncursion, ankitlord, 256, null)
    call GroupAddUnit(vguard, ankitlord)
    endif
  
 else
  call UnitChat("Hi!... Can I help you?" , gg_unit_n08I_0090)
  call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
  set nothng=true
 endif
 
 
 call TriggerSleepAction(3)
 if libraryseek[id] == true then
  set libraryseek[id]=false
  call UnitChat("Hi...." , udg_PHero[id])
  call IssueImmediateOrder(udg_PHero[id], "stop")
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call TriggerSleepAction(2)
  call UnitChat("Well... maybe." , udg_PHero[id])
  call TriggerSleepAction(2)
  call UnitChat("I'm searching something related to centaurs languaje..." , udg_PHero[id])
  call TriggerSleepAction(4)
  call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
  call UnitChat("Oh, you mean sylvan languaje." , gg_unit_n08I_0090)
  call TriggerSleepAction(3)
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call UnitChat("Sylvan languaje?." , udg_PHero[id])
  call TriggerSleepAction(2)
  call UnitChat("Yes, an old elven dialect used in some centaur tribes." , gg_unit_n08I_0090)
  call TriggerSleepAction(4)
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call UnitChat("Yes!!. I believe that's what I need." , udg_PHero[id])
  call TriggerSleepAction(3)
  call MakeFaceToUnit(gg_unit_n08I_0090 , udg_PHero[id])
  call UnitChat("Oh, I see..." , gg_unit_n08I_0090)
  call TriggerSleepAction(2)
  call UnitChat("well... I've made some studies about Sylvan words but they were stolen some months ago by a rare man" , gg_unit_n08I_0090)
  call TriggerSleepAction(5)
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call UnitChat("Ah??  How could it be... Someone took it and ran out??." , udg_PHero[id])
  call TriggerSleepAction(3)
  call SetUnitFacing(gg_unit_n08I_0090, 270)
  call UnitChat("Not exactly... He asked me for read them. I put the books here over the table..." , gg_unit_n08I_0090)
  call TriggerSleepAction(5)
  call UnitChat("then he picked up all very fast and...he just vanished into the air...." , gg_unit_n08I_0090)
  call TriggerSleepAction(4)
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call UnitChat("What the heck!! You'd never seen he before??" , udg_PHero[id])
  call TriggerSleepAction(4)
  call UnitChat("No... Really I would like to recover these books. their value is very high for me" , gg_unit_n08I_0090)
  call TriggerSleepAction(5)
  call UnitChat("And for me sure... But where can we start??" , udg_PHero[id])
  call TriggerSleepAction(3)
  call UnitChat("I don't know... I just remember his repulsive odor... His dress smelled like sewers water..." , gg_unit_n08I_0090)
  call TriggerSleepAction(5)
  call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
  call UnitChat("Sewers water odor? like Valdivia's culvert???..." , udg_PHero[id])
  call TriggerSleepAction(3)
  call UnitChat("Maybe???..." , gg_unit_n08I_0090)
  call TriggerSleepAction(4)
  set questid=SetupQuest(id , gg_unit_n08I_0090 , "UNKNOWN ENEMY - PART III" , "Search stolen books on Valdivia's culvert " , "0" , "/1" , 0 , s__qty[3])
  call SaveInteger(udg_cache, GetHandleId(gg_unit_n08I_0090), GetHandleId(udg_PHero[id]), questid)
  set Qrequ[questid]=1
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00NEW PERSONAL QUEST: UNKNOWN ENEMY - PART III|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Search into Valdivia's culvert for stolen books")
  call StartSound(bj_questDiscoveredSound)
  set findfarmer[id]=true
  
 

 else
  if nothng == true then
     call MakeFaceToUnit(udg_PHero[id] , gg_unit_n08I_0090)
     call UnitChat("Thanks.. I'm just seeing..." , udg_PHero[id])
   endif
 endif

call TriggerSleepAction(7)
call EnableTrigger(gg_trg_librarian)

endfunction

