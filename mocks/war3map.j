//===========================================================================
// Trigger: Oracle Test
//===========================================================================
//TESH.scrollpos=452
//TESH.alwaysfold=0
// scope oracle begins


function LearnSkill takes unit u,integer i returns nothing

local integer l__l= 0

 if ( i == 21 ) then
 
      set l__l=0
      loop
      exitwhen l__l > 3
      call SelectHeroSkill(u, 'A078')
      set l__l=l__l + 1
      endloop
      
 elseif ( i == 22 ) then
      set l__l=0
      loop
      exitwhen l__l > 3
      call SelectHeroSkill(u, 'A06K')
      set l__l=l__l + 1
      endloop
 elseif ( i == 23 ) then
      set l__l=0
      loop
      exitwhen l__l > 3
      call SelectHeroSkill(u, 'A06U')
      set l__l=l__l + 1
      endloop
 elseif ( i == 24 ) then
      set l__l=0
      loop
      exitwhen l__l > 3
      call SelectHeroSkill(u, 'A06P')
      set l__l=l__l + 1
      endloop
 elseif ( i == 25 ) then
      set l__l=0
      loop
      exitwhen l__l > 3
      call SelectHeroSkill(u, 'A074')
      set l__l=l__l + 1
      endloop
                       
 elseif ( i == 26 ) then
       set l__l=0
      loop
      exitwhen l__l > 3
      call SelectHeroSkill(u, 'A06Z')
      set l__l=l__l + 1
      endloop
endif

endfunction

function LaunchAttack takes nothing returns nothing

  call IssueTargetOrder(oracle__attacker, "attack", oracle__oracle_fighter)
endfunction


function SetFighter takes integer l__l returns nothing
local integer i= ModuloInteger(l__l, 20)

 if ( i == 1 or i == 2 or i == 5 ) then
   set oracle__fight1=udg_HeroTipe[10]
  elseif ( i == 7 ) then
   set oracle__fight1=udg_HeroTipe[20]
  else
   set oracle__fight1=udg_HeroTipe[0]
 endif
 
 set oracle__fight2=udg_HeroTipe[i]
 set oracle__fight3=udg_HeroTipe[i + 20]
 set oracle__fight4=udg_HeroTipe[i + 40]
endfunction

function ORAC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0SJ' )
endfunction
 
function Spawnp takes nothing returns location
 local integer i= GetRandomInt(1, 4)
 
 
     if ( i == 1 ) then
       set oracle__pp=oracle__op1

 elseif ( i == 2 ) then
    set oracle__pp=oracle__op2
 elseif ( i == 3 ) then
    set oracle__pp=oracle__op3
 elseif ( i == 4 ) then
    set oracle__pp=oracle__op4
 endif
  call DestroyEffect(AddSpecialEffectLoc(sethunder, oracle__pp))
 return oracle__pp
 
endfunction

function SecondFight takes nothing returns nothing
call PauseTimer(oracle__att)
call SetUnitOwner(oracle__fighter1, Player(bj_PLAYER_NEUTRAL_VICTIM), true)
//call RemoveUnit(fighter1)
// set fighter1 = null
// set fight1 = 0
      call TriggerSleepAction(4)
 set oracle__fighter2=CreateUnitAtLoc(Player(PLAYER_DARK_LORD), oracle__fight2, Spawnp(), 180)
      
      call TriggerRegisterUnitEvent(oracle__df, oracle__fighter2, EVENT_UNIT_DEATH)
      
      call TriggerSleepAction(1)
      call SetHeroLevel(oracle__fighter2, 40, false)
      call SetHeroAgi(oracle__fighter2, oracle__hagi, true)
      call SetHeroInt(oracle__fighter2, oracle__hint, true)
      call SetHeroStr(oracle__fighter2, oracle__hstr, true)
      
      call UnitAddAbility(oracle__fighter2, 'A089') // battle expertise
      call UnitAddAbility(oracle__fighter2, 'A093')
      
      call TriggerSleepAction(1)
      
     // call SetUnitAcquireRange(fighter2, 1500.00 )//
      
      set oracle__pp=null
      call TriggerSleepAction(2)
      call IssueTargetOrder(oracle__fighter2, "attack", oracle__oracle_fighter)
      set oracle__attacker=oracle__fighter2
      
      call TimerStart(oracle__att, 2, true, function LaunchAttack)
      
endfunction

function ThirdFight takes nothing returns nothing
call PauseTimer(oracle__att)
call SetUnitOwner(oracle__fighter2, Player(bj_PLAYER_NEUTRAL_VICTIM), true)
 //call RemoveUnit(fighter2)
 //set fighter2 = null
 //set fight2 = 0
 call TriggerSleepAction(4)
 set oracle__fighter3=CreateUnitAtLoc(Player(PLAYER_DARK_LORD), oracle__fight3, Spawnp(), 180)
      
      call TriggerRegisterUnitEvent(oracle__ds, oracle__fighter3, EVENT_UNIT_DEATH)
      
      call TriggerSleepAction(1)
      call SetHeroLevel(oracle__fighter3, 60, false)
      call SetHeroAgi(oracle__fighter3, oracle__hagi, true)
      call SetHeroInt(oracle__fighter3, oracle__hint, true)
      call SetHeroStr(oracle__fighter3, oracle__hstr, true)
      call UnitAddAbility(oracle__fighter3, 'A089') // battle expertise
      call UnitAddAbility(oracle__fighter3, 'A093')
      call LearnSkill(oracle__fighter3 , oracle__lev)
      
      call TriggerSleepAction(1)
      
      //call SetUnitAcquireRange(fighter3, 1500.00 )//
      
      set oracle__pp=null
      call TriggerSleepAction(2)
      call IssueTargetOrder(oracle__fighter3, "attack", oracle__oracle_fighter)
      set oracle__attacker=oracle__fighter3
      
      call TimerStart(oracle__att, 2, true, function LaunchAttack)
      

endfunction

function LastFight takes nothing returns nothing
call PauseTimer(oracle__att)
call SetUnitOwner(oracle__fighter3, Player(bj_PLAYER_NEUTRAL_VICTIM), true)
 //call RemoveUnit(fighter3)
 //set fighter3 = null
 //set fight3 = 0
 call TriggerSleepAction(4)
 set oracle__fighter4=CreateUnitAtLoc(Player(PLAYER_DARK_LORD), oracle__fight4, Spawnp(), 180)
      
      call TriggerRegisterUnitEvent(oracle__dl, oracle__fighter4, EVENT_UNIT_DEATH)
      
      call TriggerSleepAction(1)
      call SetHeroLevel(oracle__fighter4, 75, false)
      call SetHeroAgi(oracle__fighter4, oracle__hagi, true)
      call SetHeroInt(oracle__fighter4, oracle__hint, true)
      call SetHeroStr(oracle__fighter4, oracle__hstr, true)
      //call UnitAddAbility( fighter4, 'A089' ) // battle expertise
      call UnitAddAbility(oracle__fighter4, 'A093')
      
      call TriggerSleepAction(1)
      
      //call SetUnitAcquireRange(fighter4, 1500.00 )//
      
      set oracle__pp=null
      call TriggerSleepAction(2)
      call IssueTargetOrder(oracle__fighter4, "attack", oracle__oracle_fighter)
      set oracle__attacker=oracle__fighter4
      
      call TimerStart(oracle__att, 2, true, function LaunchAttack)

endfunction

function fade takes nothing returns nothing

call SetUnitVertexColor(oracle__fighter1, 255, 255, 255, 255 - ( oracle__vertex * 2 ))
call SetUnitVertexColor(oracle__fighter2, 255, 255, 255, 255 - ( oracle__vertex * 2 ))
call SetUnitVertexColor(oracle__fighter3, 255, 255, 255, 255 - ( oracle__vertex * 2 ))
call SetUnitVertexColor(oracle__fighter4, 255, 255, 255, 255 - ( oracle__vertex * 2 ))
set oracle__vertex=oracle__vertex + 1

if ( oracle__vertex > 128 ) then
call RemoveUnit(oracle__fighter1)
call RemoveUnit(oracle__fighter2)
call RemoveUnit(oracle__fighter3)
call RemoveUnit(oracle__fighter4)
 set oracle__fighter1=null
 set oracle__fighter2=null
 set oracle__fighter3=null
 set oracle__fighter4=null
 
call PauseTimer(oracle__att)
endif

endfunction


function FinalTest takes nothing returns nothing
set oracle__vertex=0

call PauseTimer(oracle__att)
call SetUnitOwner(oracle__fighter4, Player(bj_PLAYER_NEUTRAL_VICTIM), true)
call TriggerSleepAction(3)
//call SetUserControlForceOff( bj_FORCE_PLAYER[playerid] )

call SetUnitPositionLoc(oracle__oracle_fighter, oracle__oraclep)
call PauseUnit(oracle__oracle_fighter, true)
call PanCameraToTimedLocForPlayer(GetOwningPlayer(oracle__oracle_fighter), oracle__oraclep, 0)
call TriggerSleepAction(3)
call ReviveHeroLoc(oracle__fighter1, oracle__of1, true)
call ReviveHeroLoc(oracle__fighter2, oracle__of2, true)
call ReviveHeroLoc(oracle__fighter3, oracle__of3, true)
call ReviveHeroLoc(oracle__fighter4, oracle__of4, true)

call UnitAddAbility(oracle__fighter1, 'Aloc')
call UnitAddAbility(oracle__fighter2, 'Aloc')
call UnitAddAbility(oracle__fighter3, 'Aloc')
call UnitAddAbility(oracle__fighter4, 'Aloc')

call TriggerSleepAction(1)
call UnitChat("The real..." , oracle__fighter1)
call TriggerSleepAction(1)
call UnitChat("..game..." , oracle__fighter2)
call TriggerSleepAction(1)
call UnitChat("..begins..." , oracle__fighter3)
call TriggerSleepAction(1)
call UnitChat("..now..." , oracle__fighter4)

call TriggerSleepAction(2)
call TimerStart(oracle__att, 0.01, true, function fade)
call IssuePointOrderLoc(oracle__fighter1, "move", oracle__oraclep)
call IssuePointOrderLoc(oracle__fighter2, "move", oracle__oraclep)
call IssuePointOrderLoc(oracle__fighter3, "move", oracle__oraclep)
call IssuePointOrderLoc(oracle__fighter4, "move", oracle__oraclep)

call TriggerSleepAction(2)
call DestroyEffect(AddSpecialEffectLoc(sethunder, oracle__oraclep))
call TriggerSleepAction(2)
call DestroyEffect(AddSpecialEffectLoc(sethunder, oracle__oraclep))
call TriggerSleepAction(2)
call DestroyEffect(AddSpecialEffectLoc(sethunder, oracle__oraclep))
call TriggerSleepAction(2)

call ReleaseTimer(oracle__att)


call DestroyEffect(AddSpecialEffectLoc(sethunder, oracle__oraclep))
call PauseUnit(oracle__oracle_fighter, false)
call NextClass(GetPlayerId(GetOwningPlayer(oracle__oracle_fighter)) , oracle__oracle_fighter)
call TriggerSleepAction(0.2)
call UnitAddAbility(udg_PHero[oracle__playerid], udg_FSpell[udg_Faction[oracle__playerid]])
set oracle__oracle_fighter=udg_PHero[oracle__playerid]
call TriggerSleepAction(2)
call RemoveAllQuestFromPlayer(oracle__playerid)
//call SetUserControlForceOn( bj_FORCE_PLAYER[playerid] )
call DisplayTimedTextToPlayer(GetOwningPlayer(oracle__oracle_fighter), 0, 0, bj_TEXT_DELAY_QUESTDONE, "|cffffcc00FINAL CLASS MISSION DONE:|r")
call DisplayTimedTextToPlayer(GetOwningPlayer(oracle__oracle_fighter), 0, 0, bj_TEXT_DELAY_QUESTDONE, "You have 15 seconds to pick up your items, then you will teleported out of here")
call DisplayTimedTextToPlayer(GetOwningPlayer(oracle__oracle_fighter), 0, 0, bj_TEXT_DELAY_QUESTDONE, "|cffaaff00Go to listen the Oracle words|r")
call StartSound(bj_questCompletedSound)
call TriggerSleepAction(15)
call SetUnitPositionLoc(oracle__oracle_fighter, udg_portal[14])
call TriggerSleepAction(2)
call UnitChat("Well done Hero, you has reached a final class..." , gg_unit_n04V_0538)
call TriggerSleepAction(4)
call UnitChat("But this comes with a big responsability... You real journey begins now..." , gg_unit_n04V_0538)
call TriggerSleepAction(4)
call UnitChat("The Kingdoom of Enthashara is walking to the Darkness. We need you..." , gg_unit_n04V_0538)
call TriggerSleepAction(4)
call UnitChat("There is a gif for you, good luck in your way" , gg_unit_n04V_0538)
call TriggerSleepAction(2)
call UnitAddItem(oracle__oracle_fighter, CreateItem(udg_itmpool[80], GetUnitX(oracle__oracle_fighter), GetUnitY(oracle__oracle_fighter)))
call DisplayTimedTextToPlayer(GetOwningPlayer(oracle__oracle_fighter), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Received |cffffcc00-Emperor's Chest-|r")
call StartSound(bj_questHintSound)
call TriggerSleepAction(2)
set oracle_busy=false


set oracle__fight1=0
set oracle__fight2=0
set oracle__fight3=0
set oracle__fight4=0

set oracle__fighter1=null
set oracle__fighter2=null
set oracle__fighter3=null
set oracle__fighter4=null
set oracle__oracle_fighter=null
set oracle__hagi=0
set oracle__hstr=0
set oracle__hint=0

endfunction

function OracleDeath takes nothing returns nothing
call ReleaseTimer(oracle__att)
set oracle_busy=false

set oracle__fight1=0
set oracle__fight2=0
set oracle__fight3=0
set oracle__fight4=0

call RemoveUnit(oracle__fighter1)
call RemoveUnit(oracle__fighter2)
call RemoveUnit(oracle__fighter3)
call RemoveUnit(oracle__fighter4)

set oracle__fighter1=null
set oracle__fighter2=null
set oracle__fighter3=null
set oracle__fighter4=null
set oracle__oracle_fighter=null
set oracle__hagi=0
set oracle__hstr=0
set oracle__hint=0

endfunction


function ORAA takes nothing returns nothing
local unit u= GetTriggerUnit()
set oracle__playerid=GetPlayerId(GetOwningPlayer(u))
set oracle__att=(NewTimerEx(0)) // INLINED!!

set oracle__hagi=GetHeroAgi(u, true)
set oracle__hint=GetHeroInt(u, true)
set oracle__hstr=GetHeroStr(u, true)

 set oracle__lev=GetUnitPointValue(u) - 100


     if ( oracle_busy == true ) then
         call UnitChat("Wait a moment, someone is fighting now...." , gg_unit_n04V_0538)
 
  
    elseif ( GetUnitTypeId(GetTriggerUnit()) == 'H00H' or GetUnitTypeId(GetTriggerUnit()) == 'H00G' ) then
        call UnitChat("My child, I feel the power of your determination, but you are weak at this moment, come back later... " , gg_unit_n04V_0538)

 
    elseif ( GetUnitUserData(GetTriggerUnit()) < 2700 ) then
            call UnitChat("You dont have neccesary experience to take this examen |n|cffffcc00Needs 2700 kills|r" , gg_unit_n04V_0538)

    elseif ( 20 < oracle__lev and oracle__lev < 39 ) then
    
            call UnitChat("Are you ready to fight against your Destiny? ...take a deep breath..." , gg_unit_n04V_0538)
            call TriggerSleepAction(4)
            call SetUnitPositionLoc(u, oracle__oraclep)
           // call SetUnitPositionLoc(udg_Slave[id] ,oraclep)
            
            call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), oracle__oraclep, 0)
            set oracle_busy=true
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "NEW CLASS MISSION")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "Survive...")
            call StartSound(bj_questDiscoveredSound)
            set oracle__oracle_fighter=u
            call TriggerRegisterUnitEvent(oracle__do, oracle__oracle_fighter, EVENT_UNIT_DEATH)
            call SetFighter(oracle__lev)
      
      set oracle__fighter1=CreateUnitAtLoc(Player(PLAYER_DARK_LORD), oracle__fight1, Spawnp(), 180)
      
      call TriggerRegisterUnitEvent(oracle__dn, oracle__fighter1, EVENT_UNIT_DEATH)
      
      call TriggerSleepAction(1)
      call SetHeroLevel(oracle__fighter1, 20, false)
      call SetHeroAgi(oracle__fighter1, oracle__hagi, true)
      call SetHeroInt(oracle__fighter1, oracle__hint, true)
      call SetHeroStr(oracle__fighter1, oracle__hstr, true)
      call TriggerSleepAction(1)
      
      call UnitAddAbility(oracle__fighter1, 'A089') // battle expertise
      call UnitAddAbility(oracle__fighter1, 'A093') //Oracles warath
      
      call SelectHeroSkill(oracle__fighter1, N_SKILL_1)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_1)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_1)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_1)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_2)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_2)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_3)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_3)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_3)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_3)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_4)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_4)
      call SelectHeroSkill(oracle__fighter1, N_SKILL_4)
     // call SetUnitAcquireRange(fighter1, 1500.00 )//
      
      
      
      set oracle__pp=null
      call TriggerSleepAction(2)
      call IssueTargetOrder(oracle__fighter1, "attack", oracle__oracle_fighter)
      set oracle__attacker=oracle__fighter1
      
      call TimerStart(oracle__att, 2, true, function LaunchAttack)
      
            
    endif
        
 
      
      
set u=null

endfunction

//===========================================================================
function oraclet takes nothing returns nothing
    local trigger ot= CreateTrigger()

    
    local integer i= 0
      loop
        call TriggerRegisterPlayerUnitEvent(ot, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function btrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
    call TriggerAddCondition(ot, Condition(function ORAC))
    
    call TriggerAddAction(ot, function ORAA)
    call TriggerAddAction(oracle__dn, function SecondFight) //death novice
    call TriggerAddAction(oracle__df, function ThirdFight) //Death first Class
    call TriggerAddAction(oracle__ds, function LastFight)
    call TriggerAddAction(oracle__dl, function FinalTest)
    call TriggerAddAction(oracle__do, function OracleDeath)
endfunction

// scope oracle ends


//===========================================================================
// Trigger: Ekromtest
//===========================================================================
//TESH.scrollpos=30
//TESH.alwaysfold=0
function EARC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0M6' )
endfunction

function EARA takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer lev= GetUnitPointValue(udg_PHero[id]) - 100
local location p=udg_Pit_loc[2]

     if ( udg_ekrom_ocu == true ) then
        call UnitChat("Wait a moment, someone is taking the test now...." , gg_unit_H01I_1612)

  
   elseif ( GetUnitTypeId(udg_PHero[id]) == 'H00G' or GetUnitTypeId(udg_PHero[id]) == 'H00G' ) then
       call UnitChat("Novices get out my face!!" , gg_unit_H01I_1612)

       
 
    elseif ( GetUnitUserData(udg_PHero[id]) < 900 ) then
            call UnitChat("You dont have neccesary experience to take this examen |n|cffffcc00Need 900 kills|r" , gg_unit_H01I_1612)
   
   elseif ( GetHeroLevel(udg_PHero[id]) < 17 ) then
           call UnitChat("You dont have neccesary level to take this examen |n|cffffcc00Need level 17|r" , gg_unit_H01I_1612)
  
            
            
    elseif ( 0 < lev and lev < 20 ) then
    
           call UnitChat("Let's go. Make me proud of hiring you..." , gg_unit_H01I_1612)

            call TriggerSleepAction(2)
            call SetUnitPositionLoc(udg_PHero[id], p)
            call SetUnitPositionLoc(udg_Slave[id], p)
            call SetUnitPositionLoc(udg_Familiar[id], p)
            call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
            set udg_ekrom_ocu=true
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "NEW QUEST")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "Kill the tauren...")
            call StartSound(bj_questDiscoveredSound)
            set udg_unit_ekrom=udg_PHero[id]
            set PlayerInTest[id]=true
    endif
        

set p=null
set u=null

endfunction

