function InitTrig_natureforce takes nothing returns nothing
    set gg_trg_natureforce=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_natureforce, EVENT_PLAYER_UNIT_SPELL_CHANNEL)
    call TriggerAddCondition(gg_trg_natureforce, Condition(function Trig_natureforce_Conditions))
    call TriggerAddAction(gg_trg_natureforce, function Trig_natureforce_Actions)
endfunction


//===========================================================================
// Trigger: charm
//===========================================================================
//TESH.scrollpos=15
//TESH.alwaysfold=0
function Trig_charm_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == CHARMDRUI or GetSpellAbilityId() == CHARMALCH
endfunction

function Trig_charm_Actions takes nothing returns nothing
   local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   local unit a= GetSpellTargetUnit()
   local integer tid= GetPlayerId(GetOwningPlayer(a))
   local integer required= 0
   local integer unitlevel= GetUnitLevel(a)
   
   if GetSpellAbilityId() == CHARMDRUI then
    set required=s__charmlev[GetUnitAbilityLevel(udg_PHero[id], CHARMDRUI)]
   elseif GetSpellAbilityId() == CHARMALCH then
    set required=50
   endif
  
   if ( GetPlayerController(Player(tid)) == MAP_CONTROL_USER ) then
   set a=null
   return
   elseif IsUnitType(a, UNIT_TYPE_HERO) == true then
   set a=null
   return
   elseif unitlevel > required then
   set a=null
   return
   elseif a == TeamBonusUnit then
   call CS_Error(Player(id) , "Charm failed!...")
   set a=null
   return
   else
   call UnitRemoveBuffs(a, false, true)
   call SetUnitOwner(a, Player(id), true)
   call DestroyEffect(AddSpecialEffectTarget(charmfx, a, "chest"))
 
   if IsUnitInGroup(a, centaurss) == true then
       call GroupRemoveUnit(centaurss, a)
    endif

   endif
    set a=null
endfunction

