function rnd takes nothing returns integer
  return GetRandomInt(1, 200)
endfunction

function KillGnollAssasinsC takes nothing returns boolean
    return ( GetPlayerController(GetOwningPlayer(GetKillingUnit())) == MAP_CONTROL_USER and GetUnitTypeId(GetTriggerUnit()) == 'n01H' )
endfunction

function rangingc takes nothing returns boolean
    return ( GetPlayerController(GetOwningPlayer(GetKillingUnit())) == MAP_CONTROL_USER and GetUnitTypeId(GetTriggerUnit()) == 'n003' )
endfunction

function KillGnollAssasinsA takes nothing returns nothing
    local integer id= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
    local integer questid= 0
    
  if GnollAssasins[id] == true then
   set GnollAssasinsC[id]=GnollAssasinsC[id] + 1
   if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
   endif

   call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Gnoll Assasins killed:|r " + I2S(GnollAssasinsC[id]) + "/3")
   set questid=LoadInteger(udg_cache, GetHandleId(tutor), GetHandleId(udg_PHero[id]))
   call UpdatePersQuestND(id , questid , GnollAssasinsC[id] , "-" , I2S(GnollAssasinsC[id]) , "-")
  // call UpdateQuestLog(tutor,id,"|cffffcc00Gnoll Assasins killed:|r "+I2S(GnollAssasinsC[id])+"/3")
  endif
    
endfunction

function ranging takes nothing returns nothing
    local integer id= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
     local integer questid= 0
     
  if rangingbears[id] == true then
   set rangingbearsC[id]=rangingbearsC[id] + 1
   if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
   endif

   call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Ranging bears killed:|r " + I2S(rangingbearsC[id]) + "/6")
//   call UpdateQuestLog(reinhard,id,"|cffffcc00Ranging bears killed:|r "+I2S(rangingbearsC[id])+"/6")
  
  set questid=LoadInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[id]))
  call UpdatePersQuestND(id , questid , rangingbearsC[id] , "-" , I2S(rangingbearsC[id]) , "-")
   
  endif
    
endfunction



function createforce takes nothing returns nothing

local integer i= 0

 loop
  exitwhen i > 11
    if ( udg_Faction[i] == 1 ) then
        call ForceAddPlayer(udg_pgancient, Player(i))
        set forc[1]=forc[1] + 1
    elseif ( udg_Faction[i] == 2 ) then
        call ForceAddPlayer(udg_pgwolffang, Player(i))
        set forc[2]=forc[2] + 1
    elseif ( udg_Faction[i] == 3 ) then
        call ForceAddPlayer(udg_pgekrom, Player(i))
        set forc[3]=forc[3] + 1
    elseif ( udg_Faction[i] == 4 ) then
        call ForceAddPlayer(udg_pgblackhand, Player(i))
   endif
  set i=i + 1
 endloop
  
endfunction



