function Trig_unlink_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetTriggerPlayer())
local integer i= 0
local item it= null
local integer sure= 0
call TriggerSleepAction(1.6)
if ( cslave[id] != null ) then
 loop
 exitwhen i > 3
 set it=UnitItemInSlot(cslave[id], i)
 if it != null then
 call FlushChildHashtable(nodump, GetHandleId(it))
  set sure=sure + 1
 endif
 set i=i + 1
 endloop
 
 if sure > 0 then
  call UnitChat("|cffffcc00My Lord...Are these items for gifts" , cslave[id])
  call TriggerSleepAction(1.6)
  call UnitChat("Yes slave... all of them" , udg_PHero[id])
  call TriggerSleepAction(1.6)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Slave items unlinked")
 endif
endif
    set it=null

endfunction

//===========================================================================
function InitTrig_unlink takes nothing returns nothing
local integer i= 0
    set gg_trg_unlink=CreateTrigger()
    loop
    exitwhen i > 8
    call TriggerRegisterPlayerChatEvent(gg_trg_unlink, Player(i), "-save", true)
    set i=i + 1
    endloop
    
    call TriggerAddAction(gg_trg_unlink, function Trig_unlink_Actions)
endfunction


//===========================================================================
// Trigger: DestructableHidder
//===========================================================================
//===========================================================================
// Trigger: DEXp
//===========================================================================
// scope DEXP begins

  //Configuration globals

constant function DEXP__Formula takes integer XPfactor,integer unitlevel,integer heroesinradius,integer bonus returns integer
  return globalKnowledge * ( XPfactor * unitlevel ) + ( heroesinradius * bonus )
    //This is the function that determines how XP is calculted.
    //Unless you have a different method, don't touch this.*
endfunction
   
//This is the filter that picks up heroes in the radius of the killer.
//To modify it, simply add more booleans.
function DEXP__filter takes nothing returns boolean
  local unit u= GetFilterUnit()
  local boolean b1= IsUnitType(u, UNIT_TYPE_DEAD) == false
  local boolean b2= IsUnitType(u, UNIT_TYPE_HERO) == true
  local boolean b3= IsUnitAlly(u, GetOwningPlayer(GetKillingUnit())) == true
  
  set u=null
  return b1 and b2 and b3
endfunction

//Use this filter to modify the exp given for certain conditions.
function DEXP__ExpFilter takes integer exp,unit u returns integer
   return exp
endfunction

//This applies the XP accordingly.
function DEXP__GiveXP takes nothing returns nothing
  local unit u= GetDyingUnit()
  local unit f
  local unit Killer= GetKillingUnit()
  local player p= GetOwningPlayer(Killer)
  local integer add
  local integer KilledUnitLevel
  local integer unitNum= 0
  local group g= CreateGroup()
  local real x= GetUnitX(Killer)
  local real y= GetUnitY(Killer)
  local boolexpr istru= Condition(function DEXP__filter)
  local real distance
  local boolean boss= false
  local integer id
  local integer repbns
  set bj_groupCountUnits=0

  
  call GroupEnumUnitsInRange(g, x, y, DEXP__RADIUS, istru)
  call DestroyBoolExpr(istru)
  set istru=null
  call ForGroup(g, function CountUnitsInGroupEnum)
  set unitNum=bj_groupCountUnits

//============================================================
  if IsUnitAlly(u, p) == false then
    if GetUnitPointValue(u) == 300 then
      set KilledUnitLevel=GetUnitLevel(u)
      set add=(globalKnowledge * ( (DEXP__BOSS_EXP ) * ( KilledUnitLevel ) ) + ( ( unitNum ) * ( DEXP__BONUS_BSS) )) // INLINED!!
      set boss=true
      call PlaySoundBJ(gg_snd_BossEnd)
      
    elseif IsUnitType(u, UNIT_TYPE_HERO) == true then
      set KilledUnitLevel=GetHeroLevel(u)
      set add=(globalKnowledge * ( (DEXP__HERO_EXP ) * ( KilledUnitLevel ) ) + ( ( unitNum ) * ( DEXP__BONUS_EXP) )) // INLINED!!
    else
      set KilledUnitLevel=GetUnitLevel(u)
      set add=(globalKnowledge * ( (DEXP__UNIT_EXP ) * ( KilledUnitLevel ) ) + ( ( unitNum ) * ( DEXP__BONUS_EXP) )) // INLINED!!
    endif
  endif
    
  if DEXP__SPLIT then
    set add=R2I(add / unitNum)
  endif
//============================================================
         
  if DEXP__DISTANCE_EFFECT then

    set add=DEXP__ExpFilter(add , u)
    loop
    set f=FirstOfGroup(g)
      exitwhen f == null
      set distance=( ( GetUnitX(Killer) - GetUnitX(f) ) * ( GetUnitX(Killer) - GetUnitX(f) ) ) + ( ( GetUnitY(Killer) - GetUnitY(f) ) * ( GetUnitY(Killer) - GetUnitY(f) ) )
      //Far Away Units
      if distance > DEXP__MEDIUM * DEXP__MEDIUM and distance <= DEXP__FAR * DEXP__FAR then
        call SetPlayerHandicapXP(GetOwningPlayer(f), 1.00)
        set add=R2I(add * DEXP__FAR_FACTOR)
        call AddHeroXP(f, add, true)
        call SetPlayerHandicapXP(GetOwningPlayer(f), 0.00)
      //Medium Distance Units  
      elseif distance > DEXP__CLOSE * DEXP__CLOSE and distance <= DEXP__MEDIUM * DEXP__MEDIUM then
        call SetPlayerHandicapXP(GetOwningPlayer(f), 1.00)
        set add=R2I(add * DEXP__MEDIUM_FACTOR)
        call AddHeroXP(f, add, true)
        call SetPlayerHandicapXP(GetOwningPlayer(f), 0.00)
      //Close Range Units
      elseif distance <= DEXP__CLOSE * DEXP__CLOSE then
        call SetPlayerHandicapXP(GetOwningPlayer(f), 1.00)
        set add=R2I(add * DEXP__CLOSE_FACTOR)
        call AddHeroXP(f, add, true)
        call SetPlayerHandicapXP(GetOwningPlayer(f), 0.00)
      endif
        if DEXP__SHOW_TEXT and add > 0 and boss == true then
            set repbns=KilledUnitLevel / 2
            call DestroyEffect(AddSpecialEffect(goldpile, GetUnitX(u), GetUnitY(u)))
            set id=GetPlayerId(GetOwningPlayer(f))
            call DisplayTimedTextToPlayer(GetOwningPlayer(f), 0, 0, 8, "journey update")
            call DisplayTimedTextToPlayer(GetOwningPlayer(f), 0, 0, 8, "THE HUNT OF THE " + StringCase(GetUnitName(u), true))
            call DisplayTimedTextToPlayer(GetOwningPlayer(f), 0, 0, 8, "  ")
            call DisplayTimedTextToPlayer(GetOwningPlayer(f), 0, 0, 8, "you get |cff00bfff+" + I2S(add) + "|r experience.")
            call DisplayTimedTextToPlayer(GetOwningPlayer(f), 0, 0, 8, "      |cffffbbff+" + I2S(repbns) + "|r reputation.")
            set Reputation[id]=Reputation[id] + repbns
             
       // call CreateTextTagEX("+ " + I2S(add), SIZE, f, DURATION, RED, GREEN, BLUE)
      endif
        call GroupRemoveUnit(g, f)
    endloop
    
  else
    set add=DEXP__ExpFilter(add , u)
    loop
    set f=FirstOfGroup(g)
      exitwhen f == null
      if DEXP__SHOW_TEXT and add > 0 then
      //  call CreateTextTagEX("+ " + I2S(add), SIZE, f, DURATION, RED, GREEN, BLUE)
      endif
      call SetPlayerHandicapXP(GetOwningPlayer(f), 1.00)
      call AddHeroXP(f, add, true)
      call SetPlayerHandicapXP(GetOwningPlayer(f), 0.00)
      call GroupRemoveUnit(g, f)
    endloop
  endif

  set p=null
  call DestroyGroup(g)
  set g=null
  set u=null
  set Killer=null
  set f=null
endfunction


//This trigger stops players from gaining XP when they shouldn't be.
function DEXP__Cut_XP_Gain takes nothing returns nothing
   local integer i= 0
   loop
     exitwhen i > 12
     call SetPlayerHandicapXP(Player(i), 0.00)
     set i=i + 1
   endloop
   call DestroyTimer(GetExpiredTimer())
endfunction

