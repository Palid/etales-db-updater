function Trig_baul_Conditions takes nothing returns boolean
    return ( GetDestructableTypeId(GetOrderTargetDestructable()) == 'B00X' or GetDestructableTypeId(GetOrderTargetDestructable()) == 'B00T' or GetDestructableTypeId(GetOrderTargetDestructable()) == 'B00S' or GetDestructableTypeId(GetOrderTargetDestructable()) == 'B00Y' )
endfunction

