function GetParabolaZ takes real x,real d,real h returns real
    return 4 * h * x * ( d - x ) / ( d * d )
endfunction

function filterss takes nothing returns boolean
    return ( IsPlayerEnemy(GetOwningPlayer(GetTriggerUnit()), GetOwningPlayer(GetFilterUnit())) == true and GetUnitState(GetFilterUnit(), UNIT_STATE_LIFE) > 0 )
endfunction

function ciclo takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
  
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 4)
    local location p= GetUnitLoc(u)
    local location p1= PolarProjectionBJ(p, inc, ang)
    
    
    set inc=inc - 1.5
  
    call SetUnitPathing(u, false)
 
  if IsTerrainWalkable(GetLocationX(p1) , GetLocationY(p1)) then
    call SetUnitPositionLoc(u, p1)
endif
    
   // call SetUnitPositionLoc( u, p1 )
   

    
    call RemoveLocation(p)
    call RemoveLocation(p1)
    call SaveReal(hts, GetHandleId(t), 4, inc)
    
    set u=null
    set t=null
  
 endfunction

 
 function noHolyRad takes nothing returns nothing
  local unit u= GetTriggerUnit()
  local integer id= GetPlayerId(GetOwningPlayer(u))
  local trigger t= GetTriggeringTrigger()
 
 call DisableTrigger(t)
  call IssueImmediateOrder(u, "unimmolation")
  loop
   exitwhen GetUnitState(u, UNIT_STATE_MANA) > 122
     call TriggerSleepAction(1)
   endloop
     
   call EnableTrigger(t)
   
   set t=null
   set u=null
   
 endfunction

function CamShakeIni takes integer playerId,real magnitud,real escala returns nothing
        if ( GetLocalPlayer() == Player(playerId) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call CameraSetTargetNoiseEx(magnitud * 2.0, magnitud * Pow(10, escala), true)
         call CameraSetSourceNoiseEx(magnitud * 2.0, magnitud * Pow(10, escala), true)
    endif
endfunction

function CamShakeEnd takes integer playerId returns nothing
      if ( GetLocalPlayer() == Player(playerId) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
    endif

endfunction

function EnduranceA takes nothing returns nothing
 local unit u= GetTriggerUnit()
 //local integer Id = GetPlayerId(GetOwningPlayer(u))
 local real dmg= GetEventDamage()
 
// call UnitRemoveBuffsEx(u,false,true,true,true,true,false,true)
  call UnitRemoveBuffs(u, false, true)
 if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.5 ) then
    call SetUnitState(u, UNIT_STATE_LIFE, GetUnitState(u, UNIT_STATE_LIFE) + dmg)
 endif
 set u=null
endfunction


function InsRestC takes nothing returns boolean
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
return not ( IsUnitInGroup(GetTriggerUnit(), Endurancegroup) ) and I2R(s__Mstrength[id]) / 23 > GetRandomReal(1, 100)

endfunction

function InsRestAct takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local real perc= I2R(s__Constitution[id]) / 402
 local real dmg= GetEventDamage() * perc
 
   //call SpellName("|cffffccaa+"+R2S(dmg)+" ir|r",udg_PHero[id],2)
   
        call CreateTextTagUnitBJ("|cffffcc00+" + I2S(R2I(dmg)) + " ir|r", u, - 70, 9, 100.00, 100, 100, 0.00)
        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
        call SetTextTagLifespan(GetLastCreatedTextTag(), 1)
        call SetTextTagFadepoint(GetLastCreatedTextTag(), 1.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 48.00, 90)
   
   
   
   call DestroyEffect(AddSpecialEffectTarget(holyfx, udg_PHero[id], "chest"))
 
// call UnitRemoveBuffsEx(u,false,true,true,true,true,false,true)
 // call UnitRemoveBuffs(u,false,true)
 if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.5 ) then
    call SetUnitState(u, UNIT_STATE_LIFE, GetUnitState(u, UNIT_STATE_LIFE) + dmg)
 endif
 set u=null
endfunction

function Agls takes nothing returns nothing
local integer i= 0

loop
exitwhen i > 11

 set EnduranceTrg[i]=CreateTrigger()
 set InsRestTrg[i]=CreateTrigger()
 set deactivateHR[i]=CreateTrigger()
 call DisableTrigger(EnduranceTrg[i])
 call TriggerAddAction(EnduranceTrg[i], function EnduranceA)
 
 call TriggerAddCondition(InsRestTrg[i], Condition(function InsRestC))
 call TriggerAddAction(InsRestTrg[i], function InsRestAct)
 call TriggerAddAction(deactivateHR[i], function noHolyRad)
set i=i + 1
endloop




    set s__charmlev[0]= 3
    set s__charmlev[1]= 6
    set s__charmlev[2]= 8
    set s__charmlev[3]= 11
    set s__charmlev[4]= 14
    set s__charmlev[5]= 18
    set s__charmlev[6]= 21
    set s__charmlev[7]= 26
    set s__charmlev[8]= 30
    set s__charmlev[9]= 35
    set s__charmlev[10]= 41

endfunction


