//===========================================================================
// Trigger: zombikill
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_zombikill_Conditions takes nothing returns boolean
    return IsUnitType(GetDyingUnit(), UNIT_TYPE_UNDEAD) == true and GetUnitLevel(GetDyingUnit()) < 34
endfunction

function Trig_zombikill_Actions takes nothing returns nothing
 local unit u= GetDyingUnit()
 local unit a= GetKillingUnit()
 local integer oid= GetPlayerId(GetOwningPlayer(a))
 local integer id
 
 local group g= LoadGroupHandle(questtm, GetHandleId(u), 10)
 local integer questid
    
   if g != null then
   
      if ( GetLocalPlayer() == Player(oid) ) then
          call ClearTextMessages()
      endif
   
    call DisplayTimedTextToPlayer(Player(oid), 0, 0, 6, "|cff7777dd+300 XP|r")
    call AddHeroXP(udg_PHero[oid], 300, false)
    
    set id=LoadInteger(questtm, GetHandleId(u), 11)
   
    
      if oid == id then
         set zkilled[id]=zkilled[id] + 1
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cff7777dd" + I2S(zkilled[id]) + "/7 Zombies killed")
         
         set questid=LoadInteger(questtm, GetHandleId(g), 1)
         call UpdatePersQuestND(id , questid , zkilled[id] , "-" , I2S(zkilled[id]) , "-")
         
      endif
    call GroupRemoveUnit(g, u)
   
   endif
 set u=null
 set a=null
 set g=null


endfunction

