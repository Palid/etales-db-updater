//===========================================================================
// Trigger: corruption
//
// Unit has corruoption
//===========================================================================
function Trig_corruption_Conditions takes nothing returns boolean
    return ( GetUnitAbilityLevel(GetAttacker(), 'B015') > 0 )
endfunction

function Trig_corruption_Actions takes nothing returns nothing
local unit a= GetAttacker()
local unit u= GetTriggerUnit()
local location p= GetUnitLoc(u)
local unit dummy

   //call UnitChat("Die!...",a)
 
    set dummy=CreateUnitAtLoc(GetOwningPlayer(a), 'n04O', p, bj_UNIT_FACING)
    
 if ( IsUnitType(u, UNIT_TYPE_HERO) == false ) then
    call SetUnitAbilityLevel(dummy, 'A081', ( GetUnitLevel(u) / 5 ))
else
    call SetUnitAbilityLevel(dummy, 'A081', ( GetUnitLevel(u) / 10 ))
endif

    call IssueTargetOrder(dummy, "attack", u)
    call UnitApplyTimedLife(dummy, 'BTLF', 2)
    
call RemoveLocation(p)
set p=null
set u=null
set a=null
set dummy=null

endfunction

//===========================================================================
function InitTrig_corruption takes nothing returns nothing
    local integer index
    set gg_trg_corruption=CreateTrigger()
    
    set index=0
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_corruption, Player(index), EVENT_PLAYER_UNIT_ATTACKED, Condition(function bool))

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop

    call TriggerAddCondition(gg_trg_corruption, Condition(function Trig_corruption_Conditions))
    call TriggerAddAction(gg_trg_corruption, function Trig_corruption_Actions)
endfunction


