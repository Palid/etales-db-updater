    set gg_trg_AncientCoreTest=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_AncientCoreTest, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_AncientCoreTest, Condition(function ACETC))
    call TriggerAddAction(gg_trg_AncientCoreTest, function ACETA)
