function InitSarco takes nothing returns nothing
   local integer i= 0
   local boolexpr istru= Condition(function ctrue)
   
   call GroupEnumUnitsOfType(tombs, UnitId2String('n05I'), istru)
   call DestroyBoolExpr(istru)
   set istru=null
  // call TriggerSleepAction(0.5)
   loop
    exitwhen i > 8
    set trgprofaner[i]=CreateTrigger()
    call SaveInteger(hts, GetHandleId(trgprofaner[i]), 0, i)
 
    call TriggerAddCondition(trgprofaner[i], Condition(function tombcond))
    call TriggerAddAction(trgprofaner[i], function tombact)
    set i=i + 1
  endloop
endfunction


