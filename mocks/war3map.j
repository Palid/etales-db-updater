function InitTrig_NaiarStomp takes nothing returns nothing
    set gg_trg_NaiarStomp=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_NaiarStomp, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_NaiarStomp, Condition(function Trig_NaiarStomp_Conditions))
