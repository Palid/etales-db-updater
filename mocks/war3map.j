function Trig_dadvarq_Actions takes nothing returns nothing
 local integer i= 0
       //call ShowUnit( gg_unit_E00I_2515,false)
    call DisableTrigger(gg_trg_dadvarq)
    call UnitChat("How many time have passed..." , dadvar)
    call TriggerSleepAction(2.5)
    call UnitChat("Thanks " + GetPlayerName(GetOwningPlayer(GetTriggerUnit())) + ", I cannot scape from this place without your help " , dadvar)
    call TriggerSleepAction(3.5)
    call UnitChat("I was caught here by a superior power." , dadvar)
    call TriggerSleepAction(2)
    call UnitChat("And this place seems to have high amounts of negative energy" , dadvar)
    call TriggerSleepAction(3)
    call UnitChat("My power decays any new hour here" , dadvar)
    call TriggerSleepAction(3)
    call UnitChat("We have no time to lost..." , dadvar)
    call TriggerSleepAction(3)
    call UnitChat("Find me in the Father's Sun altar..." , dadvar)
    call TriggerSleepAction(3)
    call DestroyEffect(AddSpecialEffectTarget(seblink, dadvar, "origin"))
    call TriggerSleepAction(0.8)
    call SetUnitPosition(dadvar, - 6868, 7985)
    call TriggerSleepAction(0.8)
      if ( IsPlayerInForce(GetLocalPlayer(), GetPlayersAll()) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
                call PingMinimap(- 6868, 7985, 10)
        //call StartSound(bj_pingMinimapSound)
        endif
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffcccc00MAIN QUEST COMPLETED|r")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffffcc00The Minstreels of Enthashara|r: All players got +15000 XP, +1 Legendary Chest")
    call StartSound(bj_questCompletedSound)
    
    loop
    exitwhen i > 8
      
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[81], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
      call AddHeroXP(udg_PHero[i], 15000, false)
     set i=i + 1
    
    endloop
    
    call QuestItemSetCompleted(dadvarqi, true)
    call QuestSetCompleted(dadvarq, true)
    call EnableTrigger(gg_trg_flamesq)
   // call TriggerSleepAction(8) 
endfunction

