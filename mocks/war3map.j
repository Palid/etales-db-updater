//library KnuthChecksum:
    function GetKnuthChecksum takes integer k,integer m returns integer
        local integer c= s__BigInt_copy(k)
        local integer c2= s__BigInt_copy(k)
        call s__BigInt_add(c,3 , 0)
        call s__BigInt_multiplyBig(c2,c)
        call s__BigInt_destroy(c)
        set c=s__BigInt_mod(c2,m)
        call s__BigInt_destroy(c2)
        return c
    endfunction

