local integer i= 0

 loop
 exitwhen i > 7
    set herodiag[i]=CreateTrigger()
    
    call SaveInteger(HTsets, GetHandleId(herodiag[i]), 1, i + 7)
    
    call TriggerAddCondition(herodiag[i], Condition(function Trig_dialogues_Conditions))
    call TriggerAddAction(herodiag[i], function Trig_dialogues_Actions)
    set i=i + 1
    endloop
endfunction


