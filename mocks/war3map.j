endfunction


//===========================================================================
// Trigger: SCR
//===========================================================================
//TESH.scrollpos=66
//TESH.alwaysfold=0
function Trig_SCR_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A05U' or GetSpellAbilityId() == 'A06W' )
endfunction

function DMGG takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer level= 0
local integer idmg= 0
local real dmg= 0
local real selfdmg= GetUnitState(GetTriggerUnit(), UNIT_STATE_LIFE) - I2R(GetHeroInt(GetTriggerUnit(), true))

    if ( GetSpellAbilityId() == 'A06W' ) then
    set level=11
    else
    set level=( GetUnitAbilityLevel(GetTriggerUnit(), GetSpellAbilityId()) + 1 )
    endif

     set idmg=GetHeroInt(udg_PHero[id], true) * level / 3
     set dmg=I2R(idmg) * tmpinsp
     set dmg=dmg + dmg * AddRacialBonus(GetEnumUnit() , id)
     if ( IsUnitInGroup(GetEnumUnit(), udg_Spelledg) == false ) then
         call GroupAddUnit(udg_Spelledg, GetEnumUnit())
         call TriggerRegisterUnitEvent(gg_trg_SPDMG, GetEnumUnit(), EVENT_UNIT_DAMAGED)
     endif
     
      call EnableTrigger(gg_trg_SPDMG)
      call UnitDamageTarget(GetTriggerUnit(), GetEnumUnit(), dmg, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
      //call UnitDamageTargetBJ( GetTriggerUnit(), GetEnumUnit(),dmg, ATTACK_TYPE_NORMAL , DAMAGE_TYPE_UNIVERSAL  )
      call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , GetSpellTargetUnit())
      set spelldmg[id]=0
        
      call SetUnitState(GetTriggerUnit(), UNIT_STATE_LIFE, selfdmg)
      call SetUnitVertexColorBJ(GetEnumUnit(), 10, 10, 10, 0)
endfunction

function DMGOF takes nothing returns nothing
      call SetUnitVertexColorBJ(GetEnumUnit(), 100, 100, 100, 0)
endfunction

function SHOWD takes nothing returns nothing
     local integer idmg= 0
     local real dmg= 0

      set dmg=LoadReal(udg_spelledh, GetHandleId(GetEnumUnit()), 10)
      set idmg=R2I(dmg)
      
      call SpellDmgText(idmg , GetEnumUnit())

     // call SetUnitVertexColorBJ( GetEnumUnit(), 100, 100,100,0 )
endfunction


function ISEMY takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(GetTriggerUnit())) == true and GetUnitState(GetFilterUnit(), UNIT_STATE_LIFE) > 0.3 )
endfunction


function Trig_SCR_Actions takes nothing returns nothing
 local unit u= GetSpellAbilityUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local location p= GetUnitLoc(u)
 local real x= GetLocationX(p)
 local real y= GetLocationY(p)
 local group g= GetUnitsInRangeOfLocMatching(250, p, Condition(function ISEMY))
 local unit d= CreateUnitAtLoc(GetOwningPlayer(GetTriggerUnit()), 'h00J', p, 270)
 local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif
 set tmpinsp=inspired

 call UnitApplyTimedLife(d, 'BTLF', 1.10)

// call DisableTrigger(gg_trg_DMG)
 call ForGroup(g, function DMGG)
// call TriggerSleepAction(0.2)
// call ForGroupBJ(g, function SHOWD )
 call TriggerSleepAction(0.6)
 
call ForGroup(g, function DMGOF)
 call DestroyGroup(g)
  set g=null
// call RemoveDestructable(d1)
 call RemoveLocation(p)
  set p=null
 set d=null


 set u=null
//call EnableTrigger(gg_trg_DMG)
endfunction

