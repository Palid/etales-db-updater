//===========================================================================
// Trigger: akashaEng
//
// When engaging a battle
//===========================================================================
function akashacycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer id= GetPlayerId(GetOwningPlayer(u))
local real xc= LoadReal(hts, GetHandleId(t), 2)
local real yc= LoadReal(hts, GetHandleId(t), 3)
local real distance= LoadInteger(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i=  LoadInteger(hts, GetHandleId(t), 7)
local unit h= LoadUnitHandle(hts, GetHandleId(t), 8)
local real inc= 12
local real x
local real y
local real xb
local real yb
local real amp
local real face
local real bx= xc
local real by= yc



	set it=it - ( it * 0.07 )
	set i=i + 9
	set xc=xc + it * Cos(angle * bj_DEGTORAD)
	set yc=yc + it * Sin(angle * bj_DEGTORAD)
	
    set face=Sin(i * bj_DEGTORAD)
 
  if IsTerrainWalkable(xc , yc) then
    set bx=xc
    set by=yc
endif
 
    call SetUnitX(u, bx)
    call SetUnitY(u, by)
   
   
 //call SetUnitFacing(u,angle*face) 


 
 call SaveReal(hts, GetHandleId(t), 2, xc)
 call SaveReal(hts, GetHandleId(t), 3, yc)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 
if it <= 2 then

  call PauseUnit(u, false)
  call SetUnitTimeScale(u, 1)
  set AkashaSwp=false
  call UnitRemoveAbility(u, 'A0GL') //carrion attack 
  call DestroyEffect(LoadEffectHandle(hts, GetHandleId(t), 9))
  call DestroyEffect(LoadEffectHandle(hts, GetHandleId(t), 10))
  
  call IssueTargetOrder(u, "smart", h)
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  
  
endif

set t=null
set u=null
set h=null



endfunction



function akashaDispl takes unit a,unit u returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(a))
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real distance= SquareRoot(dx * dx + dy * dy) + 400
 local real it= distance / 14
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local effect lh= AddSpecialEffectTarget(sweepfx, a, "chest")
 local effect rh= AddSpecialEffectTarget(sweepfx, a, "weapon")


 
 //call ShowUnit(a,false)
 call PauseUnit(a, true)
 call SetUnitAnimationByIndex(a, 6)
 call SetUnitTimeScale(a, 0.65)
 call UnitAddAbility(a, 'A0GL') //carrionattack
 set AkashaSwp=true

 call SaveUnitHandle(hts, GetHandleId(t), 1, a)
 call SaveReal(hts, GetHandleId(t), 2, ux)
 call SaveReal(hts, GetHandleId(t), 3, uy)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveUnitHandle(hts, GetHandleId(t), 8, u)
 call SaveEffectHandle(hts, GetHandleId(t), 9, lh)
 call SaveEffectHandle(hts, GetHandleId(t), 10, rh)
 

 call TimerStart(t, 0.03, true, function akashacycle)
 
 set t=null

 set lh=null
 set rh=null

endfunction



function akfilter takes nothing returns boolean
    return true
endfunction

function akashaec takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetPlayerController(GetOwningPlayer(GetTriggerUnit())) == MAP_CONTROL_USER //banshee
endfunction

function akashaActions takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit B= LoadUnitHandle(AiHash, GetHandleId(t), 1)
    local integer i= LoadInteger(AiHash, GetHandleId(t), 2)
 local integer buf= LoadInteger(AiHash, GetHandleId(t), 3)
	
 local unit gu= null
 local unit mi= null
 local boolexpr filter= null
 local real dmg= 0
 local real x= GetUnitX(B)
 local real y= GetUnitY(B)


set buf=buf + 1

 if buf > 3 then
 set buf=0
   call UnitRemoveBuffs(B, false, true)
 endif
 
  set i=i + 1

  if i > 40 then
    set i=0
	set akashaevent1=akashaevent1 + 1
    set akashaevent3=akashaevent3 + 1
    set akashagr=CreateGroup()
	set filter=Condition(function akfilter)
    call GroupEnumUnitsInRange(akashagr, x, y, 1024, filter)
    call DestroyBoolExpr(filter)
    set filter=null

	   loop
	    set gu=FirstOfGroup(akashagr)
		  exitwhen gu == null
			if ( IsUnitType(gu, UNIT_TYPE_HERO) == true and IsUnitEnemy(gu, GetOwningPlayer(B)) == true and GetWidgetLife(gu) > 0.4 ) then
				 call GroupClear(akashagr)
				 call akashaDispl(B , gu)
			endif
		   
		call GroupRemoveUnit(akashagr, gu)
		set gu=null
		endloop

	 call DestroyGroup(akashagr)
	 set akashagr=null
	 
 
  endif

  call SaveInteger(AiHash, GetHandleId(t), 2, i)
  call SaveInteger(AiHash, GetHandleId(t), 3, buf)

set B=null
set t=null
set filter=null
set mi=null

endfunction



function akashaea takes nothing returns nothing
 local unit B= udg_BOSS[6]
 local integer i= 0
 local integer buf= 0
 if AkashaEng == null then
 call DisableTrigger(AkashaTrg)
 call EnableTrigger(gg_trg_Akraid)
 call TriggerSleepAction(1)
 if ( GetTriggerExecCount(GetTriggeringTrigger()) < 2 ) then
// call PlaySoundOnUnitBJ(gg_snd_BansheeWelcome, 127, B )  
// call PlaySoundBJ( gg_snd_BansheeWelcome )  
 call TriggerSleepAction(3)
 call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "|cffffcc00Anastashia says|r: Hoo   I have new visitors here...")
 call TriggerSleepAction(3)

endif
 call TriggerSleepAction(2.8)
  
 //call PlaySoundOnUnitBJ(gg_snd_BansheeYesAttack1, 127, B )  
 
 call PauseUnit(B, false)
 call SetUnitInvulnerable(B, false)
 set AkashaEng=(NewTimerEx(0)) // INLINED!!
 call SaveUnitHandle(AiHash, GetHandleId(AkashaEng), 1, B)
 call SaveInteger(AiHash, GetHandleId(AkashaEng), 2, i)
 call SaveInteger(AiHash, GetHandleId(AkashaEng), 3, buf)
call TimerStart(AkashaEng, 1, true, function akashaActions)
 set B=null

else
 set B=null
 return
endif


endfunction

//===========================================================================
function InitTrig_akashaEng takes nothing returns nothing
    set AkashaTrg=CreateTrigger()
    call TriggerAddCondition(AkashaTrg, Condition(function akashaec))
    call TriggerAddAction(AkashaTrg, function akashaea)
endfunction


//===========================================================================
// Trigger: akashadmgd
//===========================================================================
function akashadmga takes nothing returns nothing
 local integer perc= R2I(GetEventDamage()) / 200
 local integer i= LoadInteger(AiHash, GetHandleId(AkashaEng), 2)
     set i=i + 1
     call SaveInteger(AiHash, GetHandleId(AkashaEng), 2, i)
     set akashaevent2=akashaevent2 + perc
     
endfunction

//===========================================================================
function InitTrig_akashadmgd takes nothing returns nothing
    set Akashadmgd=CreateTrigger()
   
    call TriggerAddAction(Akashadmgd, function akashadmga)
endfunction


//===========================================================================
// Trigger: akashaprv
//===========================================================================
function Akashaprvc takes nothing returns boolean
       return true
endfunction
 
 
function akashapcicle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real dist= LoadReal(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i= LoadInteger(hts, GetHandleId(t), 7)
 
local real xi= LoadReal(hts, GetHandleId(t), 8) + it
local real height= dist / 2.5
//local real h = GetParabolaZ(xi,dist,height)

 
 set x=x + it * Cos(angle * bj_DEGTORAD)
 set y=y + it * Sin(angle * bj_DEGTORAD)

// call SetUnitFlyHeight( a, h, 0) 
 //call SetUnitPosition(a,x,y)
 if IsTerrainWalkable(x , y) then
    call SetUnitX(a, x)
    call SetUnitY(a, y)
endif
 //call DestroyEffect(AddSpecialEffect(seffectjump,x,y))
 
 if it < 1 or GetUnitState(a, UNIT_STATE_LIFE) < 0.4 then

 // call SetUnitFlyHeight( a, 0, 1 ) 
  //call PauseUnit(a,false)
  call SetUnitPathing(a, true)
  call SetUnitTimeScale(a, 1)
  call UnitRemoveAbility(a, 'A0HQ') //evasion 
  call IssueImmediateOrder(a, "stop")
  
  call PauseTimer(t)
  //call DestroyEffect(AddSpecialEffect(seffectjump,x,y)) 
          if IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) then //false
         loop
           exitwhen IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) == false
              call TriggerSleepAction(0.3)
              set x=x + 32 * Cos(angle * bj_DEGTORAD)
              set y=y + 32 * Sin(angle * bj_DEGTORAD)

         endloop
        call SetUnitX(a, x)
        call SetUnitY(a, y)
         
      endif
 
  call FlushChildHashtable(hts, GetHandleId(t))
  call ReleaseTimer(t)



  else
  call SaveReal(hts, GetHandleId(t), 2, x)
  call SaveReal(hts, GetHandleId(t), 3, y)
  
  set it=it - 1
  call SaveReal(hts, GetHandleId(t), 5, it)
 // call SaveReal(hts,GetHandleId(t),6,inc)  
  //call SaveReal(hts,GetHandleId(t),5,angle_t)  
      call SaveReal(hts, GetHandleId(t), 8, xi)
 endif
set a=null
set t=null

endfunction


function akashaprvSetup takes unit u,unit a returns nothing
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real acuracy= GetRandomReal(150, 250)
 local real distance= SquareRoot(dx * dx + dy * dy) / 1.6 + acuracy
 local real it= distance / 14
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer dec= 10

    
 call SetUnitPathing(u, false)
 call UnitAddAbility(u, 'A0HQ') //evasion 
call IssueTargetOrder(u, "smart", a)
 

 
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, x)
 call SaveReal(hts, GetHandleId(t), 3, y)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveReal(hts, GetHandleId(t), 8, 0)

 call TimerStart(t, 0.02, true, function akashapcicle)


 set t=null
 call TriggerSleepAction(2)
 call GroupRemoveUnit(backing, u)

endfunction


function Akashaprva takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local unit a= GetAttacker()
 local real x1= GetUnitX(u)
 local real y1= GetUnitY(u)
 local real x2= GetUnitX(a)
 local real y2= GetUnitY(a)
 local real dx= x2 - x1
 local real dy= y2 - y1
 local real distance= SquareRoot(dx * dx + dy * dy)
 local real angle=180 + bj_RADTODEG * Atan2(dy, dx)
 local real x
 local real y
 local real spd= GetUnitMoveSpeed(u)
 local real atspd= GetUnitMoveSpeed(a)
 local real erange= GetUnitAcquireRange(a) + atspd + 50
 local real safereq= erange - distance
 local real rtime= 0.3 + safereq / ( spd + 1 )
 local real nangle= GetRandomReal(angle - 45, angle + 45)
 local integer major= ( GetUnitLevel(a) - GetUnitLevel(u) ) / 2
 local boolexpr filter
 local real w= 0.00
 local unit gu
 local integer i= 0
 
 

 call DisableTrigger(Akashaprv)
 
if true then
 set akashaevent1=akashaevent1 + 1
 set akashaevent3=akashaevent3 + 1
 
  call GroupAddUnit(meleeUnits, u)
  
 
 if distance < 600 then
 
   if IsUnitInGroup(u, backing) == false then
  	   call GroupAddUnit(backing, u)
	  // call TriggerSleepAction(0.2)
	   call akashaprvSetup(u , a)
   else
    call IssueTargetOrder(u, "attack", a)
   endif
 
 elseif spd > atspd then
  set x=x2 + erange * Cos(angle * bj_DEGTORAD)
  set y=y2 + erange * Sin(angle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(rtime)
  call IssueTargetOrder(u, "attack", a)

 elseif ( distance * 2 ) > erange then
 
  if IsUnitType(a, UNIT_TYPE_MELEE_ATTACKER) == true then
    set safereq=GetUnitMoveSpeed(u)
  endif
 
  set x=x1 + safereq * Cos(angle * bj_DEGTORAD)
  set y=y1 + safereq * Sin(angle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(rtime)
  call IssueTargetOrder(u, "attack", a)
 else
  
  if IsUnitType(a, UNIT_TYPE_RANGED_ATTACKER) == true then
    set erange=GetUnitMoveSpeed(u)
  endif
 
  set x=x1 + erange * Cos(nangle * bj_DEGTORAD)
  set y=y1 + erange * Sin(nangle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(1 + rtime)
  call IssueTargetOrder(u, "attack", a)
 endif
 
   call TriggerSleepAction(1)
   call GroupRemoveUnit(meleeUnits, u)
 endif

    set akwait=CreateGroup()
	set filter=Condition(function bool)
    call GroupEnumUnitsInRange(akwait, x, y, 1024, filter)
    call DestroyBoolExpr(filter)
    set filter=null

	   loop
	    set gu=FirstOfGroup(akwait)
		  exitwhen gu == null
			if ( IsUnitType(gu, UNIT_TYPE_HERO) == true and IsUnitEnemy(gu, GetOwningPlayer(u)) == true and GetWidgetLife(gu) > 0.4 ) then
				set w=w + 1
			endif
		   
		call GroupRemoveUnit(akwait, gu)
		set gu=null
		endloop

	 call DestroyGroup(akwait)
	 set akwait=null



set a=null
set u=null

if w < 1 then
  set w=1.00
endif


set w=0.50 + ( 6 / w )

call TriggerSleepAction(w)
call EnableTrigger(Akashaprv)


endfunction

//===========================================================================
function InitTrig_akashaprv takes nothing returns nothing

    set Akashaprv=CreateTrigger()
    call TriggerAddCondition(Akashaprv, Condition(function Akashaprvc))
    call TriggerAddAction(Akashaprv, function Akashaprva)
 
endfunction


//===========================================================================
// Trigger: Akraid
//===========================================================================

function akraidcycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit ak= LoadUnitHandle(hts, GetHandleId(t), 6)
local real xc= GetUnitX(ak)
local real yc= GetUnitY(ak)

local integer c= LoadInteger(hts, GetHandleId(t), 3)
local real anglel= LoadReal(hts, GetHandleId(t), 4)
local real angler= LoadReal(hts, GetHandleId(t), 5)

local real x1= xc + 2048 * Cos(anglel * bj_DEGTORAD)
local real y1= yc + 2048 * Sin(anglel * bj_DEGTORAD)

local real x2= xc + 2048 * Cos(angler * bj_DEGTORAD)
local real y2= yc + 2048 * Sin(angler * bj_DEGTORAD)

local unit dl= CreateUnit(Player(11), 'n08S', xc, yc, anglel)
local unit dr= CreateUnit(Player(11), 'n08S', xc, yc, angler)
				
	set c=c + 1
				call SetUnitTimeScale(dl, 1)
				call UnitApplyTimedLife(dl, 'BTLF', 4)
				call IssuePointOrder(dl, "move", x1, y1)
				
				call SetUnitTimeScale(dr, 1)
				call UnitApplyTimedLife(dr, 'BTLF', 4)
				call IssuePointOrder(dr, "move", x2, y2)
				
 
  set anglel=anglel + 8
  set angler=angler - 8

 call SaveInteger(hts, GetHandleId(t), 3, c)
 call SaveReal(hts, GetHandleId(t), 4, anglel)
 call SaveReal(hts, GetHandleId(t), 5, angler)

if c > 18 then

  call PauseUnit(ak, false)
  call SetUnitInvulnerable(ak, false)
  call SetUnitTimeScale(ak, 1)
  set Akasharaid=false
  call DestroyEffect(LoadEffectHandle(hts, GetHandleId(t), 2))
 
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  
  call EnableTrigger(gg_trg_Akraid)
endif

set t=null
set ak=null
set dl=null
set dr=null


endfunction



function akraid takes unit a returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(a))
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)

 local real anglel= 0
 local real angler= 0
 local integer c= 0
 local timer t= (NewTimerEx(0)) // INLINED!!
 local real xr= GetRectCenterX(gg_rct_araid)
 local real yr= GetRectCenterY(gg_rct_araid)
 local effect rdfx= null
     set anglel=GetRandomReal(0, 359)
     call SetUnitFacing(a, anglel)
     call PauseUnit(a, true)
     call SetUnitTimeScale(a, 0.3)
   
     call SetUnitInvulnerable(a, true)
     call DestroyEffect(AddSpecialEffectTarget(seblink, a, "chest"))
     call TriggerSleepAction(0.4)
     
     call SetUnitX(a, GetRectCenterX(gg_rct_araid))
     call SetUnitY(a, GetRectCenterY(gg_rct_araid))
     set rdfx=AddSpecialEffect(s__castfx[3], xr, yr)
  
     call TriggerSleepAction(1)
     call SetUnitAnimationByIndex(a, 11)
	 call DestroyEffect(AddSpecialEffect(seffectclap, xr, yr))
    

  
  set angler=anglel - 10
  if angler < 0 then
   set angler=360 + angler
  endif
 call PlaySoundOnUnitBJ(gg_snd_akasharaid, 127, udg_BOSS[6])

 call SaveEffectHandle(hts, GetHandleId(t), 2, rdfx)
 call SaveInteger(hts, GetHandleId(t), 3, c)
 call SaveReal(hts, GetHandleId(t), 4, anglel)
 call SaveReal(hts, GetHandleId(t), 5, angler)
 call SaveUnitHandle(hts, GetHandleId(t), 6, a)

 call TimerStart(t, 0.15, true, function akraidcycle)

 set t=null
 set rdfx=null
endfunction


function Trig_Akraid_Conditions takes nothing returns boolean
    return akashaevent1 > 4 and AkashaSwp == false and Akashatg == false
endfunction

function Trig_Akraid_Actions takes nothing returns nothing
  local integer i= 0
     call DisableTrigger(gg_trg_Akraid)
     set akashaevent1=0
     set Akasharaid=true
     set akashaevent3=akashaevent3 + 1
    
     call SaveInteger(AiHash, GetHandleId(AkashaEng), 2, i)
	 call akraid(udg_BOSS[6])
    

endfunction

//===========================================================================
function InitTrig_Akraid takes nothing returns nothing
    set gg_trg_Akraid=CreateTrigger()

    call TriggerRegisterTimerEvent(gg_trg_Akraid, 1, true)
    call TriggerAddCondition(gg_trg_Akraid, Condition(function Trig_Akraid_Conditions))
    call TriggerAddAction(gg_trg_Akraid, function Trig_Akraid_Actions)
endfunction


//===========================================================================
// Trigger: aktarget
//===========================================================================
//TESH.scrollpos=75
//TESH.alwaysfold=0
function settarget takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit ak= LoadUnitHandle(hts, GetHandleId(t), 1)
local real angle= GetUnitFacing(ak)
local real xc= GetUnitX(ak)
local real yc= GetUnitY(ak)
local real xd= xc + 512 * Cos(angle * bj_DEGTORAD)
local real yd= yc + 512 * Sin(angle * bj_DEGTORAD)
local real xe= xc - 512 * Cos(angle * bj_DEGTORAD)
local real ye= yc - 512 * Sin(angle * bj_DEGTORAD)
local integer c= LoadInteger(hts, GetHandleId(t), 2)
local unit ds= CreateUnit(Player(11), 'n08T', xc, yc, 270)
local unit dr= CreateUnit(Player(11), 'n08T', xd, yd, 270)
local unit dt= CreateUnit(Player(11), 'n08T', xe, ye, 270)

 call DestroyEffect(AddSpecialEffect(symbolfx, xc, yc))
 call DestroyEffect(AddSpecialEffect(symbolfx, xd, yd))
 call DestroyEffect(AddSpecialEffect(symbolfx, xe, ye))
				
 call UnitApplyTimedLife(dr, 'BTLF', 1.3)
 call UnitApplyTimedLife(ds, 'BTLF', 1.3)
 call UnitApplyTimedLife(dt, 'BTLF', 1.3)
 set c=c + 1
 call SaveInteger(hts, GetHandleId(t), 2, c)


if c > 4 then

  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
 
endif

set t=null
set ak=null
set dr=null
set ds=null
set dt=null

endfunction


function akashatarget takes unit v returns nothing
  local timer t= (NewTimerEx(0)) // INLINED!!
  local integer c= 0
  
  
  call SaveUnitHandle(hts, GetHandleId(t), 1, v)
  call SaveInteger(hts, GetHandleId(t), 2, c)

  call TimerStart(t, 1, true, function settarget)
endfunction


function Trig_aktarget_Conditions takes nothing returns boolean
    return akashaevent2 > 250
endfunction

function Trig_aktarget_Actions takes nothing returns nothing
 local unit B= udg_BOSS[6]
 local boolexpr filter= Condition(function bool)
 local unit gu= null

 set akashaevent2=0
 call DisableTrigger(gg_trg_aktarget)
    
      call PlaySoundOnUnitBJ(gg_snd_akashadie, 127, B)
    set akashagr=CreateGroup()
	call GroupEnumUnitsInRange(akashagr, GetRectCenterX(gg_rct_araid), GetRectCenterY(gg_rct_araid), 2048, filter)
    call DestroyBoolExpr(filter)
    set filter=null

	   loop
	    set gu=FirstOfGroup(akashagr)
		  exitwhen gu == null
			if ( IsUnitType(gu, UNIT_TYPE_HERO) == true and IsUnitEnemy(gu, GetOwningPlayer(B)) == true and GetWidgetLife(gu) > 0.4 ) then
				 call GroupClear(akashagr)
				 call akashatarget(gu)
			endif
		   
		call GroupRemoveUnit(akashagr, gu)
		set gu=null
		endloop

	 call DestroyGroup(akashagr)
	 set akashagr=null
     
    set B=null
    set gu=null
    call TriggerSleepAction(20)
    call EnableTrigger(gg_trg_aktarget)
 

endfunction

//===========================================================================
function InitTrig_aktarget takes nothing returns nothing
    set gg_trg_aktarget=CreateTrigger()
   
    call TriggerRegisterTimerEvent(gg_trg_aktarget, 2, true)
    call TriggerAddCondition(gg_trg_aktarget, Condition(function Trig_aktarget_Conditions))
    call TriggerAddAction(gg_trg_aktarget, function Trig_aktarget_Actions)
endfunction


//===========================================================================
// Trigger: targetexp
//
// "RedAftershock.mdx"
//===========================================================================
function Trig_targetexp_Conditions takes nothing returns boolean
    return GetUnitTypeId(GetDyingUnit()) == 'n08T' //exploder
endfunction

function Trig_targetexp_Actions takes nothing returns nothing
  local real x= GetUnitX(GetDyingUnit())
  local real y= GetUnitY(GetDyingUnit())

  call DestroyEffect(AddSpecialEffect(s__castfx[9], x, y))
  call DestroyEffect(AddSpecialEffect("RedAftershock.mdx", x, y))
endfunction

//===========================================================================
function InitTrig_targetexp takes nothing returns nothing
    set gg_trg_targetexp=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_targetexp, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_targetexp, Condition(function Trig_targetexp_Conditions))
    call TriggerAddAction(gg_trg_targetexp, function Trig_targetexp_Actions)
endfunction


//===========================================================================
// Trigger: akburn
//===========================================================================
function akappr takes nothing returns nothing
  local timer t= GetExpiredTimer()
  local integer tr= LoadInteger(hts, GetHandleId(t), 0) + 7
  local unit dummy= LoadUnitHandle(hts, GetHandleId(t), 1)

  call SetUnitVertexColor(dummy, tr, tr, tr, tr)
  call SaveInteger(hts, GetHandleId(t), 0, tr)
  
  if tr > 254 then
     call SetUnitVertexColor(dummy, 255, 255, 255, 255)
    // call SetUnitFlyHeight(dummy,0,0)
     call FlushChildHashtable(hts, GetHandleId(t))
     call PauseTimer(t)
     call ReleaseTimer(t)
  endif
  
  
  set t=null
  set dummy=null
  
endfunction


function akburnci takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit ak= LoadUnitHandle(hts, GetHandleId(t), 6)
local real xc= GetUnitX(ak)
local real yc= GetUnitY(ak)
local integer c= LoadInteger(hts, GetHandleId(t), 3)
local real anglel= GetRandomReal(0, 359)
local real x1= xc + 2048 * Cos(anglel * bj_DEGTORAD)
local real y1= yc + 2048 * Sin(anglel * bj_DEGTORAD)

local unit dl= CreateUnit(Player(11), 'n08U', xc, yc, anglel)
				
	set c=c + 1
				call SetUnitTimeScale(dl, 0.5)
				call UnitApplyTimedLife(dl, 'BTLF', 6)
				call IssuePointOrder(dl, "move", x1, y1)
 call SaveInteger(hts, GetHandleId(t), 3, c)

if c > 128 then

  call PauseUnit(ak, false)
 // call RemoveUnit(LoadUnitHandle(hts,GetHandleId(t),1))
  set Akashatg=false
  call DestroyEffect(LoadEffectHandle(hts, GetHandleId(t), 2))
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  //call EnableTrigger(gg_trg_akburn)
endif

set t=null
set ak=null
set dl=null
endfunction



function akburn takes unit a returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(a))
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local integer tr= 0
 local integer c= 0
 local timer t= (NewTimerEx(0)) // INLINED!!
 local real xr= GetRectCenterX(gg_rct_araid)
 local real yr= GetRectCenterY(gg_rct_araid)
 local effect rdfx= null
 local unit brillo= null
 local timer tx= (NewTimerEx(0)) // INLINED!!
 
     call SetUnitFacing(a, 270)
     call PauseUnit(a, true)
     call DestroyEffect(AddSpecialEffectTarget(seblink, a, "chest"))
     call TriggerSleepAction(0.2)
     call SetUnitVertexColor(a, 255, 255, 255, 0)
     

     
     call SetUnitX(a, GetRectCenterX(gg_rct_araid))
     call SetUnitY(a, GetRectCenterY(gg_rct_araid))
     call SetUnitFlyHeight(a, 100, 0)
     call TriggerSleepAction(1)
     call SaveInteger(hts, GetHandleId(tx), 0, tr)
     call SaveUnitHandle(hts, GetHandleId(tx), 1, a)

     call TimerStart(tx, 0.02, true, function akappr)
     call SetUnitAnimationByIndex(a, 3)
     set rdfx=AddSpecialEffect(s__castfx[3], xr, yr)
     //set brillo = CreateUnit(Player(11),'n08V',xr,yr,270) //bansheeminion
     call SetUnitFlyHeight(a, 20, 60)
     call TriggerSleepAction(2)
	 call PlaySoundOnUnitBJ(gg_snd_akashatimeup, 127, udg_BOSS[6])
    
    
  

 call SaveUnitHandle(hts, GetHandleId(t), 1, brillo)
 call SaveEffectHandle(hts, GetHandleId(t), 2, rdfx)
 call SaveInteger(hts, GetHandleId(t), 3, c)
 call SaveUnitHandle(hts, GetHandleId(t), 6, a)

 call TimerStart(t, 0.1, true, function akburnci)

 set t=null
 set tx=null
 set rdfx=null
 set brillo=null
endfunction


function akburnc takes nothing returns boolean
    return akashaevent3 > 3 and AkashaSwp == false and Akasharaid == false
endfunction

function Trig_akburn_Actions takes nothing returns nothing

    local integer i= 0
     call DisableTrigger(gg_trg_akburn)
     set akashaevent3=0
     set Akashatg=true
    
     call SaveInteger(AiHash, GetHandleId(AkashaEng), 2, i)
	 call akburn(udg_BOSS[6])
   // call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "|cffffcc00Anastashia says|r: Die..." )
     call TriggerSleepAction(11)
     call EnableTrigger(gg_trg_akburn)

endfunction

//===========================================================================
function InitTrig_akburn takes nothing returns nothing
    set gg_trg_akburn=CreateTrigger()
    
     call TriggerRegisterTimerEvent(gg_trg_akburn, 0.5, true)
     call TriggerAddCondition(gg_trg_akburn, Condition(function akburnc))
     call TriggerAddAction(gg_trg_akburn, function Trig_akburn_Actions)
endfunction


//===========================================================================
// Trigger: atilaD
//===========================================================================
function atilac takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == udg_Bosses[5] and GetOwningPlayer(GetTriggerUnit()) == Player(PLAYER_NEUTRAL_AGGRESSIVE) )
endfunction

function atilaa takes nothing returns nothing
//call shakecam()
 call DropPvpBoss(GetTriggerUnit())
 call CreateFixed(GetTriggerUnit() , 134) //wolf shoulders
 call CreateFixed(GetTriggerUnit() , 1008) // 'I0AU' //Legendary Solvek saryon sword
 call CreateFixed(GetTriggerUnit() , 1036) // 'I0B0' //Zero kayryu


call shakecam(GetTriggerExecCount(gg_trg_atilaD))
//This for avoiding dump items from stealers when the players are attacking some boss
call SetUnitDrop(udg_BOSSID[5] , 0 , 0 , 0 , 0 , 0 , 0 , 0 , 0)
call EnableTrigger(gg_trg_atiladrop)

if ( GetTriggerExecCount(GetTriggeringTrigger()) > 1 ) then
  call CreateItemLoc('I00E', udg_BossesP[5]) //Divine Chest
else

 call TriggerRegisterUnitEvent(gg_trg_atiladrop, udg_BOSS[5], EVENT_UNIT_DAMAGED)
  endif
  

  
  call TriggerSleepAction(respawnboss)
 call ReviveHeroLoc(udg_BOSS[5], udg_BossesP[5], true)


endfunction

//===========================================================================
function InitTrig_atilaD takes nothing returns nothing
    set gg_trg_atilaD=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_atilaD, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_atilaD, Condition(function atilac))
    call TriggerAddAction(gg_trg_atilaD, function atilaa)
endfunction


