    function CodeVersioning__OnSuccessfulLoad takes nothing returns nothing
        call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, 0, 0, 20, "Load Successful")
        set udg_PlayerReady[GetPlayerId(GetTriggerPlayer())]=true
     
    
    endfunction
//end of: CORE_ON_SUCCESSFUL_LOAD()
//textmacro instance: CORE_ON_FAILED_LOAD()
    
    function CodeVersioning__DisplayInvalidCode takes nothing returns nothing
        call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, 0, 0, 20, "Invalid Code")
    endfunction
    function CodeVersioning__OnFailedLoad takes nothing returns nothing
        call DisplayTimedTextToPlayer(CodeVersioning__triggerPlayer, 0, 0, 20, "Invalid Code") // INLINED!!
    endfunction
//end of: CORE_ON_FAILED_LOAD()
//textmacro instance: CORE_LOAD_CONDITION()
    
    function CodeVersioning__CanLoad takes nothing returns boolean
        return true
    endfunction
