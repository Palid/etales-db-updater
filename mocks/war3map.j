function Trig_ScorpionKingDie_Actions takes nothing returns nothing
call DropPvpBoss(GetTriggerUnit())
call CreateFixed(GetTriggerUnit() , 79) // Divine chest

call CreateFixed(GetTriggerUnit() , 143) // 'I039' //Forgotten legs 
call CreateFixed(GetTriggerUnit() , 1005) // 'I0B2' //Legendary Solvek abyss tear 
 call PauseTimer(ScorpionEng)
 call ReleaseTimer(ScorpionEng)
 set ScorpionEng=null

endfunction

