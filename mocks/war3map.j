function skip_Actions takes nothing returns nothing
 local player pl= GetTriggerPlayer()
   
   if IsPlayerInForce(pl, textforce) == true then
     call ForceRemovePlayer(textforce, pl)
   endif
   
   if ( GetLocalPlayer() == pl ) then
          call ClearTextMessages()
   endif

    
    set pl=null
endfunction

