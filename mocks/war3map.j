//===========================================================================
// Trigger: agedman
//===========================================================================
function Trig_agedman_Conditions takes nothing returns boolean
    return agedadviced[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == false and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_agedman_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 call DisableTrigger(gg_trg_agedman)
 set agedadviced[id]=true

  call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    I knew that these days would come to us, But i'm surprised about how fast was it")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    It was like they were under us all the time, then someone rise them instantly...")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    after a few hours we saw a huge march of undeads from the gardens of death!..")
          call TriggerSleepAction(11)
          call MakeFaceToUnit(gg_unit_n08J_0382 , udg_PHero[id])
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man looks you:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    As you can check, our village is a little group of houses around the way...")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    our deads number are very low compared to these undeads walking, they are not our parents, or our died brothers")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    they are soldiers, generals, they are warriors... all deads from the ancient war...")
          call TriggerSleepAction(11)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    I remember the stories of my grandpa, He talked about that war where two gods became evil")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Sun and Satan made a deal, nodoby knows why, but they wanted to reign over the entire world")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    they rejected human life and decree its extermination")
          call TriggerSleepAction(11)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    The humankind fought for his existence, aided by the other gods")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Great heroes rise from each country to fight together, kingdoms's heirs, princes, lords")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    their spirits were reinforced with their faith. and finally they forced the fusión of these two gods in one")
          call TriggerSleepAction(11)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    This one is known as Iveor... ")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    He was defeated using some legendaries weapons which were provided by the the high one.")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    |cffffcc00Kreator|r... father of all gods gave to the humankind defenders a powerfull weapon: Fievas")
          call TriggerSleepAction(11)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    The hero chosen was Calemor, son of Ekrom, gem of Enthashara... ")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    But the final blow was dealed by Ethernal, son of Serantas, the place where the final battle ends")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    All gods were condemned by Kreator to retire their investment and become humans")
          call TriggerSleepAction(11)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    And some of those heroes who fought against Iveor except Calemor were chosen to be the gods for a new era... ")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Peace and armony returned to these lands and Calemor ordered to build a huge graveyard for all the fallen")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    But the evil essense never was destroyed, and today those fallen are risen to march one more time")
          call TriggerSleepAction(11)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00The aged man says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Unfortunately this time, they march against us.... ")
          call TriggerSleepAction(11)
call EnableTrigger(gg_trg_agedman)
endfunction

