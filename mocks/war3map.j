//     endif
//   local texttag t=CreateTextTagUnitBJ("MASSIVE KILL +5kp", k, 0, 14.00, 100.00, 0.00, 0.00, 100.00 )
//  if GetLocalPlayer() == GetOwningPlayer(au) then
//===========================================================================


function DMGHWBA takes nothing returns nothing

local integer playerId= GetPlayerId(GetOwningPlayer(GetEventDamageSource()))
set udg_HawkDmg[playerId]=GetEventDamage()
    
 
endfunction

