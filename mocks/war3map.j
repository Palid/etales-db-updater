        call QuestSetDiscovered(udg_pt, true)
        call QuestSetCompleted(udg_pt, false)
        set udg_ptR=CreateQuestItemBJ(udg_pt, "|cffffcc00Enables all Oracle Portals|r")
       
        set undeadq=CreateQuest()
        call QuestSetTitle(undeadq, "Undeads Siege")
        call QuestSetDescription(undeadq, "The land route to |cffffcc00Colddream|r is blocked by an army of highly ranked undeads. There are two allied squadrons waiting to fall over them. The obstacle is a watchtower located at the center of the undead encampment that warns for enemy movements. That tower's fall will the sign to enter into the battle|r.")
        call QuestSetIconPath(undeadq, "ReplaceableTextures\\CommandButtons\\BTNGhoul.blp")
        call QuestSetRequired(undeadq, true)
        call QuestSetDiscovered(undeadq, true)
        call QuestSetCompleted(undeadq, false)
        set undeadqia=CreateQuestItemBJ(undeadq, "Destroy the enemy watchtower into the undead encampment")
        set undeadqib=CreateQuestItemBJ(undeadq, "Clean the land route to Colddream.")

        set cellarq=CreateQuest()
        call QuestSetTitle(cellarq, "You Dirty Rat!")
        call QuestSetDescription(cellarq, "|cffffcc00Recently a rat plague has been spreaded into Velhilmen. they are hidden into cellar's rooms. You must clean all those dirty rats. you can take all items found into the cellar.|r")
        call QuestSetIconPath(cellarq, "ReplaceableTextures\\CommandButtons\\BTNYouDirtyRat!.blp")
        call QuestSetRequired(cellarq, true)
        call QuestSetDiscovered(cellarq, false)
        call QuestSetCompleted(cellarq, false)
        set cellarqi=CreateQuestItemBJ(cellarq, "Find all the keys to open inner rooms.")
        set cellarqb=CreateQuestItemBJ(cellarq, "Clean all the rats from the cellar, number is increased per each low level player.")
        
         set banditsq=CreateQuest()
        call QuestSetTitle(banditsq, "Bandits Syndicate")
        call QuestSetDescription(banditsq, "When the undeads started to walk freely on the fields, Enthashara's forces were ordered|nto stop the invasion from its source. Main forces left the cities to march against the undeads|nto the southern lands. These conditions allowed to rise a new proscrit force named|n<<Bandits Syndicate>> leaded by Lady Katherinne. Bandits Syndicate's power grew|nto the point that they requested to keep all ways into the country building gates to check|nall passengers. but the truth is that they only want to collect gold from the infortunated travelers.|nTo defeat all keepers you will require help of low level player to provoke them due that they are|na bunch of cowards who will not attack you if your level is higher than them")
        call QuestSetIconPath(banditsq, "ReplaceableTextures\\CommandButtons\\BTNBandit.blp")
        call QuestSetRequired(banditsq, true)
        call QuestSetDiscovered(banditsq, false)
        call QuestSetCompleted(banditsq, false)
        set banditsia=CreateQuestItemBJ(banditsq, "Destroy all bandits control points 1/6")
        call QuestItemSetCompleted(banditsia, false)
        
