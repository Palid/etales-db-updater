    set gg_trg_masterdruidstart=CreateTrigger()
     call TriggerRegisterAnyUnitEventBJ(gg_trg_masterdruidstart, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_masterdruidstart, Condition(function mdruidc))
     call TriggerAddAction(gg_trg_masterdruidstart, function mdruida)
endfunction


//===========================================================================
// Trigger: masterdruidhello
//
// gg_unit_e00P_0247 //masterdruid
// druidseek[i]
// gemdready[i]
// druidcolg[i]
//===========================================================================
function masterdruidc takes nothing returns boolean
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and s__druidseek[id] == true
endfunction

function masterdruida takes nothing returns nothing
     local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
     local integer i= 1
     local unit u= GetTriggerUnit()
     local integer exp= GetHeroXP(u)
     local location p
     local integer questid
     set s__druidseek[id]= false
     call TriggerSleepAction(1)
      
    
     
    //   set InvampTest[id] = false
    //   call GroupRemoveUnit( udg_inTest, u)
       
       
        call MakeFaceToUnit(mdruid , udg_PHero[id])
        call UnitChat("I sense there is a search in your spirit..." , mdruid)
        call TriggerSleepAction(2.3)
        call UnitChat("You have come to embrace the ancient world." , mdruid)
        call TriggerSleepAction(2.3)
        call UnitChat("What is thy gift?." , mdruid)
        call TriggerSleepAction(2.3)

         call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "|cffffcc00MAIN QUEST UPDATE|r")
         call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Give |cffffcc005 gems|r to Master Druid, |cffffcc00Once|r per of each type...")
         //   call StartSound(bj_questCompletedSound)  
         set s__druidcolg[id]= true
            loop
              exitwhen s__gemdready[id] == true
              call TriggerSleepAction(0.5)
              endloop
         set s__druidcolg[id]= false
         set s__gemdready[id]= false
         
           set p=GetUnitLoc(u)
           
           
         call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "|cffffcc00MAIN QUEST COMPLETED|r")
         call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "You now have entered into the Druid order...")
         call StartSound(bj_questCompletedSound)
         
         set questid=LoadInteger(udg_cache, GetHandleId(mdruid), GetHandleId(udg_PHero[id]))
         call UpdatePersQuest(QPid[questid] , questid , Qdata[questid] , "You now have entered into the Druid order [" , "5" , "5")
         call RemoveQuestFromPlayer(questid , QPid[questid])
      
           set udg_PHero[id]=CreateUnitAtLoc(GetOwningPlayer(u), 'E00O', p, 270)
           call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Resurrect\\ResurrectCaster.mdl", udg_PHero[id], "origin"))
           
           call AddProfaner(id) //Trigger registrado
       
           
            call SetHeroAgi(udg_PHero[id], GetHeroAgi(u, false) + 24, true)
            call SetHeroStr(udg_PHero[id], GetHeroStr(u, false) + 24, true)
            call SetHeroInt(udg_PHero[id], GetHeroInt(u, false) + 24, true)
            
            call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
            call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
            call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
           loop
               exitwhen i > 6
               call UnitRemoveItemFromSlot(u, i)
               set i=i + 1
               endloop
           
            
            
            call RemoveUnit(u)
            
            call SetHeroXP(udg_PHero[id], exp, false)
            call AdjustPlayerStateBJ(7, GetOwningPlayer(u), PLAYER_STATE_RESOURCE_LUMBER)
            set udg_Hnext[id]=4
            call RemoveLocation(p)
            set p=null
            set u=null

endfunction

//===========================================================================
function InitTrig_masterdruidhello takes nothing returns nothing
    set gg_trg_masterdruidhello=CreateTrigger()
    //Evento asignado en trigger de inicio 
    call TriggerAddCondition(gg_trg_masterdruidhello, Condition(function masterdruidc))
    call TriggerAddAction(gg_trg_masterdruidhello, function masterdruida)
endfunction


