        //call StartSound(bj_pingMinimapSound)
   endif
  call TriggerSleepAction(3)
  call UnitChat("I will wait for you on the next altar, please take the spire from the Arcane Hydra" , dadvar)
  call TriggerSleepAction(1)
  set caltarx=- 4430
