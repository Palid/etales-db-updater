//===========================================================================
// Trigger: resurrect
//===========================================================================
function Trig_resurrect_Conditions takes nothing returns boolean
    return ( ( GetSpellAbilityId() == 'A0EO' or GetSpellAbilityId() == 'A0I3' ) and GetUnitTypeId(GetSpellTargetUnit()) == 'n04W' )
endfunction

function Trig_resurrect_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetSpellTargetUnit()))

if GetUnitState(udg_PHero[id], UNIT_STATE_LIFE) < 1 then
 set resurrected[id]=true
 call ReviveHero(udg_PHero[id], GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id]), true)
 call ShowUnit(hsoul[id], false)
 call SetUnitPosition(hsoul[id], hsoulx[id], hsouly[id])

endif


endfunction

//===========================================================================
function InitTrig_resurrect takes nothing returns nothing

 local integer index
 set gg_trg_resurrect=CreateTrigger()
    set index=0
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_resurrect, Player(index), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function istrue))
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
    
    call TriggerAddCondition(gg_trg_resurrect, Condition(function Trig_resurrect_Conditions))
    call TriggerAddAction(gg_trg_resurrect, function Trig_resurrect_Actions)
endfunction


