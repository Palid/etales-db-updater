//===========================================================================
// Trigger: drunkencycle
//
// drunkquote
//===========================================================================
function Dizzynes takes nothing returns nothing
local timer t= GetExpiredTimer()
local real xx= LoadReal(hts, GetHandleId(t), 1)
local real yy= LoadReal(hts, GetHandleId(t), 2)
local real angle_x= LoadReal(hts, GetHandleId(t), 3)
local real maxh= LoadReal(hts, GetHandleId(t), 4)
local real angle_t= LoadReal(hts, GetHandleId(t), 5)
local real inc= LoadReal(hts, GetHandleId(t), 6)
local unit a= LoadUnitHandle(hts, GetHandleId(t), 7)
local real xini= LoadReal(hts, GetHandleId(t), 8) + inc
local real tdist= LoadReal(hts, GetHandleId(t), 9)
local real h= GetParabolaZ(xini , tdist , maxh)
local integer id

 set angle_x=angle_x + GetRandomReal(1, 3)

 set angle_t=angle_t + angle_x * Sin(angle_x * bj_DEGTORAD)

 set inc=inc + inc * ( 0.05 * Sin(angle_t + 45 * bj_DEGTORAD) )
 if inc < 3.14 then
 set inc=3.14
 endif
 // set inc = inc + 6.28*Sin(angle_t+90* bj_DEGTORAD)  
 set xx=xx + inc * Cos(angle_t * bj_DEGTORAD)
 set yy=yy + inc * Sin(angle_t * bj_DEGTORAD)

 if IsTerrainWalkable(xx , yy) then
  call SetUnitX(a, xx)
  call SetUnitY(a, yy)
  //  call SetUnitPosition(a,xx,yy)
    
endif
    
    call QueueUnitAnimation(a, "walk")
 

 
 if h < 1 then
 // call PauseUnit(a,false)
  set id=GetPlayerId(GetOwningPlayer(a))
  call SetUnitPathing(a, true)
  call UnitRemoveAbility(a, 'A0HQ')

  // call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl",GetUnitX(a),GetUnitY(a) ))   
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  
 
 
  
  if ( 110 - ( s__dstate[id] * 20 ) < GetRandomInt(1, 100 + ( ( s__Constitution[id] + s__Mstrength[id] ) / 5 )) ) then
    call SetUnitAnimation(a, "death")
    call UnitChat(s__drunkquote[GetRandomInt(0, 20)] , a)
  else
    call SetUnitAnimation(a, "stand")
  endif
  

  
else
  call SaveReal(hts, GetHandleId(t), 1, xx)
  call SaveReal(hts, GetHandleId(t), 2, yy)
  call SaveReal(hts, GetHandleId(t), 3, angle_x)
  call SaveReal(hts, GetHandleId(t), 6, inc)
  //call SaveReal(hts,GetHandleId(t),5,angle_t)  
      call SaveReal(hts, GetHandleId(t), 8, xini)
 endif
set a=null
set t=null


endfunction


function Startdyzzy takes integer id returns nothing
local unit a= udg_PHero[id]

local real xx= GetUnitX(a)
local real yy= GetUnitY(a)
local real x= GetRandomReal(xx - 200, xx + 200)
local real y= GetRandomReal(yy - 200, yy + 200)


 local real dx= xx - x
 local real dy= yy - y
 local real dist_a= SquareRoot(dx * dx + dy * dy)
 local real angle_x= bj_RADTODEG * Atan2(dy, dx)
 
 local real xy= GetRandomReal(x - 200, x + 200)
 local real yx= GetRandomReal(y - 200, y + 200)
 local real ex= x - xy
 local real ey= y - yx
 local real dist_b= SquareRoot(ex * ex + ey * ey)
 local real angle_y= bj_RADTODEG * Atan2(ey, ex)
 local real angle_t= GetRandomReal(- 90, 270)
 local real maxh= GetRandomReal(180, 360) + 50
 local real tdist= dist_a + dist_b / 2
 local real inc= 3.14
 local real xini= 1
 local timer t= (NewTimerEx(0)) // INLINED!!
 
  call SaveReal(hts, GetHandleId(t), 1, xx)
  call SaveReal(hts, GetHandleId(t), 2, yy)
  call SaveReal(hts, GetHandleId(t), 3, angle_x)
  call SaveReal(hts, GetHandleId(t), 4, maxh)
  call SaveReal(hts, GetHandleId(t), 5, angle_t)
  call SaveReal(hts, GetHandleId(t), 6, inc)
  call SaveUnitHandle(hts, GetHandleId(t), 7, a)
    call SaveReal(hts, GetHandleId(t), 8, xini)
    call SaveReal(hts, GetHandleId(t), 9, tdist)

 // call PauseUnit(a,true)
 call IssuePointOrder(a, "move", xy, yx)
 // call SetUnitAnimationWithRarity( a, "walk", RARITY_FREQUENT )
  call UnitAddAbility(a, 'A0HQ') //evasion 
  call SetUnitPathing(a, false)
  call TimerStart(t, 0.02, true, function Dizzynes)
 // call SetUnitAnimation(a,"walk")

  set t=null
  set a=null

endfunction


function Trig_drunkencycle_Actions takes nothing returns nothing
local integer id= 0
local integer i= 0
local real resist= 0
local real range= 0

loop
exitwhen id > 9
     if s__dstate[id] > 0 then //the hero is drunken
         
             if s__dstate[id] > 2 then
                 set resist=( s__Mstrength[id] + s__Constitution[id] ) / 10
                 set range=( s__dstate[id] * 20 ) - resist
                 if ( 4 > GetRandomReal(1, range) ) then
                     call Startdyzzy(id)
                 endif
             endif
         
             if ( 10 > GetRandomReal(1, 250) ) then
                 
                call UnitChat(s__drunkquote[GetRandomInt(0, 20)] , udg_PHero[id])
            
             endif
         
         loop
         exitwhen i > 9
              if s__altstatedur[(id)*(10)+i] > 0 then
               set s__curstatedur[(id)*(10)+i]= s__curstatedur[(id)*(10)+i] + 1.00
               
                   if s__curstatedur[(id)*(10)+i] > s__altstatedur[(id)*(10)+i] then
                        call CleanState(id , i)
                   endif
               
               
              endif
         call TriggerSleepAction(0.01)
         set i=i + 1
         endloop
     endif
set id=id + 1
endloop



endfunction

