//===========================================================================
// Trigger: check
//===========================================================================
function Trig_checktower_Conditions takes nothing returns boolean
    return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_checktower_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local item it

   if ( wtowerdtryd[id] == true ) then
      call SetUnitFacingToFaceUnitTimed(valdkeeper, udg_PHero[id], 0)
     if ownertower[id] == false then
     call UnitChat("Good job man, the tower has fallen, although was another person who destroyed it" , valdkeeper)
     call AddHeroXP(udg_PHero[id], 3500, false)
     call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, " Got +|cffffcc003500|r Experience!")
     call TriggerSleepAction(2)
     
     else
     call UnitChat("Good job man, the tower has fallen" , valdkeeper)
     call AddHeroXP(udg_PHero[id], 7000, false)
     call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, " Got +|cffffcc007000|r Experience!")
     call TriggerSleepAction(2)
     endif
   
    set findwtower[id]=false
    set wtowerdtryd[id]=false
 elseif ogreready[id] == true then
    set ogreready[id]=false
     call SetUnitFacingToFaceUnitTimed(valdkeeper, udg_PHero[id], 0)
     call UnitChat("What?? ogres have increased his number?... Dammit! It isn't working" , valdkeeper)
     call TriggerSleepAction(4)
     call UnitChat("Anyway, take this reward for your efford" , valdkeeper)
     call AddHeroXP(udg_PHero[id], 8000, false)
     call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, " Got +|cffffcc008000|r Experience!")
     set killingogres[id]=false
     call TriggerSleepAction(2)
 elseif workersdied[id] == true then
     set workersdied[id]=false
     call SetUnitFacingToFaceUnitTimed(valdkeeper, udg_PHero[id], 0)
     call UnitChat("What?? Our workers are all dead" , valdkeeper)
     call TriggerSleepAction(3)
     call UnitChat("I shouldn't have trusted you" , valdkeeper)
     set Reputation[id]=Reputation[id] - 40
     call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, " You lose |cffff0000-40|r Reputation!")
     set workingonsuplies[id]=false
     call TriggerSleepAction(2)
 elseif suppliesready[id] == true then
     set suppliesready[id]=false
     call SetUnitFacingToFaceUnitTimed(valdkeeper, udg_PHero[id], 0)
     call UnitChat("For the God's Favor, you did it!!!" , valdkeeper)
     call TriggerSleepAction(3)
     call UnitChat("Our people now can survive a few days more. Thank you Hero!!!" , valdkeeper)
     set Reputation[id]=Reputation[id] + 40
     call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, " You get |cffffcc00+40|r Reputation!")
     call AddHeroXP(udg_PHero[id], 12000, false)
     call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, " You get |cffffcc00+12000|r Experience!")
     set workingonsuplies[id]=false
     call TriggerSleepAction(2)

 elseif minidemonk[id] == true then
    set minidemonk[id]=false
    set it=LoadItemHandle(questtm, GetHandleId(Player(id)), 28)
    
    if ( UnitHasItem(udg_PHero[id], it) == true ) then
      
        call UnitRemoveItem(udg_PHero[id], it)
        call RemoveItem(it)
        set it=null
        call UnitChat("Great!!, You did it!" , valdkeeper)
        set valdiviafinal[id]=true
    
    else
     call UnitChat("Where are the supplies???" , valdkeeper)
     call TriggerSleepAction(3)
     call UnitChat("I don't see you have loaded them. Go and find the reserves, bring them here please" , valdkeeper)
     call TriggerSleepAction(2)
     set minidemonk[id]=true
    endif
  
 endif
  
  
  
 set it=null
  
  
endfunction

