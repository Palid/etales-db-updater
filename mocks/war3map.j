    call TriggerRegisterAnyUnitEventBJ(gg_trg_deliverinfo, EVENT_PLAYER_UNIT_USE_ITEM)
    call TriggerAddCondition(gg_trg_deliverinfo, Condition(function Trig_deliverinfo_Conditions))
    call TriggerAddAction(gg_trg_deliverinfo, function Trig_deliverinfo_Actions)
endfunction


//===========================================================================
// Trigger: huntkill
//
//       call SaveInteger(questtm,GetHandleId(Hunt),1708,questid)//guardo id de quest en el viajero
//       call SaveInteger(questtm,GetHandleId(Hunt),1709,count)
//       call SaveInteger(questtm,GetHandleId(Hunt),1707,dispatched)
//       call SaveInteger(questtm,GetHandleId(Hunt),1706,killed)
//===========================================================================
function huntkc takes nothing returns boolean
    return GetUnitUserData(GetDyingUnit()) == 3711
endfunction

function huntka takes nothing returns nothing
 local unit u= GetDyingUnit()
 local unit a= GetKillingUnit()
 local integer oid= GetPlayerId(GetOwningPlayer(a))
 local integer id
 
 local group g= LoadGroupHandle(questtm, GetHandleId(u), 10)
 local integer questid
 local integer count= LoadInteger(questtm, GetHandleId(g), 1709)
 local integer killed= LoadInteger(questtm, GetHandleId(g), 1706)
 local integer dispatched= LoadInteger(questtm, GetHandleId(g), 1707)
    
   if g != null then
   
      if ( GetLocalPlayer() == Player(oid) ) then
          call ClearTextMessages()
      endif
   
    call DisplayTimedTextToPlayer(Player(oid), 0, 0, 6, "|cff7777dd+322 XP|r")
    call AddHeroXP(udg_PHero[oid], 322, false)
    
    set id=LoadInteger(questtm, GetHandleId(u), 11) - 10
   
    
      if oid == id then
        set killed=killed + 1
        set dispatched=dispatched + GetUnitLevel(u)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Targets Eliminated: |cff7777dd" + I2S(killed) + "/" + I2S(count))
         
         set questid=LoadInteger(questtm, GetHandleId(g), 1708)
         call UpdatePersQuestND(id , questid , killed , "-" , I2S(killed) , "-")
         
       call SaveInteger(questtm, GetHandleId(g), 1706, killed)
       call SaveInteger(questtm, GetHandleId(g), 1707, dispatched)
      endif
    call GroupRemoveUnit(g, u)
   
   endif
 set u=null
 set a=null
 set g=null


endfunction

//===========================================================================
function InitTrig_huntkill takes nothing returns nothing
    set gg_trg_huntkill=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_huntkill, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_huntkill, Condition(function huntkc))
    call TriggerAddAction(gg_trg_huntkill, function huntka)
endfunction


//===========================================================================
// Trigger: valanmeet
//===========================================================================
function Trig_valanmeet_Conditions takes nothing returns boolean
    return Valanmeets == true and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_valanmeet_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
call DisableTrigger(gg_trg_valanmeet)

call SetupTextForce()
set Valanmeets=false
    call MakeFaceToUnit(gg_unit_h03L_0388 , u) //wolfang
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00General Valan faces you...|r")
    call DisplayTimedTextToForce(textforce, 16, "      Sir. I have orders to give you some advices about this passage and the lands next to its exit")
    call DisplayTimedTextToForce(textforce, 16, "      First of all this passage were opened from the other side. We found some clues that say ")
    call DisplayTimedTextToForce(textforce, 16, "      there were a silent invasion from those lands. We reached here too late.  ")
    call DisplayTimedTextToForce(textforce, 16, "      Our scouts have detected many movements into Serantas fields. (type |cffffcc00-skip|r to skip dialogs)")
    call TriggerSleepAction(17)
    call MakeFaceToUnit(gg_unit_h03L_0388 , u) //wolfang
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00General Valan says...|r")
    call DisplayTimedTextToForce(textforce, 16, "      Unfortunately our knowledge about the source of these movements is limited.")
    call DisplayTimedTextToForce(textforce, 16, "      We sent some experienced scouts to check the main target. but we cannot track them")
    call DisplayTimedTextToForce(textforce, 16, "      all tracks are lost when they reach a graveyard located to the north.  ")
    call DisplayTimedTextToForce(textforce, 16, "      There's a small village across the forest named |cffffcc00Taneryn|r. at this point the way isn't hard")
    call TriggerSleepAction(17)
    call MakeFaceToUnit(gg_unit_h03L_0388 , u) //wolfang
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00General Valan faces down...|r")
    call DisplayTimedTextToForce(textforce, 16, "      But we got news that Taneryn has been infested and fall down by the advance of undead forces")
    call DisplayTimedTextToForce(textforce, 16, "      We have learn some tips about this force. They are commanded by powerfull warriors")
    call DisplayTimedTextToForce(textforce, 16, "      those declare themself as followers of |cffffcc00Irntu Hel's Cult|r, an unknown order")
    call DisplayTimedTextToForce(textforce, 16, "      who operates in the shadows of those graveyard")
    call TriggerSleepAction(17)
     call MakeFaceToUnit(gg_unit_h03L_0388 , u) //wolfang
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00General Valan looks you:|r")
    call DisplayTimedTextToForce(textforce, 16, "      Our main info related to this order's leadership")
    call DisplayTimedTextToForce(textforce, 16, "      is that they are subordinated to two women. they are very powerfull")
    call DisplayTimedTextToForce(textforce, 16, "      A priestess named Cristinne and a dark ranger named Andaira.")
    call DisplayTimedTextToForce(textforce, 16, "      We suspect that they are personal guards of order's maximun leader.")
    call TriggerSleepAction(17)
     call MakeFaceToUnit(gg_unit_h03L_0388 , u) //wolfang
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00General Valan looks you:|r")
    call DisplayTimedTextToForce(textforce, 16, "      Hero, my orders say that you all are sent by Enthashara's high command")
    call DisplayTimedTextToForce(textforce, 16, "      If they believe in you, I believe on you.")
    call DisplayTimedTextToForce(textforce, 16, "      Please explore these lands and find a way to defeat this horrible force")
    call DisplayTimedTextToForce(textforce, 16, "      before they launch a massive attack against us...")
    call TriggerSleepAction(17)
    
       call StartSound(bj_questUpdatedSound)
   
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffcccc00WORLD QUEST UPDATE|r: Iveor's Destiny")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00Movements on Serantas. ")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "          |cffffffff- Travel to Varanger and meets General Valan (completed)|r ")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "          |cff888888- Talk with Oracle about Ejio Versal requirements. ")
    call FlashQuestDialogButton()
   
     call QuestItemSetCompleted(iveordia, true)
        call TriggerSleepAction(7)
    
     call StartSound(bj_questUpdatedSound)
     if ( IsPlayerInForce(GetLocalPlayer(), textforce) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 16, "|cffffcc00WORLD QUEST UPDATE|r: The cult of Irntu Hel")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 16, "The events on Valdivia has given some clues about a new enemy that is working under the shadows")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 16, "Main information says that their leader is named |cffffcc00Rodavlas Nauj|r and they want to take ")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 16, "the control of all country powers. Reached this point you know that the Cult of Irntu Hel is operating ")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 16, "into the gardens of death. As Valan says you must explore and find those maidens described on his report.")
               
      endif
   call QuestSetDiscovered(irntuq, true)
   call QuestItemSetCompleted(irntuia, true)
   set irntuib=CreateQuestItemBJ(irntuq, "Explore gardens of death and defeat maiden guards")
    
    
    
    set u=null
    
endfunction

