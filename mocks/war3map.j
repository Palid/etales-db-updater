//===========================================================================
// Trigger: ekromfinal
//===========================================================================
//TESH.scrollpos=9
//TESH.alwaysfold=0
function EFNC takes nothing returns boolean
    return ( GetTriggerUnit() == ekromtauren )
endfunction

function FinishedEkrom takes integer id returns nothing
local location p= GetRectCenter(gg_rct_factionfinal1)
local unit u= udg_PHero[id]
           set udg_ekrom_ocu=false
           set udg_unit_ekrom=null
           call SetUnitPositionLoc(u, p)
           call SetUnitPositionLoc(udg_Slave[id], p)
           call SetUnitPositionLoc(udg_Familiar[id], p)
           
           if PlayerInTest[id] == true then
           call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
           call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "QUEST DONE")
           call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Ekrom Army Examen")
           call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Ekrom receives you, you receives Ekrom")
           call StartSound(bj_questCompletedSound)
            

            call TriggerSleepAction(2)
            call RemoveAllQuestFromPlayer(id)
            call UnitAddAbility(NextClass(id , u), 'A054')
            call UnitMakeAbilityPermanent(udg_PHero[id], true, 'A054')
            set udg_Faction[id]=3
            set PlayerInTest[id]=false
         //   call TriggerExecute( gg_trg_ALLY )
            endif
            call RemoveLocation(p)
            set p=null

            
endfunction


function EFNA takes nothing returns nothing
 local unit tauren= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
 local real x= 14868
 local real y= 9269
// local integer i = 0

 call FinishedEkrom(id)
 call TriggerSleepAction(2)
 
  set ekromtauren=CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), GetUnitTypeId(tauren), x, y, 270)
  set tauren=null
 
endfunction

