    set gg_trg_Huracan=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Huracan, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Huracan, Condition(function Huracan_Conditions))
    call TriggerAddAction(gg_trg_Huracan, function Huracan_Actions)
