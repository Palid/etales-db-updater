//===========================================================================

//===========================================================================
// Trigger: raystorm
//
// integer array casttype[16]
// castamount[id]
// string array castname[casttype[id]]
// string array castfx[10]
//===========================================================================
function Trig_raystorm_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == Raystorm
endfunction

function raystormcycle takes nothing returns nothing
local timer t= GetExpiredTimer()

local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local integer id= LoadInteger(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real x1= GetRandomReal(x - 150, x + 150)
local real y1= GetRandomReal(y - 150, y + 150)
local real dmg= I2R(GetHeroInt(u, true)) * 2
local unit r1= CreateUnit(Player(id), ldummyD, x1, y1, GetRandomReal(0, 359))
//local unit r2 = CreateUnit(Player(id),ldummyD,x1-150,y1+150,GetRandomReal(0,359))
//local unit r3 = CreateUnit(Player(id),ldummyD,x1+150,y1-150,GetRandomReal(0,359))
//local unit r4 = CreateUnit(Player(id),ldummyD,x1+150,y1+150,GetRandomReal(0,359))

  call UnitApplyTimedLife(r1, 'BTLF', 0.5)
  //call UnitApplyTimedLife(r2, 'BTLF', 0.5) 
  //call UnitApplyTimedLife(r3, 'BTLF', 0.5) 
  //call UnitApplyTimedLife(r4, 'BTLF', 0.5) 

  set u=null
  set t=null
  set r1=null
 // set r2=null
 // set r3=null
 // set r4=null
  
  set id=0
  set x=0
  set y=0
  set x1=0
  set y1=0
        
endfunction

function Trig_raystorm_Actions takes nothing returns nothing
local unit u= GetSpellAbilityUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local real x= GetSpellTargetX()
local real y= GetSpellTargetY()
local timer t= (NewTimerEx(0)) // INLINED!!
local unit c= CreateUnit(Player(id), ldummyF, x, y, 0)
local real dur= 0

if ActSpecast(id , GetSpellAbilityId()) == true then
 set dur=( s__casttype[id] * 2 )
endif
call SetUnitVertexColor(c, 67, 67, 67, 10)
call UnitApplyTimedLife(c, 'BTLF', 5)
call SaveUnitHandle(hts, GetHandleId(t), 0, u)
call SaveInteger(hts, GetHandleId(t), 1, id)
call SaveReal(hts, GetHandleId(t), 2, x)
call SaveReal(hts, GetHandleId(t), 3, y)
call TimerStart(t, 0.2, true, function raystormcycle)
call TriggerSleepAction(5 + dur)
call PauseTimer(t)
call FlushChildHashtable(hts, GetHandleId(t))
call ReleaseTimer(t)

set t=null
set u=null
set c=null
endfunction

//===========================================================================
function InitTrig_raystorm takes nothing returns nothing
    set gg_trg_raystorm=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_raystorm, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_raystorm, Condition(function Trig_raystorm_Conditions))
    call TriggerAddAction(gg_trg_raystorm, function Trig_raystorm_Actions)
endfunction


//===========================================================================
// Trigger: electrocute
//
// integer array casttype[16]
// castamount[id]
// string array castname[casttype[id]]
// string array castfx[10]
//===========================================================================
//TESH.scrollpos=120
//TESH.alwaysfold=0
function Trig_electrocute_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == Electrocute )
endfunction

function electrocuting takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 0)
local unit u= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer vertex= LoadInteger(hts, GetHandleId(t), 2)
local integer attch= LoadInteger(hts, GetHandleId(t), 3)
local integer res= LoadInteger(hts, GetHandleId(t), 4)
local location p= GetUnitLoc(a)
local location q= LoadLocationHandle(hts, GetHandleId(t), 5)
local lightning light= LoadLightningHandle(hts, GetHandleId(t), 6)
local boolean spcast= LoadBoolean(hts, GetHandleId(t), 7)
local integer id= GetPlayerId(GetOwningPlayer(u))
local real xdmg= I2R(GetHeroInt(u, true))
local real dmg= xdmg + ( xdmg * udg_magicBonus[id] )
local integer idmg= 0
//calculate damage


   
   
      call DisableTrigger(gg_trg_DMG)
      set dmg=dmg * 0.61
      
          if spcast == true then
            set dmg=dmg * s__castamount[id]
          endif
    
      set dmg=dmg + dmg * AddRacialBonus(a , id)
    
      set idmg=R2I(dmg)
     
      call EnableTrigger(gg_trg_SPDMG)
      call UnitDamageTarget(u, a, dmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
      call DisableTrigger(gg_trg_SPDMG)
     
      set res=res + R2I(spelldmg[id])
      call SaveInteger(hts, GetHandleId(t), 4, res)
      set spelldmg[id]=0
      call EnableTrigger(gg_trg_DMG)







//visual effect
set vertex=vertex * - 1

call SaveInteger(hts, GetHandleId(t), 2, vertex)
set vertex=vertex * 255
set attch=attch + 1
if attch > 5 then
set attch=0
endif
   call SaveInteger(hts, GetHandleId(t), 3, attch)
   call SetUnitAnimationByIndex(a, GetRandomInt(0, 9))
  // call SetUnitVertexColor(a, vertex, vertex, vertex, 230 )
   call MoveLightningEx(light, true, GetLocationX(q), GetLocationY(q), GetLocationZ(q) + 135, GetLocationX(p), GetLocationY(p), GetLocationZ(p) + 50)
   call DestroyEffect(AddSpecialEffectTarget(STATIC, a, electrocuteattch[attch]))
   
   if ( GetUnitState(a, UNIT_STATE_LIFE) < 0.404 ) then
    call PauseTimer(t)
   endif
   
set light=null
call RemoveLocation(p)
set p=null
set a=null
set u=null
set t=null
endfunction

function Trig_electrocute_Actions takes nothing returns nothing
local unit a= GetSpellTargetUnit()
local location p= GetUnitLoc(a)
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local location q= GetUnitLoc(u)
local real x1= GetLocationX(q)
local real y1= GetLocationY(q)
local real x2= GetLocationX(p)
local real y2= GetLocationY(p)
local real face= GetUnitFacing(a)
local integer vertex= 1
local integer attch= 0
local effect sfx= AddSpecialEffectTarget(BURNER, a, "overhead")
local effect sfx2= AddSpecialEffectTarget(LIGHTBALL, u, "weapon")
local timer t= (NewTimerEx(0)) // INLINED!!
local lightning light= AddLightningEx(CHIMA, true, x1, y1, GetLocationZ(q) + 135, x2, y2, GetLocationZ(p) + 50)
local integer res= 0
local boolean spcast= ActSpecast(id , GetSpellAbilityId())

 call PauseUnit(a, true)

 call SetUnitTimeScale(a, 1.5)
 // call UnitAddAbilityBJ( 'Amrf', a )
//  call UnitRemoveAbilityBJ( 'Amrf', a )
//  call SetUnitFlyHeight( a, 350, 350) 
  call SaveUnitHandle(hts, GetHandleId(t), 0, a)
  call SaveUnitHandle(hts, GetHandleId(t), 1, u)
  call SaveInteger(hts, GetHandleId(t), 2, vertex)
  call SaveInteger(hts, GetHandleId(t), 3, attch)
  call SaveInteger(hts, GetHandleId(t), 4, res)
  call SaveLocationHandle(hts, GetHandleId(t), 5, q)
 //call SetUnitFlyHeight( a, 350, 350) 
// call TriggerSleepAction(1)
 //  set electro = AddLightningEx(CHAIN, true, x1, y1, 135, x2, y2,100)
  call SaveLightningHandle(hts, GetHandleId(t), 6, light)
  call SaveBoolean(hts, GetHandleId(t), 7, spcast)
  call TimerStart(t, 0.2, true, function electrocuting)

 call TriggerSleepAction(3)
 
 call PauseTimer(t)
 set res=LoadInteger(hts, GetHandleId(t), 4)
 call SpellDmgText(res , a)
 call FlushChildHashtable(hts, GetHandleId(t))
 call ReleaseTimer(t)
 call DestroyLightning(light)
 //call SetUnitFlyHeight( a,0, 750)  
 call RemoveLocation(p)
 call RemoveLocation(q)
 
 set p=null
 set q=null
 

  
 call TriggerSleepAction(1)
 call PauseUnit(a, false)
 call SetUnitTimeScale(a, 1)
 call SetUnitVertexColor(a, 255, 255, 255, 255)
 call DestroyEffect(sfx)
  call DestroyEffect(sfx2)
  
   call IssueTargetOrder(a, "attack", u)
   
 set u=null
 set t=null
 set a=null
 set sfx=null
 set sfx2=null
 set light=null
endfunction

//===========================================================================
function InitTrig_electrocute takes nothing returns nothing
    set gg_trg_electrocute=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_electrocute, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_electrocute, Condition(function Trig_electrocute_Conditions))
    call TriggerAddAction(gg_trg_electrocute, function Trig_electrocute_Actions)
endfunction


//===========================================================================
// Trigger: wideboltcast
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_wideboltcast_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == Awidebolts and GetUnitAbilityLevel(GetSpellTargetUnit(), widebolts) == 0 )
endfunction

function overloaded takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer attp= LoadInteger(hts, GetHandleId(t), 0)
set attp=attp + 1
if attp > 5 then
set attp=0
endif
call SaveInteger(hts, GetHandleId(t), 0, attp)

   call DestroyEffect(AddSpecialEffectTarget(STATIC, u, electrocuteattch[attp]))


   
   set t=null
   set u=null

endfunction

function Trig_wideboltcast_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetSpellAbilityUnit()))
local unit u= GetSpellTargetUnit()
local timer t= null
local integer attp= 0
local real dur= 0

if not ( GetUnitAbilityLevel(u, widebolts) > 0 or GetUnitAbilityLevel(u, hasbolts) > 0 ) then



 if ActSpecast(id , GetSpellAbilityId()) == true then
    set dur=( 5 * s__casttype[id] )
 endif


set t=(NewTimerEx(0)) // INLINED!!
call SaveUnitHandle(hts, GetHandleId(t), 1, u)
call SaveInteger(hts, GetHandleId(t), 0, attp)
call TimerStart(t, 0.1, true, function overloaded)
call UnitAddAbility(u, widebolts)
call TriggerSleepAction(30 + dur)
call UnitRemoveAbility(u, widebolts)
call PauseTimer(t)
call FlushChildHashtable(hts, GetHandleId(t))
call ReleaseTimer(t)
set t=null
else

 call CS_Error(Player(id) , "This unit has already been overloaded with bolts.")
endif
set u=null


endfunction

//===========================================================================
function InitTrig_wideboltcast takes nothing returns nothing
    set gg_trg_wideboltcast=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_wideboltcast, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_wideboltcast, Condition(function Trig_wideboltcast_Conditions))
    call TriggerAddAction(gg_trg_wideboltcast, function Trig_wideboltcast_Actions)
endfunction


//===========================================================================
// Trigger: castbolts
//===========================================================================
//TESH.scrollpos=12
//TESH.alwaysfold=0
function Trig_castbolts_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == chargew
endfunction

function Trig_castbolts_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetSpellAbilityUnit()))
local unit u= GetSpellTargetUnit()
local real dur= 0

if not ( GetUnitAbilityLevel(u, hasbolts) > 0 or GetUnitAbilityLevel(u, widebolts) > 0 ) then


 if ActSpecast(id , GetSpellAbilityId()) == true then
    set dur=( 5 * s__casttype[id] )
 endif

  call UnitAddAbility(u, hasbolts)
   call TriggerSleepAction(30 + dur)
  call UnitRemoveAbility(u, hasbolts)
else
 call CS_Error(Player(id) , "This unit has already been overloaded with bolts.")
endif

set u=null



endfunction

