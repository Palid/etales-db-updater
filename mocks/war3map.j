//===========================================================================
// Trigger: Maindrop
//===========================================================================
function IsNeutral takes nothing returns boolean
    return ( GetUnitUserData(GetTriggerUnit()) != 7 and GetPlayerId(GetOwningPlayer(GetTriggerUnit())) > 7 )
endfunction

function CreateFixed takes unit u,integer id returns nothing
local real x= GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120)
local real y= GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120)
local item it= null

set it=CreateItem(udg_itmpool[id], x, y)
call ItemName(GetItemName(it) , x , y)

set it=null
endfunction


function CreateDrop takes boolean rate,unit u,integer drop returns nothing
local real x= GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120)
local real y= GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120)
local integer id= 0

local item it= null
if ( rate == true ) then
set id=Getkey(LoadInteger(HTcreep, GetUnitTypeId(u), drop))
set it=CreateItem(udg_itmpool[id], x, y)
   if ( id == 88 ) then
      call SaveUnitHandle(questtm, GetHandleId(it), 3, u)
   endif
  // if (id<42 and id>36) then
   
  // endif
          if ( id == 88 ) then
         call ItemSoulName(GetUnitName(u) + "'s " + GetItemName(it) , x , y)
          else
          call ItemName(GetItemName(it) , x , y)
          endif

  
endif


set it=null
endfunction




function Drops takes nothing returns nothing
local unit u= GetTriggerUnit()
local real elite= GetUnitPointValue(u)

if ( elite == 300 ) then //boss
    call CreateDrop(true , u , MEDIO_DROP)
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) > 660) , u , TERCIO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) > 500) , u , CUARTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) > 500) , u , QUINTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 333) , u , DECIMO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 250) , u , CINCO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 100) , u , UNO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) == 1) , u , MINIMO_DROP) // INLINED!!

elseif ( elite == 244 ) then //black hand
     if IsUnitInGroup(u, sundeads) == true then
          
          set u=null
          return
     endif
    call CreateDrop(true , u , MEDIO_DROP)
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) > 660) , u , TERCIO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) > 500) , u , CUARTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 70) , u , QUINTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 70) , u , DECIMO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 30) , u , CINCO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 10) , u , UNO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) == 1) , u , MINIMO_DROP) // INLINED!!

elseif ( elite == 200 ) then
    
    if IsUnitInGroup(u, sundeads) == true then
          
          set u=null
          return
     endif
   
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) > 660) , u , MEDIO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) > 500) , u , TERCIO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 100) , u , CUARTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 70) , u , QUINTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 70) , u , DECIMO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 30) , u , CINCO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 10) , u , UNO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) == 1) , u , MINIMO_DROP) // INLINED!!

else

    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 200) , u , MEDIO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 150) , u , TERCIO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 100) , u , CUARTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 70) , u , QUINTO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 30) , u , DECIMO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 10) , u , CINCO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) < 5) , u , UNO_DROP) // INLINED!!
    call CreateDrop((GetRandomInt(0, creep__MAX_RATE) == 1) , u , MINIMO_DROP) // INLINED!!

endif



set u=null
endfunction

//===========================================================================
function InitTrig_Maindrop takes nothing returns nothing
   local integer index
   set gg_trg_Maindrop=CreateTrigger()
   
   // call TriggerRegisterAnyUnitEventBJ( gg_trg_Maindrop, EVENT_PLAYER_UNIT_DEATH )
   set index=0
   loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_Maindrop, Player(index), EVENT_PLAYER_UNIT_DEATH, null)

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
   endloop
    
    call TriggerAddCondition(gg_trg_Maindrop, Condition(function IsNeutral))
    call TriggerAddAction(gg_trg_Maindrop, function Drops)
    
    
endfunction


//===========================================================================
// Trigger: cleanothers
//===========================================================================
function noncleaned takes nothing returns boolean
    return ( GetPlayerId(GetOwningPlayer(GetTriggerUnit())) > 7 )
endfunction



function Cleanergroup takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer ids
local timer snt
local unit chk= null

//=====clean some groups

     if IsUnitInGroup(u, sneakers) == true then
      call GroupRemoveUnit(sneakers, u)
      set snt=LoadTimerHandle(AiHash, GetHandleId(u), GetHandleId(sneakers))
      set ids=LoadInteger(AiHash, GetHandleId(snt), 2)
      set sneakerscnt[ids]=sneakerscnt[ids] - 1
      call PauseTimer(snt)
      call ReleaseTimer(snt)
      set snt=null
     endif
 
      if IsUnitInGroup(u, aggresiveUnits) == true then
        call GroupRemoveUnit(aggresiveUnits, u)
      endif
   
     if IsUnitInGroup(u, crazybeast) == true then
       call GroupRemoveUnit(crazybeast, u)
     endif
     
     if IsUnitInGroup(u, sneakersfnd) == true then
        call GroupRemoveUnit(sneakersfnd, u)
     endif
     
    if IsUnitInGroup(u, giantbeast) == true then
       call GroupRemoveUnit(giantbeast, u)
    endif
     
    if IsUnitInGroup(u, Ambushgroup) == true then
       call GroupRemoveUnit(Ambushgroup, u)
    endif
   
    if IsUnitInGroup(u, stingers) == true then
      set snt=LoadTimerHandle(AiHash, GetHandleId(u), GetHandleId(stingers))
      call PauseTimer(snt)
      call ReleaseTimer(snt)
      set snt=null
      call GroupRemoveUnit(stingers, u)
    endif
	
	if IsUnitInGroup(u, bansheeminions) == true then
	  call GroupRemoveUnit(bansheeminions, u)
 	endif
     
    if IsUnitInGroup(u, hasprotector) == true then
      call GroupRemoveUnit(hasprotector, u)
    endif
   
    if IsUnitInGroup(u, cathedralunits) == true then
      call GroupRemoveUnit(cathedralunits, u)
    endif
   
    call FlushChildHashtable(AiHash, GetHandleId(u))

set u=null
endfunction

//===========================================================================
function InitTrig_cleanothers takes nothing returns nothing
   local integer index
   set gg_trg_cleanothers=CreateTrigger()
   
   // call TriggerRegisterAnyUnitEventBJ( gg_trg_cleanothers, EVENT_PLAYER_UNIT_DEATH )
   set index=0
   loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_cleanothers, Player(index), EVENT_PLAYER_UNIT_DEATH, null)

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
   endloop
    
    call TriggerAddCondition(gg_trg_cleanothers, Condition(function noncleaned))
    call TriggerAddAction(gg_trg_cleanothers, function Cleanergroup)
    
    
endfunction


//===========================================================================
// Trigger: AIglobals
//===========================================================================
//===========================================================================
// Trigger: lichkd
//===========================================================================
function Trig_lichkd_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == 'n00T' )
endfunction


function Trig_lichkd_Actions takes nothing returns nothing
local unit caster= GetTriggerUnit()
local unit target
 local boolean hastarget= false
 local boolexpr istru= Condition(function bool)
 
  call GroupEnumUnitsInRange(targetgroup, GetUnitX(caster), GetUnitY(caster), 1200, istru)
  call DestroyBoolExpr(istru)
  set istru=null
  loop
   exitwhen hastarget == true
    set target=FirstOfGroup(targetgroup)
    if ( IsUnitEnemy(target, GetOwningPlayer(caster)) == true ) then
       set hastarget=true
     else
       call GroupRemoveUnit(targetgroup, target)
     endif
  endloop
  call GroupClear(targetgroup)
  
  call TriggerSleepAction(1)
  call IssuePointOrder(caster, "carrionswarm", GetUnitX(target), GetUnitY(target))
  
  set caster=null
  set target=null
  

endfunction

//===========================================================================
function InitTrig_lichkd takes nothing returns nothing
local integer index= 9
    set gg_trg_lichkd=CreateTrigger()
      
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_lichkd, Player(index), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function bool))

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    call TriggerAddCondition(gg_trg_lichkd, Condition(function Trig_lichkd_Conditions))
    call TriggerAddAction(gg_trg_lichkd, function Trig_lichkd_Actions)
endfunction


//===========================================================================
// Trigger: Scape
//===========================================================================
function Trig_Scape_Conditions takes nothing returns boolean
    return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == false and IsUnitInGroup(GetTriggerUnit(), sneakers) == false and IsUnitInGroup(GetTriggerUnit(), udg_ScapeCreepG) == false and GetUnitLifePercent(GetTriggerUnit()) < 15.00 )
endfunction

function Trig_Scape_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(GetAttacker()))
 local real face= GetUnitFacing(GetAttacker())
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real x2= x + 650 * Cos(face * bj_DEGTORAD)
 local real y2= y + 650 * Sin(face * bj_DEGTORAD)
 local integer fear= 20 * LoadInteger(AiHash, GetHandleId(u), 2)

 call GroupAddUnit(udg_ScapeCreepG, u)
 if GetRandomInt(0, 99) < fear then
      if ( GetOwningPlayer(u) == Player(PLAYER_NEUTRAL_AGGRESSIVE) or GetOwningPlayer(u) == Player(PLAYER_BAND_SIND) ) then
        call IssuePointOrder(u, "move", x2, y2)
      
        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\TalkToMe\\TalkToMe.mdl", u, "chest"))
        
         if GetUnitPointValue(u) == 119 and Tryingsylvan[id] == true then
             call UnitChat(s__clanguaje[(s__SylvanLang[id])*(9)+GetRandomInt(1, 8)] , u)
         endif
      endif
  endif
    

    set u=null
endfunction

//===========================================================================
function InitTrig_Scape takes nothing returns nothing
     local integer index
    set gg_trg_Scape=CreateTrigger()
    set index=8
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_Scape, Player(index), EVENT_PLAYER_UNIT_ATTACKED, null)

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
   // call TriggerRegisterAnyUnitEventBJ( , EVENT_PLAYER_UNIT_ATTACKED )
    call TriggerAddCondition(gg_trg_Scape, Condition(function Trig_Scape_Conditions))
    call TriggerAddAction(gg_trg_Scape, function Trig_Scape_Actions)
endfunction


//===========================================================================
// Trigger: ClearScape
//===========================================================================
function Trig_ClearScape_Actions takes nothing returns nothing
    call GroupClear(udg_ScapeCreepG)
endfunction

//===========================================================================
function InitTrig_ClearScape takes nothing returns nothing
    set gg_trg_ClearScape=CreateTrigger()
    call TriggerRegisterTimerEvent(gg_trg_ClearScape, 20.00, true)
    call TriggerAddAction(gg_trg_ClearScape, function Trig_ClearScape_Actions)
endfunction


