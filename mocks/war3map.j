        set udg_pt=CreateQuest()
        call QuestSetTitle(udg_pt, "The way to the Oracle")
        call QuestSetDescription(udg_pt, "There are seven waygates around the map. Each portal has a Elite Creature as guard that you need to kill to activate the portal. Entering on it you can move around Enthashara's land faster. Finishing all teleporters, the waygate to the Oracle will be opened.|n|cffffcc00Required for Third tier tests.|r")
        call QuestSetIconPath(udg_pt, "ReplaceableTextures\\CommandButtons\\BTNWaygate.blp")
