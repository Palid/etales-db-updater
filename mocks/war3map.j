//===========================================================================
// Trigger: prosf
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_prosf_Conditions takes nothing returns boolean
    return ( UnitHasBuffBJ(GetTriggerUnit(), 'B01D') == true )
endfunction

function Trig_prosf_Actions takes nothing returns nothing
 local real dmg= GetEventDamage()
 local unit protector= LoadUnitHandle(udg_cache, GetHandleId(GetTriggerUnit()), 777)
 local real life= GetUnitState(GetTriggerUnit(), UNIT_STATE_LIFE)
 
 if life > 1 then
  set dmg=dmg / 6
  call UnitDamageTargetBJ(GetEventDamageSource(), protector, dmg, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL)
endif
  
  set protector=null
endfunction

