//===========================================================================
function InitTrig_unitpreload takes nothing returns nothing
    set gg_trg_unitpreload=CreateTrigger()
    call TriggerRegisterTimerEvent(gg_trg_unitpreload, 25.00, false)
    call TriggerAddCondition(gg_trg_unitpreload, Condition(function makepreload))
endfunction


