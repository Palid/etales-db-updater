//===========================================================================
// Trigger: teampvpB
//
// bj_questHintSound 
//===========================================================================
//TESH.scrollpos=12
//TESH.alwaysfold=0
function TBPVPC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I02D' )
endfunction

function settingtbpvp takes nothing returns nothing
    call MakeEnemy(GetOwningPlayer(GetManipulatingUnit()) , GetEnumPlayer())
    call MakeEnemy(GetEnumPlayer() , GetOwningPlayer(GetManipulatingUnit()))
endfunction

function TBPVPA takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetManipulatingUnit()))
local unit u= udg_PHero[id]
local location p
local string pname= GetPlayerName(GetOwningPlayer(u))
local string hname= GetUnitName(udg_PHero[id])
local boolean ok= false
local integer coord= GetRandomInt(0, 9)
   if ( on_event == false ) then
     call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 3, "Teams arena is closed due there isn't event in course")
   elseif IsPlayerInForce(Player(id), teamA) == true then
       call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 6, "You cannot change team while event is in course.")
   elseif IsPlayerInForce(Player(id), teamB) == true then
      // call ForceAddPlayer(teamEventForce,Player(id))   
       call ForForce(teamA, function settingtbpvp)
       set p=Location(s__tlocx[coord], s__tlocy[coord])
       call SetUnitPositionLoc(u, p)
       call SetUnitPositionLoc(udg_Slave[id], p)
       call SetUnitPositionLoc(udg_Familiar[id], p)
       call SetUnitPositionLoc(cslave[id], p)
       call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
       call DisplayTimedTextToForce(GetPlayersAll(), 6.00, "|cffffcc00" + pname + "|r, the " + hname + " has returned to the battle")
       call StartSound(bj_questHintSound)
       call DisableTrigger(natkp[id])
       call RemoveLocation(p)
       call GroupRemoveUnit(diedheroes, u)
   elseif teamBc >= maxTeam then
    call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 6, "|cff0033ffHeroes|r has reached its players limit, select |cffff3300Villains|r")
   else
        call ForceAddPlayer(teamEventForce, Player(id))
        call ForceAddPlayer(teamB, Player(id))
        call ForForce(teamA, function settingtbpvp)
        set teamBc=teamBc + 1
        set p=Location(10145, - 21462)
        if teamBc == 1 then
         set Htitan=CreateUnitAtLoc(Player(id), tBaluart, p, 225)
         call SetUnitAnimationByIndex(Htitan, 0)
         call PauseUnit(Htitan, true)
         if InsetupBattle == true then
          call SetUnitInvulnerable(Htitan, true)
         endif
         
         call TriggerRegisterUnitEvent(gg_trg_titanHdie, Htitan, EVENT_UNIT_DEATH)
         call SaveUnitHandle(udg_cache, GetHandleId(teamB), 1, Htitan)
        endif
        
        call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 6, "type |cffffcc00-rules|r to view a display with main rules of team event")
        // call UnitChat("You'll be moved into the PvP Arena", GetSellingUnit())
        call StartSound(bj_questDiscoveredSound)
        call TriggerSleepAction(2)
         if EventRunning == true then
          call LeaderboardAddItem(clashlb, GetPlayerName(Player(id)), 0, Player(id))
              if GetLocalPlayer() == Player(id) then
                call LeaderboardDisplay(clashlb, true)
              endif
        endif

             
        call SetUnitPositionLoc(u, p)
       // call movegroup(id,p)
       call SetUnitPositionLoc(udg_Slave[id], p)
       call SetUnitPositionLoc(udg_Familiar[id], p)
       call SetUnitPositionLoc(cslave[id], p)
        
        call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
        call DisplayTimedTextToForce(GetPlayersAll(), 6.00, "|cffffcc00" + pname + "|r, the " + hname + " has entered into the |cff0033ffHeroes|r")
        call PlaySoundBJ(gg_snd_HeroEnters)

        call DisableTrigger(natkp[id])
        call RemoveLocation(p)
   endif



set p=null
set u=null
set pname=null
set hname=null

endfunction

