function Trig_healer_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer questid
   
   if ( GetUnitTypeId(GetTriggerUnit()) != 'H00G' ) then
        call UnitChat("Only female novices can take this responsability" , gg_unit_Hpal_1040)

   elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
        call UnitChat("Have you came to pray.... what about the |cffffcc00healer bulbs|r?" , gg_unit_Hpal_1040)
 
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
            call UnitChat("You dont have necessary experience to do this quest. |n|cffffcc00Needs 300 kills|r" , gg_unit_Hpal_1040)

        else
            call UnitChat("Do you want to be a healer?, please bring me |cffffcc007 Healer bulbs|r" , gg_unit_Hpal_1040)

            call EnableTrigger(gg_trg_healbulb)
            call EnableTrigger(gg_trg_growbulb)
            call TriggerExecute(gg_trg_healbulb)
        call GroupAddUnitSimple(GetTriggerUnit(), udg_inTest)
         call TriggerSleepAction(3)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00MAIN QUEST DISCOVERED|r")
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "          |cffeeee88The holy path|r: Collect 7 healer bulbs and return to the minstreel")
         set questid=SetupQuest(id , null , "THE HOLY PATH" , "Collect 7 healer bulbs and return to the minstreel" , "-" , "-" , 0 , s__qty[2])
         call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
     
    
    endif
        
        
endfunction

