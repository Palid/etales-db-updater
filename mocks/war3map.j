    return ( GetItemLifeBJ(GetManipulatedItem()) == 121.00 )
endfunction

function Trig_thief_Actions takes nothing returns nothing
local location p
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer questid

    if ( GetUnitTypeId(GetTriggerUnit()) != 'H00G' ) then
        call UnitChat(udg_ThiefnoType , gg_unit_h00D_0293)

    
    elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
            call UnitChat("Yes Honey, you need something?" , gg_unit_h00D_0293)
           
        
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
            call UnitChat(udg_Thiefrejected , gg_unit_h00D_0293)

        else
            call UnitChat("Ok, you are ready!|nListen, there's a cave on the graveyard.|nAt the end of the cave you will find a chest.|njust take it a leave the cave " , gg_unit_h00D_0293)

         
           
            set p=GetRectCenter(gg_rct_Thiefs_chests)
            call CreateItemLoc('I0L4', p)
            call GroupAddUnitSimple(GetTriggerUnit(), udg_inTest)
            call TriggerSleepAction(3)
            if ( GetLocalPlayer() == Player(id) ) then
                call PingMinimapEx(- 16938, 6636, 16, 255, 255, 50, false)
            endif
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00MAIN QUEST DISCOVERED|r")
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "          |cffeeee88Fast fingers, fast legs|r: Find thief's chest and leave graveyard cave")
            set questid=SetupQuest(id , null , "FAST FINGERS; FAST LEGS" , " Find thief's chest and leave graveyard cave" , "-" , "-" , 0 , s__qty[2])
            call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
         
       
       
        endif
    call RemoveLocation(p)

set p=null
endfunction

