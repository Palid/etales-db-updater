function IsBonusUnitc takes nothing returns boolean
 return GetDyingUnit() == TeamBonusUnit
endfunction


function Trig_bonusdie_Actions takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
  local integer i= 0
  local integer left= totalbns - Bnscnt
   local string bnus= "|cffffcc00"
   local string team
      
      set tleaver[id]=true
      // call ForceRemovePlayer(teamEventForce,Player(id))  
      // call ForForce(teamEventForce, function settingteamout )
       if IsPlayerInForce(Player(id), teamA) == true then
            set teamAp=teamAp + 2
            set team="|cffcd853fVillains|r "
            
       elseif IsPlayerInForce(Player(id), teamB) == true then
            set teamBp=teamBp + 2
            set team="|cff6495edHeroes|r "
            
       endif
       
       // GetPlayerController(GetOwningPlayer(GetKillingUnit())) == MAP_CONTROL_USER 
     if IsPlayerInForce(Player(id), teamEventForce) == true then
         set s__playerkills[id]= s__playerkills[id] + 2
         call LeaderboardSetItemValue(clashlb, LeaderboardGetPlayerIndex(clashlb, Player(id)), s__playerkills[id])
         set bnus=bnus + GetPlayerName(Player(id)) + "|r has hunted |cffffcc00Life Bonus (+2)|r for " + team + ". |cffffcc00" + I2S(left) + "|r bonuses left."
     else
        set bnus="Unit Bonus lost, |cffffcc00" + I2S(left) + "|r bonuses left."
     endif
     
      loop
         exitwhen i > 7
         if IsPlayerInForce(Player(i), bj_FORCE_ALL_PLAYERS) then
             call DisplayTimedTextToPlayer(Player(i), 0, 0, 6, bnus)
         endif
         set i=i + 1
         endloop
     
     set TeamBonusUnit=null
     
     call UpdateLeaderBoard()
 set team=null
 set bnus=null
endfunction

