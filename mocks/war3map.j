//===========================================================================
// Trigger: activateq
//===========================================================================
function Trig_activateq_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_activateq_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local real x
local real y

call DestroyEffect(AddSpecialEffectTarget(seblink, u, "origin"))
set altar=altar + 1

if altar > 2 then
 call DisableTrigger(gg_trg_activateq)
 set x=GetUnitX(u) + 250 * Cos(37 * bj_DEGTORAD)
 set y=GetUnitY(u) + 250 * Sin(37 * bj_DEGTORAD)
 call TriggerSleepAction(1.6)
 call SetUnitPosition(ankalia, x, y)
 call ShowUnit(ankalia, true)
 call DestroyEffect(AddSpecialEffectTarget(seblink, ankalia, "origin"))
 call SetUnitFacingToFaceUnitTimed(ankalia, u, 0)
 call UnitChat("Dadvar?..." , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("(surprised) You're not Dadvar..." , ankalia)
 call TriggerSleepAction(2.6)
 call SetUnitFacingToFaceUnitTimed(ankalia, u, 0)
 call UnitChat("You're |cffffcc00" + GetPlayerName(GetOwningPlayer(u)) + "|r. Your hearth has invoked me..." , ankalia)
 call TriggerSleepAction(2)
 call UnitChat("Who are you?" , u)
 call TriggerSleepAction(1.8)
 call UnitChat("My name is |cffffcc00Ankalia|r from Krento, Home of Sun Father's servants" , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("We are minstreels that praise for Enthashara's people" , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("|cffffcc00Dadvar|r is the minstreel of this land" , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("I can feel his presence, but he seems to be hidden for an unknown power" , ankalia)
 call TriggerSleepAction(2)
 call UnitChat("I have no idea what are you talking about..." , u)
 call TriggerSleepAction(3)
 call SetUnitFacingToFaceUnitTimed(ankalia, u, 0)
 call UnitChat(":)   ...Mi child..." , ankalia)
 call TriggerSleepAction(2)
 call UnitChat("I can sense a naiar's seal on your blood .." , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("If you're here, It is something..." , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("Well I don't know much about these stories..." , u)
 call TriggerSleepAction(3)
 call UnitChat("But I saw a lot of undeads here, that's very strange" , u)
 call TriggerSleepAction(3)
 call SetUnitFacingToFaceUnitTimed(ankalia, u, 0)
 call UnitChat("Wait... I can feel the presence of |cffffcc00Dadvar|r" , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("He is trying to tell me something..." , ankalia)
 call TriggerSleepAction(3)
 call DisplayTimedTextToForce(GetPlayersAll(), 8, "|cff999999You listen a deeper voice: Come to the|r |cffffcc00Monastery|r")
 call TriggerSleepAction(3)
 call UnitChat("Did you heard that?" , u)
 call TriggerSleepAction(3)
 call UnitChat("Yes, Is |cffffcc00Dadvar|r" , ankalia)
 call TriggerSleepAction(3)
 call UnitChat("Please find him, terrible things come so fast to this land..." , ankalia)
 call TriggerSleepAction(4)
 call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00NEW WORLD QUEST DISCOVERED:|r Find Dadvar into the |cffffcc00Haunted Monastery|r.")
 call StartSound(bj_questDiscoveredSound)
 call QuestSetDiscovered(dadvarq, true)
 set dadvarready=true
     
        if ( IsPlayerInForce(GetLocalPlayer(), GetPlayersAll()) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
                call PingMinimap(- 8580, - 8888, 10)
        //call StartSound(bj_pingMinimapSound)
        endif
  
 
 call ShowUnit(dadvar, true)
 call EnableTrigger(gg_trg_dadvarq)
 call TriggerRegisterUnitInRangeSimple(gg_trg_dadvarq, 256, gg_unit_E003_0853)
        
 call TriggerSleepAction(1.6)
 call DestroyEffect(AddSpecialEffectTarget(seblink, ankalia, "origin"))
 call TriggerSleepAction(0.8)
 call SetUnitPosition(ankalia, 21500, - 1550)
 call ShowUnit(ankalia, false)
 set u=null
endif

endfunction

