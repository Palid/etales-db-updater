//Is hawk Attack
function hawkOff takes nothing returns boolean
  return ( GetUnitTypeId(GetEventDamageSource()) != poisonivy and GetUnitTypeId(GetEventDamageSource()) != 'n005' and GetUnitTypeId(GetEventDamageSource()) != 'n065' )
endfunction


function DesirePot takes unit u returns nothing



