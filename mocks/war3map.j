//===========================================================================
// Trigger: VS
//
//  set udg_CAM_unitangle = GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit())
//     call SetUnitLifeBJ( GetTriggerUnit(), GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit()) )
// "Abilities\\Spells\\Other\\Drain\\DrainCaster.mdl"
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_VS_Conditions takes nothing returns boolean
return GetUnitAbilityLevel(GetTriggerUnit(), 'B01E') > 0
//return ( UnitHasBuffBJ(GetTriggerUnit(), 'B01E') == true )
endfunction

function Trig_VS_Actions takes nothing returns nothing
    local unit a= GetEventDamageSource()
    local unit u= GetTriggerUnit()
    local real ahp=  GetUnitState(a, UNIT_STATE_LIFE)
    local real fhp= ahp - ( ( ahp * 0.01 ) / 2 )
    local real uhp=  GetUnitState(u, UNIT_STATE_LIFE)
    local real ghp= uhp + ( ( ahp * 0.01 ) / 2 )
    
    call SetUnitState(a, UNIT_STATE_LIFE, fhp)
    call SetUnitState(u, UNIT_STATE_LIFE, ghp)
    
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\Drain\\DrainCaster.mdl", a, "head"))
    
    set a=null
    set u=null
   
endfunction

//===========================================================================
function InitTrig_VS takes nothing returns nothing
 local integer i= 9
    set gg_trg_VS=CreateTrigger()
    
   loop
    exitwhen i > 12
    
      call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[i], EVENT_UNIT_DAMAGED)
    
    set i=i + 1
    endloop
    
    
    
    call TriggerAddCondition(gg_trg_VS, Condition(function Trig_VS_Conditions))
    call TriggerAddAction(gg_trg_VS, function Trig_VS_Actions)
endfunction


//===========================================================================
// Trigger: ESS
//
//  set udg_CAM_unitangle = GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit())
//     call SetUnitLifeBJ( GetTriggerUnit(), GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit()) )
// "Abilities\\Spells\\Other\\Drain\\DrainCaster.mdl"
//===========================================================================
//TESH.scrollpos=15
//TESH.alwaysfold=0
function ESSC takes nothing returns boolean
    return GetUnitAbilityLevel(GetTriggerUnit(), 'A09Z') > 0
endfunction

function ESSA takes nothing returns nothing
    local unit a= GetEventDamageSource()
    local unit u= GetTriggerUnit()
    local location p= GetUnitLoc(u)
    local unit dummy
 
    set dummy=CreateUnitAtLoc(GetOwningPlayer(u), 'n04Y', p, bj_UNIT_FACING)
    
    call IssueTargetOrder(dummy, "attack", a)
    call UnitApplyTimedLife(dummy, 'BTLF', 1.5)
    
call RemoveLocation(p)
set p=null
set a=null
set u=null
set dummy=null
   
endfunction

