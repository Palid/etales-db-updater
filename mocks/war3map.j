//===========================================================================
// Trigger: enablepanda
//
// 
//===========================================================================
function enablepanc takes nothing returns boolean
  return ( GetItemTypeId(GetManipulatedItem()) == 'I061' and IsUnitType(GetManipulatingUnit(), UNIT_TYPE_HERO) == true )
endfunction

function enablepanda takes nothing returns nothing
 if GetUnitLevel(GetManipulatingUnit()) < 60 then
    call UnitChat("Mmmm thinking better, you are to weak to helpme" , hugss)
    call TriggerSleepAction(3)
    call UnitChat("Fshhh, Fshhhss... Go away child, don't waste my time |cffaaaaaa(lev required = 60)|r" , hugss)
 else
    call DisableTrigger(gg_trg_enablepanda)
    
    call TriggerSleepAction(0.4)
    call RemoveItemFromStock(hugss, 'I061')
    call UnitRemoveAbility(hugss, 'Asid')
    call UnitChat("Je, Je, Je... come on, come on!... Prepare yourself with anything needed for the travel" , hugss)
    call ShowUnit(gg_unit_n06J_0458, true) //arcane lightning
    call SetUnitPosition(gg_unit_n06J_0458, - 8300, - 19550)
    call TriggerSleepAction(3)
    call UnitChat("I will wait for you into the first dungeon room. " , hugss)
    call TriggerSleepAction(2)
    call IssuePointOrder(hugss, "move", 10500, - 2860)
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00NEW WORLD QUEST DISCOVERED:|r Help |cffffcc00Hugss|r to find the |cffff3333-Secret of Youth-|r treasure into the |cffffcc00Coldream Sanctuary|r.")
    call StartSound(bj_questDiscoveredSound)
    call QuestSetDiscovered(pandaq, true)
     
        if ( IsPlayerInForce(GetLocalPlayer(), GetPlayersAll()) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
                call PingMinimap(10500, - 2860, 10)
        //call StartSound(bj_pingMinimapSound)
        endif
    set hugsst=(NewTimerEx(0)) // INLINED!!
     call TriggerSleepAction(20)
     call SetUnitPosition(hugss, - 9430, - 20600)
     call IssueImmediateOrder(hugss, "stop")
    endif

endfunction

//===========================================================================
function InitTrig_enablepanda takes nothing returns nothing
 local integer i= 0
    set gg_trg_enablepanda=CreateTrigger()
 //  call TriggerRegisterUnitInRange(gg_trg_enablepanda, gg_unit_n05C_0662, 255, Condition(function rescok))
        loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_enablepanda, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function btrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
   call TriggerAddCondition(gg_trg_enablepanda, Condition(function enablepanc))
   call TriggerAddAction(gg_trg_enablepanda, function enablepanda)
endfunction


//===========================================================================
// Trigger: pandadeath
//===========================================================================
function removeblessed takes nothing returns nothing
call UnitRemoveAbility(GetEnumUnit(), 'A0EH') //armor
call UnitRemoveAbility(GetEnumUnit(), 'A0EG') //life
call UnitRemoveAbility(GetEnumUnit(), 'A0EI') //damage red
endfunction


function removebless takes nothing returns nothing
 call ForGroup(blessedunits, function removeblessed)
 call TimerDialogDisplay(blesstime, false)
 call DestroyTimerDialog(blesstime)
 call ReleaseTimer(blesstimer)

endfunction

function addbless takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetEnumUnit()))
call UnitAddAbility(GetEnumUnit(), 'A0EH') //armor
call UnitAddAbility(GetEnumUnit(), 'A0EG') //life
call UnitAddAbility(GetEnumUnit(), 'A0EI') //damage red
call DestroyEffect(AddSpecialEffectTarget(blessunit, GetEnumUnit(), "origin"))
call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "the Arcane spirits have blessed you over 15 minutes")
call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "Your |cffffcc00life|r, |cffffcc00Armor|r and |cffffcc00Damage reduction|r have been increased heavily")
  

endfunction


function pandahero takes nothing returns boolean
   return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true )
endfunction

function pandablessed takes nothing returns nothing

  call GroupEnumUnitsInRect(blessedunits, gg_rct_Xdungon, Condition(function pandahero))
  call ForGroup(blessedunits, function addbless)

endfunction

function pandadeath takes nothing returns nothing
//local effect sfx
  call GroupRemoveUnit(arcanepanda, GetDyingUnit())
    
    call TriggerSleepAction(0.1)
     if IsUnitGroupEmptyBJ(arcanepanda) == true then
    // call DisplayTimedTextToPlayer(Player(0),0,0,2,"pandas")
     
      call PauseUnit(arcanespirit, false)
     //set sfx = AddSpecialEffect(pandabless,13950,14975)
       call IssuePointOrder(arcanespirit, "move", 13950, 14850)
       call TriggerSleepAction(4)
       call PauseUnit(arcanespirit, true)
       call UnitChat("Well done Heroes, you can receive the |cffffcc00Secret of Youth|r" , arcanespirit)
        call TriggerSleepAction(1)
       call PauseUnit(arcanespirit, false)
       call IssueImmediateOrder(arcanespirit, "stop")
       call TriggerSleepAction(2)
       call IssueImmediateOrder(arcanespirit, "tranquility")
       call TriggerSleepAction(2)
       call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffffcc00WORLD QUEST COMPLETED:|r The Secret of Youth")
       call StartSound(bj_questCompletedSound)
       call QuestItemSetCompleted(pandaqi, true)
       call QuestSetCompleted(pandaq, true)
       call ExecuteFunc("pandablessed")
       call DestroyGroup(arcanepanda)
       set arcanepanda=null
       
       call TimerStart(blesstimer, 1200, false, function removebless)
       set blesstime=CreateTimerDialog(blesstimer)
       call TimerDialogSetTitle(blesstime, "Arcane Bless")
       call TimerDialogDisplay(blesstime, true)
       call TriggerSleepAction(7)
       call RemoveUnit(arcanespirit)
       set arcanespirit=null
    // call DestroyEffect(sfx)
       
    endif

//set sfx = null
endfunction

//===========================================================================
function InitTrig_pandadeath takes nothing returns nothing
    set gg_trg_pandadeath=CreateTrigger()
    
    call TriggerRegisterUnitEvent(gg_trg_pandadeath, gg_unit_n06J_0811, EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_pandadeath, gg_unit_n06V_0815, EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_pandadeath, gg_unit_n06Q_0813, EVENT_UNIT_DEATH)
    call TriggerAddAction(gg_trg_pandadeath, function pandadeath)
endfunction


