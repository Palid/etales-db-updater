    set gg_trg_tomb=CreateTrigger()
    call DisableTrigger(gg_trg_tomb)
    call TriggerRegisterEnterRectSimple(gg_trg_tomb, gg_rct_tomb1i)
    call TriggerAddCondition(gg_trg_tomb, Condition(function Trig_tomb_Conditions))
    call TriggerAddAction(gg_trg_tomb, function Trig_tomb_Actions)
endfunction


