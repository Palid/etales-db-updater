    set gg_trg_acostarse=CreateTrigger()
    call TriggerRegisterGameStateEvent(gg_trg_acostarse, GAME_STATE_TIME_OF_DAY, EQUAL, 4.30)
    call TriggerAddAction(gg_trg_acostarse, function Trig_acostarse_Actions)
endfunction


//===========================================================================
// Trigger: levantarse
//===========================================================================
   //gg_unit_h02L_0647 )//ogro
   //gg_unit_h00V_0646 )//tauren
   //gg_unit_h02K_0724 )//tuskar
   //gg_unit_h02M_0725 )//bandit
   //gg_unit_h02O_0739 )//panda
   //gg_unit_h02N_0726 )//rexxar

function Trig_levantate takes nothing returns nothing

local integer i= 0
call SetUnitPosition(gg_unit_h02L_0647, - 2015, 6533)
call SetUnitPosition(gg_unit_h00V_0646, 5465, 14620)
call SetUnitPosition(gg_unit_h02K_0724, - 5763, - 7372)
call SetUnitPosition(gg_unit_h02M_0725, 1359, - 5044)
call SetUnitPosition(gg_unit_h02O_0739, 5061, - 10430)
call SetUnitPosition(gg_unit_h02N_0726, 12927, - 12557)

call ShowUnit(gg_unit_h02L_0647, true)
call ShowUnit(gg_unit_h00V_0646, true)
call ShowUnit(gg_unit_h02K_0724, true)
call ShowUnit(gg_unit_h02M_0725, true)
call ShowUnit(gg_unit_h02O_0739, true)
call ShowUnit(gg_unit_h02N_0726, true)

 call IssuePointOrder(gg_unit_h02L_0647, "move", 5680, 6980)
 call TriggerSleepAction(2)
 call IssuePointOrder(gg_unit_h00V_0646, "move", 7000, 10750)
  call TriggerSleepAction(3)
 call IssuePointOrder(gg_unit_h02K_0724, "move", - 3357, - 3401)
  call TriggerSleepAction(2)
 call IssuePointOrder(gg_unit_h02M_0725, "move", - 3098, - 3412)
  call TriggerSleepAction(1)
 call IssuePointOrder(gg_unit_h02O_0739, "move", 7963, - 17483)
  call TriggerSleepAction(2)
 call IssuePointOrder(gg_unit_h02N_0726, "move", 8414, - 17623)
  call TriggerSleepAction(3)

 loop
 exitwhen i > 5
 
 set smgItemA[i]=ChooseRandomItem(10)
 set smgItemB[i]=ChooseRandomItem(10)
 set smgItemC[i]=ChooseRandomItem(10)
 set smgItemD[i]=ChooseRandomItem(10)
 set smgItemE[i]=ChooseRandomItem(10)
 set smgItemF[i]=ChooseRandomItem(10)
 
 set i=i + 1
 endloop
 
 set i=0
 
  loop
 exitwhen i > 5
 

 call AddItemToStock(gg_unit_h02L_0647, smgItemA[i], 1, 1)
   call TriggerSleepAction(0.03)
 call AddItemToStock(gg_unit_h00V_0646, smgItemB[i], 1, 1)
  call TriggerSleepAction(0.03)
 call AddItemToStock(gg_unit_h02K_0724, smgItemC[i], 1, 1)
  call TriggerSleepAction(0.03)
 call AddItemToStock(gg_unit_h02M_0725, smgItemD[i], 1, 1)
  call TriggerSleepAction(0.03)
 call AddItemToStock(gg_unit_h02O_0739, smgItemE[i], 1, 1)
  call TriggerSleepAction(0.03)
 call AddItemToStock(gg_unit_h02N_0726, smgItemF[i], 1, 1)
 
 set i=i + 1
 endloop
 
 
 
endfunction

//===========================================================================
function InitTrig_levantarse takes nothing returns nothing
    set gg_trg_levantarse=CreateTrigger()
    call TriggerRegisterGameStateEvent(gg_trg_levantarse, GAME_STATE_TIME_OF_DAY, EQUAL, 19.30)
    call TriggerAddAction(gg_trg_levantarse, function Trig_levantate)
endfunction


