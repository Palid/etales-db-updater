function InitTrig_dgems takes nothing returns nothing
    set gg_trg_dgems=CreateTrigger()
  //  call TriggerRegisterUnitEvent( gg_trg_dgems, mdruid, EVENT_UNIT_PICKUP_ITEM )
    call TriggerAddAction(gg_trg_dgems, function Trig_dgems_Actions)
endfunction


//===========================================================================
// Trigger: masterdruidstart
//
// gg_unit_h007_0026//healer giver
//===========================================================================
function mdruidc takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I09J' )
endfunction

function mdruida takes nothing returns nothing
   local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   local integer questid
   local real face= GetUnitFacing(gdruid)
   
   call MakeFaceToUnit(gdruid , udg_PHero[id])

   if ( GetUnitTypeId(GetTriggerUnit()) != 'H00H' ) then
    
      call UnitChat("It doesn't belong To you" , gdruid)
      
        
   elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
      call UnitChat("What are you doing here!" , gdruid)
        
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
      call UnitChat("You have not the necessary power.. |n|cffffcc00Needs 300 kills|r!" , gdruid)
          
        else
         call UnitChat("There is a Master Druid in Ekrom, He will teach you what is needed..." , gdruid)
         call TriggerSleepAction(2)
         call UnitChat("Remember It's necessary you must offer a gift." , gdruid)
         call TriggerSleepAction(2)
         call UnitChat("You'll need 5 different gems..." , gdruid)
       
         set s__druidseek[id]= true
             
         call GroupAddUnit(udg_inTest, udg_PHero[id])
         call TriggerSleepAction(2)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "|cffffcc00MAIN QUEST DISCOVERED|r")
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 8, "          |cffeeee88The Shaman way|r: Travel to Ekrom and talk with Master Druid...")
         call StartSound(bj_questDiscoveredSound)
         set questid=SetupQuest(id , mdruid , "THE SHAMAN WAY" , "Travel to Ekrom and talk with Master Druid... " , "0" , "/5" , 0 , s__qty[2])
         call SaveInteger(udg_cache, GetHandleId(mdruid), GetHandleId(udg_PHero[id]), questid)
           
         
         call TriggerSleepAction(2)
          if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
            call PingMinimap(7660, 10767, 15)
        //call StartSound(bj_pingMinimapSound)
          endif
           
      endif
   call SetUnitFacing(gdruid, face)
endfunction



