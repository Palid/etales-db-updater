  call TriggerSleepAction(3)
  call UnitChat("Or maybe for your own targets" , arcanespirit)
  call TriggerSleepAction(3)
  call UnitChat("But all your ways end in an unique last way for hope; Save Enthashara" , arcanespirit)
  call TriggerSleepAction(3)
  call UnitChat("We can help you..." , arcanespirit)
  call TriggerSleepAction(3)
  call UnitChat("But all of you must demonstrate that you're capable of manage our secret..." , arcanespirit)
  call TriggerSleepAction(4)
  call IssuePointOrder(arcanespirit, "move", 13840, 16120)
  call UnitChat("Defeat my brothers... if you can..." , arcanespirit)
  call TriggerSleepAction(4)
  
   call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "|cffffcc00WORLD QUEST UPDATE:|r Win the battle against the Arcane Spirits.")
   call StartSound(bj_questDiscoveredSound)
   call TriggerSleepAction(1)
   call SetUnitPosition(arcanespirit, 13840, 16120)
   call SetUnitFacingTimed(arcanespirit, 270, 1)
   call PauseUnit(arcanespirit, true)
 
endfunction


