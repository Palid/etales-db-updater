function IsLegitHit takes nothing returns boolean
  return GetUnitAbilityLevel(GetEventDamageSource(), 'Aloc') == 0
endfunction

function Scorpiondmga takes nothing returns nothing
 local integer perc= R2I(GetEventDamage()) / 200
 local integer i= LoadInteger(AiHash, GetHandleId(ScorpionEng), 2)
     set i=i + 1
     call SaveInteger(AiHash, GetHandleId(ScorpionEng), 2, i)
     set Scorpionevent2=Scorpionevent2 + perc
     
endfunction

//===========================================================================
function InitTrig_ScorpionDmg takes nothing returns nothing
    set Scorpiondmgd=CreateTrigger()
    call TriggerAddCondition(Scorpiondmgd, Condition(function IsLegitHit))
    call TriggerAddAction(Scorpiondmgd, function Scorpiondmga)
endfunction


