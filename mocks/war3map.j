function GetInventory takes unit u,integer id returns integer
  local integer i= 0
  local integer j= 0
  local integer l__l= 0
  
 
   loop
     exitwhen i > 5
      
        if not ( UnitItemInSlot(u, i) == null ) then
        
        set udg_tempinventory[j]=UnitItemInSlot(u, i)
      //  call SaveInteger(nodump,GetHandleId(Player(id)),GetHandleId(udg_tempinventory[j]),1)
        call SaveInteger(nodump, GetHandleId(udg_tempinventory[j]), GetHandleId(udg_tempinventory[j]), id + 10)
        set udg_tmpItemId[j]=GetItemTypeId(udg_tempinventory[j])
        
           if ( GetItemCharges(udg_tempinventory[j]) > 0 ) then
              
               set udg_tempinvcharges[l__l]=GetItemCharges(udg_tempinventory[j])
               
                  if ( udg_tempinvcharges[l__l] > 20 ) then //prevents overflow in save code
                     set udg_tempinvcharges[l__l]=20
                  endif
               set udg_Slots[l__l]=j
               set l__l=l__l + 1
            endif
            set j=j + 1
        endif
     set i=i + 1
   endloop
 
 // if (l>0) then
 //  set l = l-1
 // endif
 // if (j>0) then
 //   set j = j-1
 // endif
  
 set udg_Slots[6]=l__l //saved counted items with charges
 set udg_Slots[7]=j //saved counted items

 set i=0

loop //itemtype
     exitwhen i == j
     if not ( udg_tempinventory[i] == null ) then
                 if ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_ARTIFACT ) then
                      set currentType[i]=1
                elseif ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_PERMANENT ) then
                      set currentType[i]=2
                elseif ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_MISCELLANEOUS ) then
                      set currentType[i]=3
                elseif ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_CAMPAIGN ) then
                      set currentType[i]=4
                elseif ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_CHARGED ) then
                      set currentType[i]=5
                elseif ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_PURCHASABLE ) then
                      set currentType[i]=6
                elseif ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_UNKNOWN ) then
                      set currentType[i]=3
                elseif ( GetItemType(udg_tempinventory[i]) == ITEM_TYPE_ANY ) then
                      set currentType[i]=3
                endif
   endif
     
     set i=i + 1
     endloop
   return j //number of total allocations in tempbuffer   
 endfunction
 
function FreeInventory takes nothing returns nothing
local integer i= 0
loop
 exitwhen i > 8
  set udg_tempinventory[i]=null
  set udg_tempinvcharges[i]=0
  set udg_tmpItemId[i]=0
  set udg_Slots[i]=20
  set currentType[i]=0
 set i=i + 1
 endloop
endfunction

