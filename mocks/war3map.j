//===========================================================================
// Trigger: Huracan
//===========================================================================
//TESH.scrollpos=132
//TESH.alwaysfold=0
function Huracan_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A0J2'
endfunction

function hurfilter takes nothing returns boolean
    return not ( GetUnitFlyHeight(GetFilterUnit()) > 0 )
endfunction

function SpiralOrder takes nothing returns nothing
    local unit u= GetEnumUnit()
    local real x= LoadReal(udg_MG1Hash, GetHandleId(u), 0)
    local real y= LoadReal(udg_MG1Hash, GetHandleId(u), 1)
    local real xf= GetUnitX(u)
    local real yf= GetUnitY(u)
    local real dx= xf - x
    local real dy= yf - y
    local real angle=bj_RADTODEG * Atan2(dy, dx) + 5
    set xf=xf + 384 * Cos(angle * bj_DEGTORAD)
    set yf=yf + 384 * Sin(angle * bj_DEGTORAD)
               
                  call IssuePointOrder(u, "move", xf, yf)
                  
    set u=null
endfunction


function SpiralMovement takes nothing returns nothing
    local unit u=  GetEnumUnit()
    local real x= LoadReal(udg_MG1Hash, GetHandleId(u), 0)
    local real y= LoadReal(udg_MG1Hash, GetHandleId(u), 1)
    local real ux= GetUnitX(u)
    local real uy= GetUnitY(u)
    local real dx= ux - x
    local real dy= uy - y
    local real delta= SquareRoot(dx * dx + dy * dy)
    local real trazo=  LoadReal(udg_MG1Hash, GetHandleId(u), 2)
    local real angle= bj_RADTODEG * Atan2(dy, dx) - 2
    local real d= delta - trazo
    local real xf= 0
    local real yf= 0
    local real lnang= angle
    local real a= 47
    local real b= 0.98
    
  if lnang == 0 then
     set angle=360
  endif
    
    set xf=x + d * Cos(angle * bj_DEGTORAD)
    set yf=y + d * Sin(angle * bj_DEGTORAD)
    
     if IsTerrainPathable(xf, yf, PATHING_TYPE_WALKABILITY) == false then
       call SetUnitX(u, xf)
       call SetUnitY(u, yf)
     endif
     

    
    if GetUnitFlyHeight(GetFilterUnit()) > 0 then
       call GroupRemoveUnit(LoadGroupHandle(udg_MG1Hash, GetHandleId(u), 3), u)
       call FlushChildHashtable(udg_MG1Hash, GetHandleId(u))
       call GroupRemoveUnit(huracans, u)
       call SetUnitPathing(u, true)
       
    endif
      
    
    call SaveReal(udg_MG1Hash, GetHandleId(u), 2, trazo)
    set u=null
endfunction


function ClearSpiral takes nothing returns nothing
    call FlushChildHashtable(udg_MG1Hash, GetHandleId(GetEnumUnit()))
    call GroupRemoveUnit(huracans, GetEnumUnit())
   // call SetUnitPathing(GetEnumUnit(),true)
endfunction

function Huracan takes nothing returns nothing
  local timer t= GetExpiredTimer()
  local integer id= LoadInteger(hts, GetHandleId(t), 0)
  local real x= LoadReal(hts, GetHandleId(t), 1)
  local real y= LoadReal(hts, GetHandleId(t), 2)
//  local unit h = LoadUnitHandle(hts,GetHandleId(t),3) 
//  local unit hx = LoadUnitHandle(hts,GetHandleId(t),4)
  local group g= LoadGroupHandle(hts, GetHandleId(t), 5)
  local integer c= LoadInteger(hts, GetHandleId(t), 6)
  local group tg= LoadGroupHandle(hts, GetHandleId(t), 7)
  local boolexpr hfilter= Condition(function hurfilter)
  local unit gu= null
  local real dx= 0
  local real dy= 0
  local real angle= 0
  local real xf= 0
  local real yf= 0
    
  call GroupClear(tg)
  call GroupEnumUnitsInRange(tg, x, y, 768, hfilter)
  call DestroyBoolExpr(hfilter)
  set hfilter=null

	   loop
            set gu=FirstOfGroup(tg)
              exitwhen gu == null
              
                if IsUnitInGroup(gu, g) == false and IsUnitEnemy(gu, Player(id)) == true then
                //  call SetUnitPathing(gu,false)
                  call GroupAddUnit(g, gu)
                  call GroupAddUnit(huracans, gu)
                  call SaveReal(udg_MG1Hash, GetHandleId(gu), 0, x)
                  call SaveReal(udg_MG1Hash, GetHandleId(gu), 1, y)
                  call SaveReal(udg_MG1Hash, GetHandleId(gu), 2, 0.01)
                  call SaveGroupHandle(udg_MG1Hash, GetHandleId(t), 3, g)
                  
                  set xf=GetUnitX(gu)
                  set yf=GetUnitY(gu)
                  set dx=xf - x
                  set dy=yf - y
                  set angle=bj_RADTODEG * Atan2(dy, dx) + 5
                  
                   set xf=xf + 384 * Cos(angle * bj_DEGTORAD)
                   set yf=yf + 384 * Sin(angle * bj_DEGTORAD)
                  
                  call IssuePointOrder(gu, "move", xf, yf)
                endif
               
            call GroupRemoveUnit(tg, gu)
            set gu=null
       endloop
	 set tg=null
    
     
    call ForGroup(g, function SpiralMovement)
    set c=c + 1
    call SaveInteger(hts, GetHandleId(t), 6, c)
    
    if ModuloInteger(c, 80) == 0 then
      call DestroyEffect(AddSpecialEffect(terranfx, x, y))
     call ForGroup(g, function SpiralOrder)
    endif
     
     
    if c > 799 then
       call UnitApplyTimedLife(LoadUnitHandle(hts, GetHandleId(t), 3), 'BTLF', 0.1)
       call UnitApplyTimedLife(LoadUnitHandle(hts, GetHandleId(t), 4), 'BTLF', 0.1)
       call FlushChildHashtable(hts, GetHandleId(t))
       call PauseTimer(t)
       call ReleaseTimer(t)
       call ForGroup(g, function ClearSpiral)
       call TriggerSleepAction(1)
       call DestroyGroup(g)
    endif

   set t=null
 //  set h = null
 //  set hx = null
   set g=null
   set tg=null
endfunction

function Huracan_Actions takes nothing returns nothing
    local integer id= GetPlayerId(GetOwningPlayer(GetSpellAbilityUnit()))
    local real x= GetSpellTargetX()
    local real y= GetSpellTargetY()
    local unit h= CreateUnit(Player(id), 'n093', x, y, 270)
    local unit hx= CreateUnit(Player(id), 'n094', x, y, 270)
    local integer f= 0
    local timer t= null
    local group tg= CreateGroup()
    local group hg= CreateGroup()
    local integer c= 0

 set t=(NewTimerEx(0)) // INLINED!!
  call SaveInteger(hts, GetHandleId(t), 0, id)
  call SaveReal(hts, GetHandleId(t), 1, x)
  call SaveReal(hts, GetHandleId(t), 2, y)
  call SaveUnitHandle(hts, GetHandleId(t), 3, h)
  call SaveUnitHandle(hts, GetHandleId(t), 4, hx)
  call SaveGroupHandle(hts, GetHandleId(t), 5, tg)
  call SaveInteger(hts, GetHandleId(t), 6, c)
  call SaveGroupHandle(hts, GetHandleId(t), 7, hg)
  
  call TimerStart(t, 0.03, true, function Huracan)
    
    
            call SetUnitVertexColor(h, 255, 255, 255, 0)
            call SetUnitVertexColor(hx, 255, 255, 255, 0)
            
            loop
            exitwhen f > 255
                call TriggerSleepAction(0.03)
                call SetUnitVertexColor(h, 255, 255, 255, f)
                call SetUnitVertexColor(hx, 255, 255, 255, f)
                set f=f + 5
            endloop

 
            
   
set t=null
set tg=null
set h=null
set hx=null



endfunction

