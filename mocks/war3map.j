function Trig_slowthorns_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local real dspeed= GetUnitDefaultMoveSpeed(u)
local real nspeed= GetUnitMoveSpeed(u) - 32
        
        if nspeed < 0 then
        set nspeed=0
        endif

            call SetUnitMoveSpeed(u, nspeed)
            
            call TriggerSleepAction(5)
            
            set nspeed=GetUnitMoveSpeed(u) + 32
            
            if nspeed > dspeed then
            set nspeed=dspeed
            endif

            call SetUnitMoveSpeed(u, nspeed)
set u=null
endfunction

