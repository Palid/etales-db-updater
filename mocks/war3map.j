//Generated method caller for Board.create
function sc__Board_create takes nothing returns integer
    call TriggerEvaluate(st__Board_create)
 return f__result_integer
endfunction

//Generated method caller for Board.onDestroy
function sc__Board_onDestroy takes integer this returns nothing
        call DestroyMultiboard(s__Board_Board___bBoard[this])
        set s__Board_Board___bBoard[this]=null
endfunction

//Generated method caller for Board._getindex
function sc__Board__getindex takes integer this,integer column returns integer
    set f__arg_this=this
    set f__arg_integer1=column
    call TriggerEvaluate(st__Board__getindex)
 return f__result_integer
endfunction

//Generated method caller for Board._set_title
function sc__Board__set_title takes integer this,string value returns nothing
        call MultiboardSetTitleText(s__Board_Board___bBoard[this], value)
endfunction

//Generated allocator of Board
function s__Board__allocate takes nothing returns integer
 local integer this=si__Board_F
    if (this!=0) then
        set si__Board_F=si__Board_V[this]
    else
        set si__Board_I=si__Board_I+1
        set this=si__Board_I
    endif
    if (this>681) then
        return 0
    endif
    set s__Board_Board___bVisibleFor[this]=(this-1)*12
   set s__Board_Board___bColCount[this]= 0
   set s__Board_Board___bRowCount[this]= 0
    set si__Board_V[this]=-1
 return this
endfunction

//Generated destructor of Board
function sc__Board_deallocate takes integer this returns nothing
    if this==null then
        return
    elseif (si__Board_V[this]!=-1) then
        return
    endif
    set f__arg_this=this
    call TriggerEvaluate(st__Board_onDestroy)
    set si__Board_V[this]=si__Board_F
    set si__Board_F=this
endfunction

//Generated method caller for Board___ItemHelper._getindex
function sc__Board___ItemHelper__getindex takes integer this,integer row returns integer
    set f__arg_this=this
    set f__arg_integer1=row
    call TriggerEvaluate(st__Board___ItemHelper__getindex)
 return f__result_integer
endfunction

