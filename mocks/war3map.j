//===========================================================================
// Trigger: gd7
//
//      set udg_portal[0]= Location(-16959,4865)//Velhilmen
//      set udg_portal[1]= Location(-10561,6914)//lasthope
//      set udg_portal[2]= Location(446,-2816)//VAldivia
//      set udg_portal[3]= Location(-4351,-16191)//Undeadvalley
//      set udg_portal[4]= Location(4861,4676)//ekrom
//      set udg_portal[5]= Location(4285,-14143)//Colddream
//      set udg_portal[6]= Location(14720,-1800)//Hiddenlands
//         call SetUnitAcquireRange( gg_unit_n00B_0542, 100.00 )//guardian
//     call SetUnitAcquireRange( gg_unit_n02S_0543, 100.00 )//tidal lord
//     call SetUnitAcquireRange( gg_unit_n021_0544, 100.00 )//Ogrelord
//     call SetUnitAcquireRange( gg_unit_u002_0545, 100.00 )//Abomintion
//     call SetUnitAcquireRange( gg_unit_n02G_0546, 100.00 )//Golem
//     call SetUnitAcquireRange( gg_unit_n026_0547, 100.00 )//Satyr
//     call SetUnitAcquireRange( gg_unit_n00T_0548, 100.00 )//Lich
//===========================================================================
function Trig_gd7_Actions takes nothing returns nothing
local integer i= 0
    call AddSpecialEffectLocBJ(udg_tunnel[14], "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTo.mdl")
    call CreateDestructableLoc('OTsp', udg_tunnel[10], 270.00, 1, 0)
    call SetDestructableInvulnerableBJ(GetLastCreatedDestructable(), true)
    call DisableTrigger(gg_trg_puiq)
         
    call TriggerSleepAction(3.00)
    
    
    call EnableTrigger(gg_trg_pui)
    call EnableTrigger(gg_trg_puo)
    call EnableTrigger(gg_trg_poi)
    call EnableTrigger(gg_trg_poo)
    
    //call ShowUnit(  gg_unit_n00T_0548,true )

    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffcccc00MAIN QUEST COMPLETED|r")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffffcc00-THE WAY TO THE ORACLE:|r All players got |cffccff00Legendary Chest|r")
    call StartSound(bj_questCompletedSound)

    call QuestSetCompleted(udg_pt, true)
    loop
    exitwhen i > 8
      
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[81], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
     
    set i=i + 1
    
    endloop
    
    call DisableTrigger(GetTriggeringTrigger())
endfunction

