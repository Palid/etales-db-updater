function MakeEnemy takes player p1,player p2 returns nothing
 if ( p1 != p2 ) then
   call SetPlayerAlliance(p1, p2, ALLIANCE_PASSIVE, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_HELP_REQUEST, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_HELP_RESPONSE, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_XP, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_SPELLS, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_VISION, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_CONTROL, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_ADVANCED_CONTROL, false)
 endif
endfunction

function MakeAlly takes player p1,player p2 returns nothing
  if ( p1 != p2 ) then
   call SetPlayerAlliance(p1, p2, ALLIANCE_PASSIVE, true)
   call SetPlayerAlliance(p1, p2, ALLIANCE_HELP_REQUEST, true)
   call SetPlayerAlliance(p1, p2, ALLIANCE_HELP_RESPONSE, true)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_XP, true)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_SPELLS, true)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_VISION, true)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_CONTROL, false)
   call SetPlayerAlliance(p1, p2, ALLIANCE_SHARED_ADVANCED_CONTROL, false)
  endif
endfunction



function setaspect takes string aspect returns nothing
local integer i= 0
local integer j

loop
    exitwhen i > 8
    set j=i + 1
        loop
          exitwhen j > 8
    
        if ( udg_Faction[i] != 0 and udg_Faction[j] != 0 and udg_Faction[i] != udg_Faction[j] ) then
           if ( aspect == "enemy" ) then
             
             call MakeEnemy(Player(i) , Player(j))
             
           elseif ( aspect == "ally" ) then
           
             call MakeAlly(Player(i) , Player(j))
           endif
            
         endif
         set j=j + 1
        endloop
        
    set i=i + 1
endloop

endfunction

 function ClearEventForce takes nothing returns nothing
      call MakeAlly(Player(ClearPlayer) , GetEnumPlayer())
      call MakeAlly(GetEnumPlayer() , Player(ClearPlayer))
 endfunction

function AttachLeaderBoard takes nothing returns nothing
             set teamtag="[?] "
              if IsPlayerInForce(GetEnumPlayer(), teamA) == true then
                   set teamtag="|cffcd853f[V]|r "
               elseif IsPlayerInForce(GetEnumPlayer(), teamB) == true then
                   set teamtag="|cff6495ed[H]|r "
               endif
               
               set teamtag=teamtag + GetPlayerName(GetEnumPlayer())
    
    call PlayerSetLeaderboard(GetEnumPlayer(), clashlb)
    call LeaderboardAddItem(clashlb, teamtag, 0, GetEnumPlayer())
    
 endfunction

  function RemoveLeaderBoard takes nothing returns nothing
    call LeaderboardRemovePlayerItem(clashlb, GetEnumPlayer())
 endfunction
 
 function StartLeaderBoard takes nothing returns nothing
    local integer index= 0
    local integer size= 0
    set clashlb=CreateLeaderboard()
    set lb_tittle="|cffcd853fVillains|r " + I2S(teamAp) + "  |cffffcc00vs|r  " + I2S(teamBp) + " |cff6495edHeroes|r"
    call LeaderboardSetStyle(clashlb, true, true, true, true)
    call LeaderboardSetLabel(clashlb, lb_tittle)
    call LeaderboardAddItemBJ(Player(8), clashlb, "|cff0033ffHero. Titan (" + I2S(tlifereq) + ")|r", 0)
    call LeaderboardAddItemBJ(Player(9), clashlb, "|cffff3300Vill. Titan (" + I2S(tlifereq) + ")|r", 0)
    call LeaderboardAddItem(clashlb, "====Bonuses====", totalbns, Player(10))
 set size=LeaderboardGetItemCount(clashlb)
    call LeaderboardSetSizeByItemCount(clashlb, size)
    call ForForce(teamEventForce, function AttachLeaderBoard)
    if IsPlayerInForce(GetLocalPlayer(), teamEventForce) == true then
      call LeaderboardDisplay(clashlb, true)
    endif
 endfunction
 
 function UpdateLeaderBoard takes nothing returns nothing
    local integer size= LeaderboardGetItemCount(clashlb)
    set lb_tittle="|cffcd853fVillains|r " + I2S(teamAp) + "  |cffffcc00vs|r  " + I2S(teamBp) + " |cff6495edHeroes|r"
    call LeaderboardSetLabel(clashlb, lb_tittle)
    call LeaderboardSetSizeByItemCount(clashlb, size)
    if IsPlayerInForce(GetLocalPlayer(), teamEventForce) == true then
      call LeaderboardDisplay(clashlb, true)
    endif
 endfunction
 
 function StartBattle takes nothing returns nothing
  local integer Pid= 0
     set pinb=CountPlayersInForceBJ(teamEventForce)
     set InsetupBattle=false
     call TimerDialogDisplay(TeamTdialog, false)
     call DestroyTimerDialog(TeamTdialog)
     set TeamTdialog=null
     call ReleaseTimer(TeamTimer)
     set TeamTimer=null
     if pinb < 4 then
          set on_event=false
          set Vtitan=LoadUnitHandle(udg_cache, GetHandleId(teamA), 1)
          set Htitan=LoadUnitHandle(udg_cache, GetHandleId(teamB), 1)
          
          call ForceClear(teamA)
          call ForceClear(teamB)
          call DestroyGroup(diedheroes)
          set diedheroes=null
          
          loop
           exitwhen Pid > 7
             if IsPlayerInForce(Player(Pid), teamEventForce) == true then
               set ClearPlayer=Pid
               call EnableTrigger(natkp[Pid])
               call ForceRemovePlayer(teamEventForce, Player(Pid))
               call ForForce(teamEventForce, function ClearEventForce)
             endif
           set Pid=Pid + 1
           endloop
          
            set ClearPlayer=22
            set tlifereq=0
            set teamAp=0
            set teamBp=0
            set teamAc=0
            set teamBc=0
         
         if GetUnitState(Vtitan, UNIT_STATE_LIFE) > 1 then
           //  call SetUnitInvulnerable(Vtitan,false)
            // call UnitApplyTimedLife(Vtitan, 'BTLF',2)
            call RemoveUnit(Vtitan)
            set Vtitan=null
           endif
           if GetUnitState(Htitan, UNIT_STATE_LIFE) > 1 then
           //  call SetUnitInvulnerable(Htitan,false)
           //  call UnitApplyTimedLife(Htitan, 'BTLF',2)
            call RemoveUnit(Htitan)
            set Htitan=null
           endif
           
           if lanceralive == true then
            call PauseUnit(gg_unit_n06A_0475, false)
            call ShowUnit(gg_unit_n06A_0475, true)
           endif
          
           set Halive=false
           set Valive=false
           set HPHTleft=0
           set HPVTleft=0
          
          call StartSound(bj_questFailedSound)
          if IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) then
               call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 6, "Team battle cancelled due teams were not ready.")
           endif
           
     else

       call EnableTrigger(gg_trg_leftarea)
       call EnableTrigger(gg_trg_bonusdie)
       call StartLeaderBoard()
       call SetUnitInvulnerable(Vtitan, false)
       call SetUnitInvulnerable(Htitan, false)
       set EventRunning=true
       set TeamBonusUnit=null
       set totalbns=maxTeam * 4
       set titanlife=maxTeam * 2
       set Bnscnt=0
      
       call PlaySoundBJ(gg_snd_BattleBegins)
       call TriggerSleepAction(9)
       call PlaySoundBJ(gg_snd_Startbattle)
       
       
     endif
     
 endfunction
    
 function EndTeamEvent takes force lteam returns nothing
      local integer Pid= 0
      local string teaml
      local string teamw
  
     set pinb=CountPlayersInForceBJ(teamEventForce)
       if lteam == teamA then
         
            set teaml="|cffcd853fVillains|r "
            set teamw="|cff6495edHeroes|r "
       elseif lteam == teamB then
           set teaml="|cff6495edHeroes|r "
           set teamw="|cffcd853fVillains|r "
          
       endif
  
  call PlaySoundBJ(gg_snd_Newedict)
   
  set on_event=false
          set Vtitan=LoadUnitHandle(udg_cache, GetHandleId(teamA), 1)
          set Htitan=LoadUnitHandle(udg_cache, GetHandleId(teamB), 1)
          call ForceClear(teamA)
          call ForceClear(teamB)
          call DestroyGroup(diedheroes)
          set diedheroes=null
          loop
           exitwhen Pid > 7
             if IsPlayerInForce(Player(Pid), bj_FORCE_ALL_PLAYERS) then
                 call DisplayTimedTextToPlayer(Player(Pid), 0, 0, 16, "Team battle is over. " + teamw + " won the match against " + teaml)
            endif
             if IsPlayerInForce(Player(Pid), teamEventForce) == true then
               set ClearPlayer=Pid
               call EnableTrigger(natkp[Pid])
               call ForceRemovePlayer(teamEventForce, Player(Pid))
               call ForForce(teamEventForce, function ClearEventForce)
             endif
           set Pid=Pid + 1
           endloop
          
            set ClearPlayer=22
            set tlifereq=0
            set teamAp=0
            set teamBp=0
            set teamAc=0
            set teamBc=0
          
            call DisableTrigger(gg_trg_bonusdie)
          
