  function Getkey takes integer id returns integer
  
  if ( id == 665 or id == 561 or id == 600 or id == 548 or id == 574 or id == 587 or id == 470 or id == 418 or id == 483 or id == 444 or id == 457 or id == 431 or id == 678 or id == 496 or id == 379 or id == 327 or id == 353 or id == 314 or id == 366 or id == 301 or id == 340 or id == 626 or id == 652 or id == 639 or id == 613 or id == 522 or id == 509 or id == 535 or id == 405 or id == 392 ) then
    return GetRandomInt(id, id + 12)
  elseif ( id == 1000 ) then
   return frag()
elseif ( id == 1100 ) then
   return gema()
endif
    return id
   endfunction
  
  
  function SetUnitDrop takes integer typeId,integer fir,integer sec,integer thi,integer fur,integer fiv,integer six,integer sev,integer eig returns nothing
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], MEDIO_DROP, ( fir)) // INLINED!!
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], TERCIO_DROP, ( sec)) // INLINED!!
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], CUARTO_DROP, ( thi)) // INLINED!!
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], QUINTO_DROP, ( fur)) // INLINED!!
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], DECIMO_DROP, ( fiv)) // INLINED!!
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], CINCO_DROP, ( six)) // INLINED!!
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], UNO_DROP, ( sev)) // INLINED!!
  call SaveInteger(HTcreep, udg_CreepType[(typeId )], MINIMO_DROP, ( eig)) // INLINED!!
  endfunction
  
  function IsHeroNear takes integer r returns boolean
  local integer i= 0
  local boolean si= false
   loop
    exitwhen i > 11
    if ( IsUnitInRegion(creep__regions[r], udg_PHero[i]) ) then
    set si=true
    //call SaveInteger(questtm,GetHandleId(udg_PHero[i]),)
    endif
    set i=i + 1
   endloop
  return si
  endfunction
  
  function SetupRectTimer takes timer t returns nothing
   if t == G_easy_tmr then
     set CurrentRectE=CurrentRectE + 1
     if CurrentRectE > 199 then
      set CurrentRectE=0
     endif
     
     call SaveInteger(HTcreep, GetHandleId(t), 0, CurrentRectE)
elseif t == G_normal_tmr then
      set CurrentRectN=CurrentRectN + 1
     if CurrentRectN > 199 then
      set CurrentRectN=0
     endif

     call SaveInteger(HTcreep, GetHandleId(t), 0, CurrentRectN)
elseif t == G_hard_tmr then
      set CurrentRectH=CurrentRectH + 1
     if CurrentRectH > 199 then
      set CurrentRectH=0
     endif
     call SaveInteger(HTcreep, GetHandleId(t), 0, CurrentRectH)
elseif t == G_vhard_tmr then

      set CurrentRectV=CurrentRectV + 1
     if CurrentRectV > 199 then
      set CurrentRectV=0
     endif
     call SaveInteger(HTcreep, GetHandleId(t), 0, CurrentRectV)
  endif
  endfunction
  
  function IsRectEmpty takes integer nrect returns boolean
    return creep__regions[nrect] == null
 endfunction
  
  function CreateEasySpawn takes nothing returns nothing
   // local timer t = GetExpiredTimer()
    local integer Crrect= LoadInteger(HTcreep, GetHandleId(GetExpiredTimer()), 0)
    local integer nrect= IdRectE[Crrect]
    local integer nplayer= IdPlayerRect[Crrect]
   // local integer nrect = LoadInteger(HTcreep,GetHandleId(t),0)
   // local integer nplayer = LoadInteger(HTcreep,GetHandleId(t),1)
    local integer i= 1
    local integer maxloc= LoadInteger(HTcreep, GetHandleId(rects[nrect]), EASY_SLOT)
    local integer maxunit= LoadInteger(HTcreep, GetHandleId(rects[nrect]), EASY_UNIT_SLOT)
    local integer unitslot= 0
    local integer unitId= 0
   // local unit ant = null
   // local unit u1 = null
    local integer unitdata= 0
    //local integer c = 0
    
    set etmr=GetExpiredTimer()
    
    if (creep__regions[(nrect)] == null) == true then // INLINED!!
    call SetupRectTimer(etmr)
    set etmr=null
  //  set u1e = null
 //   set ante = null
 
      return
    endif
    
   if ( IsHeroNear(nrect) == false ) then

         loop
            exitwhen i > maxloc
         
            //call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"Current Easy unit slot in rect " + I2S(nrect) + " :" + I2S(maxunit))
            set creep__eloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
            set ante=LoadUnitHandle(HTcreep, GetHandleId(creep__eloc), 0)
         
           if ( GetWidgetLife(ante) > 0.405 ) then
            set unitdata=GetUnitUserData(ante)
         
                if unitdata > 5 then
                    call SetUnitUserData(ante, 7)
                 
                   call UnitApplyTimedLife(ante, 'BTLF', 5)
                  // call FlushChildHashtable(AiHash,GetHandleId(ante))
                   // call KillUnit(ante)
                else
                    call SetUnitUserData(ante, unitdata + 1)
                endif
            set unitdata=0
           endif
            set i=i + 1
           
            set ante=null
          //  set target = null
            set creep__eloc=null
            endloop
        call SetupRectTimer(etmr)
        set etmr=null
       // set u1e = null
      //  set ante = null
 
        return
   endif
    

    
    
     if ( IsActiveRect[nrect] < 1 ) then
    
     loop
       exitwhen i > maxloc
    
          set unitslot=GetRandomInt(EASY_UNIT_SLOT, maxunit) + 1
    //  call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"Current Easy unit slot in rect " + I2S(nrect) + " :" + I2S(maxunit))
          set creep__eloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
          set ante=LoadUnitHandle(HTcreep, GetHandleId(creep__eloc), 0)
        if ( GetWidgetLife(ante) <= 0.405 ) then
         set ante=null
         call FlushChildHashtable(HTcreep, GetHandleId(creep__eloc))

          set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
          set u1e=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__eloc, GetRandomReal(0, 360))
          call enabledmg(u1e)
          
          if nrect < 118 then
          call SetUnitAcquireRange(u1e, 180)
          endif
         // call SaveLocationHandle(HTcreep,GetHandleId(u1),0,eloc)
          call SaveUnitHandle(HTcreep, GetHandleId(creep__eloc), 0, u1e)
          set u1e=null
          else
          set ante=null
          set creep__eloc=null
        endif
                   
        set i=i + 1
     
     
        
        endloop
       
      set IsActiveRect[nrect]=1
      else
     loop
        exitwhen i > maxloc
          set unitslot=GetRandomInt(EASY_UNIT_SLOT, maxunit) + 1
          //call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"Current Easy unit slot in rect " + I2S(nrect) + " :" + I2S(maxunit))
          set creep__eloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
         set ante=LoadUnitHandle(HTcreep, GetHandleId(creep__eloc), 0)
          
        if ( GetWidgetLife(ante) <= 0.405 ) then
         set ante=null
         call FlushChildHashtable(HTcreep, GetHandleId(creep__eloc))

         set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
         set u1e=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__eloc, GetRandomReal(0, 360))
         call enabledmg(u1e)
         if nrect < 118 then
           call SetUnitAcquireRange(u1e, 180)
         endif
       //  call SaveLocationHandle(HTcreep,GetHandleId(u1),0,eloc)
         call SaveUnitHandle(HTcreep, GetHandleId(creep__eloc), 0, u1e)
         set u1e=null
        else
         set ante=null
         set creep__target=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), GetRandomInt(1, maxloc))
         set u1e=LoadUnitHandle(HTcreep, GetHandleId(creep__eloc), 0)
         if GetRandomInt(1, 6) == 3 then
           call IssuePointOrderLoc(u1e, "attack", creep__target)
         endif
         set u1e=null
         set creep__target=null
        endif
                   
       set i=i + 1

       set creep__eloc=null
      endloop
    endif
     call SetupRectTimer(etmr)
    set etmr=null
  // set u1e = null  
 //  set ante = null
   endfunction
   

   
 function CreateNormalSpawn takes nothing returns nothing
  // local timer t = GetExpiredTimer()
   local integer Crrect= LoadInteger(HTcreep, GetHandleId(GetExpiredTimer()), 0)
    local integer nrect= IdRectN[Crrect]
    local integer nplayer= IdPlayerRect[Crrect]
    local integer i= 21
    local integer maxloc= LoadInteger(HTcreep, GetHandleId(rects[nrect]), NORM_SLOT)
    local integer maxunit= LoadInteger(HTcreep, GetHandleId(rects[nrect]), NORM_UNIT_SLOT)
    local integer unitslot= 0
    local integer unitId
     local integer unitdata= 0
   // local unit u1 = null
   // local unit ant = null
  //  local integer c = 0
    set ntmr=GetExpiredTimer()
    
       if (creep__regions[(nrect)] == null) == true then // INLINED!!
    call SetupRectTimer(ntmr)
    set ntmr=null
   // set u1n = null
   // set antn = null
 
      return
    endif
    
      if ( IsHeroNear(nrect) == false ) then

         loop
            exitwhen i > maxloc
         
            //call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"Current Easy unit slot in rect " + I2S(nrect) + " :" + I2S(maxunit))
            set creep__nloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
            set antn=LoadUnitHandle(HTcreep, GetHandleId(creep__nloc), 0)
         
           if ( GetWidgetLife(antn) > 0.405 ) then
            set unitdata=GetUnitUserData(antn)
         
                if unitdata > 1 then
                    call SetUnitUserData(antn, 7)
                    call UnitApplyTimedLife(antn, 'BTLF', 7)
                   // call FlushChildHashtable(AiHash,GetHandleId(antn))
                else
                    call SetUnitUserData(antn, unitdata + 1)
                endif
            set unitdata=0
           endif
           
            set i=i + 1
          
            set antn=null
          //  set target = null
            set creep__nloc=null
            endloop
   
         call SetupRectTimer(ntmr)
        set ntmr=null
       // set u1n = null
      //  set antn = null
 
        return
   endif
     


    
   
     if ( IsActiveRect[nrect] < 1 ) then
    
     loop
       exitwhen i > maxloc
    
          set unitslot=NORM_UNIT_SLOT + GetRandomInt(1, ( maxunit - NORM_UNIT_SLOT ))
          set creep__nloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
          set antn=LoadUnitHandle(HTcreep, GetHandleId(creep__nloc), 0)
        if ( GetWidgetLife(antn) <= 0.405 ) then
        set antn=null
           call FlushChildHashtable(HTcreep, GetHandleId(creep__nloc))
         
          set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
          set u1n=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__nloc, GetRandomReal(0, 360))
          call enabledmg(u1n)
          
          if nrect < 118 then
            call SetUnitAcquireRange(u1n, 180)
            endif
      //    call SaveLocationHandle(HTcreep,GetHandleId(u1n),0,nloc)
          call SaveUnitHandle(HTcreep, GetHandleId(creep__nloc), 0, u1n)
          set u1n=null
          else
          set antn=null
        endif
                   
        set i=i + 1
        set creep__nloc=null
       // set u1n = null
       // set antn = null
        endloop
       
      set IsActiveRect[nrect]=1
      else
     loop
        exitwhen i > maxloc
          set unitslot=GetRandomInt(1, ( maxunit - NORM_UNIT_SLOT ))
          set unitslot=unitslot + NORM_UNIT_SLOT
          set creep__nloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
          set antn=LoadUnitHandle(HTcreep, GetHandleId(creep__nloc), 0)
        if ( GetWidgetLife(antn) <= 0.405 ) then
         set antn=null
         call FlushChildHashtable(HTcreep, GetHandleId(creep__nloc))

         set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
         set u1n=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__nloc, GetRandomReal(0, 360))
         call enabledmg(u1n)
          if nrect < 118 then
            call SetUnitAcquireRange(u1n, 180)
            endif
      //   call SaveLocationHandle(HTcreep,GetHandleId(u1n),0,nloc)
         call SaveUnitHandle(HTcreep, GetHandleId(creep__nloc), 0, u1n)
         set u1n=null
  
        else
         set antn=null
         set creep__target=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), GetRandomInt(1, maxloc))
         set u1n=LoadUnitHandle(HTcreep, GetHandleId(creep__nloc), 0)
         if GetRandomInt(1, 5) == 3 then
             call IssuePointOrderLoc(u1n, "attack", creep__target)
          endif
           set creep__target=null
           set u1n=null
        endif
                   
       set i=i + 1
      
     //  set antn = null
      // set u1n = null  
       set creep__nloc=null
      endloop
    endif
    call SetupRectTimer(ntmr)
    set ntmr=null
   // set u1n = null
   // set antn = null
endfunction
 
 function CreateHardSpawn takes nothing returns nothing
  // local timer t = GetExpiredTimer()
   local integer Crrect= LoadInteger(HTcreep, GetHandleId(GetExpiredTimer()), 0)
   local integer nrect= IdRectH[Crrect]
   local integer nplayer= IdPlayerRect[Crrect]
   
   // local integer nrect = LoadInteger(HTcreep,GetHandleId(t),0)
  // local integer nplayer = LoadInteger(HTcreep,GetHandleId(t),1)
    local integer i= 41
    local integer maxloc= LoadInteger(HTcreep, GetHandleId(rects[nrect]), HARD_SLOT)
    local integer maxunit= LoadInteger(HTcreep, GetHandleId(rects[nrect]), HARD_UNIT_SLOT)
    local integer unitslot
    local integer unitId
    local integer unitdata= 0
   // local unit u1 = null
  //  local unit ant = null
  //  local integer c = 0 
    set htmr=GetExpiredTimer()
    
    
 if (creep__regions[(nrect)] == null) == true then // INLINED!!
    call SetupRectTimer(htmr)
    set htmr=null
   // set u1h = null
   /// set anth = null
 
      return
    endif
    
    if ( IsHeroNear(nrect) == false ) then

         loop
            exitwhen i > maxloc
         
            //call DisplayTimedTextToPlayer(Player(0),.75,.2,2,"Current Easy unit slot in rect " + I2S(nrect) + " :" + I2S(maxunit))
            set creep__hloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
            set anth=LoadUnitHandle(HTcreep, GetHandleId(creep__hloc), 0)
         
           if ( GetUnitState(anth, UNIT_STATE_LIFE) > 0.405 ) then
                set unitdata=GetUnitUserData(anth)
         
                    if unitdata > 0 then
                        call SetUnitUserData(anth, 7)
                         call UnitApplyTimedLife(anth, 'BTLF', 7)
                        // call FlushChildHashtable(AiHash,GetHandleId(anth))
                       // call KillUnit(anth)
                    else
                        call SetUnitUserData(anth, unitdata + 1)
                    endif
                set unitdata=0
            endif
            
            set i=i + 1
           
            set anth=null
           // set target = null
            set creep__hloc=null
            endloop
        call SetupRectTimer(htmr)
        set htmr=null
      //  set u1h = null
      //  set anth = null
 
        return
   endif
     
 
     if ( IsActiveRect[nrect] < 1 ) then
 
     loop
       exitwhen i > maxloc
    
          set unitslot=HARD_UNIT_SLOT + GetRandomInt(1, ( maxunit - HARD_UNIT_SLOT ))
          set creep__hloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
          set anth=LoadUnitHandle(HTcreep, GetHandleId(creep__hloc), 0)
        if ( GetWidgetLife(anth) <= 0.405 ) then
        set anth=null
          call FlushChildHashtable(HTcreep, GetHandleId(creep__hloc))
        
          set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
           set u1h=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__hloc, GetRandomReal(0, 360))
           call enabledmg(u1h)
           if nrect < 118 then
             call SetUnitAcquireRange(u1h, 180)
             endif
         //  call SaveLocationHandle(HTcreep,GetHandleId(u1),0,hloc)
           call SaveUnitHandle(HTcreep, GetHandleId(creep__hloc), 0, u1h)
              set u1h=null
         else
         set anth=null
        endif
                   
        set i=i + 1
        set creep__hloc=null
     
       // set anth = null
        endloop
       
       set IsActiveRect[nrect]=1
      else
     loop
        exitwhen i > maxloc
          set unitslot=GetRandomInt(1, ( maxunit - HARD_UNIT_SLOT ))
          set unitslot=unitslot + HARD_UNIT_SLOT
          set creep__hloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
          set anth=LoadUnitHandle(HTcreep, GetHandleId(creep__hloc), 0)

        if ( GetWidgetLife(anth) <= 0.405 ) then
         set anth=null
         call FlushChildHashtable(HTcreep, GetHandleId(creep__hloc))
       
         set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
         set u1h=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__hloc, GetRandomReal(0, 360))
         call enabledmg(u1h)
         if nrect < 118 then
            call SetUnitAcquireRange(u1h, 180)
            endif
       //  call SaveLocationHandle(HTcreep,GetHandleId(u1),0,hloc)
         call SaveUnitHandle(HTcreep, GetHandleId(creep__hloc), 0, u1h)
         set u1h=null
       
        else
         set anth=null
         set creep__target=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), GetRandomInt(1, maxloc))
         set u1h=LoadUnitHandle(HTcreep, GetHandleId(creep__hloc), 0)
         if GetRandomInt(1, 3) == 3 then
           call IssuePointOrderLoc(u1h, "attack", creep__target)
         endif
          set creep__target=null
          set u1h=null
        endif
                   
       set i=i + 1
      // set u1h = null   
     //  set anth = null
       set creep__hloc=null
      endloop
    endif
     call SetupRectTimer(htmr)
    set htmr=null
  //  set u1h = null
  ///  set anth = null
 
 endfunction
  
  function CreateVhardSpawn takes nothing returns nothing
   // local timer t = GetExpiredTimer()
    local integer Crrect= LoadInteger(HTcreep, GetHandleId(GetExpiredTimer()), 0)
    local integer nrect= IdRectV[Crrect]
    local integer nplayer= IdPlayerRect[Crrect]
  //  local integer nrect = LoadInteger(HTcreep,GetHandleId(t),0)
 //  local integer nplayer = LoadInteger(HTcreep,GetHandleId(t),1)
    local integer i= 61
    local integer maxloc= LoadInteger(HTcreep, GetHandleId(rects[nrect]), VHRD_SLOT)
    local integer maxunit= LoadInteger(HTcreep, GetHandleId(rects[nrect]), VHRD_UNIT_SLOT)
    local integer unitslot
    local integer unitId
  //  local unit u1 = null
  //  local unit ant = null
  //  local integer c = 0
    set vtmr=GetExpiredTimer()
    
   if (creep__regions[(nrect)] == null) == true then // INLINED!!
    call SetupRectTimer(vtmr)
    set vtmr=null
  //  set u1v = null
  //  set antv = null
 
      return
    endif
      
   if ( IsHeroNear(nrect) == false ) then
   
     call SetupRectTimer(vtmr)
    set vtmr=null
  //  set u1v = null
  //  set antv = null
    return
   endif
    
   
     if ( IsActiveRect[nrect] < 1 ) then
    
     loop
       exitwhen i > maxloc
    
        set unitslot=VHRD_UNIT_SLOT + GetRandomInt(1, ( maxunit - VHRD_UNIT_SLOT ))
          set creep__vloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
          set antv=LoadUnitHandle(HTcreep, GetHandleId(creep__vloc), 0)
        if ( GetUnitState(antv, UNIT_STATE_LIFE) <= 0.405 ) then
        set antv=null
           call FlushChildHashtable(HTcreep, GetHandleId(creep__vloc))
        
      
         set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
         set u1v=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__vloc, GetRandomReal(0, 360))
         call enabledmg(u1v)
      //   call SaveLocationHandle(HTcreep,GetHandleId(u1v),0,vloc)
         call SaveUnitHandle(HTcreep, GetHandleId(creep__vloc), 0, u1v)
         set u1v=null
         else
           set antv=null
        endif
        set i=i + 1
      //  set u1v = null 
      //  set antv = null
        set creep__vloc=null
        endloop
       
      set IsActiveRect[nrect]=1
      else
     loop
        exitwhen i > maxloc
        
         set unitslot=GetRandomInt(1, ( maxunit - VHRD_UNIT_SLOT ))
         set unitslot=unitslot + VHRD_UNIT_SLOT
         
          set creep__vloc=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), i)
          set antv=LoadUnitHandle(HTcreep, GetHandleId(creep__vloc), 0)
        if ( GetUnitState(antv, UNIT_STATE_LIFE) <= 0.405 ) then
          set antv=null
            call FlushChildHashtable(HTcreep, GetHandleId(creep__vloc))
    
         set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
         set u1v=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], creep__vloc, GetRandomReal(0, 360))
         call enabledmg(u1v)
     //    call SaveLocationHandle(HTcreep,GetHandleId(u1v),0,vloc)
         call SaveUnitHandle(HTcreep, GetHandleId(creep__vloc), 0, u1v)
         set u1v=null
        else
          set antv=null
         set creep__target=LoadLocationHandle(HTcreep, GetHandleId(rects[nrect]), GetRandomInt(1, maxloc))
         set u1v=LoadUnitHandle(HTcreep, GetHandleId(creep__vloc), 0)
         if GetRandomInt(1, 3) == 3 then
         call IssuePointOrderLoc(u1v, "attack", creep__target)
         endif
         set u1v=null
          set creep__target=null
        endif
                   
       set i=i + 1
   //    set u1v = null       
     //  set antv = null
     //
       set creep__vloc=null
      endloop
    endif
    call SetupRectTimer(vtmr)
    set vtmr=null
   // set u1v = null
  //  set antv = null
  
  endfunction

  function AddRect takes nothing returns nothing
  
  local integer nrect= LoadInteger(questtm, GetHandleId(agents), 2)
  call SaveInteger(questtm, GetHandleId(GetEnumUnit()), StringHash("nrect"), nrect)
  
  endfunction
  
 function strue takes nothing returns boolean
  return true
  endfunction
 
 function StartSpawnArea takes integer nrect,integer nplayer returns nothing
 
  local boolexpr addagent= Condition(function strue)
 
 //  local timer e = NewTimer()
 //  local timer n = NewTimer()
//   local timer h = NewTimer()
//  local timer v = NewTimer()
 
   set IdPlayerRect[CurrentRect]=nplayer
   set IdRectE[CurrentRect]=nrect
   set IdRectN[CurrentRect]=nrect
   set IdRectH[CurrentRect]=nrect
   set IdRectV[CurrentRect]=nrect
   set IsActiveRect[nrect]=0
  
   set SpawnRectId[nrect]=CurrentRect
   
   
   
   
  set CurrentRect=CurrentRect + 1
  
  set agents=CreateGroup()
  call GroupEnumUnitsInRect(agents, rects[nrect], addagent)
  call DestroyBoolExpr(addagent)
  set addagent=null
  call SaveInteger(questtm, GetHandleId(agents), 2, nrect)
  call ForGroup(agents, function AddRect)
  call TriggerSleepAction(0.02)
  call FlushChildHashtable(questtm, GetHandleId(agents))
  call DestroyGroup(agents)
  set agents=null
 
 endfunction
 
 

  
function get66 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) > 660 )
endfunction

function get50 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) > 500 )
endfunction

function get33 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 333 )
endfunction

function get25 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 250 )
endfunction

function get20 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 200 )
endfunction

function get15 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 150 )
endfunction

function get10 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 100 )
endfunction

function get07 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 70 )
endfunction

function get05 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 50 )
endfunction

function get03 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 30 )
endfunction

function get01 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 10 )
endfunction

function get005 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) < 5 )
endfunction

function get001 takes nothing returns boolean
 return ( GetRandomInt(0, creep__MAX_RATE) == 1 )
endfunction

function SetRegions takes integer n returns nothing
local integer i= 1
   loop
    exitwhen i > n
     set creep__regions[i]=CreateRegion()
     call RegionAddRect(creep__regions[i], rects[i])
   set i=i + 1
endloop

endfunction
  
