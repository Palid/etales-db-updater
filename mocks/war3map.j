    set gg_trg_ScopionSpawn=CreateTrigger()
    call TriggerRegisterTimerEvent(gg_trg_ScopionSpawn, 1.00, true)
    call TriggerAddCondition(gg_trg_ScopionSpawn, Condition(function Trig_ScopionSpawn_Conditions))
