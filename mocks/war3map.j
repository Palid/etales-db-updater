constant real DEXP__RADIUS= 650.
constant real DEXP__CLOSE= 200.
constant real DEXP__MEDIUM= 400.
constant real DEXP__FAR= 650.
  //Should probably be the same as Radius.
constant real DEXP__CLOSE_FACTOR= 1.
constant real DEXP__MEDIUM_FACTOR= .5
constant real DEXP__FAR_FACTOR= .25
  
constant integer DEXP__UNIT_EXP= 10 //10 
