    set gg_trg_Destscroll=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Destscroll, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Destscroll, Condition(function Trig_Destscroll_Conditions))
    call TriggerAddAction(gg_trg_Destscroll, function destscrolla)
