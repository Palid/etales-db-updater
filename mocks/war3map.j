    function NumberEncrypter__GetPlayerBase takes integer base,integer pid returns integer
        local string b
        local integer i
        if ( not (HaveSavedInteger(Table__ht, (NumberEncrypter__bases[pid]), (base))) ) then // INLINED!!
            set b=(Base__b[(base)]) // INLINED!!
            set i=s__BigInt_convertString((Base__b[(base)]) , s__Base__staticgetindex(SubString(b, 1, 2) + SubString(b, 0, 1) + SubString(b, 2, (Base__s[(base)])))) // INLINED!!
            call Scramble(i , pid , 3 , (BigInt__b[(i)]) , true) // INLINED!!
            call SaveInteger(Table__ht, (NumberEncrypter__bases[pid]), (base), ( s__Base__staticgetindex(s__BigInt_toString(i)))) // INLINED!!
            call s__BigInt_destroy(i)
        endif
        return (LoadInteger(Table__ht, (NumberEncrypter__bases[pid]), (base))) // INLINED!!
    endfunction
    function NumberEncrypter__GetPlayerChecksum takes integer checksum,integer pid,string playerSalt,real variance returns integer
        local integer ch
        local integer min
        local integer range
        set checksum=checksum + 1
        if ( not (HaveSavedInteger(Table__ht, (NumberEncrypter__checksums[pid]), (checksum))) ) then // INLINED!!
            set ch=StringHash(StringCase(NumberEncrypter__names[pid] + playerSalt, false))
            if ( 0 > ch ) then
                set ch=- ch
            endif
            set min=R2I(checksum * variance)
            set range=checksum - min
            set ch=ch - ch / range * range + min
            call SaveInteger(Table__ht, (NumberEncrypter__checksums[pid]), (checksum), ( ch)) // INLINED!!
            return ch
        endif
        return (LoadInteger(Table__ht, (NumberEncrypter__checksums[pid]), (checksum))) // INLINED!!
    endfunction
    
    function EncryptNumberVersion takes integer number,integer security,integer shuffles,integer forPlayerId,string playerSalt,real checksumVariance,integer maxVersion,integer ver returns string
        local integer s
        set security=NumberEncrypter__GetPlayerChecksum(security , forPlayerId , playerSalt , checksumVariance) //get player unique security
        call s__BigInt__set_base(number,NumberEncrypter__GetPlayerBase((BigInt__b[(number)]) , forPlayerId)) //get player unique base // INLINED!!
        
        //apply security
        set s=GetKnuthChecksum(number , security)
        call s__BigInt_multiply(number,security + maxVersion)
        call s__BigInt_add(number,s + ver , 0)
        
        //apply player unique shuffle
        call Shuffle(number , forPlayerId , shuffles)
        
        //return number as string
        return s__BigInt_toString(number)
    endfunction
    
    function EncryptNumber takes integer number,integer security,integer shuffles,integer forPlayerId,string playerSalt,real checksumVariance returns string
        local integer s
        set security=NumberEncrypter__GetPlayerChecksum(security , forPlayerId , playerSalt , checksumVariance) //get player unique security
        call s__BigInt__set_base(number,NumberEncrypter__GetPlayerBase((BigInt__b[(number)]) , forPlayerId)) //get player unique base // INLINED!!
        
        //apply security
        set s=GetKnuthChecksum(number , security)
        call s__BigInt_multiply(number,security)
        call s__BigInt_add(number,s , 0)
        
        //apply player unique shuffle
        call Shuffle(number , forPlayerId , shuffles)
        
        //return number as string
        return s__BigInt_toString(number)
    endfunction
    function GetLastDecryptedVersion takes nothing returns integer
        return NumberEncrypter__v
    endfunction
    function DecryptNumberVersion takes string c,integer base,integer security,integer shuffles,integer forPlayerId,string playerSalt,real checksumVariance,integer maxVersion returns integer
        //convert to BigInt using player unique base
        local integer number= s__BigInt_convertString(c , NumberEncrypter__GetPlayerBase(base , forPlayerId))
        
        //if converted
        if ( 0 != number ) then
            //retrieve player unique security
            set security=NumberEncrypter__GetPlayerChecksum(security , forPlayerId , playerSalt , checksumVariance)
            
            //remove player unique shuffle
            call Unshuffle(number , forPlayerId , shuffles)
            
            //retrieve version out of checksum
            set NumberEncrypter__v=s__BigInt_divide(number,security + maxVersion) - GetKnuthChecksum(number , security)
            
            //if version is out of bounds, return 0
            if ( NumberEncrypter__v < 1 or NumberEncrypter__v > maxVersion ) then
                call s__BigInt_destroy(number)
                set NumberEncrypter__v=0
                return 0
            endif
            
        endif
        return number
    endfunction
    function DecryptNumber takes string c,integer base,integer security,integer shuffles,integer forPlayerId,string playerSalt,real checksumVariance returns integer
        //convert to BigInt using player unique base
        local integer number= s__BigInt_convertString(c , NumberEncrypter__GetPlayerBase(base , forPlayerId))
        
        //if converted
        if ( 0 != number ) then
            //retrieve player unique security
            set security=NumberEncrypter__GetPlayerChecksum(security , forPlayerId , playerSalt , checksumVariance)
            
            //remove player unique shuffle
            call Unshuffle(number , forPlayerId , shuffles)
            
            //if security doesn't match up, return 0
            if ( s__BigInt_divide(number,security) != GetKnuthChecksum(number , security) ) then
                call s__BigInt_destroy(number)
                return 0
            endif
            
        endif
        return number
    endfunction
