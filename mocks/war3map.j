function Trig_Endurancecast_Actions takes nothing returns nothing
 local unit u= GetSpellAbilityUnit()
 local integer Id= GetPlayerId(GetOwningPlayer(u))
  if IsUnitInGroup(u, Endurancegroup) == false then
    call GroupAddUnit(Endurancegroup, u)
    call TriggerRegisterUnitEvent(EnduranceTrg[Id], u, EVENT_UNIT_DAMAGED)
  endif
 
 
 call EnableTrigger(EnduranceTrg[Id])
 set EnduranceSfxA[Id]=AddSpecialEffectTarget("Abilities\\Spells\\Human\\DivineShield\\DivineShieldTarget.mdl", u, "overhead")
 
 
 call TriggerSleepAction(20)
 call DisableTrigger(EnduranceTrg[Id])
 call DestroyEffect(EnduranceSfxA[Id])
 set EnduranceSfxA[Id]=null
 call DestroyEffect(EnduranceSfxB[Id])
 set EnduranceSfxB[Id]=null
 

 set u=null
endfunction

