function Trig_ScopionSpawn_Conditions takes nothing returns boolean
 return Scorpionevent1 > 3 and ScorpionSwp == false and ScorpionTg == false and ScorpionRd == false
endfunction

function attackScm takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= GetUnitX(u) + GetRandomReal(- 255, 255)
local real y= GetUnitY(u) + GetRandomReal(- 255, 255)

 call IssuePointOrder(u, "attack", x, y)

 call FlushChildHashtable(hts, GetHandleId(t))
 call PauseTimer(t)
 call ReleaseTimer(t)
 
 set t=null
 set u=null

endfunction

function SpawnScorpMinion takes real x,real y,unit u returns nothing
local real tx= GetRandomReal(x - 180, x + 180)
local real ty= GetRandomReal(y - 180, y + 180)
local real sx= GetRandomReal(x - 120, x + 120)
local real sy= GetRandomReal(y - 120, y + 120)
local real ux= 0
local real uy= 0
local real face= GetUnitFacing(u) + GetRandomReal(- 50, 50)

local boolean create= GetRandomInt(0, 80) == 12
local unit spawn= null
local timer t= null

    if GetRandomInt(0, 2) == 1 then
     call DestroyEffect(AddSpecialEffect(terranfx, tx, ty))
    else
     call DestroyEffect(AddSpecialEffect(sffectdusta, tx, ty))
    endif
     
     if create == true then
       
       set spawn=CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), 'n083', sx, sy, GetRandomReal(0, 359)) //red stinger
       call SetUnitAnimationByIndex(spawn, 11)
        set t=(NewTimerEx(0)) // INLINED!!
       call SaveUnitHandle(hts, GetHandleId(t), 1, spawn)
       call TimerStart(t, 1.1, false, function attackScm)
       
     endif
     
     set ux=x + 15 * Cos(face * bj_DEGTORAD)
	 set uy=y + 15 * Sin(face * bj_DEGTORAD)
     
    // set ux = GetRandomReal(x-520,x+520)
    // set uy = GetRandomReal(y-520,y+520)
     
     call IssuePointOrder(u, "move", ux, uy)
 
 set spawn=null
 
 if not ( t == null ) then
    set t=null
 endif
 
endfunction


function ScSpCycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local integer maxh= LoadInteger(hts, GetHandleId(t), 4)
local unit d= LoadUnitHandle(hts, GetHandleId(t), 6)
local unit a= LoadUnitHandle(hts, GetHandleId(t), 7)
local real x= GetUnitX(d)
local real y= GetUnitY(d)



 if IsPointInRegion(scorpArea, x, y) then
 
    call SpawnScorpMinion(x , y , d)
    
 endif
 
 set maxh=maxh + 1
 call SaveInteger(hts, GetHandleId(t), 4, maxh)
 
 if maxh > 300 then
  //call SetUnitFlyHeight( a, 0, 0 ) 
  call SetUnitPathing(a, true)
  call SetUnitPosition(a, x, y)
  call SetUnitAnimationByIndex(a, 11)
  call ShowUnit(a, true)
  call PauseUnit(a, false)
  call UnitApplyTimedLife(d, 'BTLF', 1)
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  set ScorpionTg=false
  call SaveInteger(AiHash, GetHandleId(ScorpionEng), 2, 64) //triggers Scorpion jump
 

 endif
set a=null
set d=null
set t=null

endfunction


function Trig_ScopionSpawn_Actions takes nothing returns nothing
 local unit B= gg_unit_U00O_0266
 local unit D= null
 local integer maxh= 1
 local timer t= (NewTimerEx(0)) // INLINED!!
 local real x= 0
 local real y= 0
 set ScorpionTg=true
  
  call TriggerSleepAction(1.4)
  set Scorpionevent1=0
  call PauseUnit(B, true)
  call SetUnitAnimationByIndex(B, 9)
  call TriggerSleepAction(0.8)
  call PlaySoundOnUnitBJ(gg_snd_scorph, 100, B)
  call ShowUnit(B, false)
  call SetUnitPathing(B, false)
  //call TriggerSleepAction(0.3)
  set x=GetUnitX(B)
  set y=GetUnitY(B)
  if not ( IsPointInRegion(scorpArea, x, y) ) then
      set x=GetRectCenterX(gg_rct_scorpion3)
      set y=GetRectCenterY(gg_rct_scorpion3)
   endif
  
  set D=CreateUnit(Player(12), 'n08W', x, y, 270) //dusk unit
  call SaveInteger(hts, GetHandleId(t), 4, maxh)
  call SaveUnitHandle(hts, GetHandleId(t), 6, D)
  call SaveUnitHandle(hts, GetHandleId(t), 7, B)


  call TimerStart(t, 0.02, true, function ScSpCycle)

  set t=null
  set B=null
  set D=null



endfunction

