//===========================================================================
// Trigger: repick
//===========================================================================
function Trig_repick_Conditions takes nothing returns boolean
   return ( norepick[GetPlayerId(GetTriggerPlayer())] == false )
endfunction

function Trig_repick_Actions takes nothing returns nothing
 local integer pid= GetPlayerId(GetTriggerPlayer())
 local integer i= 0
 
 
  if s__dstate[pid] > 0 then
   call CleanAllStates(pid)
   call TriggerSleepAction(0.3)
  endif
 
 
     call s__Board___VisibleHelper__setindex(((Qboard[pid])),Player(pid), false) // INLINED!!
     call s__Board___VisibleHelper__setindex(((Pboard[pid])),Player(pid), false) // INLINED!!
 
  call RemoveAllQuestFromPlayer(pid)
 
  set norepick[pid]=true
  call RemoveUnit(udg_PHero[pid])
      set udg_PHero[pid]=null
  call RemoveUnit(udg_Slave[pid])
      set udg_Slave[pid]=null
  call RemoveUnit(udg_Familiar[pid])
      set udg_Familiar[pid]=null
  call RemoveUnit(cslave[pid])
    set cslave[pid]=null



     
  call ForceRemovePlayer(udg_pgancient, Player(pid))
  call ForceRemovePlayer(udg_pgblackhand, Player(pid))
  call ForceRemovePlayer(udg_pgwolffang, Player(pid))
  call ForceRemovePlayer(udg_pgekrom, Player(pid))
  
     call removedumping(pid)
     
    set udg_HasOgre[pid]=false
    set udg_HasWolf[pid]=false
    set udg_Hastroll[pid]=false
    set udg_HTrollarray[pid]=null
    set udg_OgreArray[pid]=null
    set udg_WolfArray[pid]=null
    set famtype[pid]=0
    set reinhardON[pid]=false
  
 // if (rescuedscout[pid]!=null) then     
 //       call RemoveUnit(rescuedscout[pid])
   //     set rescuedscout[pid] = null
  //endif
     
  if udg_Hashawk[pid] == true then
       call RemoveUnit(udg_Hawkarray[pid])
       set udg_Hawkarray[pid]=null
  endif
  
      set rubi[pid]=0
      set diamond[pid]=0
      set saphire[pid]=0
      set emerald[pid]=0
      set onix[pid]=0
      
      
      
      set GemVar_A[pid]=0
      set GemVar_B[pid]=0
      set GemVar_C[pid]=0
      
      
      set scrolldex[pid]=0 //dexterty
      set scrollrea[pid]=0 //reality
      set scrollpro[pid]=0 //protection
      set scrollvit[pid]=0 //vitality
      set scrollbri[pid]=0 //brightness
      set scrollabs[pid]=0 //absorption
      set scrolldmg[pid]=0 //damage
      set scrolleff[pid]=0 //effectiveness
      set scrollreg[pid]=0 //regeneration
      set questIndex[pid]=0
      set questCount[pid]=0
      set udg_PlayerReady[pid]=false
      set udg_Faction[pid]=0
      
      set s__Mstrength[pid]= 0
      set s__Fortune[pid]= 0
      set s__Constitution[pid]= 0
      
      call RemoveItemFromStock(udg_MAVault[pid], 'I0MJ')
      call RemoveItemFromStock(udg_MAVault[pid], 'I0MK')
      call RemoveItemFromStock(udg_MAVault[pid], 'I0ML')
      call RemoveItemFromStock(udg_MAVault[pid], 'I0MM')
      call RemoveItemFromStock(udg_MAVault[pid], 'I0MN')
      call RemoveItemFromStock(udg_MAVault[pid], 'I0UH')

        loop
         exitwhen i > 5
     
         call RemoveItem(UnitRemoveItemFromSlot(udg_MAVault[pid], i))
         call RemoveItem(UnitRemoveItemFromSlot(udg_ARVault[pid], i))
         set i=i + 1
       endloop
      
      
      call SetPlayerState(GetTriggerPlayer(), PLAYER_STATE_RESOURCE_LUMBER, 0)
      call SetPlayerState(GetTriggerPlayer(), PLAYER_STATE_RESOURCE_GOLD, 0)
      
      call DisplayTimedTextToPlayer(GetTriggerPlayer(), 0, 0, 3, "|cffffcc00'Repick'|r used: type |cffffcc00-new|r to start another hero or |cffffcc00-load|r to continue with another hero.")

  

endfunction

