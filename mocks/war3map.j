//===========================================================================
// Trigger: workerstoship
//===========================================================================
//TESH.scrollpos=12
//TESH.alwaysfold=0
function wtoshipc takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == 'h030' )
endfunction

function endworker takes nothing returns nothing
 call RemoveUnit(GetEnumUnit())
endfunction

function wtoshipa takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetUnitUserData(u)
local integer questid= LoadInteger(udg_cache, GetHandleId(valdkeeper), GetHandleId(udg_PHero[id]))
 
call SetUnitPathing(u, false)
//call ShowUnit(u,false)
call TriggerSleepAction(1)
call AddUnitAnimationProperties(u, "gold", false)
call UnitChat("|cffffcc00+1|r" , u)
set Qdata[questid]=Qdata[questid] + 1
               if Qdata[questid] >= Qrequ[questid] then
               
                    if suppliesready[id] == false then
                        call StartSound(bj_questUpdatedSound)
                        call UpdatePersQuest(id , questid , Qdata[questid] , "All required supplies have been carried, come back and report it to the Keeper [" , I2S(Qrequ[questid]) , "-")
                        set suppliesready[id]=true
                    endif
                call GroupRemoveUnit(workerstogrocery[id], u)
                call RemoveUnit(u)
                call ForGroup(workerstoship[id], function endworker)
                call ForGroup(workerstogrocery[id], function endworker)
                else
                call UpdatePersQuest(id , questid , Qdata[questid] , "Supplies collected [" , I2S(Qdata[questid]) , "-")
               // call ShowUnit(u,true)
                call IssuePointOrder(u, "move", - 10850, 720)
                call GroupAddUnit(workerstoship[id], u)
                call GroupRemoveUnit(workerstogrocery[id], u)
                endif
//call SetUnitAnimationByIndex(u,11)
set u=null
endfunction

