function InitTrig_alphaprv takes nothing returns nothing

    set gg_trg_alphaprv=CreateTrigger()
    call TriggerAddCondition(gg_trg_alphaprv, Condition(function alphaMprvc))
    call TriggerAddAction(gg_trg_alphaprv, function alphaMprva)
 
endfunction


