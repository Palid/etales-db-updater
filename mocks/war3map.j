//===========================================================================
// Trigger: SA
//
// Soul Awakeing
//===========================================================================
function Trig_SA_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A06E' or GetSpellAbilityId() == 'A076' )
endfunction


function RemoveCritFromGroup takes nothing returns nothing
    call UnitRemoveAbility(GetEnumUnit(), 'A061')
endfunction



function Trig_SA_Actions takes nothing returns nothing
local unit u= GetSpellAbilityUnit()
   local location p= GetUnitLoc(u)
   local group g
   local group gr= CreateGroup()
   local unit gu
  local boolexpr istru= Condition(function bool)
     
set g=GetUnitsInRangeOfLocMatching(600, p, istru)
call DestroyBoolExpr(istru)
set istru=null

loop

   set gu=FirstOfGroup(g)
   exitwhen gu == null
   
   if IsUnitEnemy(gu, GetOwningPlayer(u)) == false then
    call GroupAddUnit(gr, gu)
    call UnitAddAbility(gu, 'A061')
   endif
   call GroupRemoveUnit(g, gu)
  // set gu = null
endloop
   
   call DestroyGroup(g)
     set g=null
    call RemoveLocation(p)
    set p=null
    call TriggerSleepAction(60.00)
    
    call ForGroup(gr, function RemoveCritFromGroup)
    
      call DestroyGroup(gr)
     set gr=null


    
    set u=null
endfunction

//===========================================================================
function InitTrig_SA takes nothing returns nothing
    set gg_trg_SA=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_SA, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_SA, Condition(function Trig_SA_Conditions))
    call TriggerAddAction(gg_trg_SA, function Trig_SA_Actions)
endfunction


//===========================================================================
// Trigger: holyradiance
//===========================================================================
function Trig_holyradiance_Conditions takes nothing returns boolean
    return ( OrderId2String(GetIssuedOrderId()) == "immolation" or OrderId2String(GetIssuedOrderId()) == "unimmolation" )
endfunction

function HolyRadCicle takes nothing returns nothing
// local timer t = GetExpiredTimer()
 local integer id= LoadInteger(udg_cache, GetHandleId(GetExpiredTimer()), 1)
 
 local unit gu
 local real dmg= I2R(GetHeroInt(udg_PHero[id], true)) * 2.4
 local real fdmg
 local integer idmg
 local real cmana
 
  call GroupClear(holyradGroup[id])
  call GroupEnumUnitsInRange(holyradGroup[id], GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id]), 400, Condition(function bool))
  
  loop

   set gu=FirstOfGroup(holyradGroup[id])
   exitwhen gu == null
   if IsUnitEnemy(gu, GetOwningPlayer(udg_PHero[id])) == true and GetUnitState(gu, UNIT_STATE_LIFE) > 0.5 then
     call CheckIfHasDMG(gu)
     set fdmg=dmg + dmg * AddRacialBonus(gu , id)
     call DisableTrigger(gg_trg_DMG)
     call EnableTrigger(gg_trg_SPDMG)
     call UnitDamageTarget(udg_PHero[id], gu, fdmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
     call DestroyEffect(AddSpecialEffectTarget(holyfx, gu, "chest"))
     call DisableTrigger(gg_trg_SPDMG)
     call EnableTrigger(gg_trg_DMG)
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , gu)
      set spelldmg[id]=0
    
   endif
   call GroupRemoveUnit(holyradGroup[id], gu)
 
endloop
   
 set gu=null

endfunction

function Trig_holyradiance_Actions takes nothing returns nothing
    local integer id= GetPlayerId(GetOwningPlayer(GetOrderedUnit()))
    
if ( OrderId2String(GetIssuedOrderId()) == "immolation" ) then
 call SaveInteger(udg_cache, GetHandleId(holyradiancet[id]), 1, id)
 call TimerStart(holyradiancet[id], 0.5, true, function HolyRadCicle)
    
elseif ( OrderId2String(GetIssuedOrderId()) == "unimmolation" ) then
   call PauseTimer(holyradiancet[id])
   call GroupClear(holyradGroup[id])
endif


endfunction

//===========================================================================
function InitTrig_holyradiance takes nothing returns nothing
    set gg_trg_holyradiance=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_holyradiance, EVENT_PLAYER_UNIT_ISSUED_ORDER)
    call TriggerAddCondition(gg_trg_holyradiance, Condition(function Trig_holyradiance_Conditions))
    call TriggerAddAction(gg_trg_holyradiance, function Trig_holyradiance_Actions)
endfunction


//===========================================================================
// Trigger: divine word
//===========================================================================
//TESH.scrollpos=6
//TESH.alwaysfold=0
function divinec takes nothing returns boolean
    return GetSpellAbilityId() == 'A0DX' //Divine word
endfunction

function divinea takes nothing returns nothing


    local unit u= GetSpellAbilityUnit()
    local location p= GetSpellTargetLoc()
    local integer id= GetPlayerId(GetOwningPlayer(u))
  //  local unit dummy
    local group g
    local unit gu
    local real dmg= GetHeroInt(u, true)
    local real fdmg
    local effect sfx= AddSpecialEffectLoc("Abilities\\Spells\\NightElf\\Starfall\\StarfallCaster.mdl", p)
    local boolexpr istru= Condition(function bool)
    local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

     


  
    set dmg=dmg + ( dmg * udg_magicBonus[id] )
        
     set dmg=dmg * inspired
  
     
set g=GetUnitsInRangeOfLocMatching(300, p, istru)
call DestroyBoolExpr(istru)
set istru=null
loop

   set gu=FirstOfGroup(g)
   exitwhen gu == null
   if IsUnitEnemy(gu, GetOwningPlayer(u)) == true then
       set fdmg=dmg + dmg * AddRacialBonus(gu , id)
 
     call UnitDamageTarget(u, gu, dmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
     call DestroyEffect(AddSpecialEffectTarget("Abilities\\Weapons\\DragonHawkMissile\\DragonHawkMissile.mdl", gu, "chest"))
    
   endif
   call GroupRemoveUnit(g, gu)
   //set gu = null
endloop
   
   if ( GetPlayerController(Player(id)) == MAP_CONTROL_USER and IsUnitType(u, UNIT_TYPE_HERO) == true ) then
       call shakebattle(id , 15 , spelldmg[id] , null)
    endif
   call TriggerSleepAction(1)
   call DestroyEffect(sfx)
   set sfx=null
   call DestroyGroup(g)
     set g=null
    call RemoveLocation(p)
  set p=null
  
  set u=null
endfunction

