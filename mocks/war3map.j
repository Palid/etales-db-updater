//===========================================================================
// Trigger: LSDMG
//===========================================================================
function Trig_LSDMG_Actions takes nothing returns nothing
 local integer playerId= GetPlayerId(GetOwningPlayer(GetEventDamageSource()))
 local integer did= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  set lstrikedmg[playerId]=GetEventDamage()
   if ( GetPlayerController(Player(playerId)) == MAP_CONTROL_USER and IsUnitType(GetEventDamageSource(), UNIT_TYPE_HERO) == true and GetEventDamage() > 250.00 ) then
       //call shakebattle(playerId,did,GetEventDamage(),GetTriggerUnit())
   endif
  
endfunction

//===========================================================================
function InitTrig_LSDMG takes nothing returns nothing
    set gg_trg_LSDMG=CreateTrigger()
    call DisableTrigger(gg_trg_LSDMG)
    call TriggerAddAction(gg_trg_LSDMG, function Trig_LSDMG_Actions)
endfunction


