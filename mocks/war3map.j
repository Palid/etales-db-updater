function lightbolt takes nothing returns nothing
 local timer t= GetExpiredTimer()
local unit l__l= LoadUnitHandle(hts, GetHandleId(t), 1)
local lightning lnn= LoadLightningHandle(hts, GetHandleId(t), 2)
local integer dec= LoadInteger(hts, GetHandleId(t), 3)
local real x= LoadReal(hts, GetHandleId(t), 4)
local real y= LoadReal(hts, GetHandleId(t), 5)
local real z= 50
local location p=  LoadLocationHandle(hts, GetHandleId(t), 6)
local location q=  LoadLocationHandle(hts, GetHandleId(t), 7)


set dec=dec - 1
if dec < 1 then
set dec=20
set x=GetRandomReal(GetUnitX(l__l) - 100, GetUnitX(l__l) + 100)
set y=GetRandomReal(GetUnitY(l__l) - 100, GetUnitY(l__l) + 100)
 call MoveLocation(p, x, y)
 call SaveReal(hts, GetHandleId(t), 4, x)
 call SaveReal(hts, GetHandleId(t), 5, y)
endif

call MoveLocation(q, GetUnitX(l__l), GetUnitY(l__l))
set z=GetLocationZ(q) + GetUnitFlyHeight(l__l)
call MoveLightningEx(lnn, true, x, y, GetLocationZ(p), GetUnitX(l__l), GetUnitY(l__l), z)

call SaveInteger(hts, GetHandleId(t), 3, dec)

set p=null
set q=null
set t=null
set l__l=null
set lnn=null
set dec=0
set x=0
set y=0

endfunction

function lightacc takes nothing returns nothing
 local integer id= LoadInteger(hts, GetHandleId(gg_trg_launchbolts), 1)
 local unit u= lightningboltT[id]
 local location p= GetUnitLoc(u)
 local location q= GetUnitLoc(u)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real z_a
 local unit l__l
 local lightning lnn
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer dec= 10
 call TriggerSleepAction(0.1)
 set l__l=CreateUnit(Player(id), ldummyA, x, y, 0)
 call SetUnitPathing(l__l, false)
 set z_a=GetUnitFlyHeight(l__l)
 //set ln = AddLightningEx("CLSB", true, GetUnitX(u), GetUnitY(u), 0, GetUnitX(u), GetUnitY(u),z_a)
 set lnn=AddLightningEx(CHAIN, true, GetUnitX(l__l), GetUnitY(l__l), GetLocationZ(p), GetUnitX(l__l), GetUnitY(l__l), GetLocationZ(p) + z_a)
 call SetLightningColor(lnn, 1, 1, 1, 0.5)
 call IssuePointOrder(l__l, "move", light_x[id], light_y[id])
 call SaveUnitHandle(hts, GetHandleId(t), 1, l__l)
 call SaveLightningHandle(hts, GetHandleId(t), 2, lnn)
 call SaveInteger(hts, GetHandleId(t), 3, dec)
 call SaveReal(hts, GetHandleId(t), 4, x)
 call SaveReal(hts, GetHandleId(t), 5, y)
 call SaveLocationHandle(hts, GetHandleId(t), 6, p)
 call SaveLocationHandle(hts, GetHandleId(t), 7, q)
 call TimerStart(t, 0.01, true, function lightbolt)
 call UnitApplyTimedLife(l__l, 'BTLF', 3)
 call TriggerSleepAction(2.9)

 call FlushChildHashtable(hts, GetHandleId(t))
 call PauseTimer(t)
 call ReleaseTimer(t)
 call RemoveLocation(p)
 set p=null
 call RemoveLocation(q)
 set q=null
 call DestroyLightning(lnn)

set u=null
set t=null
set lnn=null
set l__l=null
endfunction

//=======================================widebolts========================================


function wideboltc takes nothing returns boolean
    return ( GetUnitAbilityLevel(GetAttacker(), widebolts) > 0 and IsUnitInGroup(GetAttacker(), widebolters) == false )
endfunction

function setbolt takes real x,real y,real tangle,integer id returns nothing
local real xu= x + 300 * Cos(tangle * bj_DEGTORAD)
local real yu= y + 300 * Sin(tangle * bj_DEGTORAD)
local real xf= x + 2000 * Cos(tangle * bj_DEGTORAD)
local real yf= y + 2000 * Sin(tangle * bj_DEGTORAD)
local unit u= CreateUnit(Player(id), ldummyB, xu, yu, 0)
  call SetUnitPathing(u, false)
 call IssuePointOrder(u, "move", xf, yf)
  call UnitApplyTimedLife(u, 'BTLF', 1.5)
  set u=null
endfunction

function widelaunch takes nothing returns nothing
local timer t= GetExpiredTimer()

 local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
 local real angle= LoadReal(hts, GetHandleId(t), 1)
 local integer id= GetPlayerId(GetOwningPlayer(u))

 //local integer id = GetPlayerId(GetOwningPlayer(u))
 local real x= GetUnitX(u) - 250 * Cos(angle * bj_DEGTORAD)
 local real y= GetUnitY(u) - 250 * Sin(angle * bj_DEGTORAD)
 
call setbolt(x , y , angle - 30 , id)
call setbolt(x , y , angle - 15 , id)
call setbolt(x , y , angle , id)
call setbolt(x , y , angle + 15 , id)
call setbolt(x , y , angle + 30 , id)

   

set u=null
set t=null



endfunction

function widebolta takes nothing returns nothing

 local unit u= GetAttacker()
 local unit a= GetTriggerUnit()
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real x2= GetUnitX(a)
 local real y2= GetUnitY(a)
 local real xf= x2 - x
 local real yf= y2 - y
 local real angle= bj_RADTODEG * Atan2(yf, xf)

 call GroupAddUnit(widebolters, u)
 call TriggerSleepAction(0.1)
 call SaveUnitHandle(hts, GetHandleId(t), 0, u)
 call SaveReal(hts, GetHandleId(t), 1, angle)
 
 
 call TimerStart(t, 0.3, true, function widelaunch)
 call TriggerSleepAction(1)
 call PauseTimer(t)
 call FlushChildHashtable(hts, GetHandleId(t))
 call ReleaseTimer(t)
 call TriggerSleepAction(0.7)
 call GroupRemoveUnit(widebolters, u)

 
 set t=null
 set u=null
 set a=null
 
 
endfunction


function initlightning takes nothing returns nothing
local integer i= 0
local trigger trgwb= CreateTrigger()

loop
exitwhen i == bj_MAX_PLAYER_SLOTS
 
 call TriggerRegisterPlayerUnitEvent(trgwb, Player(i), EVENT_PLAYER_UNIT_ATTACKED, Condition(function bool))
set i=i + 1
endloop

 call TriggerAddCondition(trgwb, Condition(function wideboltc))
 call TriggerAddAction(trgwb, function widebolta)
 
set electrocuteanim[0]="stand"
set electrocuteanim[2]="spell"

set electrocuteattch[0]="origin"
set electrocuteattch[1]="chest"
set electrocuteattch[2]="head"
set electrocuteattch[3]="hand,right"
set electrocuteattch[4]="hand,left"
set electrocuteattch[5]="weapon"
endfunction


