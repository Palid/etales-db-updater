//===========================================================================
// Trigger: checkrewards
//===========================================================================
function centaursrc takes nothing returns boolean
    return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function centaursra takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local item it

   if s__centaursready[id] == true then
     set s__centaursready[id]= false
     call MakeFaceToUnit(ankit , udg_PHero[id])
     call UnitChat("What??, You cannot find their main base??..." , ankit)
     call TriggerSleepAction(3)
     call UnitChat("Unfortunately not...and I swear that they tried to tell me something while I fought them..." , udg_PHero[id])
     call TriggerSleepAction(5)
     call UnitChat("What?...Just ignore them. you mustn't forget that they are beast and we need to protect our people from these menaces" , ankit)
     call MakeFaceToUnit(ankit , udg_PHero[id])
     call TriggerSleepAction(7)
     call UnitChat("I don't know... There is something disturbing in the air" , udg_PHero[id])
     call TriggerSleepAction(4)
     call UnitChat("These are war times my friend, we must be ready for anything..." , ankit)
     call MakeFaceToUnit(ankit , udg_PHero[id])
     call TriggerSleepAction(4)
     set s__killingcentaurs[id]= false
 endif
  
  
  
  
  
 set it=null
  
  
endfunction

//===========================================================================
function InitTrig_checkrewards takes nothing returns nothing
    set gg_trg_checkrewards=CreateTrigger()
    call TriggerRegisterUnitInRange(gg_trg_checkrewards, gg_unit_h036_0171, 256, null) //ankit
    call TriggerAddCondition(gg_trg_checkrewards, Condition(function centaursrc))
    call TriggerAddAction(gg_trg_checkrewards, function centaursra)
endfunction


//===========================================================================
// Trigger: runcentaurs
//===========================================================================
function centaurssiege takes nothing returns nothing
  local timer t= GetExpiredTimer()
        set centaurg=FirstOfGroup(centaurss)
        
    if centaurg != null then
      call ForGroup(centaurss, function centattack)
    else
       call PauseTimer(t)
       call ReleaseTimer(t)
    endif
    
  set t=null

endfunction

function Trig_runcentaurs_Actions takes nothing returns nothing
local integer i= 10
local timer t

 set centaurss=CreateGroup()
 
       
       call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[12], - 6100, 11450, 270))
       call TriggerSleepAction(0.1)
       call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[12], - 6100, 11450, 270))
       call TriggerSleepAction(0.1)
       call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[12], - 6100, 11450, 270))
       call TriggerSleepAction(0.1)
 loop
        set i=i - 1
        exitwhen i < 0
        call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[68], - 6100, 11450, 270))
         call TriggerSleepAction(0.1)
 endloop
    set i=7
  loop
        set i=i - 1
        exitwhen i < 0
        call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[67], - 6100, 11450, 270))
          call TriggerSleepAction(0.1)
 endloop

     set i=7
  loop
        set i=i - 1
        exitwhen i < 0
        call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[104], - 6100, 11450, 270))
          call TriggerSleepAction(0.1)
 endloop
 
     set i=5
  loop
        set i=i - 1
        exitwhen i < 0
        call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[26], - 6100, 11450, 270))
          call TriggerSleepAction(0.1)
 endloop
 
 
       call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[13], - 6100, 11450, 270))
       call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[13], - 6100, 11450, 270))
       call GroupAddUnit(centaurss, CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[13], - 6100, 11450, 270))

      
       
       call TriggerSleepAction(0.1)

       set t=(NewTimerEx(0)) // INLINED!!
       call TimerStart(t, 5, true, function centaurssiege)
    
      call ForGroup(centaurss, function centattack)
      set centaurg=FirstOfGroup(centaurss)
    call DisableTrigger(gg_trg_runcentaurs)
    set t=null
endfunction

//===========================================================================
function InitTrig_runcentaurs takes nothing returns nothing
    set gg_trg_runcentaurs=CreateTrigger()
    call TriggerAddAction(gg_trg_runcentaurs, function Trig_runcentaurs_Actions)
endfunction


