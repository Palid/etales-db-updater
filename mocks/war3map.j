function InitTrig_bansheeprvent takes nothing returns nothing

    set gg_trg_bansheeprvent=CreateTrigger()
    call TriggerAddCondition(gg_trg_bansheeprvent, Condition(function bansheeMprvc))
    call TriggerAddAction(gg_trg_bansheeprvent, function bansheeMprva)
 
endfunction


