function batdance takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetEnumUnit()))
local real hx= GetUnitX(udg_PHero[id])
local real hy= GetUnitY(udg_PHero[id])
local real x= GetRandomReal(hx - 250, hx + 250)
local real y= GetRandomReal(hy - 250, hy + 250)
call IssuePointOrder(GetEnumUnit(), "move", x, y)

endfunction



