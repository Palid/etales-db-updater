function ClonedError takes player ForPlayer,string msg returns nothing
 local sound error=CreateSoundFromLabel("InterfaceError", false, false, false, 10, 10)
    if ( GetLocalPlayer() == ForPlayer ) then
        if ( msg != "" ) and ( msg != null ) then
            call ClearTextMessages()
            call DisplayTimedTextToPlayer(ForPlayer, 0.52, - 1.00, 2.00, "|cffffcc00" + msg + "|r")
        endif
        call StartSound(error)
    endif
 call KillSoundWhenDone(error)
 set error=null
endfunction
   
   
function castbook takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A05O' )
endfunction

function GetStats takes unit hero,integer nplayer returns nothing
local integer agix= 0
local integer intx= 0
local integer strx= 0
local integer itm= 0
local integer i= 0


  set s__SVFortune[nplayer]= s__Fortune[nplayer]
  set s__SVMstrength[nplayer]= s__Mstrength[nplayer]
  set s__SVConstitution[nplayer]= s__Constitution[nplayer]

       if s__dstate[nplayer] > 0 then
          set agix=agix + s__altstate[(nplayer)*(10)+AGI]
          set strx=strx + s__altstate[(nplayer)*(10)+STR]
          set intx=intx + s__altstate[(nplayer)*(10)+INT]
          
          set s__SVFortune[nplayer]= s__Fortune[nplayer] - s__altstate[(nplayer)*(10)+LUCK]
          set s__SVMstrength[nplayer]= s__Mstrength[nplayer] - s__altstate[(nplayer)*(10)+MSTR]
          set s__SVConstitution[nplayer]= s__Constitution[nplayer] - s__altstate[(nplayer)*(10)+CONS]
      endif
   
   
                 if s__AdvancedBonus[(nplayer)*(4)+1] == true then // 
                    set s__SVMstrength[nplayer]= s__SVMstrength[nplayer] - 322
                 endif
                
              
                
                   if s__AdvancedBonus[(nplayer)*(4)+2] == true then
                      set s__SVFortune[nplayer]= s__SVFortune[nplayer] - 322
                   endif
            
                   if s__AdvancedBonus[(nplayer)*(4)+3] == true then
                        set s__SVConstitution[nplayer]= s__SVConstitution[nplayer] - 322
                   endif
             
                  if s__AdvancedBonus[(nplayer)*(4)+4] == true then
                          set s__SVFortune[nplayer]= s__SVFortune[nplayer] - 322
                          set s__SVMstrength[nplayer]= s__SVMstrength[nplayer] - 322
                          set s__SVConstitution[nplayer]= s__SVConstitution[nplayer] - 322
                       
                    endif



 loop
 exitwhen i > 5
 
   if ( GetItemType(UnitItemInSlot(hero, i)) == ITEM_TYPE_PERMANENT ) then
   
      set agix=agix + LoadInteger(udg_ItemStatHash, GetHandleId(UnitItemInSlot(hero, i)), 2)
      set strx=strx + LoadInteger(udg_ItemStatHash, GetHandleId(UnitItemInSlot(hero, i)), 3)
      set intx=intx + LoadInteger(udg_ItemStatHash, GetHandleId(UnitItemInSlot(hero, i)), 4)
   endif
   
 set i=i + 1
 endloop

    set agix=agix + 35
    set strx=strx + 35
    set intx=intx + 35

  set udg_AGI[nplayer]=GetHeroAgi(hero, false) - agix //base
  set udg_STR[nplayer]=GetHeroStr(hero, false) - strx //base
  set udg_INT[nplayer]=GetHeroInt(hero, false) - intx //base
  
endfunction

function HideBook takes nothing returns nothing
 local integer nplayer= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local location p= GetUnitLoc(GetTriggerUnit())

 call ShowUnit(udg_BMaster[nplayer], false)
 call SetUnitPosition(udg_BMaster[nplayer], GetLocationX(udg_SBML[nplayer]), GetLocationY(udg_SBML[nplayer]))
  
 call ShowUnit(udg_ARVault[nplayer], false)
 call SetUnitPosition(udg_ARVault[nplayer], GetLocationX(udg_ARVpoint[nplayer]), GetLocationY(udg_ARVpoint[nplayer]))
 
 call ShowUnit(udg_MAVault[nplayer], false)
 call SetUnitPosition(udg_MAVault[nplayer], GetLocationX(udg_MAVpoint[nplayer]), GetLocationY(udg_MAVpoint[nplayer]))
 
 call DestroyEffect(AddSpecialEffectLoc("Objects\\Spawnmodels\\Other\\ToonBoom\\ToonBoom.mdl", p))
 call RemoveLocation(p)
 set p=null

endfunction

function releasejewel takes integer id returns nothing

    call RemoveItemFromStock(udg_MAVault[id], 'I0MJ')
    call AddItemToStock(udg_MAVault[id], 'I0MJ', onix[id], onix[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0MK')
    call AddItemToStock(udg_MAVault[id], 'I0MK', rubi[id], rubi[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
    call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0MM')
    call AddItemToStock(udg_MAVault[id], 'I0MM', emerald[id], emerald[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0MN')
    call AddItemToStock(udg_MAVault[id], 'I0MN', saphire[id], saphire[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
    call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
    
    
    
endfunction




function DisplayStats takes nothing returns nothing
 local integer nplayer= GetPlayerId(GetTriggerPlayer())
 local real x= GetUnitX(udg_PHero[nplayer])
 local real y= GetUnitY(udg_PHero[nplayer])
 local real ang= GetUnitFacing(udg_PHero[nplayer])
 local real x1= x + 180 * Cos(ang * bj_DEGTORAD)
 local real y1= y + 180 * Sin(ang * bj_DEGTORAD)
 
 local real x2= x + 180 * Cos(( ang + 120 ) * bj_DEGTORAD)
 local real y2= y + 180 * Sin(( ang + 120 ) * bj_DEGTORAD)
 
 local real x3= x + 180 * Cos(( ang + 240 ) * bj_DEGTORAD)
 local real y3= y + 180 * Sin(( ang + 240 ) * bj_DEGTORAD)

 
 if s__nocamp[nplayer] == true then
  call ClonedError(Player(nplayer) , "You cannot deploy your encampment in these places.")
  return
 endif
 
 
 call releasejewel(nplayer)
 
 call SetUnitPosition(udg_BMaster[nplayer], x1, y1)
 call SetUnitFacingTimed(udg_BMaster[nplayer], ang + 90, 0)
 call ShowUnit(udg_BMaster[nplayer], true)
 
 call SetUnitPosition(udg_ARVault[nplayer], x2, y2)
 call SetUnitFacingTimed(udg_ARVault[nplayer], 270, 0)
 call ShowUnit(udg_ARVault[nplayer], true)
 
 call SetUnitPosition(udg_MAVault[nplayer], x3, y3)
 call SetUnitFacingTimed(udg_MAVault[nplayer], 270, 0)
 call ShowUnit(udg_MAVault[nplayer], true)

endfunction

function InitBMaster takes nothing returns nothing
 local integer i= 0
 set openstat=CreateTrigger()
 set closestat=CreateTrigger()
 
 
  loop
   exitwhen i > 12
     call TriggerRegisterPlayerEvent(openstat, Player(i), EVENT_PLAYER_END_CINEMATIC)
     call TriggerRegisterPlayerUnitEvent(closestat, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, null)
    set i=i + 1
  endloop
   call TriggerAddCondition(closestat, Condition(function castbook))
   
   
   call TriggerAddAction(openstat, function DisplayStats)
   call TriggerAddAction(closestat, function HideBook)
   
endfunction


function SpellDmgText takes integer d,unit u returns nothing
    
    if d < 1 then
     return
     endif
    
    call CreateTextTagUnitBJ(I2S(d), u, 30, 17, 100, 100, 0, 0)
    call SetTextTagPermanent(GetLastCreatedTextTag(), false)
    call SetTextTagLifespan(GetLastCreatedTextTag(), 1.3)
    call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 30, 90)
   
endfunction

function RedDmgText takes integer d,unit u returns nothing
    
    if d < 1 then
     return
     endif
    
    call CreateTextTagUnitBJ(I2S(d), u, 30, 17, 100, 20, 0, 0)
    call SetTextTagPermanent(GetLastCreatedTextTag(), false)
    call SetTextTagLifespan(GetLastCreatedTextTag(), 1.3)
    call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 30, 90)
   
endfunction



