//===========================================================================
// Trigger: killedbandit
//===========================================================================
//TESH.scrollpos=85
//TESH.alwaysfold=0

function PurseOpen takes real x,real y returns nothing

set goldcoin=CreateItem(udg_itmpool[91], GetRandomReal(x - 130, x + 130), GetRandomReal(y - 130, y + 130))
call SaveInteger(questtm, GetHandleId(goldcoin), 0, goldAmount)

endfunction

function Trig_killedbandit_Actions takes nothing returns nothing
 local integer i= 0
 local unit b= GetDyingUnit()
 local unit u= GetKillingUnit()
 local real x= GetUnitX(b)
 local real y= GetUnitY(b)
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local integer Bid= LoadInteger(questtm, GetHandleId(b), 0)
 local integer times= GetRandomInt(6, 13)
 local integer gamount= taxes[Bid] / ( times * 4 )

   call TriggerSleepAction(1)
  
  if id > 7 then
   set s__KatherineAdvice[0]= true
   else
   set s__KatherineAdvice[id]= true
   set Reputation[id]=Reputation[id] + gamount
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "You killed the leader!. Someone will be very angry (|cffffcc00+" + I2S(gamount) + " Reputation|r)")
  endif

   set i=0
   loop
    exitwhen i > times
     set goldAmount=gamount
     call PurseOpen(x , y)
     call TriggerSleepAction(0.1)
    set i=i + 1
    endloop
    set goldcoin=null
   
     set s__GateIsOpen[Bid]= true
     call ModifyGateBJ(bj_GATEOPERATION_OPEN, taxgates[Bid])
     call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, u)
   
    set i=0
   loop
    exitwhen i > 8
    
     if IsUnitInRegion(gateregion[Bid], udg_PHero[i]) == true then
          call DisplayTimedTextToPlayer(Player(i), 0, 0, 3, "|cffffcc00Good News!!|r A group of cowards bandits have been destroyed, their gate will be permantly open!")
     endif
    
    set i=i + 1
    endloop
     
     call TriggerSleepAction(3)
     
     set i=0
     if banditsincident == false then
         set banditsincident=true
         call QuestSetDiscovered(banditsq, true)
         call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00NEW WORLD QUEST DISCOVERED - BANDITS GATES:|r Search and destroy all bandit's outpost 1/6.")
         call StartSound(bj_questDiscoveredSound)
         set outpostleft=1
    else
       if outpostleft < 5 then
	           set outpostleft=outpostleft + 1
               call QuestItemSetDescription(banditsia, "Destroy all bandits control points " + I2S(outpostleft) + "/6")
               call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "|cffffcc00WORLD QUEST UPDATE - BANDITS GATES:|r Search and destroy all bandit's outpost " + I2S(outpostleft) + "/6.")
               call StartSound(bj_questUpdatedSound)
         else
		       set outpostleft=outpostleft + 1
               call QuestItemSetDescription(banditsia, "Destroy all bandits control points " + I2S(outpostleft) + "/6")
               call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffffcc00WORLD QUEST UPDATE - BANDITS GATES:|r All bandit's gates have been destroyed " + I2S(outpostleft) + "/6.")
               call StartSound(bj_questCompletedSound)
               call QuestItemSetCompleted(banditsia, true)
               call QuestSetCompleted(banditsq, true)
			
			  call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "All players got +16180 XP, +44 reputation")
    
				loop
				exitwhen i > 8
		          set Reputation[i]=Reputation[i] + 44
				  call AddHeroXP(udg_PHero[i], 16180, false)
				 set i=i + 1
				
				endloop
			
           
         endif
     
  endif
     
    set u=null
    set b=null
     
 
endfunction

//===========================================================================
function InitTrig_killedbandit takes nothing returns nothing

    set gg_trg_killedbandit=CreateTrigger()
    
    call TriggerAddAction(gg_trg_killedbandit, function Trig_killedbandit_Actions)
endfunction


//===========================================================================
// Trigger: paymentlib
//
//     set bgates[0] = gg_rct_gatevelh
//     set bgates[1] = gg_rct_gatemisha
//     set bgates[2] = gg_rct_gatescout
//     set bgates[3] = gg_rct_gatespider
//     set bgates[4] = gg_rct_gatebandit
//     set bgates[5] = gg_rct_gateundead
//     set bgates[6] = gg_rct_gatemonas
//===========================================================================
//TESH.scrollpos=147
//TESH.alwaysfold=0
//===========================================================================
// Trigger: taxpayment
//===========================================================================
//TESH.scrollpos=59
//TESH.alwaysfold=0
function Trig_taxpayment_Conditions takes nothing returns boolean
    return GetItemTypeId(GetSoldItem()) == 'I08I' //hero accepts
endfunction


function Trig_taxpayment_Actions takes nothing returns nothing
  local unit u= GetBuyingUnit()
  local unit b= GetSellingUnit()
  local integer id= GetPlayerId(GetOwningPlayer(u))
  local integer Bid= LoadInteger(questtm, GetHandleId(b), 0)
  local integer ctax= taxes[Bid]
  local boolean NoMoney= GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) < ctax
  
  
    if IsUnitType(GetBuyingUnit(), UNIT_TYPE_HERO) == true then
  
                       if s__GateIsOpen[Bid] == true then
                        call UnitChat("You have allowed access, just pass" , b)
                        call MakeFaceToUnit(b , u)
                        set u=null
                        call AddItemToStock(b, 'I08I', 1, 1)
                        set b=null
                        return
                        endif
                      
                      call DisableTrigger(gg_trg_taxpayment)
                      set currentTax=ctax
                      
                      call TriggerSleepAction(0.2)
                      if cowardslev[Bid] >= GetUnitLevel(u) then
                      call UnitChat(TaxRequest(currentTax) , b)
                      call MakeFaceToUnit(b , u)
                      call TriggerSleepAction(3)
                      call UnitChat(passengerR[GetRandomInt(1, 6)] , u)
                      call MakeFaceToUnit(u , b)
                      call TriggerSleepAction(3)
                      call UnitChat(banditrt[GetRandomInt(1, 11)] , b)
                      call MakeFaceToUnit(b , u)
                      call TriggerSleepAction(3)
                          if NoMoney == true then
                            call UnitChat("I don't have enough money... I'll be back soon" , u)
                          else
                             call UnitChat("Ok take here the gold (+|cffffcc00" + I2S(ctax) + "|r coins)" , u)
                             call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) - ctax)
                             set s__gatesopened[(id)*(7)+Bid]= true
                             call MakeFaceToUnit(u , b)
                             call TriggerSleepAction(2)
                             call UnitChat("Thanks!!, It's nice to make bussines with you!" , b)
                             call TriggerSleepAction(2)
                             call UnitChat("OPEN THE DOOR!!" , b)
                             call TriggerSleepAction(1)
                             set s__GateIsOpen[Bid]= true
                                call ModifyGateBJ(bj_GATEOPERATION_OPEN, taxgates[Bid])
                                call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, u)
                                call TriggerSleepAction(10)
                                set s__GateIsOpen[Bid]= false
                                call ModifyGateBJ(bj_GATEOPERATION_CLOSE, taxgates[Bid])
                                call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, u)
                          endif
                      else
                      call UnitChat("You don't have to pay mate, just come back when you want" , b)
                      call MakeFaceToUnit(b , u)
                      endif
                    call EnableTrigger(gg_trg_taxpayment)
  endif
  
  call AddItemToStock(b, 'I08I', 1, 1) //accept taxpayment
  set u=null
  set b=null

endfunction

//===========================================================================
function InitTrig_taxpayment takes nothing returns nothing
    set gg_trg_taxpayment=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_taxpayment, EVENT_PLAYER_UNIT_SELL_ITEM)
    call TriggerAddCondition(gg_trg_taxpayment, Condition(function Trig_taxpayment_Conditions))
    call TriggerAddAction(gg_trg_taxpayment, function Trig_taxpayment_Actions)
endfunction


//===========================================================================
// Trigger: rejectpayment
//===========================================================================
//TESH.scrollpos=65
//TESH.alwaysfold=0
function rejectC takes nothing returns boolean
    return GetItemTypeId(GetSoldItem()) == 'I08J' //hero rejects
endfunction

function MakeBandit takes nothing returns nothing
 call SetUnitOwner(GetEnumUnit(), Player(PLAYER_BAND_SIND), true)
 call SetUnitInvulnerable(GetEnumUnit(), false)
endfunction

function MakeTaxer takes nothing returns nothing
 call SetUnitOwner(GetEnumUnit(), Player(PLAYER_NEUTRAL_PASSIVE), true)
 call SetUnitInvulnerable(GetEnumUnit(), true)
 call SetUnitPosition(GetEnumUnit(), GetRandomReal(GetRectMinX(bandrect[CurrentBID]), GetRectMaxX(bandrect[CurrentBID])), GetRandomReal(GetRectMinY(bandrect[CurrentBID]), GetRectMaxY(bandrect[CurrentBID])))
endfunction

function rejectA takes nothing returns nothing
  local unit u= GetBuyingUnit()
  local unit b= GetSellingUnit()
  local integer id= GetPlayerId(GetOwningPlayer(u))
  local integer Bid= LoadInteger(questtm, GetHandleId(b), 0)
  local integer ctax= taxes[Bid]
 // local boolean NoMoney = GetPlayerState(Player(id),PLAYER_STATE_RESOURCE_GOLD) < ctax
  if IsUnitType(GetBuyingUnit(), UNIT_TYPE_HERO) == true then
 
  
                   if s__GateIsOpen[Bid] == true then
                   
                    call AddItemToStock(b, 'I08J', 1, 1) //reject taxpayment
                    call UnitChat("We have a trouble here. just come back in a few hours" , b)
                    call MakeFaceToUnit(b , u)
                    set u=null
                    set b=null
                    return
                    endif
                  
                  call DisableTrigger(gg_trg_taxpayment)
                  call DisableTrigger(gg_trg_rejectpayment)
                  set currentTax=ctax
                  
                  call TriggerSleepAction(0.2)
                  if cowardslev[Bid] >= GetUnitLevel(u) then
                  call UnitChat(TaxRequest(currentTax) , b)
                  call MakeFaceToUnit(b , u)
                  call TriggerSleepAction(4)
                  call UnitChat(passengerR[GetRandomInt(1, 6)] , u)
                  call MakeFaceToUnit(u , b)
                  call TriggerSleepAction(4)
                  call UnitChat(banditrt[GetRandomInt(1, 11)] , b)
                  call MakeFaceToUnit(b , u)
                  call TriggerSleepAction(4)

                         call UnitChat(passengerS[GetRandomInt(1, 11)] , u)
                         call MakeFaceToUnit(u , b)
                         call TriggerSleepAction(1.5)
                         call ForGroup(taxmen[Bid], function MakeBandit)
                         set s__GateIsOpen[Bid]= true

                         call TriggerSleepAction(30)
                         set CurrentBID=Bid
                         call ForGroup(taxmen[Bid], function MakeTaxer)
                         set s__GateIsOpen[Bid]= false

                   
                  else
                  call UnitChat("You don't have to pay mate, just come back when you want" , b)
                  call MakeFaceToUnit(b , u)
                  endif
                  call EnableTrigger(gg_trg_taxpayment)
                  call EnableTrigger(gg_trg_rejectpayment)
                  
  endif
                  
  call AddItemToStock(b, 'I08J', 1, 1) //reject taxpayment
  set u=null
  set b=null
 
endfunction

