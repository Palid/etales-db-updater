 function endreassig takes nothing returns nothing
 local timer t= GetExpiredTimer()
 local integer i= 0
 local integer id= LoadInteger(questtm, GetHandleId(t), 1) - 10
 
 call PauseTimer(t)
 call FlushChildHashtable(questtm, GetHandleId(t))
 call DisplayTimedTextToPlayer(Player(id), .5, .1, 15, " Reassignation session ended. Thanks for use Chronoss service.")
 call ReleaseTimer(t)
 set t=null
 
 
                      loop
                      exitwhen i > 5
                      set s__TMPstats[(id)*(6)+i]= 0
                      set i=i + 1
                      endloop
                       set s__TMPresiduo[id]= 0
                       set s__OriginalAmn[id]= 0
                       
                       set s__ISreseting[id]= false
 
 endfunction
  
  
 function UpdateReset takes integer id returns nothing
   local player pl= Player(id)

  local string l__sstr=  "|cffff8888STR|r = " + I2S(s__TMPstats[(id)*(6)+0])
  local string l__sagi=  "|cff88ff88AGI|r = " + I2S(s__TMPstats[(id)*(6)+1])
  local string l__sint=  "|cff8888ffINT|r = " + I2S(s__TMPstats[(id)*(6)+2])
  local string l__cons=  "|cff8888ffCNS|r = " + I2S(s__TMPstats[(id)*(6)+5])
  local string l__mstr=  "|cff88ff88MSR|r = " + I2S(s__TMPstats[(id)*(6)+4])
  local string l__fort=  "|cffff8888FRT|r = " + I2S(s__TMPstats[(id)*(6)+3])
  
  
    if ( GetLocalPlayer() == pl ) then
     call ClearTextMessages()
   endif
   
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, "================= S T A T S  R E A S S I G N A T I O N =================")
 //  call DisplayTimedTextToPlayer(pl,.5,.1,3,"On faction service = |cffffcc00" +fmission+"|r")
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, "Remaining Points = |cffffcc00" + I2S(s__TMPresiduo[id]) + "|r")
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, " ")
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, l__sstr)
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, l__sagi)
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, l__sint)
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, " ")
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, l__fort)
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, l__cons)
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, l__mstr)
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, " ")
   call DisplayTimedTextToPlayer(pl, .5, .1, 15, " Type |cffffcc00-set done|r when you be ready to finish assignation")

   call PauseTimer(reassignt[id])
   call TimerStart(reassignt[id], 35, false, function endreassig)
   
   
       set pl=null
      set l__sstr=null
      set l__sagi=null
      set l__sint=null
      set l__cons=null
      set l__mstr=null
      set l__fort=null

endfunction 
  
  

