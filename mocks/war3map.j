    call TriggerRegisterEnterRectSimple(gg_trg_activateq, gg_rct_forgot)
    call TriggerRegisterEnterRectSimple(gg_trg_activateq, gg_rct_forgot2)
    call TriggerAddCondition(gg_trg_activateq, Condition(function Trig_activateq_Conditions))
    call TriggerAddAction(gg_trg_activateq, function Trig_activateq_Actions)
endfunction


