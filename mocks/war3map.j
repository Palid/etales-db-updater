//===========================================================================
// Trigger: natureforce
//===========================================================================
//TESH.scrollpos=33
//TESH.alwaysfold=0
function Trig_natureforce_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == FORCENATU or GetSpellAbilityId() == FORCENATD
endfunction

function Trig_natureforce_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local integer typec= 1
 local integer i= 0
 local unit dummy= null
 local real x= GetSpellTargetX()
 local real y= GetSpellTargetY()
 local real xi= 0
 local real yi= 0
 local integer sl= 0
 local integer l__l= GetUnitLevel(u)
 local integer a= ModuloInteger(l__l, 10)
 local integer j= 1
 local integer b= l__l / 10

 
 if GetSpellAbilityId() == FORCENATD or l__l < 40 then
   
   set sl=GetUnitAbilityLevel(u, FORCENATD)
   if a < 2 then
     set a=2
   endif
    
   set a=1 + a / 2
   
   if a > 4 then
    set a=4
   endif
    
   if GetSpellAbilityId() == FORCENATU then
     set sl=b
   endif
    
   
   loop
   exitwhen j > a
   
        set xi=x + GetRandomReal(- 40, 40)
        set yi=y + GetRandomReal(- 40, 40)

           set dummy=CreateUnit(Player(id), s__fnatured[sl], xi, yi, GetRandomReal(0, 359))
           call DestroyEffect(AddSpecialEffectTarget(entbirth, dummy, "origin"))
           call UnitApplyTimedLife(dummy, 'BTLF', 40)
   
   set j=j + 1
   endloop
 
 else

      if ActSpecast(id , GetSpellAbilityId()) == true then
          set typec=typec + s__casttype[id]
      else
         set typec=GetRandomInt(0, 2)
      endif
     
       
       loop
        exitwhen i > s__natureforce[(typec)*(2)+1]
        set xi=x + GetRandomReal(- 70, 70)
        set yi=y + GetRandomReal(- 70, 70)
        
           set dummy=CreateUnit(Player(id), s__natureforce[(typec)*(2)+0], xi, yi, GetRandomReal(0, 359))
           call DestroyEffect(AddSpecialEffectTarget(entbirth, dummy, "origin"))
           call UnitApplyTimedLife(dummy, 'BTLF', 40)
        
       
       set i=i + 1
       endloop
     
   endif //  GetSpellabilityId
 
  set u=null
  set dummy=null




endfunction

