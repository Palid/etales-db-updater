//===========================================================================
// Trigger: NaiarStomp
//===========================================================================
//TESH.scrollpos=12
//TESH.alwaysfold=0
function Trig_NaiarStomp_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A0DF' //naiarstomp
endfunction

function Trig_NaiarStomp_Actions takes nothing returns nothing
   local unit u= GetSpellAbilityUnit()
    local location p= GetUnitLoc(u)
    local integer id= GetPlayerId(GetOwningPlayer(u))
  //  local unit dummy
    local group g= null
    local unit gu= null
    local real dmg= 2576
    local boolexpr istru= Condition(function bool)
    
  
  
     call DestroyEffect(AddSpecialEffectLoc("RedAftershock.mdx", p))
     
     
set g=GetUnitsInRangeOfLocMatching(300, p, istru)
call DestroyBoolExpr(istru)
set istru=null
loop

   set gu=FirstOfGroup(g)
   exitwhen gu == null
   if IsUnitEnemy(gu, GetOwningPlayer(u)) == true then
     
 
     
     set bj_lastCreatedUnit=CreateUnitAtLoc(GetOwningPlayer(u), 'n059', p, 0)
     call IssueTargetOrder(bj_lastCreatedUnit, "creepthunderbolt", gu)
     call UnitApplyTimedLife(bj_lastCreatedUnit, 'BTLF', 3)
     call UnitDamageTarget(u, gu, dmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
   // call SetUnitTimeScalePercent( gu, 0.00 )
    
   endif
   call GroupRemoveUnit(g, gu)
  // set gu = null
endloop

   call DestroyGroup(g)
     set g=null
    call RemoveLocation(p)
    set p=null
    set u=null
 
endfunction

