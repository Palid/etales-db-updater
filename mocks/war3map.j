//===========================================================================
// Trigger: clownHaterA
//===========================================================================
//TESH.scrollpos=67
//TESH.alwaysfold=0
function Trig_clownHaterA_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == HaterID )
endfunction

function CHtU takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local integer c= LoadInteger(hts, GetHandleId(t), 2)
    local real inc= LoadReal(hts, GetHandleId(t), 3)
    
    local real x= GetUnitX(u) + inc * Cos(ang * bj_DEGTORAD)
    local real y= GetUnitY(u) + inc * Sin(ang * bj_DEGTORAD)
    
    if c < 1 then
    
    call PauseTimer(t)
    call FlushChildHashtable(hts, GetHandleId(t))
    call ReleaseTimer(t)
    call RemoveUnit(u)
       set u=null
   else
        set c=c - 1
        set inc=inc - 2
  
        call SetUnitPathing(u, false)
 
  
        call SetUnitPosition(u, x, y) //( u, p1 )
   
        call SaveInteger(hts, GetHandleId(t), 2, c)
        call SaveReal(hts, GetHandleId(t), 3, inc)
    endif
    

    set t=null
       set u=null
 endfunction

function Trig_clownHaterA_Actions takes nothing returns nothing
local integer i= 0
local unit c= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(c))
local real face= GetUnitFacing(c)
local real x= GetUnitX(c) - 60 * Cos(face * bj_DEGTORAD)
local real y= GetUnitY(c) - 60 * Sin(face * bj_DEGTORAD)
//local real x = GetUnitX(c)
//local real y = GetUnitY(c)


local real xi= x - 70
local real yi= y - 70
local real xf= x + 70
local real yf= y + 70


local real inc= 63

local unit hater
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

  


call SetUnitTimeScale(c, 3)
 call PlaySoundOnUnitBJ(gg_snd_hello, 100, c)
   loop
    exitwhen i > 11
     set x=GetRandomReal(xi, xf)
     set y=GetRandomReal(yi, yf)
     set haters[i]=(NewTimerEx(0)) // INLINED!!
     set hater=CreateUnit(Player(id), haterdummy, x, y, face)
       call SaveUnitHandle(hts, GetHandleId(haters[i]), 0, hater)
       call SaveReal(hts, GetHandleId(haters[i]), 1, face)
       call SaveInteger(hts, GetHandleId(haters[i]), 2, 31) //count
       call SaveReal(hts, GetHandleId(haters[i]), 3, inc)
       call SaveReal(hts, GetHandleId(haters[i]), StringHash("spcast"), inspired)
       call TimerStart(haters[i], 0.02, true, function CHtU)
 
       
     set i=i + 1
     call TriggerSleepAction(0.03)
     call PlaySoundOnUnitBJ(gg_snd_launcharrow, 70, c)
   endloop



  // call TriggerSleepAction(3)
   call SetUnitTimeScale(c, 1)
   
   set c=null
endfunction

