function Trig_dialogues_Conditions takes nothing returns boolean
    return GetOwningPlayer(GetTriggerUnit()) == Player(10) and GetUnitPointValue(GetTriggerUnit()) == 41
endfunction

function Trig_dialogues_Actions takes nothing returns nothing
local trigger trg= GetTriggeringTrigger()
 local integer id= LoadInteger(HTsets, GetHandleId(trg), 1) - 7
 local unit u= GetTriggerUnit()
 local real face= GetUnitFacing(u)
  
 call DisableTrigger(trg)
   if GetRandomInt(0, 6) == 3 then
   call MakeFaceToUnit(u , udg_PHero[id])
   call TriggerSleepAction(0.5)
   call UnitChat(s__dialg[(udg_Plugar[id])*(22)+GetRandomInt(0, 20)] , u)
   
   call TriggerSleepAction(4)
   call SetUnitFacing(u, face)
   
   elseif GetRandomInt(0, 3) == 1 then
   
   call MakeFaceToUnit(u , udg_PHero[id])
   call TriggerSleepAction(0.5)
   call UnitChat(s__dialg[(0)*(22)+GetRandomInt(0, 19)] , u)
   
    if GetRandomInt(0, 6) == 3 then
       call TriggerSleepAction(1.5)
       call MakeFaceToUnit(u , udg_PHero[id])
       call TriggerSleepAction(0.5)
       call UnitChat(s__dialg[(udg_Plugar[id])*(22)+GetRandomInt(0, 20)] , u)
     endif
    
      call TriggerSleepAction(4)
      call SetUnitFacing(u, face)
   endif
  
  call EnableTrigger(trg)
  set u=null
  set trg=null

endfunction

