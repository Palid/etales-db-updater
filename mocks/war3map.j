function GetNextClass takes unit u returns integer
 local integer i= GetUnitPointValue(u)
 return ( i - nextclass__POINT_VARIANT )
endfunction

function NextClass takes integer id,unit u returns unit
 local unit a= null
 local location p= GetUnitLoc(u)
 local real x= GetLocationX(p)
 local real y= GetLocationY(p)
 local integer exp= GetHeroXP(u)
 local integer i= 0

 
 
 
 
 call RemoveLocation(p)
 set p=null
 
 //rescueing inventory
  loop
     exitwhen i > 5
     
       call UnitRemoveItemFromSlot(u, i)
    
     set i=i + 1
    endloop

 //making the new hero
 set a=CreateUnit(Player(id), udg_HeroTipe[GetNextClass(u)], x, y, 270)
 set udg_PHero[id]=a
 call SetHeroXP(udg_PHero[id], exp, false)
    
 call SetHeroAgi(udg_PHero[id], GetHeroAgi(u, false), true)
 call SetHeroStr(udg_PHero[id], GetHeroStr(u, false), true)
 call SetHeroInt(udg_PHero[id], GetHeroInt(u, false), true)

 call SetUnitUserData(udg_PHero[id], 1)
 call AdjustPlayerStateBJ(7, GetOwningPlayer(u), PLAYER_STATE_RESOURCE_LUMBER)
 call RemoveUnit(u)
 set u=null
 
    call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
    call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
    call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
    call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
 //call TriggerRegisterUnitEvent( gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED )//for vampiric shield
 call AddProfaner(id) //Trigger registrado
 return a
endfunction



//library nextclass ends
//library BigInt:


        function s__BigInt__get_previous takes integer this returns integer
            return BigInt__p[this]
        endfunction
        function s__BigInt__get_next takes integer this returns integer
            return BigInt__n[this]
        endfunction
        function s__BigInt__get_digit takes integer this returns integer
            return BigInt__v[this]
        endfunction
        function s__BigInt__set_digit takes integer this,integer y returns nothing
            set BigInt__v[this]=y
        endfunction
        function s__BigInt__get_end takes integer this returns boolean
            return BigInt__e[this]
        endfunction
        
        //copy
        function s__BigInt_c0 takes nothing returns boolean
            local integer y
            local integer z
            local integer q
            local integer k=BigInt__td
            
            //allocate a new big int
            if ( 0 == BigInt__n[0] ) then
                set BigInt__i=BigInt__i + 1
                set z=BigInt__i
            else
                set z=BigInt__n[0]
                set BigInt__n[0]=BigInt__n[z]
            endif
            set BigInt__e[z]=true //mark head
            set BigInt__b[z]=BigInt__b[k] //copy base
            set BigInt__v[z]=0 //reset value to 0
            set q=z //move current node to head
            
            //loop through each each node
            loop
                set k=BigInt__n[k] //get next node
                exitwhen BigInt__e[k] //exitwhen at head
                
                //allocate new node
                if ( 0 == BigInt__n[0] ) then
                    set BigInt__i=BigInt__i + 1
                    set y=BigInt__i
                else
                    set y=BigInt__n[0]
                    set BigInt__n[0]=BigInt__n[y]
                endif
                
                //add new node to copied big int
                set BigInt__n[q]=y
                set BigInt__p[y]=q
                
                set BigInt__v[y]=BigInt__v[k] //copy value
                
                //go to next node
                set q=y
            endloop
            
            //tie BigInt to head
            set BigInt__p[z]=q
            set BigInt__n[q]=z
            
            //return head
            set BigInt__dz=z
            
            return true
        endfunction
        function s__BigInt_copy takes integer this returns integer
            set BigInt__td=this
            //call c0





                call TriggerEvaluate(BigInt__y8)

            return BigInt__dz
        endfunction
        
        //addBig
        function s__BigInt_a1 takes nothing returns boolean
            local integer y=BigInt__td
            local integer a
            local integer z=(Base__s[(BigInt__b[y])]) // INLINED!!
            local integer q=0
            local integer m
            local integer g=BigInt__dz
            local integer k=BigInt__my
            
            //loop through first big int and add extra power to it
            loop
                //if no current node, allocate new
                if ( BigInt__e[BigInt__n[y]] ) then
                    //allocate
                    if ( 0 == BigInt__n[0] ) then
                        set BigInt__i=BigInt__i + 1
                        set a=BigInt__i
                    else
                        set a=BigInt__n[0]
                        set BigInt__n[0]=BigInt__n[a]
                    endif
                    //add to big int
                    set BigInt__p[a]=y
                    set BigInt__n[a]=BigInt__td
                    set BigInt__n[y]=a
                    set BigInt__p[BigInt__td]=a
                    
                    //set value to 0
                    set BigInt__v[a]=0
                endif
                
                //go to next node
                set y=BigInt__n[y]
                
                //exitwhen there is no more extra power to add
                exitwhen 0 == g
                set g=g - 1
            endloop
            
            //add second big int to current big int
            loop
                //go to next node on second big int (starts on first)
                set k=BigInt__n[k]
                
                //add values of 2 nodes together (first and first)
                set BigInt__v[y]=BigInt__v[y] + BigInt__v[k]
                
                //remainder node (used for looping through until remainder is gone)
                //adding 2 digits together like 9+9 in base 10 results in 18, which
                //can't fit in 1 digit
                //set to first node on digit being added (second digit)
                set m=y
                loop
                    //loop until the base size is bigger than the value in current digit
                    //for example, base 10 would loop until digit was smaller than 10
                    exitwhen z > BigInt__v[m]
                    set q=BigInt__v[m] / z //cut out extra numbers in current digit (what goes into next digit)
                    set BigInt__v[m]=BigInt__v[m] - BigInt__v[m] / z * z //retrieve remainder (what goes into current digit)
                    
                    //if no node, allocate
                    if ( BigInt__e[BigInt__n[m]] ) then
                        //allocate
                        if ( 0 == BigInt__n[0] ) then
                            set BigInt__i=BigInt__i + 1
                            set a=BigInt__i
                        else
                            set a=BigInt__n[0]
                            set BigInt__n[0]=BigInt__n[a]
                        endif
                        
                        //add to big int
                        set BigInt__p[a]=m
                        set BigInt__n[a]=BigInt__td
                        set BigInt__n[m]=a
                        set BigInt__p[BigInt__td]=a

                        set BigInt__v[a]=0 //reset value to 0
                    endif
                    //go to next remainder node (possibly one that was just allocated)
                    set m=BigInt__n[m]
                    //add extra value to current remainder node
                    set BigInt__v[m]=BigInt__v[m] + q
                endloop
                //exitwhen no more nodes left on the integer being added
                exitwhen BigInt__e[BigInt__n[k]]
                //if the current integer is out of digits, allocate new
                if ( BigInt__e[BigInt__n[y]] ) then
                    //allocate
                    if ( 0 == BigInt__n[0] ) then
                        set BigInt__i=BigInt__i + 1
                        set a=BigInt__i
                    else
                        set a=BigInt__n[0]
                        set BigInt__n[0]=BigInt__n[a]
                    endif
                    //add
                    set BigInt__p[a]=y
                    set BigInt__n[a]=BigInt__td
                    set BigInt__n[y]=a
                    set BigInt__p[BigInt__td]=a
                    set BigInt__v[a]=0 //reset value to 0
                endif
                //go to next node
                set y=BigInt__n[y]
            endloop
            return true
        endfunction
        function s__BigInt_addBig takes integer this,integer k,integer g returns nothing
            //make sure power isn't negative and that
            //bases between both big ints are the same
                //make sure second big int is > 0
                if ( 0 < BigInt__v[BigInt__p[k]] ) then
                    set BigInt__td=this
                    set BigInt__my=k
                    set BigInt__dz=g
                    //call a1





                        call TriggerEvaluate(BigInt__y9)

                endif
        endfunction
        //multiplyBig nested loop, read multiplyBig below first
        function s__BigInt_m2 takes nothing returns boolean
            local integer q=BigInt__td2
            local integer m=BigInt__dz
            local integer a
            local integer k=BigInt__my3
            
            //loop through each digit in the buffer
            //remember that every digit in the multiplier is multiplied by
            //every digit in the number being multiplied
            
            //the buffer contains the first number's origial digits
            loop
                set q=q - 1 //buffer index
                
                //if no new node, allocate
                if ( BigInt__e[BigInt__n[m]] ) then
                    //allocate
                    if ( 0 == BigInt__n[0] ) then
                        set BigInt__i=BigInt__i + 1
                        set a=BigInt__i
                    else
                        set a=BigInt__n[0]
                        set BigInt__n[0]=BigInt__n[a]
                    endif
                    
                    //add
                    set BigInt__p[a]=m
                    set BigInt__n[a]=BigInt__td
                    set BigInt__n[m]=a
                    set BigInt__p[BigInt__td]=a
                    
                    //reset value to 0
                    set BigInt__v[a]=0
                endif
                
                //go to next additive digit
                set m=BigInt__n[m]
                
                //add it to the product of the current digits
                set BigInt__v[m]=BigInt__v[m] + s__BigInt_zs[q] * BigInt__v[k]
                
                //exitwhen no more digits in first number left to be multiplied by second number
                exitwhen 0 == q
            endloop
            return true
        endfunction
        //multiplyBig
        function s__BigInt_m1 takes nothing returns boolean
            local integer y=0
            local integer a=BigInt__td
            local integer m=a
            local integer w=a
            local integer k=BigInt__my
            
            //load up all nodes in current big int to buffer
            //this is done because the current big int is going to be
            //modified by every single digit in the next big int (that is how multiplication works)
            //the original digits have to be maintained somewhere so as to know what
            //to multiply by what
            //just multiplying them out without backing up the big int's current digits will
            //cause bad multiplication
            
            //improper
            //8*12=96
            //8*2=16, 16+12=28
            //8*2=160+128=288
            
            //proper
            //8*2=  1|6
            //8*1=  8|  +
            //      -----
            //      9|6 = 96
            //
            //remember operations are done digit by digit, so 80 is never seen
            loop
                set a=BigInt__p[a]
                exitwhen BigInt__e[a]
                set s__BigInt_zs[y]=BigInt__v[a]
                set y=y + 1
            endloop
            
            //reset current big int to 0
            set BigInt__n[BigInt__p[a]]=BigInt__n[0]
            set BigInt__n[0]=BigInt__n[a]
            set BigInt__n[a]=a
            set BigInt__p[a]=a
            
            //loop through second big int
            loop
                set k=BigInt__n[k] //go to next digit on second big int (multiplying)
                exitwhen BigInt__e[k] //exitwhen no more digits
                set BigInt__td2=y //pass last digit in buffer
                
                //remember that in mulitplication, as numbers are added, placeholders are added
                // 11
                // 11 x
                //----
                // 11
                //110 +
                //----
                //121
                
                //this means that the first big int's digit has to be incremented by 1 each time
                //for the placeholder
                // 11
                // 11 x
                //----
                // |1|1
                //1|1| +
                //----
                //1|2|1
                
                //notice how on the second operation (1|1| ), the placeholder is shown as a blank
                //this is how it is done here, because the digit is shifted over 1
                
                set w=BigInt__n[w] //current additive digit in first big int (added)
                set BigInt__dz=w //pass current additive digit
                set BigInt__my3=k //pass second big int
                //call m2





                    call TriggerEvaluate(BigInt__x2)

            endloop
            
            //at the end, the digits are going to have bad values in them
            //so the number has to be reformed so that all of the digits
            //are < base size
            
            set y=0 //extra value that doesn't fit into current digit
            set a=BigInt__td //big int
            set k=(Base__s[(BigInt__b[a])]) //base size // INLINED!!

            //loop through each digit and normalize
            loop
                //if no node, allocate a new one
                if ( BigInt__e[BigInt__n[a]] ) then
                    //allocate
                    if ( 0 == BigInt__n[0] ) then
                        set BigInt__i=BigInt__i + 1
                        set m=BigInt__i
                    else
                        set m=BigInt__n[0]
                        set BigInt__n[0]=BigInt__n[m]
                    endif
                    
                    //add
                    set BigInt__p[m]=a
                    set BigInt__n[m]=BigInt__td
                    set BigInt__n[a]=m
                    set BigInt__p[BigInt__td]=m
                    
                    //reset value to 0
                    set BigInt__v[m]=0
                endif
                
                //go to next digit on big int
                set a=BigInt__n[a]
                
                //add remaining value that couldn't fit into previous digit
                //to current digit's value
                set y=y + BigInt__v[a]
                
                //get remainder of current digit and make it current digit's value
                //(only keeping what fits)
                set BigInt__v[a]=y - y / k * k
                
                //get the bit of the value that didn't actually fit into the digit
                set y=y / k
                
                //exitwhen there are no more nodes to be normalized and there is no
                //extra value left
                exitwhen BigInt__e[BigInt__n[a]] and 0 == y
            endloop
            
            return true
        endfunction
        function s__BigInt_multiplyBig takes integer this,integer k returns nothing
            //bases of both big ints have to be the same
                if ( 0 < BigInt__v[BigInt__p[this]] ) then
                    //make sure second big int is greater than 0
                    if ( 0 < BigInt__v[BigInt__p[k]] ) then
                        set BigInt__td=this
                        set BigInt__my=k
                        //call m1





                            call TriggerEvaluate(BigInt__x1)

                    //if second big int is 0, reset first big int to 0
                    elseif ( 0 == BigInt__v[BigInt__p[k]] and not BigInt__e[BigInt__p[this]] ) then
                        set BigInt__n[BigInt__p[this]]=0
                        set BigInt__n[0]=BigInt__n[this]
                        set BigInt__n[this]=this
                        set BigInt__p[this]=this
                    endif
                endif
        endfunction
        function s__BigInt_create takes integer k returns integer
            local integer z
            //allocate a head
           // call BJDebugMsg("BigInt create in")
            if ( 0 == BigInt__n[0] ) then
                set BigInt__i=BigInt__i + 1
                set z=BigInt__i
            else
                set z=BigInt__n[0]
                set BigInt__n[0]=BigInt__n[z]
            endif
            set BigInt__e[z]=true //mark as head
            set BigInt__b[z]=k //set base
            
            //link to itself
            set BigInt__n[z]=z
            set BigInt__p[z]=z
            
            //reset value to 0
            set BigInt__v[z]=0
                  //  call BJDebugMsg("BigInt create out done")
            return z
        endfunction
        //add
        function s__BigInt_a0 takes nothing returns boolean
            local integer y=BigInt__td
            local integer a
            local integer z=BigInt__my3
            local integer k=BigInt__td2
            
            //first go to the correct digit
            //z refers to the *extra* g, so just loop from right to left
            //until no remaining g
            //1 g of 1 in base 10 would actually be 1*10^1, or 10
            loop
                //if no next node
                if ( BigInt__e[BigInt__n[y]] ) then
                    //allocate new
                    if ( 0 == BigInt__n[0] ) then
                        set BigInt__i=BigInt__i + 1
                        set a=BigInt__i
                    else
                        set a=BigInt__n[0]
                        set BigInt__n[0]=BigInt__n[a]
                    endif
                    
                    //add
                    set BigInt__p[a]=y
                    set BigInt__n[a]=BigInt__td
                    set BigInt__n[y]=a
                    set BigInt__p[BigInt__td]=a
                    
                    //reset value to 0
                    set BigInt__v[a]=0
                endif
                //go to next node
                set y=BigInt__n[y]
                //exitwhen no extra power left
                exitwhen 0 == z
                set z=z - 1
            endloop
            set z=(Base__s[(BigInt__b[BigInt__td])]) // INLINED!!
            //this will add the digit to the array
            //example in base 10 of 10+13
            //{1,0}+13p0 (1,0+13) (d being digit to add to)
                //{1,13}+0d1 (13/10=1, 13%10=3)
                //{1,3}+1d1 (1+1,3)
                //{2,3}+0d2 (exit as 2 < 10) -> (exitwhen v[y] < z)
            loop
                //add value to current digit
                set BigInt__v[y]=BigInt__v[y] + k
                //exitwhen the current digit's value fits into the digit
                //value < base size
                exitwhen z > BigInt__v[y]
                //if it didn't fit, get the portion that didn't fit
                set k=BigInt__v[y] / z
                //put the bit that did fit into the digit
                set BigInt__v[y]=BigInt__v[y] - k * z
                //if no next node, allocate
                if ( BigInt__e[BigInt__n[y]] ) then
                    //allocate
                    if ( 0 == BigInt__n[0] ) then
                        set BigInt__i=BigInt__i + 1
                        set a=BigInt__i
                    else
                        set a=BigInt__n[0]
                        set BigInt__n[0]=BigInt__n[a]
                    endif
                    //add
                    set BigInt__p[a]=y
                    set BigInt__n[a]=BigInt__td
                    set BigInt__n[y]=a
                    set BigInt__p[BigInt__td]=a
                    //reset value to 0
                    set BigInt__v[a]=0
                endif
                //go to next node
                set y=BigInt__n[y]
            endloop
            return true
        endfunction
        //adds k to number
        //k may be any positive whole number
        function s__BigInt_add takes integer this,integer k,integer g returns nothing
            //ensure that extra power isn't negative
                //ensure that value being added is greater than 0
                if ( 0 < k ) then
                    set BigInt__td=this //pass this
                    set BigInt__my3=g //pass extra power
                    set BigInt__td2=k //pass value






                        call TriggerEvaluate(BigInt__y0)

                endif
        endfunction
        //multiply
        function s__BigInt_ml takes nothing returns boolean
            local integer y=BigInt__td
            local integer z=(Base__s[(BigInt__b[BigInt__td])]) // INLINED!!
            local integer a
            local integer k=BigInt__my
            local integer q
            //first multiply every single digit by the multiplier
            loop
                set y=BigInt__n[y]
                exitwhen BigInt__e[y]
                set BigInt__v[y]=BigInt__v[y] * k
            endloop
            set y=BigInt__td
            //loop through the number and re add any digits that are >= the base
            //efficient adding as the g is already known (g is current node +1)
            //normalize the number
            loop
                set y=BigInt__n[y] //go to next node
                exitwhen BigInt__e[y] //exitwhen no more nodes
                set q=y //store as normalizing node (gets looped thru until normalized)
                loop
                    //exitwhen value fits into actual digit (< base)
                    exitwhen z > BigInt__v[q]
                    //if no next node
                    if ( BigInt__e[BigInt__n[q]] ) then
                        //allocate
                        if ( 0 == BigInt__n[0] ) then
                            set BigInt__i=BigInt__i + 1
                            set a=BigInt__i
                        else
                            set a=BigInt__n[0]
                            set BigInt__n[0]=BigInt__n[a]
                        endif
                        //add
                        set BigInt__p[a]=q
                        set BigInt__n[a]=BigInt__td
                        set BigInt__n[q]=a
                        set BigInt__p[BigInt__td]=a
                        //reset to 0
                        set BigInt__v[a]=0
                    endif
                    //put extra value into next node
                    set BigInt__v[BigInt__n[q]]=BigInt__v[BigInt__n[q]] + BigInt__v[q] / z
                    //put value that fit into current node
                    set BigInt__v[q]=BigInt__v[q] - BigInt__v[q] / z * z
                endloop
            endloop
            return true
        endfunction
        function s__BigInt_multiply takes integer this,integer k returns nothing
            //ensure value is > 0
            if ( 0 < k ) then
                //ensure big int value is > 0
                if ( 0 < BigInt__v[BigInt__p[this]] ) then
                    set BigInt__td=this //pass this
                    set BigInt__my=k //pass value
                    //call ml





                        call TriggerEvaluate(BigInt__x)

                endif
            //if value is 0, reset big int to 0
            elseif ( 0 == k and not BigInt__e[BigInt__p[this]] ) then
                set BigInt__n[BigInt__p[this]]=BigInt__n[0]
                set BigInt__n[0]=BigInt__n[this]
                set BigInt__n[this]=this
                set BigInt__p[this]=this
            endif
        endfunction
        //adds number to left
        function s__BigInt_enq takes integer this,integer k returns nothing
            local integer y=BigInt__p[this]
            local integer z
            local integer a=(Base__s[(BigInt__b[this])]) // INLINED!!
            //add the digit to itself, this way it doesn't mix with
            //the current number and it is grouped properly into the base
            loop
                //allocate new node (remember it's not being mixed in at all)
                if ( 0 == BigInt__n[0] ) then
                    set BigInt__i=BigInt__i + 1
                    set z=BigInt__i
                else
                    set z=BigInt__n[0]
                    set BigInt__n[0]=BigInt__n[z]
                endif
                //add
                set BigInt__p[z]=y
                set BigInt__n[z]=BigInt__n[y]
                set BigInt__n[y]=z
                set BigInt__p[BigInt__n[z]]=z
                //store current value
                set BigInt__v[z]=k
                //exitwhen the value fits into the digit
                exitwhen a > BigInt__v[z]
                set y=z //store y as previously added node (bit more efficient for adding digit)
                //if it didn't fit, get bit that didn't fit
                set k=BigInt__v[y] / a
                //put bit that did fit into the digit
                set BigInt__v[y]=BigInt__v[y] - k * a
            endloop
        endfunction
        //removes digit from left
        function s__BigInt_deq takes integer this returns integer
            local integer z=BigInt__p[this]
            //if there is a digit to the left, just recycle it
            if ( not BigInt__e[z] ) then
                set BigInt__p[this]=BigInt__p[z]
                set BigInt__n[BigInt__p[z]]=this
                set BigInt__n[z]=BigInt__n[0]
                set BigInt__n[0]=z
                //return value of recycled digit
                return BigInt__v[z]
            endif
            //return 0 if there was no digit to dequeue
            return 0
        endfunction
        //pushes number on to number
        //push(10,11) = 1011
        function s__BigInt_push takes integer this,integer k returns nothing
            local integer y=this
            local integer z
            local integer a=(Base__s[(BigInt__b[this])]) // INLINED!!
            //add the digit to itself, this way it doesn't mix with
            //the current number and it is grouped properly into the base
            loop
                //allocate (remember that it's not beign mixed in at all)
                if ( 0 == BigInt__n[0] ) then
                    set BigInt__i=BigInt__i + 1
                    set z=BigInt__i
                else
                    set z=BigInt__n[0]
                    set BigInt__n[0]=BigInt__n[z]
                endif
                //add
                set BigInt__p[z]=y
                set BigInt__n[z]=BigInt__n[y]
                set BigInt__n[y]=z
                set BigInt__p[BigInt__n[z]]=z
                //set digit value to value being pushed
                set BigInt__v[z]=k
                //exitwhen value fits
                exitwhen a > BigInt__v[z]
                //store previous node
                set y=z
                //get portion that didn't fit
                set k=BigInt__v[y] / a
                //get portion that did
                set BigInt__v[y]=BigInt__v[y] - k * a
            endloop
        endfunction
        //simply pops off the right most digit and returns it
        function s__BigInt_pop takes integer this returns integer
            local integer z=BigInt__n[this]
            //only pop if there 
            if ( not BigInt__e[z] ) then
                set BigInt__n[this]=BigInt__n[z]
                set BigInt__p[BigInt__n[z]]=this
                set BigInt__n[z]=BigInt__n[0]
                set BigInt__n[0]=z
                
                //return popped digit
                return BigInt__v[z]
            endif
            //return 0 if there was no digit to pop
            return 0
        endfunction
        //rotate number right
        function s__BigInt_rr takes integer this returns nothing
            //123
            //head->3->2->1->head
            
            //move 1 to right side of head
            //2->head->1
            //2->head->1->3->2
            //
            //123 -> 231
            
            local integer z
            set z=BigInt__p[this] //highest digit
            
            //move highest digit from left to the right side of head
            set BigInt__n[z]=BigInt__n[this]
            set BigInt__p[BigInt__n[z]]=z
            
            //make head point to new highest digit
            set BigInt__p[this]=BigInt__p[z]
            set BigInt__n[BigInt__p[z]]=this
            
            //finish moving old highest digit to new position
            set BigInt__p[z]=this
            set BigInt__n[this]=z
        endfunction
        //rotate left
        function s__BigInt_rl takes integer this returns nothing
            //123
            //head->3->2->1->head
            
            //move 3 to left side of head
            //3->head->2->1->3
            //
            //123 -> 312
        
            local integer z
            set z=BigInt__n[this] //smallest digit
            
            //move smallest digit from right to left side of head
            set BigInt__p[z]=BigInt__p[this]
            set BigInt__n[BigInt__p[z]]=z
            
            //make head point to new lowest digit
            set BigInt__n[this]=BigInt__n[z]
            set BigInt__p[BigInt__n[z]]=this
            
            //finish moving old lowest digit to new position
            set BigInt__n[z]=this
            set BigInt__p[this]=z
        endfunction
        //mod
        function s__BigInt_m0 takes nothing returns boolean
            local integer z=0
            local integer q=BigInt__td
            local integer u=(Base__s[(BigInt__b[q])]) // INLINED!!
            local integer k=BigInt__my
            //add up modulos of all digits
            loop
                //go to next node
                set q=BigInt__p[q]
                exitwhen BigInt__e[q] //exitwhen no nodes left
                
                set z=z * u + BigInt__v[q] //set remainder to remainder +  current digit (remember to account for placeholder
                                    //by multipying remainder by base size)
                
                set z=z - z / k * k //takes modulos of remainder
            endloop
            //return modulos
            set BigInt__dz=z
            return true
        endfunction
        function s__BigInt_mod takes integer this,integer k returns integer
            set BigInt__td=this //pass this
            set BigInt__my=k //pass modulos value
            
            if ( 0 == BigInt__v[BigInt__p[this]] or 0 == k ) then
                return 0
            endif
            
            //call m0





                call TriggerEvaluate(BigInt__y7)

            return BigInt__dz //return modulos (remainder)
        endfunction
        //destroys the entire integer
        function s__BigInt_destroy takes integer this returns nothing
                //make last node on big int point to first node in recycler
                set BigInt__n[BigInt__p[this]]=BigInt__n[0]
                //make recycler point to first node on big int
                set BigInt__n[0]=this
                //unmark head as a head
                set BigInt__e[this]=false
        endfunction
        //toString
        function s__BigInt_tos takes nothing returns boolean
            local string q=""
            local integer y=BigInt__td
            local integer z=BigInt__b[y]
            //loop through the entire number and convert each integer into a
            //char
            loop
                set y=BigInt__n[y]
                exitwhen BigInt__e[y]
                set q=(LoadStr(Table__ht, (((Base__t[(z)]))), (- (BigInt__v[y])))) + q //remember numbers are shown backwards // INLINED!!
                                            //123
                                            //"3"
                                            //"2"+"3"
                                            //"1"+"23"
                                            //"123"
            endloop
            //if string is empty, return 0
            if ( q == "" ) then
                set BigInt__yy=(LoadStr(Table__ht, (((Base__t[(z)]))), (- (0)))) // INLINED!!
            //return string
            else
                set BigInt__yy=q
            endif
            return true
        endfunction
        function s__BigInt_toString takes integer this returns string
            set BigInt__td=this //pass this
            //call tos





                call TriggerEvaluate(BigInt__y6)

            //return string
            return BigInt__yy
        endfunction
        
        function s__BigInt_xB takes nothing returns boolean
            local integer u=4
            loop
                call s__BigInt_a0()
                if ( BigInt__e[BigInt__p[s__BigInt_eq]] ) then
                    return true
                endif
                call s__BigInt_ml()
                
                set s__BigInt_ub=BigInt__p[s__BigInt_eq]
                set BigInt__p[s__BigInt_eq]=BigInt__p[s__BigInt_ub]
                set BigInt__td2=BigInt__v[s__BigInt_ub]
                set BigInt__n[s__BigInt_ub]=BigInt__n[0]
                set BigInt__n[0]=s__BigInt_ub
                
                set u=u - 1
                exitwhen 0 == u
            endloop
            return false
        endfunction
        //convert to any base
        function s__BigInt_ch takes nothing returns boolean
            local integer q=BigInt__td
            local integer u
            local integer k
            
            //first allocate a new big int to perform operations on
            if ( 0 == BigInt__n[0] ) then
                set BigInt__i=BigInt__i + 1
                set k=BigInt__i
            else
                set k=BigInt__n[0]
                set BigInt__n[0]=BigInt__n[k]
            endif
            //mark new big int as head
            set BigInt__e[k]=true
            
            //remove highest digit from current number
            set u=BigInt__p[q]
            set BigInt__p[q]=BigInt__p[u]
            
            //add it to new big int
            set BigInt__p[k]=u
            set BigInt__n[k]=u
            set BigInt__p[u]=k
            set BigInt__n[u]=k
            
            //make new big int's base target base
            set BigInt__b[k]=BigInt__td2
            
            //reset value of head to 0
            set BigInt__v[k]=0
            
            //pass args to add and multiply
            set BigInt__my=(Base__s[((BigInt__b[BigInt__td]))]) //multiply by target base size // INLINED!!
            set BigInt__my3=0
            set BigInt__td=k
            set BigInt__td2=BigInt__v[u] //add highest digit value
            set BigInt__v[u]=0 //resetting the node value to 0 since it's being passed to add
            set s__BigInt_eq=q
            set s__BigInt_ub=u
            
            //loop through the number from left to right
            //add current digit to the new big int
            //exitwhen out of digits
            //multiply new big int by current base of number, not the target base
            //no need to allocate new digits as that's done in add/multiply
            
            //123
            //1*10=10
            //10+2=12*10=120
            //120+3=123
            //exit
            loop
                exitwhen TriggerEvaluate(BigInt__xb)
            endloop
            //make current big int point to digits in the new big int that was worked on
            //then deallocate the new big int
            
            //point
            set BigInt__n[q]=BigInt__n[k]
            set BigInt__p[q]=BigInt__p[k]
            set BigInt__p[BigInt__n[k]]=q
            set BigInt__n[BigInt__p[k]]=q
            
            //deallocate worked on big int
            set BigInt__n[k]=BigInt__n[0]
            set BigInt__n[0]=k
            set BigInt__e[k]=false
            return true
        endfunction
        
        function s__BigInt__set_base takes integer this,integer k returns nothing
            //only change the digits if the base size isn't equal to target base size
            //and the number isn't empty
            if ( (Base__s[(BigInt__b[this])]) != (Base__s[(k)]) and not BigInt__e[BigInt__n[this]] ) then // INLINED!!
                set BigInt__td=this //pass this
                set BigInt__td2=k //pass target base
                call s__BigInt_ch()
            endif
            //update base
            set BigInt__b[this]=k





        endfunction
        
        //only use when big int is holding value that can fit into an integer
        function s__BigInt_toInt takes integer this returns integer
            local integer k=0
            local integer z=(Base__s[(BigInt__b[this])]) // INLINED!!
            
            //work from left to right-
            //123
            //1*10+2=12
            //12*10+3=123
            //exit
            loop
                set this=BigInt__p[this]
                exitwhen BigInt__e[this]
                set k=k * z
                set k=k + BigInt__v[this]
            endloop
            return k
        endfunction
        //divide
        function s__BigInt_div takes nothing returns boolean
            local integer z=0
            local integer a=BigInt__td
            local integer y=a
            local integer h=(Base__s[(BigInt__b[a])]) // INLINED!!
            local integer k=BigInt__my
            
            //loop until the number is big enough to be divided by
            //just merge the digits together into 1 big digit
            //1|2|3 -> |123|
            
            //123/10 = 12|3, 3 is returned as remainder and 12 is new
            //big int value
            set y=BigInt__p[y]
            loop
                //remember to account for placeholder by base
                set z=z * h + BigInt__v[y]
                exitwhen BigInt__e[BigInt__p[y]] or z >= k
                set BigInt__n[y]=BigInt__n[0]
                set BigInt__n[0]=y
                set y=BigInt__p[y]
            endloop
            
            //updated highest digit on big int
            set BigInt__p[a]=y
            set BigInt__n[y]=a
            
            //loop through and divide until no digits left
            //1234/10 -> 12|3|4 -> 1|23|4 -> 1|2|34 -> 1|2|3 remainder 4
            //note that the remainder is just passed down through each operation
            loop
                set BigInt__v[y]=z / k //digit current digit by k
                set z=z - BigInt__v[y] * k //get remainder (what's too small to go into current digit)
                set y=BigInt__p[y] //go to previous digit (left to right)
                exitwhen BigInt__e[y] //exitwhen no more digits
                set z=z * h + BigInt__v[y] //add remainder to current digit accounting for placeholder
                                    //by multiplying it by base size
            endloop
            //go back to head
            set y=a
            //clear out all of the 0s in front of the big int
            //1|2|3|4/10 = 0|1|2|3 remainder 4
            //the 0 needs to be cleared
            loop
                set y=BigInt__p[y]
                exitwhen 0 != BigInt__v[y] or BigInt__e[y]
                set BigInt__n[y]=BigInt__n[0]
                set BigInt__n[0]=y
            endloop
            //make head point to new highest digit
            set BigInt__p[a]=y
            set BigInt__n[y]=a
            //return remainder
            set BigInt__my=z
            return true
        endfunction
        //returns remainder
        function s__BigInt_divide takes integer this,integer k returns integer
            //ensure modulos is greater than 0 and big int is bigger than 0
            if ( 0 < k and 0 < BigInt__v[BigInt__p[this]] ) then
                set BigInt__td=this //pass this
                set BigInt__my=k //pass divisor





                    call TriggerEvaluate(BigInt__x4)

            else
                return 0
            endif
            //return remainder
            return BigInt__my
        endfunction
        //convertString
        function s__BigInt_s2 takes nothing returns boolean
            local integer d=BigInt__td
            local string k=BigInt__yy
            local integer y
            local integer z
            local integer h=StringLength(k)
            
            //first ensure that the string can be represented by the base (no invalid characters)
            if ( not s__Base_isValid(d,k) ) then
                //if it can't, return 0 as the head, meaning a null big int
                set BigInt__td=0
                return true
            endif
            
            //allocate head
            if ( 0 == BigInt__n[0] ) then
                set BigInt__i=BigInt__i + 1
                set z=BigInt__i
            else
                set z=BigInt__n[0]
                set BigInt__n[0]=BigInt__n[z]
            endif
            //mark as head
            set BigInt__e[z]=true
            //point to itself
            set BigInt__b[z]=d
            set BigInt__n[z]=z
            set BigInt__p[z]=z
            //reset value to 0
            set BigInt__v[z]=0
            
            //loop through each character in the string
            loop
                set h=h - 1
                //allocate new node
                if ( 0 == BigInt__n[0] ) then
                    set BigInt__i=BigInt__i + 1
                    set y=BigInt__i
                else
                    set y=BigInt__n[0]
                    set BigInt__n[0]=BigInt__n[y]
                endif
                //set value of new node to value of character in the string
                set BigInt__v[y]=(LoadInteger(Table__ht, (Base__t[(d)]), (Char2Ascii((SubString(k, h, h + 1)))))) // INLINED!!
                //add new node to big int
                set BigInt__p[y]=BigInt__p[z]
                set BigInt__n[y]=z
                set BigInt__n[BigInt__p[z]]=y
                set BigInt__p[z]=y
                //exitwhen no more chars
                exitwhen 0 == h
            endloop
            //return new big int
            set BigInt__td=z
            return true
        endfunction
        function s__BigInt_convertString takes string k,integer y returns integer
            set BigInt__yy=k //pass string
            set BigInt__td=y //pass base
            //call s2





                call TriggerEvaluate(BigInt__x5)

            //return created big int
            return BigInt__td
        endfunction
        function s__BigInt__get_base takes integer this returns integer
            return BigInt__b[this]
        endfunction
//Implemented from module BigInt__IntMod:
        function s__BigInt_BigInt__IntMod___onInit takes nothing returns nothing
            //trigger methods
            call TriggerAddCondition(BigInt__x, Condition(function s__BigInt_ml))
            call TriggerAddCondition(BigInt__x4, Condition(function s__BigInt_div))
            call TriggerAddCondition(BigInt__x5, Condition(function s__BigInt_s2))
            call TriggerAddCondition(BigInt__y0, Condition(function s__BigInt_a0))
            call TriggerAddCondition(BigInt__y7, Condition(function s__BigInt_m0))
            call TriggerAddCondition(BigInt__y6, Condition(function s__BigInt_tos))
            call TriggerAddCondition(BigInt__y8, Condition(function s__BigInt_c0))
            call TriggerAddCondition(BigInt__y9, Condition(function s__BigInt_a1))
            call TriggerAddCondition(BigInt__x1, Condition(function s__BigInt_m1))
            call TriggerAddCondition(BigInt__x2, Condition(function s__BigInt_m2))
            call TriggerAddCondition(BigInt__xb, Condition(function s__BigInt_xB))
        endfunction

