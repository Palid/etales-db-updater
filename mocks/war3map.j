endfunction

function hrwda takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))

  if orckiller[id] == true then
     
   call AddHeroXP(udg_PHero[id], orcskilled[id], true)

   
   call UnitChat("Exchanged |cffffcc00" + I2S(orcskilled[id]) + " EXP|r for current Orc hunting season" , hussarl)
   set orcskilled[id]=0
   //set orckiller[id] = false
   
   
   
   call TriggerSleepAction(7)
   call UnitChat("Thank you for your effort." , hussarl)

   else
    call UnitChat("You don't have a valid Safe-conduit. Please fill your aplication sheet before" , hussarl)
   endif
endfunction

