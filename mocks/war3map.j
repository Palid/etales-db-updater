// Trigger: acostarse
//===========================================================================
   //gg_unit_h02L_0647 )//ogro
   //gg_unit_h00V_0646 )//tauren
   //gg_unit_h02K_0724 )//tuskar
   //gg_unit_h02M_0725 )//bandit
   //gg_unit_h02O_0739 )//panda
   //gg_unit_h02N_0726 )//rexxar

function Trig_acostarse_Actions takes nothing returns nothing
local integer i= 0

 call IssuePointOrder(gg_unit_h02L_0647, "move", - 1938, 6189)
  call TriggerSleepAction(0.2)
 call IssuePointOrder(gg_unit_h00V_0646, "move", 5467, 14857)
  call TriggerSleepAction(0.2)
 call IssuePointOrder(gg_unit_h02K_0724, "move", - 5629, - 7286)
  call TriggerSleepAction(0.2)
 call IssuePointOrder(gg_unit_h02M_0725, "move", 1584, - 5081)
  call TriggerSleepAction(0.2)
 call IssuePointOrder(gg_unit_h02O_0739, "move", 8480, - 9300)
  call TriggerSleepAction(0.2)
 call IssuePointOrder(gg_unit_h02N_0726, "move", 13000, - 12306)
  call TriggerSleepAction(0.2)
 
 call TriggerSleepAction(40)
 
loop
 exitwhen i > 11
 call RemoveItemFromStock(gg_unit_h02L_0647, smgItemA[i])
 call RemoveItemFromStock(gg_unit_h00V_0646, smgItemB[i])
 call RemoveItemFromStock(gg_unit_h02K_0724, smgItemC[i])
 call RemoveItemFromStock(gg_unit_h02M_0725, smgItemD[i])
 call RemoveItemFromStock(gg_unit_h02O_0739, smgItemE[i])
 call RemoveItemFromStock(gg_unit_h02N_0726, smgItemF[i])
 
  set smgItemA[i]=0
  set smgItemB[i]=0
  set smgItemC[i]=0
  set smgItemD[i]=0
  set smgItemE[i]=0
  set smgItemF[i]=0
 
 set i=i + 1
 endloop
endfunction

