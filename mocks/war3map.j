//TESH.alwaysfold=0
function Trig_leftarea_Conditions takes nothing returns boolean
    local unit u= GetLeavingUnit()
    local boolean onTpvp= tleaver[GetPlayerId(GetOwningPlayer(u))] == false and IsUnitType(u, UNIT_TYPE_HERO) == true and IsPlayerInForce(GetOwningPlayer(u), teamEventForce) == true and IsUnitInGroup(u, diedheroes) == false
    set u=null
    return onTpvp
endfunction

    function settingteamout takes nothing returns nothing
      call MakeAlly(GetOwningPlayer(GetLeavingUnit()) , GetEnumPlayer())
      call MakeAlly(GetEnumPlayer() , GetOwningPlayer(GetLeavingUnit()))
    endfunction


function Trig_leftarea_Actions takes nothing returns nothing
   local integer id= GetPlayerId(GetOwningPlayer(GetLeavingUnit()))
   local string left= "|cffffcc00"
   local string team
      
      set tleaver[id]=true
      // call ForceRemovePlayer(teamEventForce,Player(id))  
      // call ForForce(teamEventForce, function settingteamout )
       if IsPlayerInForce(Player(id), teamA) == true then
            set teamAp=teamAp - 3
            set team="|cffcd853fVillains|r "
            if teamAp <= 0 then
              call EndTeamEvent(teamA)
            endif
       elseif IsPlayerInForce(Player(id), teamB) == true then
            set teamBp=teamBp - 3
            set team="|cff6495edHeroes|r "
            if teamBp <= 0 then
             call EndTeamEvent(teamB)
            endif
       endif
     
     set left=left + GetPlayerName(Player(id)) + "|r leaves the battle, |cffaaaaaa(-3)|r to " + team
       
   if IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) then
       call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 6, left)
   endif
   call UpdateLeaderBoard()
   
endfunction

