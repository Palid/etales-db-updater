function Trig_slaycentaur_Conditions takes nothing returns boolean
    return IsUnitInGroup(GetDyingUnit(), centaurss)
endfunction

function Trig_slaycentaur_Actions takes nothing returns nothing
  set centaursleft=centaursleft - 1
  call GroupRemoveUnit(centaurss, GetDyingUnit())
  
   if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) == true ) then
       call ClearTextMessages()
   endif
    call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "|cffffcc00Centaurs left:|r " + I2S(centaursleft))
    
   set centaurg=null
   set centaurg=FirstOfGroup(centaurss)
   
   if centaurg != null then
      call ForGroup(vguard, function ankitattack)
   endif
   
endfunction

