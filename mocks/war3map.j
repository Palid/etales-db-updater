function InitTrig_ESS takes nothing returns nothing
  local integer i= 0
    set gg_trg_ESS=CreateTrigger()
    
    loop
    exitwhen i > 12
    
      call TriggerRegisterUnitEvent(gg_trg_ESS, udg_PHero[i], EVENT_UNIT_DAMAGED)
    
    set i=i + 1
    endloop
    
    
    
    call TriggerAddCondition(gg_trg_ESS, Condition(function ESSC))
    call TriggerAddAction(gg_trg_ESS, function ESSA)
endfunction


//===========================================================================
// Trigger: SSLE
//
// sword style
//===========================================================================
function Trig_SSLE_Conditions takes nothing returns boolean
  //  return (GetUnitAbilityLevel(GetAttacker(), 'A06P') > 1 or GetUnitAbilityLevel(GetAttacker(), 'A091') > 0 )
  return GetUnitAbilityLevel(GetAttacker(), 'A08O') > 0
endfunction

function Trig_SSLE_Actions takes nothing returns nothing
 local unit u= GetAttacker()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local unit a= GetTriggerUnit()
 //local integer spell = GetSpellAbilityId()
 local integer agi= GetHeroAgi(u, true)
 local integer str= GetHeroStr(u, true)
 // local integer ssl = GetUnitAbilityLevel(GetAttacker(), 'A06P')
 local integer ssl= 7
 local real dmg= I2R(( agi + str ) * ssl)
 local integer idmg= R2I(dmg)
 
 call TriggerSleepAction(0.65)
  set dmg=dmg + dmg * AddRacialBonus(a , id)
 //call SaveInteger(udg_cache,GetHandleId(a),GetHandleId(u),idmg)
 call UnitDamageTarget(u, a, dmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
 call DestroyEffect(AddSpecialEffectTarget(sebloode, a, "chest"))
  set u=null
  set a=null

endfunction

//===========================================================================
function InitTrig_SSLE takes nothing returns nothing
    local integer index
    set gg_trg_SSLE=CreateTrigger()
    
     set index=0
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_SSLE, Player(index), EVENT_PLAYER_UNIT_ATTACKED, Condition(function bool))

        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
   
    call TriggerAddCondition(gg_trg_SSLE, Condition(function Trig_SSLE_Conditions))
    call TriggerAddAction(gg_trg_SSLE, function Trig_SSLE_Actions)
endfunction


//===========================================================================
// Trigger: FC
//
// Frenzy
//===========================================================================
function Trig_FC_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A05R' or GetSpellAbilityId() == 'A06R' )
endfunction

function Trig_FC_Actions takes nothing returns nothing
local unit u= GetSpellAbilityUnit()
local integer level= GetUnitAbilityLevel(u, GetSpellAbilityId())
    call SetUnitVertexColorBJ(u, 100, 100, 50.00, 45.00)
    call SetUnitTimeScalePercent(u, 500)
     
     call UnitAddAbility(u, 'A0J8')
    
    if GetSpellAbilityId() == 'A05R' then
       call SetUnitAbilityLevel(u, 'A0J8', level)
    else
      call SetUnitAbilityLevel(u, 'A0J8', 10)
    endif
    
    
    call UnitAddAbility(u, 'A05T')
    call TriggerSleepAction(20.00)
    call SetUnitVertexColorBJ(u, 100, 100, 100.00, 0.00)
    call UnitRemoveAbility(u, 'A05T')
    call UnitRemoveAbility(u, 'A0J8')
    call SetUnitTimeScalePercent(u, 100)
    set u=null
endfunction

//===========================================================================
function InitTrig_FC takes nothing returns nothing
    set gg_trg_FC=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_FC, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_FC, Condition(function Trig_FC_Conditions))
    call TriggerAddAction(gg_trg_FC, function Trig_FC_Actions)
endfunction


