    call TriggerAddCondition(gg_trg_rejectpayment, Condition(function rejectC))
    call TriggerAddAction(gg_trg_rejectpayment, function rejectA)
endfunction


//===========================================================================
// Trigger: endrats
//===========================================================================
function endcellar takes nothing returns boolean
return IsUnitInGroup(GetTriggerUnit(), ratheroes) == true
endfunction

function RewardRat takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetEnumUnit()))
  call AdjustPlayerStateBJ(deadrats * 7, Player(id), PLAYER_STATE_RESOURCE_GOLD)
  call StartSound(gg_snd_getgold)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "     The Merchant gives you |cffffcc00+" + I2S(deadrats * 7) + "|r gold for your services")
endfunction


function Trig_endrats_Actions takes nothing returns nothing
   local unit u= GetTriggerUnit()
       call DisableTrigger(gg_trg_endrats)
      call UnitChat("Mission Complete: All rats are gone" , u)
      call TriggerSleepAction(3.5)
      call SetUnitFacingToFaceUnitTimed(shydealer, u, 0)
      call UnitChat("Really?, that is a splendid new, thank you all for helping me with those beast!" , shydealer)
       call TriggerSleepAction(3.5)
       call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffffcc00QUEST COMPLETED:|r You Dirty Rat!")
       call StartSound(bj_questCompletedSound)
       call QuestItemSetCompleted(cellarqi, true)
       call QuestItemSetCompleted(cellarqb, true)
       call QuestSetCompleted(cellarq, true)
       call TriggerSleepAction(3)
              call ForGroup(ratheroes, function RewardRat)
       call GroupClear(ratheroes)
       call DestroyGroup(ratheroes)
       set ratheroes=null

    
    call IssuePointOrder(shydealer, "move", - 13250, 11900)
    call TriggerSleepAction(7)
    call ShowUnit(shydealer, false)
    set u=null

endfunction

