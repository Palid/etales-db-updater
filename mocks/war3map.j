function SetupRats takes nothing returns nothing
 
   //1st room 
        if extrarats == false then
              call CreateRat(snapratID , GetRandomReal(minXIRR, maxXIRR) , GetRandomReal(minYIRR, maxYIRR))
              call CreateRat(ratID , GetRandomReal(minXIRR, maxXIRR) , GetRandomReal(minYIRR, maxYIRR))
