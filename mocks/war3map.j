//===========================================================================
// Trigger: dforge
//
// ( GetItemType(udg_tmpitem) == ITEM_TYPE_PERMANENT )
// return (GetItemType(GetManipulatedItem()) == ITEM_TYPE_PERMANENT and ModuloInteger(GetItemLevel(GetManipulatedItem()), 10)  > 5 )
// return  
//===========================================================================
function ChangetoForged takes item itemm returns nothing
 local integer itm= ModuloInteger(GetItemLevel(itemm), 1000)
 local integer newitm= itm * 10 + udg_typef
 local integer i= 0
 local item tmpitem
  
 call RemoveItem(itemm)
 set udg_itemtoforge=CreateItem(udg_specialw[newitm], GetLocationX(udg_forgeloc), GetLocationY(udg_forgeloc))
   
  loop
        set tmpitem=UnitItemInSlot(udg_forger, i)
        
         call RemoveItem(tmpitem)
        set i=i + 1
        exitwhen i >= bj_MAX_INVENTORY
    endloop
 set tmpitem=null
  
   
endfunction


function Havefweapon takes nothing returns boolean
    local integer i= 0
    local item tmpitem
   
    loop
        set tmpitem=UnitItemInSlot(udg_forger, i)
        if ( GetItemType(tmpitem) == ITEM_TYPE_PERMANENT and ModuloInteger(GetItemLevel(tmpitem), 100) > 5 ) then
            set udg_itemtoforge=tmpitem
            return true
        endif

        set i=i + 1
        exitwhen i >= bj_MAX_INVENTORY
    endloop
    set tmpitem=null
    return false
endfunction

function ISNF takes nothing returns boolean
 return ( RectContainsUnit(gg_rct_nearforge, GetTriggerUnit()) == true and GetTriggerUnit() != udg_forger )
endfunction


function Trig_droping_forge_Actions takes nothing returns nothing
 local item dforg= GetManipulatedItem()
 local unit u= GetTriggerUnit()
 local integer i= 0
 local integer jeweln= 0
 local location p

 
 call TriggerSleepAction(0.2)
 if ( RectContainsUnit(gg_rct_dropforge, u) == true ) then
    
    call IssueTargetItemOrder(udg_forger, "smart", dforg)
    set udg_FIct=udg_FIct + 1
 else
    call UnitChat("Don't drop items away of me.|n I'm not your servant, I dont pick up those far items.|nDrop them here in front of me. Ok??" , udg_forger)
 endif
 
   if ( udg_FIct > 5 ) then
    call DisableTrigger(GetTriggeringTrigger())
    call UnitAddAbility(udg_forger, 'Aloc')
   // call DisableTrigger(GetTriggeringTrigger())
    call UnitChat("Let´see..." , udg_forger)
    set udg_recipeforgeok=true
    set udg_FIct=0
    call TriggerSleepAction(2)
      if ( udg_typef != 3 ) then
           set jeweln=GetItemTypeCount(udg_forger , udg_typeforge[udg_typef])
          // call UnitChat(I2S(jeweln),udg_forger)
           call TriggerSleepAction(2)
            if ( jeweln > 4 ) then
                  call UnitChat("Jewels are ok..." , udg_forger)
            else
                set udg_recipeforgeok=false
                call UnitChat("You are missing some jewels here..." , udg_forger)
            endif
        else
            if ( GetItemTypeCount(udg_forger , udg_typeforge[1]) > 0 and GetItemTypeCount(udg_forger , udg_typeforge[2]) > 0 and GetItemTypeCount(udg_forger , udg_typeforge[4]) > 0 and GetItemTypeCount(udg_forger , udg_typeforge[5]) > 0 and GetItemTypeCount(udg_forger , udg_typeforge[6]) > 0 ) then
                 call UnitChat("Jewels are ok..." , udg_forger)
            else
                set udg_recipeforgeok=false
                call UnitChat("You are missing some jewels here..." , udg_forger)
            endif
           
        endif //typef == 5   
            
      call TriggerSleepAction(3)
      
            if ( Havefweapon() == true ) then
                call UnitChat("The weapon is ok..." , udg_forger)
            else
                set udg_recipeforgeok=false
                call UnitChat("You are missing a good forgeable weapon here..." , udg_forger)
            endif
            

       
       if ( udg_recipeforgeok == true ) then
       
          call TriggerSleepAction(3)
          call UnitChat("Ok, let´s go to forging your weapon" , udg_forger)
          call IssuePointOrderLocBJ(udg_forger, "move", udg_forgerloc)
          call TriggerSleepAction(2)
          call UnitDropItemPointLoc(udg_forger, udg_itemtoforge, udg_forgeloc)
          call TriggerSleepAction(0.2)
          call SetItemVisible(udg_itemtoforge, false)
          call TriggerSleepAction(2)
          call SetUnitAnimationByIndex(udg_forger, 10)
          call TriggerSleepAction(0.3)
          call DestroyEffect(AddSpecialEffectLoc("Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl", udg_forgeloc))
          call TriggerSleepAction(0.6)
          call SetUnitAnimationByIndex(udg_forger, 10)
          call TriggerSleepAction(0.3)
          call DestroyEffect(AddSpecialEffectLoc("Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl", udg_forgeloc))
          call TriggerSleepAction(0.6)
          call SetUnitAnimationByIndex(udg_forger, 10)
          call TriggerSleepAction(0.3)
          call DestroyEffect(AddSpecialEffectLoc("Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl", udg_forgeloc))
          call TriggerSleepAction(0.6)
          call SetUnitAnimationByIndex(udg_forger, 10)
          call TriggerSleepAction(0.3)
          call DestroyEffect(AddSpecialEffectLoc("Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl", udg_forgeloc))
          call TriggerSleepAction(0.6)
          call SetUnitAnimationByIndex(udg_forger, 10)
          call TriggerSleepAction(0.3)
          call DestroyEffect(AddSpecialEffectLoc("Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl", udg_forgeloc))
                    
          call ResetUnitAnimation(udg_forger)
          call TriggerSleepAction(0.6)
          call SetItemVisible(udg_itemtoforge, true)
          call ChangetoForged(udg_itemtoforge)
          call TriggerSleepAction(0.3)
          call IssueTargetItemOrder(udg_forger, "smart", udg_itemtoforge)
          call TriggerSleepAction(0.3)
          call UnitDropItemTarget(udg_forger, udg_itemtoforge, udg_currentforger)
          call TriggerSleepAction(3)
          call ShowUnit(udg_forger, false)
          call UnitRemoveAbility(udg_forger, 'Aloc')
          call ShowUnit(udg_forger, true)
          call UnitAddAbility(udg_forger, 'Abrf')
          call IssueImmediateOrder(udg_forger, "bearform")
          call UnitRemoveAbility(udg_forger, 'Abrf')
          set udg_currentforger=null
          set udg_playerforging=false
       else
         set p=GetRectCenter(gg_rct_dropforge)
       
         call TriggerSleepAction(2)
         call AdjustPlayerStateBJ(9999, GetOwningPlayer(udg_currentforger), PLAYER_STATE_RESOURCE_GOLD)
         call UnitChat("Sorry guy, I cannot forge your weapon, collect all the items and come back later" , udg_forger)
              
         call TriggerSleepAction(1)
         set i=0
         loop
          
           set dforg=UnitItemInSlot(udg_forger, i)
           call UnitDropItemPoint(udg_forger, dforg, GetLocationX(p), GetLocationY(p))
           call TriggerSleepAction(1)
           set i=i + 1
           exitwhen i >= bj_MAX_INVENTORY
          
         endloop
          set udg_currentforger=null
          set udg_playerforging=false
          
          call ShowUnit(udg_forger, false)
          call UnitRemoveAbility(udg_forger, 'Aloc')
          call ShowUnit(udg_forger, true)
          call UnitAddAbility(udg_forger, 'Abrf')
          call IssueImmediateOrder(udg_forger, "bearform")
          call UnitRemoveAbility(udg_forger, 'Abrf')
          
       endif
       
   

   endif
//call EnableTrigger(gg_trg_dforge)   
set u=null
set dforg=null
//set udg_currentforger = null
call RemoveLocation(p)
set p=null

endfunction

