function InitTrig_Impaler_Hand takes nothing returns nothing
    set gg_trg_Impaler_Hand=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Impaler_Hand, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Impaler_Hand, Condition(function Trig_IH_Conditions))
    call TriggerAddAction(gg_trg_Impaler_Hand, function Trig_IH_Actions)
endfunction


//===========================================================================
// Trigger: darkstalker
//===========================================================================
//TESH.scrollpos=4
//TESH.alwaysfold=0
function Trig_darkstalker_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == darkstalkerA )
endfunction

function Trig_darkstalker_Actions takes nothing returns nothing
local unit u= GetSpellAbilityUnit()
    call UnitAddAbility(u, darkstalkerB)
     call UnitAddAbility(u, darkstalkerC)
     // call PlaySoundOnUnitBJ( gg_snd_bats, 100, u )
    //call SetUnitVertexColor(u, 255, 255, 255, 0 )
    call TriggerSleepAction(50.00)
   // call SetUnitVertexColor(u, 255, 255, 255, 255 )
   //if (GetSoundIsPlaying(gg_snd_bats)==true) then
  // call StopSound(gg_snd_bats, false, true)
  // endif
    call UnitRemoveAbility(u, darkstalkerB)
    call UnitRemoveAbility(u, darkstalkerC)
    set u=null
endfunction

//===========================================================================
function InitTrig_darkstalker takes nothing returns nothing
local integer i= 0
    set gg_trg_darkstalker=CreateTrigger()
    
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_darkstalker, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, Condition(function bool))
          set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
    
    call TriggerAddCondition(gg_trg_darkstalker, Condition(function Trig_darkstalker_Conditions))
    call TriggerAddAction(gg_trg_darkstalker, function Trig_darkstalker_Actions)
endfunction


//===========================================================================
// Trigger: carrionswarm
//===========================================================================
function Trig_darksigil_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == carrionsw
endfunction


function carrioncicle takes nothing returns nothing
local timer t= GetExpiredTimer()
local real ix= LoadReal(hts, GetHandleId(t), 1)
local real iy= LoadReal(hts, GetHandleId(t), 2)
local real angle= LoadReal(hts, GetHandleId(t), 3)
local real inc= LoadReal(hts, GetHandleId(t), 4)
local unit u= LoadUnitHandle(hts, GetHandleId(t), 5)
local real xini= LoadReal(hts, GetHandleId(t), 7) + inc
local real dist= LoadReal(hts, GetHandleId(t), 8)
local effect carrion= null
local effect carrionb= null
local real h= GetParabolaZ(xini , dist , 50)
local integer vx= R2I(255 - ( xini / dist ) * 200)
local integer id= GetPlayerId(GetOwningPlayer(u))
local unit dummy= LoadUnitHandle(hts, GetHandleId(t), 10)
    
 set ix=ix + inc * Cos(angle * bj_DEGTORAD)
 set iy=iy + inc * Sin(angle * bj_DEGTORAD)

     call SetUnitFlyHeight(u, h, 0)
 //call SetUnitPosition(u,ix,iy)
 
   if IsTerrainWalkable(ix , iy) then
       call SetUnitX(u, ix)
       call SetUnitY(u, iy)
       call SetUnitPosition(dummy, ix, iy)
    endif

 set inc=inc - ( inc * 0.1 )
 if ( batform[id] == false ) then
    call SetUnitVertexColor(u, 255, 255, 255, 90 + vx)
 endif
 if inc <= 3 then
  set carrion=LoadEffectHandle(hts, GetHandleId(t), 6)
    set carrionb=LoadEffectHandle(hts, GetHandleId(t), 9)
  call SetUnitFlyHeight(u, 0, 0)
  if ( batform[id] == false ) then
   call SetUnitVertexColor(u, 255, 255, 255, 255)
   endif
   
  call RemoveUnit(dummy)
  call SetUnitPathing(u, true)
  call DestroyEffect(carrion)
  set carrion=null
  call DestroyEffect(carrionb)
  set carrionb=null
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  set s__IsCarrionSwarm[id]= false
  call SetUnitTimeScale(u, 1)
  


  /// call ResetUnitLookAt(u)
  //call SetUnitAnimation(u, "stand")
    
  
  
 else
  call SaveReal(hts, GetHandleId(t), 1, ix)
  call SaveReal(hts, GetHandleId(t), 2, iy)

  call SaveReal(hts, GetHandleId(t), 4, inc)
      call SaveReal(hts, GetHandleId(t), 7, xini)
 endif


set t=null
set u=null

set carrion=null
set carrionb=null
set dummy=null


endfunction




function Trig_darksigil_Actions takes nothing returns nothing

 local unit u= GetSpellAbilityUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local real i= GetUnitX(u)
 local real j= GetUnitY(u)
 local real xini= 1
 local real x= GetSpellTargetX()
 local real y= GetSpellTargetY()
 
 local real dx= x - i
 local real dy= y - j
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local real dist= SquareRoot(dx * dx + dy * dy)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local real inc= dist / 10

 local real ix= i + inc * Cos(angle * bj_DEGTORAD)
 local real iy= j + inc * Sin(angle * bj_DEGTORAD)
 local effect carrion
 local effect carrionb
 local unit dummy
 local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
  endif


 // call Caster_SetZAngle(u,-15)
  call UnitAddAbilityBJ('Amrf', u)
  call UnitRemoveAbilityBJ('Amrf', u)
 
  call SaveReal(hts, GetHandleId(t), 1, ix)
  call SaveReal(hts, GetHandleId(t), 2, iy)
  call SaveReal(hts, GetHandleId(t), 3, angle)
  call SaveReal(hts, GetHandleId(t), 4, inc)
  call SaveUnitHandle(hts, GetHandleId(t), 5, u)
  call SaveReal(hts, GetHandleId(t), 7, xini)
  call SaveReal(hts, GetHandleId(t), 8, dist)


 // call SetUnitAnimationByIndex(u,9)
  //call TriggerSleepAction(0.1)
  call SetUnitTimeScale(u, 1.5)
  call IssuePointOrder(u, "move", x, y)

  set dummy=CreateUnit(Player(id), 'n07Y', i, j, angle)
  call SaveUnitHandle(hts, GetHandleId(t), 10, dummy)
  call SaveReal(hts, GetHandleId(dummy), StringHash("spcast"), inspired)
  
  set carrion=AddSpecialEffectTarget("Abilities\\Spells\\NightElf\\Rejuvenation", u, "hand,right")
   call SaveEffectHandle(hts, GetHandleId(t), 6, carrion)

  set carrionb=AddSpecialEffectTarget("Abilities\\Spells\\NightElf\\Rejuvenation", u, "hand,left")
   call SaveEffectHandle(hts, GetHandleId(t), 9, carrionb)
   
   set s__IsCarrionSwarm[id]= true
 call SetUnitPathing(u, false)
 
   
 
  call TimerStart(t, 0.03, true, function carrioncicle)

  set t=null
  set u=null
  set carrion=null
  set carrionb=null
  set dummy=null
    
endfunction

//===========================================================================
function InitTrig_carrionswarm takes nothing returns nothing
    set gg_trg_carrionswarm=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_carrionswarm, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_carrionswarm, Condition(function Trig_darksigil_Conditions))
    call TriggerAddAction(gg_trg_carrionswarm, function Trig_darksigil_Actions)
endfunction


//===========================================================================
// Trigger: batform
//===========================================================================
function Trig_batform_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == vampire ) //vampire form
endfunction

function Trig_batform_Actions takes nothing returns nothing
local unit u= GetSpellAbilityUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local real time= GetFloatGameState(GAME_STATE_TIME_OF_DAY)
set batform[id]=true
   call DestroyEffect(AddSpecialEffect(sffectpunch, GetUnitX(u), GetUnitY(u)))
   call SetUnitVertexColor(u, 55, 55, 55, 255)
   call TriggerSleepAction(18)
      call SetUnitVertexColor(u, 255, 255, 255, 255)
      set batform[id]=false
      
      call UnitAddAbility(udg_PHero[id], callfamiliar)
      if nightime == true then
       call DestroyEffect(lights[id])
       set lights[id]=AddSpecialEffectTarget("Light.mdx", udg_PHero[id], "origin")
      endif
      
      set u=null

endfunction

