//===========================================================================
// Trigger: oracletalk
//===========================================================================
function Trig_oracletalk_Conditions takes nothing returns boolean
    return Oracletalk == true and oracle_busy == false and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_oracletalk_Actions takes nothing returns nothing

call SetupTextForce()
call DisableTrigger(gg_trg_oracletalk)
set Oracletalk=false
set oracle_busy=true

    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00With his head facing down Oracle starts talking to you...|r")
    call DisplayTimedTextToForce(textforce, 16, "      I know why you are here, I know what are seeking all of you. I know there were a shadow")
    call DisplayTimedTextToForce(textforce, 16, "      defeated by your hands... I know there's a terrible enemy walking to Enthashara")
    call DisplayTimedTextToForce(textforce, 16, "      I know all of you want to discover where is Iveor... I know your next destiny is Varanger... ")
    call DisplayTimedTextToForce(textforce, 16, "      What have you learned after the day end?. Is your heart ready to know the truth? (type |cffffcc00-skip|r to skip dialogs)")
    call TriggerSleepAction(17)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Oracle says...|r")
    call DisplayTimedTextToForce(textforce, 16, "      You have survived hard risks to be here with this question in your soul")
    call DisplayTimedTextToForce(textforce, 16, "      the way is nearby to ends, the time is nearby to die... This era is nearby to cycle.")
    call DisplayTimedTextToForce(textforce, 16, "      It's no the time to talk about an <<Ejio Versal>>... before you must need to make free the Sun")
    call DisplayTimedTextToForce(textforce, 16, "      Quest for Ejio Versal will be the future tale... Now you need to save the Void....")
    call TriggerSleepAction(17)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Oracle says...|r")
    call DisplayTimedTextToForce(textforce, 16, "      An Ejio Versal cannot be called without them...")
    call DisplayTimedTextToForce(textforce, 16, "      An Ejio versal cannot be called in this tale...")
    call DisplayTimedTextToForce(textforce, 16, "      My childs, I know where is he... where is hidden his face")
    call DisplayTimedTextToForce(textforce, 16, "      Over the poor Velhilmen, under the winds fortress... The hidden spirit cries there...")
    call TriggerSleepAction(17)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Oracle says...|r")
    call DisplayTimedTextToForce(textforce, 16, "      He cries... secretly. they cry deeply with no sound, with no tears")
    call DisplayTimedTextToForce(textforce, 16, "      The ancient evil woke up by a selfish lust, the darkness grewth into his heart...")
    call DisplayTimedTextToForce(textforce, 16, "      Nobody named him, nobody called him. He started to destroy everything")
    call DisplayTimedTextToForce(textforce, 16, "      The men faced his eyes, Calemor, Hida, Sanzero, Kripper, Lordfion, Avahor, Ethernal...")
   call TriggerSleepAction(17)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Oracle continues...|r")
    call DisplayTimedTextToForce(textforce, 16, "      The protectors of Tera, the spirit of Enthashara, the spirit of Serantas...")
    call DisplayTimedTextToForce(textforce, 16, "      The entire world spirit living into a maiden whose tears made flowers appears")
    call DisplayTimedTextToForce(textforce, 16, "      instantly when she scream her pain by the lose of her love. ")
    call DisplayTimedTextToForce(textforce, 16, "      All these Chronicles can be found into the <<Amanecer>> wrote by terra sages")
    call TriggerSleepAction(17)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Oracle says...|r")
    call DisplayTimedTextToForce(textforce, 16, "      Evil was defeated on Serantas lands.")
    call DisplayTimedTextToForce(textforce, 16, "      and the world under Tera and Calemor's Kingdom recovered his peace.")
    call DisplayTimedTextToForce(textforce, 16, "      but the darkness have been risen again, our old enemy has stepped here into the night")
    call DisplayTimedTextToForce(textforce, 16, "      Not by his selfish, not by his evilness. He has been forced to stay here")
    call TriggerSleepAction(17)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Oracle continues...|r")
    call DisplayTimedTextToForce(textforce, 16, "      His existence was planned by a power that escapes out my visions")
    call DisplayTimedTextToForce(textforce, 16, "      Someone has taken his sleep, someone has pulled him to our reality")
    call DisplayTimedTextToForce(textforce, 16, "      His strength comes from Serantas. That power wants to catch him in our dimension ")
    call DisplayTimedTextToForce(textforce, 16, "      Someone wants to slay Iveor on his divinity...")
    call TriggerSleepAction(17)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Oracle finishes...|r")
    call DisplayTimedTextToForce(textforce, 16, "      Can all of you stop that power?")
    call DisplayTimedTextToForce(textforce, 16, "      Can all of you prevent its ascension? ")
    call DisplayTimedTextToForce(textforce, 16, "      Can your faith save us from the worst eternal damnation?")
    call DisplayTimedTextToForce(textforce, 16, "      Find Iveor, before him...")
 call TriggerSleepAction(17)
 

    call StartSound(bj_questUpdatedSound)
   
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffcccc00WORLD QUEST UPDATE|r: Iveor's Destiny")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00Oracle's Encounter. ")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "          |cffffffff- Talk with Oracle about Ejio Versal requirements. (completed)|r ")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "          |cff888888- Find and Defeat Iveor's True Form. ")
    call FlashQuestDialogButton()
   
     call QuestItemSetCompleted(iveordib, true)
     set iveordid=CreateQuestItemBJ(iveordq, "Find and Defeat Iveor's True Form.")
 
 
 
    set oracle_busy=false
 set iveorseek=true
 //set ivfstageready = true
 call ShowUnit(gg_unit_E00I_2515, true) //iveor true form
 call SetUnitOwner(gg_unit_E00I_2515, Player(PLAYER_DARK_LORD), true) //iveor true form
 call PauseUnit(gg_unit_E00I_2515, true)
 call SetUnitInvulnerable(gg_unit_E00I_2515, true)
call EnableTrigger(gg_trg_firststage)

 
 

endfunction

