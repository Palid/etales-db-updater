//===========================================================================
// Trigger: Frost Nova
//===========================================================================
function Trig_Frost_Nova_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A08D' )
endfunction

function Trig_Frost_Nova_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local unit a= GetSpellTargetUnit()
local integer idmg= 0
local real xdmg= I2R(GetHeroInt(GetTriggerUnit(), true))
local real dmg= xdmg + ( xdmg * udg_magicBonus[id] )
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

   
   
      call DisableTrigger(gg_trg_DMG)
      set dmg=dmg * 6 * inspired
      set dmg=dmg + dmg * AddRacialBonus(a , id)
      set idmg=R2I(dmg)
     
      call EnableTrigger(gg_trg_SPDMG)
      call UnitDamageTarget(GetTriggerUnit(), a, dmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
      call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , a)
      set spelldmg[id]=0
      call EnableTrigger(gg_trg_DMG)
      
  set a=null
endfunction

