function clarena takes nothing returns nothing
if ( GetPlayerId(GetOwningPlayer(GetEnumUnit())) > 7 ) then
    call RemoveUnit(GetEnumUnit())
endif
endfunction

  
function actfunc takes nothing returns nothing
if GetEnumItem() != Item then
    call RemoveItem(GetEnumItem())
endif
endfunction

function Trig_enable_Actions takes nothing returns nothing
local string num
local integer i= 0
//local group g = CreateGroup()
local boolexpr bexp= Condition(function bool)
    
 // call UnitApplyTimedLifeBJ( 1.00, 'BTLF', gg_unit_U00R_0387 ) //banshee
    
  call UnitApplyTimedLifeBJ(1.00, 'BTLF', gg_unit_n04C_1959)
   
  call UnitApplyTimedLifeBJ(1.00, 'BTLF', gg_unit_n02A_0021)
   
  call UnitApplyTimedLifeBJ(1.00, 'BTLF', gg_unit_n004_0024)
   
  call UnitApplyTimedLifeBJ(1.00, 'BTLF', gg_unit_n017_0151)
     
  call UnitApplyTimedLifeBJ(1.00, 'BTLF', gg_unit_O009_1963)
    
//  call UnitApplyTimedLifeBJ( 1.00, 'BTLF',  gg_unit_H00M_1415 )  
  
  
  
//  call ForGroup(g, function clarena )
// call DestroyGroup(g)
  
 // set g = null

   call FogEnable(true)
   call FogMaskEnable(true)
   call TriggerSleepAction(9)
   //call CinematicModeBJ( false, GetPlayersAll() )
   
  //  call TriggerSleepAction(2)
  
    

     loop
     exitwhen i > 8
      call ResetToGameCameraForPlayer(Player(i), 4)
        set i=i + 1
    endloop

   set i=0
   call EnumItemsInRect(bj_mapInitialPlayableArea, bexp, function actfunc)
   call DestroyBoolExpr(bexp)
   set bexp=null
   
  
    
     set num=I2S(udg_totalPlaying)
        call TriggerSleepAction(1)
    loop
    exitwhen i > 11
        if i != 0 then
       call SetPlayerAlliance(Player(i), Player(0), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 1 then
       call SetPlayerAlliance(Player(i), Player(1), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 2 then
       call SetPlayerAlliance(Player(i), Player(2), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 3 then
       call SetPlayerAlliance(Player(i), Player(3), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 4 then
       call SetPlayerAlliance(Player(i), Player(4), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 5 then
       call SetPlayerAlliance(Player(i), Player(5), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 6 then
       call SetPlayerAlliance(Player(i), Player(6), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 7 then
       call SetPlayerAlliance(Player(i), Player(7), ALLIANCE_SHARED_CONTROL, false)
       endif
        if i != 8 then
       call SetPlayerAlliance(Player(i), Player(8), ALLIANCE_SHARED_CONTROL, false)
       endif
       
       
          set udg_rpgc[i]=true
          call DisplayTimedTextToPlayer(Player(i), .5, .2, 10, "Players online:|cffffcc00" + num + "|r |cffaaaaaa[more players = more XP, Bosses get extra Hp bonus ]|r") //|cffffcc00"+num+"x|r")
          call DisplayTimedTextToPlayer(Player(i), .5, .2, 20, "Type |cffffcc00-new|r If you want start a new character")
          call DisplayTimedTextToPlayer(Player(i), .5, .2, 20, "Type |cffffcc00-load <code>|r If you want start a saved character")
          call DisplayTimedTextToPlayer(Player(i), .5, .2, 20, "Check |cffff8822Quest (F9)|r for detailed info and tips")

    //  call TriggerSleepAction(0.03 )  
        
    set i=i + 1
    endloop
     call TriggerSleepAction(2.5)

  //  call ShowInterfaceForceOn( GetPlayersAll(), 1 )
      call TriggerSleepAction(1)
     call CinematicModeBJ(false, GetPlayersAll())
     call SetUserControlForceOn(GetPlayersAll())

   // call CinematicModeBJ( true, GetPlayersAll() )

   
  
  
    //call CameraSetSmoothingFactor( 4.00 )
      //   call TriggerRegisterUnitInRange(gg_trg_masterdruidhello, gg_unit_e00P_0247 ,256 , null)
       //  call TriggerRegisterUnitEvent( gg_trg_dgems, gg_unit_e00P_0247, EVENT_UNIT_PICKUP_ITEM )
        
         set loadingDisplay="Starting Mercs"
         call EnableTrigger(gg_trg_mercenaries)
         call TriggerSleepAction(30)
         set loadingDisplay="Starting Damage"
         call EnableTrigger(gg_trg_DMG)
endfunction

