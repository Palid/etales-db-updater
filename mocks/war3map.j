        // Logarithms
       function lnt takes real r returns real
            local real sum= 0.0
            local real sign= 1.0
           
            if r < 1.0 then
                set r=1.0 / r
                set sign=- 1.0
            endif
            loop
                exitwhen r < E
                set r=r * E_INV
                set sum=sum + 1.0
            endloop
            loop
                exitwhen r < LN_FACTOR
                set r=r * LN_FACTOR_INV
                set sum=sum + 0.25
            endloop

            return sign * ( sum + 0.125 * ( r - 1.0 ) * ( 1 + 9.0 / ( 2.0 + r ) + 4.5 / ( 0.5 + r ) + 1.0 / r ) )
        endfunction
       
        function log2 takes real r returns real
            return LOG_02_FACTOR * lnt(r)
        endfunction
       
        function log10 takes real r returns real
            return LOG_10_FACTOR * lnt(r)
        endfunction
       
        function logg takes real base,real arg returns real
            return lnt(arg) / lnt(base)
        endfunction

