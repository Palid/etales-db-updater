    call ShowUnit(GetEnumUnit(), false)
    call SaveGroupHandle(questtm, GetHandleId(GetEnumUnit()), 10, zombieg[11])
    call SaveInteger(questtm, GetHandleId(GetEnumUnit()), 11, 11)
    
endfunction

