//===========================================================================
// Trigger: fixed
//
// Actions
//     Game - Display to (All players) the text: (String((Degrees((Distance to target of the current camera view)))))
//     Game - Display to (All players) the text: (String((Degrees((Far Z of the current camera view)))))
//     Game - Display to (All players) the text: (String((Degrees((Near Z of the current camera view)))))
//     Game - Display to (All players) the text: (String((Degrees((Angle of attack of the current camera view)))))
//     Game - Display to (All players) the text: (String((Degrees((Field of view of the current camera view)))))
//     Game - Display to (All players) the text: (String((Degrees((Roll of the current camera view)))))
//     Game - Display to (All players) the text: (String((Degrees((Rotation of the current camera view)))))
//     Game - Display to (All players) the text: (String((Degrees((Height Offset of the current camera view)))))
//===========================================================================
function Trig_fixed_Actions takes nothing returns nothing
   set udg_rpgc[GetPlayerId(GetTriggerPlayer())]=true
   call SetCameraTargetControllerNoZForPlayer(GetTriggerPlayer(), udg_PHero[GetPlayerId(GetTriggerPlayer())], 0.00, 0.00, false)
   call SetCameraFieldForPlayer(GetTriggerPlayer(), CAMERA_FIELD_TARGET_DISTANCE, cameraftd[GetPlayerId(GetTriggerPlayer())], 0.00)
   call SetCameraFieldForPlayer(GetTriggerPlayer(), CAMERA_FIELD_ZOFFSET, 0, 0.00)
    call SetCameraFieldForPlayer(GetTriggerPlayer(), CAMERA_FIELD_FIELD_OF_VIEW, 30, 0.00)
    call SetCameraFieldForPlayer(GetTriggerPlayer(), CAMERA_FIELD_ANGLE_OF_ATTACK, 316, 0.00)
   call SetCameraFieldForPlayer(GetTriggerPlayer(), CAMERA_FIELD_ROTATION, 90, 0.00)
   // call SetCameraFieldForPlayer( GetTriggerPlayer(), CAMERA_FIELD_ROLL, 0, 0.00 )
endfunction

//===========================================================================
function InitTrig_fixed takes nothing returns nothing
    local integer i= 0
    set gg_trg_fixed=CreateTrigger()
     loop
     exitwhen i > 9
    call TriggerRegisterPlayerChatEvent(gg_trg_fixed, Player(i), "-rpg", true)
     set i=i + 1
     endloop
     
    call TriggerAddAction(gg_trg_fixed, function Trig_fixed_Actions)
    
endfunction


//===========================================================================
// Trigger: rpgcameval
//===========================================================================
function Trig_rpgcameval_Actions takes nothing returns nothing
    // rpgcamera
    local integer i= 0
    
     loop
      exitwhen i > 15
        if udg_rpgc[i] == true and traveling[i] == false then
        
         call SetCameraTargetControllerNoZForPlayer(Player(i), udg_PHero[i], 0.00, 0.00, false)
         call SetCameraFieldForPlayer(Player(i), CAMERA_FIELD_TARGET_DISTANCE, cameraftd[i], 0.00)
         call SetCameraFieldForPlayer(Player(i), CAMERA_FIELD_ZOFFSET, 0, 0.00)
         call SetCameraFieldForPlayer(Player(i), CAMERA_FIELD_FIELD_OF_VIEW, 30, 0.00)
         call SetCameraFieldForPlayer(Player(i), CAMERA_FIELD_ANGLE_OF_ATTACK, 316, 0.00)
         call SetCameraFieldForPlayer(Player(i), CAMERA_FIELD_ROTATION, 90, 0.00)
      endif
 
       set i=i + 1
     endloop
    
endfunction

