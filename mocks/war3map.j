            else
                call notjewels(id)
             endif
elseif GetItemTypeId(it) == 'I07G' then //Skull shroud//50o//50e//50s
            if ( onix[id] >= 50 and emerald[id] >= 50 and saphire[id] >= 50 ) then
            set itm=CreateItem('I06T', x, y) //rare chest
