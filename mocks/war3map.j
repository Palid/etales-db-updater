endfunction

function SEA takes nothing returns nothing
 local integer i= GetUnitUserData(GetTriggerUnit())
 local unit d= GetTriggerUnit()
    

    call UnitChat(udg_SoldierEnd , GetTriggerUnit())

    set deliverwander[i]=false
    call UnitAddItemById(udg_PHero[GetPlayerId(Player(i))], 'I0L1')
    call TriggerSleepAction(4)
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTo.mdl", d, "origin"))
    call TriggerSleepAction(2.3)
    call RemoveUnit(d)
    
    set d=null
endfunction

