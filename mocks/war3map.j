  function CheckFam takes integer Fam,integer id returns nothing
     local integer i= 0
     local real x= GetUnitX(udg_Familiar[id])
     local real y= GetUnitY(udg_Familiar[id])
     local real face= GetUnitFacing(udg_Familiar[id])
 
    if GetUnitTypeId(udg_Familiar[id]) != Fam then
             loop
               exitwhen i > 5
                set famitem[i]=null
                set famitem[i]=UnitRemoveItemFromSlot(udg_Familiar[id], i)
                set i=i + 1
               endloop
                   call RemoveUnit(udg_Familiar[id])
                   set udg_Familiar[id]=CreateUnit(Player(id), Fam, x, y, face)
                   call DestroyEffect(AddSpecialEffectTarget(seffectclap, udg_Familiar[id], "origin"))
                set i=0
              loop
               exitwhen i > 5
                call UnitAddItem(udg_Familiar[id], famitem[i])
                set famitem[i]=null
                set i=i + 1
               endloop
                
            endif
  endfunction
 
function UpdateFam takes integer id returns nothing

 local integer lev= ((GetHeroLevel(udg_PHero[id])) / 10) // INLINED!!
 
 
 
        if famtype[id] == 1 then
           call CheckFam(FamWolf[lev] , id)
           set udg_Hwolfarray[id]=udg_Familiar[id]
        elseif famtype[id] == 2 then
            call CheckFam(FamOgre[lev] , id)
            set udg_Hogrearray[id]=udg_Familiar[id]
        elseif famtype[id] == 3 then
            call CheckFam(FamMaiden[lev] , id)
            set udg_HTrollarray[id]=udg_Familiar[id]
          endif
 
 
endfunction
 

