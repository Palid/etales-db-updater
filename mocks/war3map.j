         set questid=SetupQuest(id , null , "SEEKING YOUR OWN FATE" , "Travel to Ekrom and talk with the PVP Master" , "-" , "-" , 0 , s__qty[2])
         call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
       
         call StartSound(bj_questDiscoveredSound)
    endif

endfunction



