//textmacro instance: LOADERS()
    
    
    function CodeVersioning__ClearGroup takes nothing returns nothing
        call RemoveUnit(GetEnumUnit())
    endfunction
    
    function ClearTempLoad takes integer id returns nothing
     local integer i= 0
     
     
     
       set slaveId[id]=0
        
       set loadedUnit[id]=null
       set slave[id]=null
       set familiar[id]=null
       set Lfam[id]=0
       set Lf[id]=0
       set Lslave[id]=0
     
   loop
      exitwhen i > 5
      set s__FamItemId[(id)*(7)+i]= 0
      set s__FamItemSl[(id)*(7)+i]= 13
      set s__FamItemCh[(id)*(7)+i]= 0
      set i=i + 1
    endloop
   
   set i=0
   loop
      exitwhen i > 5
      set s__SolItemId[(id)*(7)+i]= 0
      set s__SolItemSl[(id)*(7)+i]= 13
      set s__SolItemCh[(id)*(7)+i]= 0
      set i=i + 1
    endloop
    
     set i=0
   loop
      exitwhen i > 5
      set s__TenItemId[(id)*(7)+i]= 0
      set s__TenItemSl[(id)*(7)+i]= 13
      set s__TenItemCh[(id)*(7)+i]= 0
      set i=i + 1
    endloop
    
  
  
     set i=0
   loop
      exitwhen i > 5
      set s__HerItemId[(id)*(7)+i]= 0
      set s__HerItemSl[(id)*(7)+i]= 13
      set s__HerItemCh[(id)*(7)+i]= 0
      set i=i + 1
    endloop
    
       set i=0
   loop
      exitwhen i > 5
      set s__FrgItemId[(id)*(7)+i]= 0
      set s__FrgItemSl[(id)*(7)+i]= 13
      set s__FrgItemCh[(id)*(7)+i]= 0
      set i=i + 1
    endloop
    
    endfunction
    
    function CodeVersioning__BuildInventory takes integer wichItemClass,integer wichValue returns integer

    
    
      if wichItemClass == 1 then
        return Artifact[wichValue]
  elseif wichItemClass == 2 then
        return Permanent[wichValue]
  elseif wichItemClass == 3 then
        return Miscelaneo[wichValue]
  elseif wichItemClass == 4 then
        return Campaign[wichValue]
  elseif wichItemClass == 5 then
        return Cargados[wichValue]
  elseif wichItemClass == 6 then
        return Comprables[wichValue]
   endif
   
  return 0
    endfunction
 
function CodeVersioning__ExtractItemsFor takes integer l__CodeVersioning__stack,unit u,integer id returns nothing
        local integer j=(s__BigInt_divide(((l__CodeVersioning__stack)),(7) + 1)) //  set udg_Slots[7] = j   // INLINED!!
        local integer l__l=(s__BigInt_divide(((l__CodeVersioning__stack)),(7) + 1)) // set udg_Slots[6] = l  // INLINED!!
        local integer i= 0
        local real x= GetUnitX(u)
        local real y= GetUnitY(u)
        local item it=null
        
        
       loop
           exitwhen i > 7
        
          set CodeVersioning__loadedtype[i]=0
       
           set i=i + 1
           endloop
     set i=j
       loop
         exitwhen i < 1
          set i=i - 1
          set CodeVersioning__loadedtype[i]=(s__BigInt_divide(((l__CodeVersioning__stack)),(7) + 1)) // INLINED!!
          endloop
      
      set i=j
       loop
         exitwhen i < 1
         set i=i - 1
         set udg_tmpItemId[i]=(s__BigInt_divide(((l__CodeVersioning__stack)),(typesize[CodeVersioning__loadedtype[i]]) + 1)) // INLINED!!
         endloop
         

       
       set i=l__l
       loop
            exitwhen i < 1
                 set i=i - 1
                 set udg_Slots[i]=(s__BigInt_divide(((l__CodeVersioning__stack)),(7) + 1)) // INLINED!!
                 
          endloop
 
       set i=l__l
         loop
            exitwhen i < 1
            set i=i - 1
            set udg_tempinvcharges[i]=(s__BigInt_divide(((l__CodeVersioning__stack)),(21) + 1)) // INLINED!!
              endloop
        
  
  //give familiar item from saved game
  if GetUnitPointValue(u) == 334 then
  
     set i=0
   loop
      exitwhen i > 5
      set s__FamItemId[(CodeVersioning__playerId)*(7)+i]= CodeVersioning__BuildInventory(CodeVersioning__loadedtype[i] , udg_tmpItemId[i])
      set s__FamItemSl[(CodeVersioning__playerId)*(7)+i]= udg_Slots[i]
      set s__FamItemCh[(CodeVersioning__playerId)*(7)+i]= udg_tempinvcharges[i]
      set i=i + 1
    endloop
    
   elseif GetUnitPointValue(u) == 777 then
  
     set i=0
   loop
      exitwhen i > 5
      set s__SolItemId[(CodeVersioning__playerId)*(7)+i]= CodeVersioning__BuildInventory(CodeVersioning__loadedtype[i] , udg_tmpItemId[i])
      set s__SolItemSl[(CodeVersioning__playerId)*(7)+i]= udg_Slots[i]
      set s__SolItemCh[(CodeVersioning__playerId)*(7)+i]= udg_tempinvcharges[i]
      set i=i + 1
    endloop
    
     elseif GetUnitPointValue(u) == 776 then
  
     set i=0
   loop
      exitwhen i > 5
      set s__TenItemId[(CodeVersioning__playerId)*(7)+i]= CodeVersioning__BuildInventory(CodeVersioning__loadedtype[i] , udg_tmpItemId[i])
      set s__TenItemSl[(CodeVersioning__playerId)*(7)+i]= udg_Slots[i]
      set s__TenItemCh[(CodeVersioning__playerId)*(7)+i]= udg_tempinvcharges[i]
      set i=i + 1
    endloop
    
   elseif IsUnitType(u, UNIT_TYPE_HERO) == true then
  
     set i=0
   loop
      exitwhen i > 5
      set s__HerItemId[(CodeVersioning__playerId)*(7)+i]= CodeVersioning__BuildInventory(CodeVersioning__loadedtype[i] , udg_tmpItemId[i])
      set s__HerItemSl[(CodeVersioning__playerId)*(7)+i]= udg_Slots[i]
      set s__HerItemCh[(CodeVersioning__playerId)*(7)+i]= udg_tempinvcharges[i]
      set i=i + 1
    endloop
    
  
  endif
    call FreeInventory()
 endfunction
 
    function CodeVersioning__OnLoadBuffer1 takes nothing returns nothing
   
        local integer i= 0
        local integer j= 0
        local integer l__l= 0
        local integer f= 0
        local integer nota= 0
        local integer st= 0
        local item it= null
        local real x= 0
        local real y= 0
     
      set slaveId[CodeVersioning__playerId]=0
      call FreeInventory()
      call ClearTempLoad(CodeVersioning__playerId)
      call s__Buffer_reset()
     
  //====
  
  
       // set extrad2[playerId] = stack.pop(101) 
      //  set extrad2[playerId] = stack.pop(101)
     //   set extrad1[playerId] = stack.pop(101)
     //   set tittle[playerId] = stack.pop(51)
  
  
  //====
  
     set GemVar_C[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) //gem variable // INLINED!!
     set GemVar_B[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) //gem variable // INLINED!!
     set GemVar_A[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) //gem variable // INLINED!!
     set onix[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) // INLINED!!
     set emerald[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) // INLINED!!
     set saphire[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) // INLINED!!
     set diamond[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) // INLINED!!
     set rubi[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(201) + 1)) // INLINED!!
     set loadedUnit[CodeVersioning__playerId]=CreateUnitAtLoc(CodeVersioning__triggerPlayer, udg_HeroPool[(s__BigInt_divide(((CodeVersioning__stack)),(101) + 1))], udg_RevivalPoints[CodeVersioning__playerId], 90) // INLINED!!
     call LoadHeroXP(CodeVersioning__stack , loadedUnit[CodeVersioning__playerId] , CodeVersioning__XP_ACCURACY)
     set Lfam[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(10) + 1)) // INLINED!!
     if Lfam[CodeVersioning__playerId] == 1 then //wolf
         set familiar[CodeVersioning__playerId]=CreateUnitAtLoc(CodeVersioning__triggerPlayer, FamWolf[((GetHeroLevel(loadedUnit[CodeVersioning__playerId])) / 10)], udg_RevivalPoints[CodeVersioning__playerId], 90.00) // INLINED!!
      elseif Lfam[CodeVersioning__playerId] == 2 then //ogre
         set familiar[CodeVersioning__playerId]=CreateUnitAtLoc(CodeVersioning__triggerPlayer, FamOgre[((GetHeroLevel(loadedUnit[CodeVersioning__playerId])) / 10)], udg_RevivalPoints[CodeVersioning__playerId], 90.00) // INLINED!!
      elseif Lfam[CodeVersioning__playerId] == 3 then //maiden
         set familiar[CodeVersioning__playerId]=CreateUnitAtLoc(CodeVersioning__triggerPlayer, FamMaiden[((GetHeroLevel(loadedUnit[CodeVersioning__playerId])) / 10)], udg_RevivalPoints[CodeVersioning__playerId], 90.00) // INLINED!!
       endif
       
     set slave[CodeVersioning__playerId]=CreateUnitAtLoc(CodeVersioning__triggerPlayer, 'n011', udg_RevivalPoints[CodeVersioning__playerId], 90.00)
 
   //  set j =stack.pop(8)
   //  set l =stack.pop(8)
  //   set i = j      
      
 //    loop
  //   exitwhen i<1
   //   set i = i-1
  //    set udg_tmpItemId[i] = stack.pop(21)   
  //  endloop
         
   //    set udg_Slots[5] = stack.pop(7)
  //     set udg_Slots[4] = stack.pop(7)
   //    set udg_Slots[3] = stack.pop(7)
   //    set udg_Slots[2] = stack.pop(7)
    //   set udg_Slots[1] = stack.pop(7)
    //   set udg_Slots[0] = stack.pop(7)
 
 //   set i = l
     // loop
      //    exitwhen i<1
      //    set i = i - 1
      //    set udg_tempinvcharges[i] = stack.pop(11)
          
  //    endloop
   //    set i = 0
 //  loop
  //    exitwhen i>5
  //    set FrgItemId[playerId][i] = fragmenttype[udg_tmpItemId[i]]
  //    set FrgItemSl[playerId][i] = udg_Slots[i]
  ///    set FrgItemCh[playerId][i] = udg_tempinvcharges[i]
  //    set i = i+1
 //   endloop 

     call FreeInventory()

     call CodeVersioning__ExtractItemsFor(CodeVersioning__stack , familiar[CodeVersioning__playerId] , CodeVersioning__playerId)
     call CodeVersioning__ExtractItemsFor(CodeVersioning__stack , loadedUnit[CodeVersioning__playerId] , CodeVersioning__playerId)
     call CodeVersioning__ExtractItemsFor(CodeVersioning__stack , slave[CodeVersioning__playerId] , CodeVersioning__playerId)
     call CodeVersioning__ExtractItemsFor(CodeVersioning__stack , udg_ARVault[CodeVersioning__playerId] , CodeVersioning__playerId)
  
        call s__Buffer_write((s__BigInt_divide(((CodeVersioning__stack)),(130) + 1))) //lumber // INLINED!!
        call s__Buffer_write((s__BigInt_divide(((CodeVersioning__stack)),(10000) + 1)) * 100) //gold  // INLINED!!
        call SetUnitUserData(loadedUnit[CodeVersioning__playerId], (s__BigInt_divide(((CodeVersioning__stack)),(6481) + 1))) // INLINED!!
        
        set Lf[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(7) + 1)) //extracting faction // INLINED!!
      //====1.2.0====
         
          set s__tempMstr[CodeVersioning__playerId]= (s__BigInt_divide(((CodeVersioning__stack)),(901) + 1)) //set Mstrength[playerId] = stack.pop(901) // INLINED!!
          set s__tempFort[CodeVersioning__playerId]= (s__BigInt_divide(((CodeVersioning__stack)),(901) + 1)) //set Fortune[playerId] = stack.pop(901) // INLINED!!
          set s__tempCons[CodeVersioning__playerId]= (s__BigInt_divide(((CodeVersioning__stack)),(901) + 1)) // set Constitution[playerId] = stack.pop(901) // INLINED!!
      
       //====1.2.0====
        
       // call SetHeroXP(loadedUnit,XPhero,false)
        
        set udg_AGI[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(1201) + 1)) // INLINED!!
        set udg_STR[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(1201) + 1)) // INLINED!!
        set udg_INT[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(1201) + 1)) // INLINED!!
        
      
        //create kobold slave
        set slaveId[CodeVersioning__playerId]=(s__BigInt_divide(((CodeVersioning__stack)),(300) + 1)) // INLINED!!
  
  
        set it=null
   endfunction
  
  function CodeVersioning__OnLoad1 takes nothing returns nothing
    local integer i= 0
    local integer level
    local integer scale
    local integer slevel
    local real nagi
    local real nstr
    local real nint
    local real nfrt
    local real nmsr
    local real ncns
    
    
    
        set udg_AGI[CodeVersioning__playerId]=udg_AGI[CodeVersioning__playerId] + 35
        set udg_STR[CodeVersioning__playerId]=udg_STR[CodeVersioning__playerId] + 35
        set udg_INT[CodeVersioning__playerId]=udg_INT[CodeVersioning__playerId] + 35
        
     
        
        
     
        
      
         
        set s__Mstrength[CodeVersioning__playerId]= s__tempMstr[CodeVersioning__playerId]
        set s__Fortune[CodeVersioning__playerId]= s__tempFort[CodeVersioning__playerId]
        set s__Constitution[CodeVersioning__playerId]= s__tempCons[CodeVersioning__playerId]
        
        set s__tempMstr[CodeVersioning__playerId]= 0
        set s__tempFort[CodeVersioning__playerId]= 0
        set s__tempCons[CodeVersioning__playerId]= 0
        
         
        call SetHeroAgi(loadedUnit[CodeVersioning__playerId], udg_AGI[CodeVersioning__playerId], true)
        call SetHeroStr(loadedUnit[CodeVersioning__playerId], udg_STR[CodeVersioning__playerId], true)
        call SetHeroInt(loadedUnit[CodeVersioning__playerId], udg_INT[CodeVersioning__playerId], true)
        
         set udg_PHero[CodeVersioning__playerId]=loadedUnit[CodeVersioning__playerId]
         set prevlevel[CodeVersioning__playerId]=GetHeroLevel(udg_PHero[CodeVersioning__playerId])
        
        //finalize hero
     
       
       if slaveId[CodeVersioning__playerId] > 0 then
            set cslave[CodeVersioning__playerId]=CreateUnit(Player(CodeVersioning__playerId), udg_CreepType[slaveId[CodeVersioning__playerId]], GetUnitX(slave[CodeVersioning__playerId]), GetUnitY(slave[CodeVersioning__playerId]), 225)
             call UnitAddAbility(cslave[CodeVersioning__playerId], 'A07R') //resurreccion
          //   call UnitAddAbility(cslave[playerId],'A0CC')//Free Slave
             call UnitAddAbility(cslave[CodeVersioning__playerId], 'A0CT') //Slave inventory
             call UnitAddAbility(cslave[CodeVersioning__playerId], 'A0CU') //Hide
             
       endif
            
     
       
    
       call AddProfaner(CodeVersioning__playerId) //trigger registrado
       
       set udg_Slave[CodeVersioning__playerId]=slave[CodeVersioning__playerId]
      
           //setting Lfam[playerId]iliar
      if Lfam[CodeVersioning__playerId] > 0 then
     
           set udg_Familiar[CodeVersioning__playerId]=familiar[CodeVersioning__playerId]
           
      endif
     
          if Lfam[CodeVersioning__playerId] == 1 then
              set udg_HasWolf[CodeVersioning__playerId]=true
              set udg_Hwolfarray[CodeVersioning__playerId]=familiar[CodeVersioning__playerId]
             
              set famtype[CodeVersioning__playerId]=1
      elseif Lfam[CodeVersioning__playerId] == 2 then
              set udg_HasOgre[CodeVersioning__playerId]=true
              set udg_Hogrearray[CodeVersioning__playerId]=familiar[CodeVersioning__playerId]
             
              set famtype[CodeVersioning__playerId]=2
      elseif Lfam[CodeVersioning__playerId] == 3 then
             set udg_Hastroll[CodeVersioning__playerId]=true
             set udg_HTrollarray[CodeVersioning__playerId]=familiar[CodeVersioning__playerId]
            
             set famtype[CodeVersioning__playerId]=3
      endif
      

     
 //      call SetHeroXP(udg_PHero[playerId],XPhero,false)
       call SetPlayerState(CodeVersioning__triggerPlayer, PLAYER_STATE_RESOURCE_LUMBER, s__Buffer_read())
       call SetPlayerState(CodeVersioning__triggerPlayer, PLAYER_STATE_RESOURCE_GOLD, s__Buffer_read())

       
     call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[CodeVersioning__playerId], EVENT_UNIT_DAMAGED)
     call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[CodeVersioning__playerId], EVENT_UNIT_ACQUIRED_TARGET)
     call TriggerRegisterUnitEvent(InsRestTrg[CodeVersioning__playerId], udg_PHero[CodeVersioning__playerId], EVENT_UNIT_DAMAGED)
     call TriggerRegisterUnitInRange(herodiag[CodeVersioning__playerId], udg_PHero[CodeVersioning__playerId], 256, null)
     call TriggerRegisterUnitInRange(s__enemyAcquire[CodeVersioning__playerId], udg_PHero[CodeVersioning__playerId], 1024, null)
 
    set i=0
    loop
      exitwhen i > 6
      set CodeVersioning__loadedtype[i]=0

      
      set i=i + 1
    endloop
    
    if GetUnitLevel(loadedUnit[CodeVersioning__playerId]) < 11 then
           set reinhardON[CodeVersioning__playerId]=true
    endif
   
                call SetUnitPositionLoc(loadedUnit[CodeVersioning__playerId], udg_Fstartp[Lf[CodeVersioning__playerId]])
                call SetUnitPositionLoc(slave[CodeVersioning__playerId], udg_Fstartp[Lf[CodeVersioning__playerId]])
                call SetUnitPositionLoc(familiar[CodeVersioning__playerId], udg_Fstartp[Lf[CodeVersioning__playerId]])
                call SetUnitPositionLoc(cslave[CodeVersioning__playerId], udg_Fstartp[Lf[CodeVersioning__playerId]])
                set udg_Plugar[CodeVersioning__playerId]=Lf[CodeVersioning__playerId]
      
    set ReadyForDress[CodeVersioning__playerId]=true
   // set Lfam[playerId] = 0

   endfunction
    
    function CodeVersioning__OnUnload1 takes nothing returns nothing
        //destroy hero
    //    call UnloadInventory(loadedUnit[playerId])
        call RemoveUnit(loadedUnit[CodeVersioning__playerId])
        call RemoveUnit(slave[CodeVersioning__playerId])
        call RemoveUnit(familiar[CodeVersioning__playerId])
       // call RemoveUnit(cslave[playerId])
       
           
        set s__tempMstr[CodeVersioning__playerId]= 0
        set s__tempFort[CodeVersioning__playerId]= 0
        set s__tempCons[CodeVersioning__playerId]= 0
       
        set s__Mstrength[CodeVersioning__playerId]= 0
        set s__Fortune[CodeVersioning__playerId]= 0
        set s__Constitution[CodeVersioning__playerId]= 0
        
        set udg_AGI[CodeVersioning__playerId]=0
        set udg_STR[CodeVersioning__playerId]=0
        set udg_INT[CodeVersioning__playerId]=0
       
        set Lf[CodeVersioning__playerId]=0
        
        set cslave[CodeVersioning__playerId]=null
        set loadedUnit[CodeVersioning__playerId]=null
        set slave[CodeVersioning__playerId]=null
        set familiar[CodeVersioning__playerId]=null
        set Lfam[CodeVersioning__playerId]=0
        set reinhardON[CodeVersioning__playerId]=false
        set udg_PHero[CodeVersioning__playerId]=null
        
    endfunction
