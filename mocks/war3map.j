endfunction


//===========================================================================
// Trigger: Hero Dies
//===========================================================================
function herodc takes nothing returns boolean
 local integer i= 0
 local boolean die= false
  loop
   exitwhen i > 8
   if ( GetDyingUnit() == udg_PHero[i] ) then
        set die=true
        return die
    endif
  set i=i + 1
 endloop
    return die
endfunction



