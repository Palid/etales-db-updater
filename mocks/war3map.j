 local integer i= 0
    set gg_trg_enablecellars=CreateTrigger()
 //  call TriggerRegisterUnitInRange(gg_trg_enablecellars, gg_unit_n05C_0662, 255, Condition(function rescok))
        loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_enablecellars, Player(i), EVENT_PLAYER_UNIT_PICKUP_ITEM, Condition(function btrue))
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
    endloop
   call TriggerAddCondition(gg_trg_enablecellars, Condition(function enablecellc))
   call TriggerAddAction(gg_trg_enablecellars, function enablecella)
endfunction


