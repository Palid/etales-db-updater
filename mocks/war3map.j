//===========================================================================
// Trigger: destructible drop
//
//     if ( percent > GetRandomReal(1,100) ) then 
//       set f = GetRandomInt(37,41)
//       call CreateItem(udg_itmpool[f],GetRandomReal(x-50,x+50),GetRandomReal(y-50,y+50))
//     endif
//     
//     set percent = percent *0.5
//     loop
//     exitwhen i>lop
//     
//      if ( percent > GetRandomReal(1,100) ) then 
//        call CreateItem(udg_itmpool[91],GetRandomReal(x-50,x+50),GetRandomReal(y-50,y+50))
//      endif
//     
//     set i = i+1
//     endloop
//     
//      if ( percent > GetRandomReal(1,100) ) then 
//        call CreateItem(udg_itmpool[90],GetRandomReal(x-50,x+50),GetRandomReal(y-50,y+50))
//      endif
//===========================================================================


function Trig_destructible_drop_Actions takes nothing returns nothing
  local destructable d= GetTriggerDestructable()
  local integer id= LoadInteger(udg_cache, GetHandleId(d), 2)
  local integer f
  local real x= GetDestructableX(d)
  local real y= GetDestructableY(d)
  local integer lop= R2I(GetRandomReal(1, logg(2 , I2R(s__Fortune[id]))))
  local real percent= 7 + ( ( I2R(s__Fortune[id]) * globalFortune ) / 1618 ) * 100
  local integer i= 0
  
   call FlushChildHashtable(udg_cache, GetHandleId(d))
  //  set udg_tmpit = GetDestructableLoc(GetDyingDestructable())
   
    
    if ( percent > GetRandomReal(1, 100) ) then
      set f=GetRandomInt(37, 41)
      call CreateItem(udg_itmpool[f], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
    endif
    
    set percent=percent * 0.5
    loop
    exitwhen i > lop
    
     if ( percent > GetRandomReal(1, 100) ) then
       call CreateItem(udg_itmpool[91], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
     endif
    
    set i=i + 1
    endloop
    
     if ( percent > GetRandomReal(1, 100) ) then
       call CreateItem(udg_itmpool[90], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
     endif
  
    
    set d=null

endfunction

//===========================================================================
function InitTrig_destructible_drop takes nothing returns nothing
    set gg_trg_destructible_drop=CreateTrigger()
    call TriggerAddAction(gg_trg_destructible_drop, function Trig_destructible_drop_Actions)
endfunction


