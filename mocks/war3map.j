// Trigger: unitpreload
//===========================================================================

function makepreload takes nothing returns boolean
call ExecuteFunc("unitpreloadler")
return false
endfunction

function unitpreloadler takes nothing returns nothing

 local integer i= 0
 //local unit preloader = null
 
      set loadingcounter=loadingcounter + 0.01
      set loadingDisplay="Starting Unitpreloader"
 loop
 exitwhen i > 263
//set preloader = CreateUnit(Player(PLAYER_NEUTRAL_PASSIVE),'hpea',0,0,270)
 call RemoveUnit(CreateUnit(Player(PLAYER_NEUTRAL_PASSIVE), udg_CreepType[i], 21513, - 21007, 270))
// call KillUnit(preloader)
 //set preloader  = null
  call TriggerSleepAction(0.03)
 set i=i + 1
 endloop
 
  loop
 exitwhen i > 1066

  call RemoveItem(CreateItem(udg_itmpool[i], 21513, - 21007))

  call TriggerSleepAction(0.03)
 set i=i + 1
 endloop
 
  loop
 exitwhen i > 60
 call RemoveUnit(CreateUnit(Player(PLAYER_NEUTRAL_PASSIVE), udg_HeroTipe[i], 21513, - 21007, 270))
 call TriggerSleepAction(0.03)
 set i=i + 1
 endloop
 
 
  call DestroyEffect(AddSpecialEffect(seffect, 21513, - 21007))
   call TriggerSleepAction(0.01)
  call DestroyEffect(AddSpecialEffect(seffectb, 21513, - 21007))
   call TriggerSleepAction(0.01)
call DestroyEffect(AddSpecialEffect(seffectf, 21513, - 21007))
   call TriggerSleepAction(0.01)
call DestroyEffect(AddSpecialEffect(seffectclap, 21513, - 21007))
   call TriggerSleepAction(0.01)
call DestroyEffect(AddSpecialEffect(seffectjump, 21513, - 21007))
   call TriggerSleepAction(0.01)
