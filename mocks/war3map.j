//===========================================================================
function InitTrig_mesera takes nothing returns nothing
    set gg_trg_mesera=CreateTrigger()
    set mesere=CreateTrigger()
    
    call TriggerRegisterEnterRectSimple(gg_trg_mesera, gg_rct_mesera1)
    call TriggerRegisterEnterRectSimple(mesere, gg_rct_mesera2)
    
    call TriggerAddCondition(gg_trg_mesera, Condition(function Trig_mesera_Conditions))
    call TriggerAddCondition(mesere, Condition(function Trig_mesera_Conditions))
    
    call TriggerAddAction(gg_trg_mesera, function Trig_mesera_Actions)
    call TriggerAddAction(mesere, function Trig_mesere_Actions)
endfunction


//===========================================================================
// Trigger: mesRumCS
//
// Cursed girl rumor mesera
//===========================================================================
//TESH.scrollpos=15
//TESH.alwaysfold=0
function Trig_mesRumCS_Conditions takes nothing returns boolean
     return ( IsUnitInGroup(GetTriggerUnit(), spidersman) == true )
endfunction

function Trig_mesRumCS_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local real face= GetUnitFacing(u)

call DisableTrigger(gg_trg_mesRumCS)
//call GroupRemoveUnit(spidersman,u)
call UnitChat("Excuse me, can I ask something to you?" , u)
call TriggerSleepAction(0.5)
call IssueImmediateOrder(mesera, "stop")
call TriggerSleepAction(0.3)
call SetUnitFacingToFaceUnitTimed(mesera, u, 0)
call TriggerSleepAction(0.7)
call UnitChat("Sure, tell me..." , mesera)
call TriggerSleepAction(3)
call UnitChat("Do you know a stranger girl, that runs crazy on the fields?" , u)
call TriggerSleepAction(3)
call UnitChat("Oh...-that- girl." , mesera)
call TriggerSleepAction(3)
call UnitChat("She was lost on spiders's forest a few months ago." , mesera)
call TriggerSleepAction(3)
call UnitChat("But, do you know if she has parents?" , u)
call TriggerSleepAction(3)
call UnitChat("You want help her??." , mesera)
call TriggerSleepAction(3)
call UnitChat("Well, no... uhm, ok yes, I feel sadly by her life" , u)
call TriggerSleepAction(3)
call UnitChat("I cannot help you, but you can ask to ERUDITO." , mesera)
call TriggerSleepAction(3)
call UnitChat("He is drinking close to the bar." , mesera)
call TriggerSleepAction(2)
call UnitChat("Ok, thank you" , u)
call TriggerSleepAction(2)
call UnitChat("You are welcome!" , mesera)
call IssuePointOrder(mesera, "move", - 19511, - 19779)
set eruditON=true

set u=null
endfunction


//===========================================================================
function InitTrig_mesRumCS takes nothing returns nothing
    set gg_trg_mesRumCS=CreateTrigger()
    call TriggerRegisterUnitInRange(gg_trg_mesRumCS, gg_unit_n05G_0886, 210, Condition(function rescok))
    call TriggerAddCondition(gg_trg_mesRumCS, Condition(function Trig_mesRumCS_Conditions))
    call TriggerAddAction(gg_trg_mesRumCS, function Trig_mesRumCS_Actions)
endfunction


//===========================================================================
// Trigger: Erudito
//===========================================================================
//TESH.scrollpos=45
//TESH.alwaysfold=0
function eruditoc takes nothing returns boolean
 return ( ( IsUnitInGroup(GetTriggerUnit(), spidersman) == true ) and eruditON == true )
endfunction

function eruditoa takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer Id= GetPlayerId(GetOwningPlayer(u))

 call DisableTrigger(gg_trg_Erudito)
 call UnitChat("...Erudito?." , u)
 call TriggerSleepAction(3)
 call UnitChat("Who is asking?." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("Me... someone says you can helpme" , u)
 call TriggerSleepAction(0.3)
 call SetUnitFacingToFaceUnitTimed(erudito, u, 0)
 call TriggerSleepAction(4.7)
 call UnitChat("Are you a stealer?." , erudito)
 call TriggerSleepAction(3)
  call UnitChat("I dont want problems." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("No No... it's just about a girl" , u)
 call TriggerSleepAction(2)
 call UnitChat("You fall in love?." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("Sorry, I cannot make enchantments." , erudito)
 call TriggerSleepAction(2)
 call UnitChat("No, dammit. Do you know that girl?" , u)
 call TriggerSleepAction(3)
 call UnitChat("She runs crazy on the fields... and..." , u)
 call TriggerSleepAction(4)
  call UnitChat("She scatters spiders......" , u)
 call TriggerSleepAction(4)
  call UnitChat("Uuuu that sounds disturbing." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("I don´t know any about that chick, but if she scatters spiders then." , erudito)
 call TriggerSleepAction(6)
 call UnitChat("She is cursed..." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("It looks like she was kissed with a strange poison..." , erudito)
 call TriggerSleepAction(5)
call UnitChat("I can help you, but we need to do something before.." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("Find me in a few hours on the bandits bridge..." , erudito)
 call TriggerSleepAction(2)
  call UnitChat("Oh, thanks man, I will find you" , u)
 call TriggerSleepAction(1)
 call IssuePointOrder(erudito, "move", - 19639, - 20877)
 call TriggerSleepAction(24)
 call ShowUnit(erudito, false)

 call TriggerSleepAction(120)
 call DisplayTimedTextToPlayer(Player(Id), 0, 0, 5, "    |cffffcc00Erudito|r is waiting on Bandit's Bridge ")
 call SetUnitPosition(erudito, - 1004, - 3608)
 call ShowUnit(erudito, true)
 set eruditbON=true

 call TriggerSleepAction(0.5)
    
      if ( GetLocalPlayer() == Player(Id) ) then
          call PingMinimap(- 1004, - 3608, 5)
       endif
   set u=null
endfunction

//===========================================================================
function InitTrig_Erudito takes nothing returns nothing
    set gg_trg_Erudito=CreateTrigger()
    call TriggerRegisterUnitInRange(gg_trg_Erudito, gg_unit_n05F_0958, 210, Condition(function rescok))
    call TriggerAddCondition(gg_trg_Erudito, Condition(function eruditoc))
    call TriggerAddAction(gg_trg_Erudito, function eruditoa)
endfunction


//===========================================================================
// Trigger: FindingspidersA
//===========================================================================
//TESH.scrollpos=56
//TESH.alwaysfold=0
function findingc takes nothing returns boolean
 return ( ( IsUnitInGroup(GetTriggerUnit(), spidersman) == true ) and eruditbON == true )
endfunction

function Trig_FindingspidersA_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer questid= 0
local integer Id= GetPlayerId(GetOwningPlayer(u))
local integer i= 0
 call UnitChat(" Hey guy..." , erudito)
  call TriggerSleepAction(2)
 if travelerc[Id] > 3 then
 call UnitChat(" You have a lot of people here (+4)" , erudito)
 call TriggerSleepAction(3)
  call UnitChat(" Please finish your other bussines before" , erudito)
 call TriggerSleepAction(3)
   call UnitChat(" I will wait you here" , erudito)
  set u=null
  return
 endif

 call DisableTrigger(gg_trg_FindingspidersA)
 call AddTraveler(Id , erudito)
 call UnitChat(" Do you know that phrase..." , erudito)
 call TriggerSleepAction(3)
 call UnitChat(" ...-Poison kills poison?-.." , erudito)
 call TriggerSleepAction(3)
  call UnitChat(" I have no idea what are you talking about..." , u)
 call TriggerSleepAction(3)
 call UnitChat(" Don't worry.." , erudito)
 call TriggerSleepAction(2)
 call UnitChat(" I just say that I can make a potion.." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("that can calm down that girl." , erudito)
 call TriggerSleepAction(2)
 call UnitChat(" That sounds great but, what you need for making the potion?..." , u)
 call TriggerSleepAction(6)
 call UnitChat(" Well, this is the hard part..." , erudito)
 call TriggerSleepAction(4)
 call UnitChat(" We need a strange liquid..." , erudito)
 call TriggerSleepAction(3)
  call UnitChat("That can be found on the visceras from a Giant spider..." , erudito)
 call TriggerSleepAction(4)
 call UnitChat(" What???..." , u)
 call TriggerSleepAction(3)
 call UnitChat(" We need to kill a Giant spider???.." , u)
 call TriggerSleepAction(4)
 call UnitChat("Well.." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("Not exactly.." , erudito)
 call TriggerSleepAction(2)
 call UnitChat("We need to kill..." , erudito)
 call TriggerSleepAction(3)
 call UnitChat("15 Giant spiders at least..." , erudito)
 call TriggerSleepAction(5)
 call UnitChat(" Man, we gonna die... do you know how strong are those spiders??" , u)
 call TriggerSleepAction(3)
  call UnitChat(" Yes, I know..." , erudito)
 call TriggerSleepAction(3)
 call UnitChat(" But this is the only solution" , erudito)
 call TriggerSleepAction(2)
 call UnitChat(" If you want to help that girl" , erudito)
 call TriggerSleepAction(2)
 
 set questid=SetupQuest(Id , erudito , "THE CURSED MAIDEN" , "Slay and extract liquid from Giant Spiders " , "0" , "/15" , 0 , s__qty[3])
 set spiderkiller=udg_PHero[Id] //for checking quest
 call SetUnitUserData(cursedlady, questid) //here I can take the quest id.
 call EnableTrigger(gg_trg_killingspiders)
    if ( GetLocalPlayer() == Player(Id) ) then
          call ClearTextMessages()
   endif
   call StartSound(bj_questDiscoveredSound)
   call DisplayTimedTextToPlayer(Player(Id), 0, 0, 4, "|cffffcc00PERSONAL QUEST|r")
   call DisplayTimedTextToPlayer(Player(Id), .1, 0, 4, "Kill 15 Giant Spiders")
   
   //set Qdata[questid]=15//delete this
   
 loop
   exitwhen Qdata[questid] > 14
   call TriggerSleepAction(2)
    set i=GetRandomInt(1, 40)
     if i == 3 then
     call UnitChat("come here little spider...fuifu!" , erudito)
     elseif i == 5 then
     call UnitChat("Hey, just keep yourself alive" , erudito)
     elseif i == 8 then
     call UnitChat("This place... makes me afraid...(*_*)!" , erudito)
     elseif i == 12 then
     call UnitChat("I wanna dream with spiders" , erudito)
    endif
   endloop
 
 call TriggerSleepAction(5)
 call UnitChat(" Nicely done Traveler, " , erudito)
 call TriggerSleepAction(3)
 call UnitChat(" I wanna make the potion " , erudito)
 call TriggerSleepAction(3)
 call UnitChat(" Found me in the Troll's Cave entrance in a few hours" , erudito)
 set questid=SetupQuest(Id , erudito , "THE CURSED MAIDEN" , "Wait for Erudito's Advice" , "-" , "-" , 0 , s__qty[3])
 call SetUnitUserData(cursedlady, questid)
 call RemoveTraveler(Id , erudito)
 call IssuePointOrder(erudito, "move", - 19639, - 20877)
 call TriggerSleepAction(10)
 call ShowUnit(erudito, false)
 call TriggerSleepAction(200)
 call DisplayTimedTextToPlayer(Player(Id), 0, 0, 5, "    |cffffcc00Erudito|r is waiting on Troll's Cave entrance ")
 call SetUnitPosition(erudito, - 6528, 2914)
 call ShowUnit(erudito, true)
 call EnableTrigger(gg_trg_EruditoPotion)
endfunction

