//===========================================================================
// Trigger: Zeppelin
//===========================================================================
function Trig_Zeppelin_Conditions takes nothing returns boolean
    return GetItemLevel(GetManipulatedItem()) == 5000 and batform[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == false and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_Zeppelin_Actions takes nothing returns nothing
    local integer pid= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
    local location p= GetUnitLoc(GetTriggerUnit())
    local integer i= R2I(GetItemLifeBJ(GetManipulatedItem()))
    local unit u= GetTriggerUnit()
    //local sound s = null
    
   call SetUserControlForceOff(bj_FORCE_PLAYER[pid])

   call SetUnitPositionLoc(udg_zeppelinunit[pid], p)
   
    call ShowUnit(udg_zeppelinunit[pid], true)
    call ShowUnit(udg_Slave[pid], false)
   // call ShowUnit( udg_Familiar[pid],false )
    call CameraSetupApplyForPlayer(true, udg_camaras[udg_Plugar[pid]], GetOwningPlayer(GetTriggerUnit()), 4.00)
    call IssueTargetOrder(udg_zeppelinunit[pid], "load", u)
    call TriggerSleepAction(4.00)
    set traveling[pid]=true
    set udg_Plugar[pid]=i - 10
   // call CinematicModeBJ( true, bj_FORCE_PLAYER[pid] )
   // call IssueTargetOrder( udg_zeppelinunit[pid], "load",u)

 
    call IssuePointOrderLoc(udg_zeppelinunit[pid], "move", udg_Zeppelinp[( i - 10 )])
   // call PlaySoundOnUnitBJ(s, 90, udg_zeppelinunit[pid] )
    
    
   // call SetCameraTargetControllerNoZForPlayer( GetOwningPlayer(GetTriggerUnit()), udg_zeppelinunit[pid], 0, 0, false )
   
    call TriggerSleepAction(2.00)
    call GroupAddUnit(udg_Travelers, udg_zeppelinunit[pid])


call RemoveLocation(p)
set p=null
set u=null
//set s = null
endfunction

//===========================================================================
function InitTrig_Zeppelin takes nothing returns nothing
    set gg_trg_Zeppelin=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Zeppelin, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_Zeppelin, Condition(function Trig_Zeppelin_Conditions))
    call TriggerAddAction(gg_trg_Zeppelin, function Trig_Zeppelin_Actions)
endfunction


//===========================================================================
// Trigger: Zeppelinend
//===========================================================================
//TESH.scrollpos=23
//TESH.alwaysfold=0
function Trig_Zeppelinend_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == 'n01F' and IsUnitInGroup(GetTriggerUnit(), udg_Travelers) == true )
endfunction

function Trig_Zeppelinend_Actions takes nothing returns nothing
   local integer pid= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   local location p= GetUnitLoc(GetTriggerUnit())
   local unit u= GetTriggerUnit()
   
    set traveling[pid]=false
    call IssueTargetOrder(udg_zeppelinunit[pid], "unload", udg_PHero[pid])
    call ShowUnit(udg_Slave[pid], true)
    call ShowUnit(udg_Familiar[pid], true)
    call SetUnitPositionLoc(udg_Slave[pid], p)
    call SetUnitPositionLoc(udg_Familiar[pid], p)
    
     
      if ( cslave[pid] != null ) then
        call SetUnitPositionLoc(cslave[pid], p)
     endif
  
   //   if (traveler1[pid]!=null) then     
  //      call SetUnitPositionLoc(traveler1[pid] ,p)
  //   endif
   //      if (traveler2[pid]!=null) then     
  //      call SetUnitPositionLoc(traveler2[pid] ,p)
  //   endif
   //      if (traveler3[pid]!=null) then     
  //      call SetUnitPositionLoc(traveler3[pid] ,p)
  //   endif
   //      if (traveler4[pid]!=null) then     
   //     call SetUnitPositionLoc(traveler4[pid] ,p)
   //  endif
  //*/
  
    call GroupRemoveUnit(udg_Travelers, udg_zeppelinunit[pid])
  //  call CinematicModeBJ( false, bj_FORCE_PLAYER[pid] )

    call ResetToGameCameraForPlayer(Player(pid), 3)
      call TriggerSleepAction(0.3)
    
      if ( GetLocalPlayer() == Player(pid) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call PanCameraToTimed(GetUnitX(udg_PHero[pid]), GetUnitY(udg_PHero[pid]), 2.4)
      endif
      
    call TriggerSleepAction(3.00)
    if ( udg_rpgc[pid] == true ) then
        call SetCameraTargetControllerNoZForPlayer(Player(pid), udg_PHero[pid], 0.00, 0.00, false)
        call SetCameraFieldForPlayer(Player(pid), CAMERA_FIELD_TARGET_DISTANCE, ( GetCameraField(CAMERA_FIELD_TARGET_DISTANCE) + 500.00 ), 0.00)

    endif
    call CameraSetSmoothingFactor(4.00)
    call ShowUnit(udg_zeppelinunit[pid], false)
    call RemoveLocation(p)
 set p=null
    
    call SetUserControlForceOn(bj_FORCE_PLAYER[pid])
    

 set u=null
endfunction

//===========================================================================
function InitTrig_Zeppelinend takes nothing returns nothing
    set gg_trg_Zeppelinend=CreateTrigger()
    call TriggerRegisterEnterRectSimple(gg_trg_Zeppelinend, gg_rct_valdivia)
    call TriggerRegisterEnterRectSimple(gg_trg_Zeppelinend, gg_rct_velhimen)
    call TriggerRegisterEnterRectSimple(gg_trg_Zeppelinend, gg_rct_colddream)
    call TriggerRegisterEnterRectSimple(gg_trg_Zeppelinend, gg_rct_ekrom)
    call TriggerRegisterEnterRectSimple(gg_trg_Zeppelinend, gg_rct_varanger)
    call TriggerAddCondition(gg_trg_Zeppelinend, Condition(function Trig_Zeppelinend_Conditions))
    call TriggerAddAction(gg_trg_Zeppelinend, function Trig_Zeppelinend_Actions)
endfunction


