    call TriggerRegisterAnyUnitEventBJ(gg_trg_newzgroup, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_newzgroup, Condition(function Trig_newzgroup_Conditions))
    call TriggerAddAction(gg_trg_newzgroup, function Trig_newzgroup_Actions)
