//===========================================================================
// Trigger: initcommand
//===========================================================================
function newInit takes nothing returns nothing
local unit u= CreateUnitAtLoc(GetTriggerPlayer(), 'e00K', udg_Startpoint, 90.00)
call PanCameraToTimedForPlayer(GetTriggerPlayer(), GetLocationX(udg_Startpoint), GetLocationY(udg_Startpoint), 0)

call CreateFogModifierRadiusLocBJ(true, GetTriggerPlayer(), FOG_OF_WAR_VISIBLE, udg_Startpoint, 900.00)
       

set udg_RevivalPoints[GetPlayerId(GetTriggerPlayer())]=Location(10300, 16410)
set udg_PlayerReady[GetPlayerId(GetTriggerPlayer())]=true
set u=null
endfunction

function IsReady takes nothing returns boolean
  return udg_PlayerReady[GetPlayerId(GetTriggerPlayer())] == false
endfunction

//===========================================================================
function InitTrig_initcommand takes nothing returns nothing
  local integer i= 0
    set gg_trg_initcommand=CreateTrigger()
    call DisableTrigger(gg_trg_initcommand)
    loop
    exitwhen i > 10
      call TriggerRegisterPlayerChatEvent(gg_trg_initcommand, Player(i), "-new", true)
      set i=i + 1
    endloop
    call TriggerAddCondition(gg_trg_initcommand, Condition(function IsReady))
    call TriggerAddAction(gg_trg_initcommand, function newInit)
endfunction


