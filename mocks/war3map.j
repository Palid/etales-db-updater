    set gg_trg_openchest=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_openchest, EVENT_PLAYER_UNIT_USE_ITEM)
    call TriggerAddCondition(gg_trg_openchest, Condition(function Trig_openchest_Conditions))
    call TriggerAddAction(gg_trg_openchest, function Trig_openchest_Actions)
endfunction


//===========================================================================
// Trigger: store gem
//===========================================================================
function Trig_store_gem_Conditions takes nothing returns boolean
    return ( GetWidgetLife(GetManipulatedItem()) == 53 )
endfunction

function Trig_store_gem_Actions takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local integer itemid= GetItemTypeId(GetManipulatedItem())
  
  
  if itemid == 'I0MJ' then
      
       set onix[id]=onix[id] + 1
   
      
  elseif itemid == 'I0MK' then
  
     set rubi[id]=rubi[id] + 1
    
  
  elseif itemid == 'I0ML' then
  
       set diamond[id]=diamond[id] + 1
     
  
  elseif itemid == 'I0MM' then
  
     set emerald[id]=emerald[id] + 1
    
  
  elseif itemid == 'I0MN' then
  
     set saphire[id]=saphire[id] + 1
     

  elseif itemid == 'I0UH' then
  
     set GemVar_A[id]=GemVar_A[id] + 1
           
  endif
  
  
  call releasejewel(id)
    
    
    set itemid=0
endfunction

//===========================================================================
function InitTrig_store_gem takes nothing returns nothing
local integer i= 0
    set gg_trg_store_gem=CreateTrigger()
    
   loop
   exitwhen i > 12

     call TriggerRegisterPlayerUnitEvent(gg_trg_store_gem, Player(i), EVENT_PLAYER_UNIT_USE_ITEM, Condition(function bool))
    set i=i + 1
  endloop
    
    call TriggerAddCondition(gg_trg_store_gem, Condition(function Trig_store_gem_Conditions))
    call TriggerAddAction(gg_trg_store_gem, function Trig_store_gem_Actions)
endfunction


//===========================================================================
// Trigger: removegem
//===========================================================================
function Trig_removegem_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetSellingUnit()) == 'e00E' )
endfunction

function Trig_removegem_Actions takes nothing returns nothing

  local integer id= GetPlayerId(GetOwningPlayer(GetSellingUnit()))
  local item it= GetSoldItem()
  local integer itemid= GetItemTypeId(it)

  call SaveInteger(nodump, GetHandleId(it), GetHandleId(it), id + 10)
  
  if itemid == 'I0MJ' then
      
       set onix[id]=onix[id] - 1
      
  elseif itemid == 'I0MK' then
  
     set rubi[id]=rubi[id] - 1
  
  elseif itemid == 'I0ML' then
  
       set diamond[id]=diamond[id] - 1
  
  elseif itemid == 'I0MM' then
  
     set emerald[id]=emerald[id] - 1
  
  elseif itemid == 'I0MN' then
  
     set saphire[id]=saphire[id] - 1

  elseif itemid == 'I0UH' then
  
     set GemVar_A[id]=GemVar_A[id] - 1
           
  endif
  
  call releasejewel(id)
  set it=null
    
endfunction

