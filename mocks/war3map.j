//===========================================================================
// Trigger: fade
//===========================================================================
function Trig_fade_Actions takes nothing returns nothing

 call CinematicFadeBJ(bj_CINEFADETYPE_FADEOUT, 0, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0)
 //call TransmissionFromUnitTypeWithNameBJ( GetPlayersAll(), Player(PLAYER_NEUTRAL_PASSIVE), 'Ntin', "Etales", GetRectCenter(gg_rct_healer_bulbs), null, "Welcome to the land of Enthashara", bj_TIMETYPE_ADD, 0, true )
    call TriggerSleepAction(5)
   // call PlaySoundBJ( gg_snd_travel1 )
    call TriggerExecute(gg_trg_Cam4)
    call TriggerSleepAction(0.1)
    call TriggerExecute(gg_trg_Cam2)

    //return
   call TriggerSleepAction(0.5)
  call CinematicFadeBJ(bj_CINEFADETYPE_FADEIN, 5.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0)
    call TriggerSleepAction(11.00)
  //  call CinematicFadeBJ( bj_CINEFADETYPE_FADEOUT, 4, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0 )
    call TriggerSleepAction(5)
    
  //  call TriggerExecute( gg_trg_cam1 )
    call TriggerSleepAction(0.05)
  //  call TriggerExecute( gg_trg_Camex )

  //  call CinematicFadeBJ( bj_CINEFADETYPE_FADEIN, 5.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0 )
    call TriggerSleepAction(11.00)
   // call CinematicFadeBJ( bj_CINEFADETYPE_FADEOUT, 4, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0 )
    call TriggerSleepAction(5)
 //   call TriggerExecute( gg_trg_cam3a )
    call TriggerSleepAction(0.1)
 //   call TriggerExecute( gg_trg_Cam3 )
 //   call CinematicFadeBJ( bj_CINEFADETYPE_FADEIN, 5.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0 )
    call TriggerSleepAction(18.00)
//    call CinematicFadeBJ( bj_CINEFADETYPE_FADEOUT, 4, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0 )
    call TriggerSleepAction(5)
 //   call TriggerExecute( gg_trg_camXi )
  //  call CinematicFadeBJ( bj_CINEFADETYPE_FADEIN, 5.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0 )
    
 
endfunction

//===========================================================================
function InitTrig_fade takes nothing returns nothing
    set gg_trg_fade=CreateTrigger()
   // call DisableTrigger(gg_trg_fade)
    call TriggerRegisterTimerEvent(gg_trg_fade, 0.1, false)
    call TriggerAddAction(gg_trg_fade, function Trig_fade_Actions)
endfunction


//===========================================================================
// Trigger: disableatinit
//===========================================================================
function Trig_disableatinit_Actions takes nothing returns nothing
 local integer i= 0
    
    
    call SetSkyModel("Environment\\Sky\\BlizzardSky\\BlizzardSky.mdl")

    

    call CinematicModeBJ(true, GetPlayersAll())
        call ShowInterfaceForceOff(GetPlayersAll(), 0)

   call DisplayTimedTextToForce(GetPlayersAll(), 3, "Welcome to the land of Enthashara")
   call TriggerSleepAction(6)
   call DisplayTimedTextToForce(GetPlayersAll(), 3, "We need to start some ugly sistems before, so please wait while  we work on it.")
   call TriggerSleepAction(5)
   call DisplayTimedTextToForce(GetPlayersAll(), 5.00, "As aditional info, in quest menu (f9) you will  find useful information about Etales.")
   call TriggerSleepAction(7)
   call DisplayTimedTextToForce(GetPlayersAll(), 5.00, "Current camera mode will be locked as isometric view. If you want to use other mode type -nor")
   call TriggerSleepAction(7)
   call DisplayTimedTextToForce(GetPlayersAll(), 3.00, "Search into quest panel for current ingame commands, there are some useful")
   call TriggerSleepAction(5)
   call DisplayTimedTextToForce(GetPlayersAll(), 5.00, "Helpful tips: At beggining of the game gold runs slow, so some items are better to sell than use")
   call TriggerSleepAction(7)
   call DisplayTimedTextToForce(GetPlayersAll(), 4.00, "At novice stage you have an ability that allows you hide from enemies, use it")
   call TriggerSleepAction(6)
   call DisplayTimedTextToForce(GetPlayersAll(), 3.00, "Game saves resurrection spot on the latest city you entered")
   call TriggerSleepAction(5)
   call DisplayTimedTextToForce(GetPlayersAll(), 3.00, "If you find hard to encounter gem fragment just go to any cave and hit some rocks.")
   call TriggerSleepAction(4)
   call DisplayTimedTextToForce(GetPlayersAll(), 2.00, "Request edicts to increase XP ratio and gold income")
   call TriggerSleepAction(4)
   call DisplayTimedTextToForce(GetPlayersAll(), 3.00, "We are publishing useful info in our discord channel.")
   call TriggerSleepAction(4)
   call DisplayTimedTextToForce(GetPlayersAll(), 5.00, "Thanks a lot to Bogdi and yxfabi95xy for their help on deploying Etales Comunity.")
 
 
   call FogMaskEnableOn()
   call FogEnableOn()
    
   // loop 
  //  exitwhen i > 11
   //     call CameraSetupApplyForPlayer( true, gg_cam_initcamera, Player(i), 0 )
   // set i = i+1
  //  endloop
    
    
endfunction

//===========================================================================
function InitTrig_disableatinit takes nothing returns nothing
    set gg_trg_disableatinit=CreateTrigger()
   // call DisableTrigger(gg_trg_disableatinit)
    call TriggerRegisterTimerEvent(gg_trg_disableatinit, 0.30, false)
    call TriggerAddAction(gg_trg_disableatinit, function Trig_disableatinit_Actions)
endfunction


//===========================================================================
// Trigger: cam1
//===========================================================================
function Trig_cam1_Actions takes nothing returns nothing
local integer i= 0

loop
  exitwhen i > 9
    call CameraSetupApplyForPlayer(true, gg_cam_chrc, Player(i), 0)
    set i=i + 1
 endloop
    
endfunction

//===========================================================================
function InitTrig_cam1 takes nothing returns nothing
    set gg_trg_cam1=CreateTrigger()
    call TriggerAddAction(gg_trg_cam1, function Trig_cam1_Actions)
endfunction


