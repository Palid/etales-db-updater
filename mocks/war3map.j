//===========================================================================
// Trigger: Purgue quest
//===========================================================================
function Trig_Purgue_quest_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0M3' )
endfunction

function Trig_Purgue_quest_Actions takes nothing returns nothing
    local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
    local integer p= udg_purguers[id] / 2

    local integer level= GetUnitLevel(udg_PHero[id])
    local string e= null

    if level > 20 then
     call UnitChat("Sorry, but your soul isn't pure enough... (|cffff0000Max level allowed = 20|r)" , priest)
    
    else
    
        if ( udg_purguers[id] == 0 ) then
            set e="|cffffcc00Kill monsters in the catacomb to exchange kill points|r"
        else
            call SetUnitUserData(udg_PHero[id], ( GetUnitUserData(udg_PHero[id]) + p ))
            set udg_purguers[id]=0
            set e="|cffffcc00Exchanged " + I2S(p) + " Kill points for " + I2S(p * 2) + " monsters killed|r"
        endif
    
            call CreateTextTagUnitBJ(e, priest, 30, 9, 100, 100, 0, 0)
            call SetTextTagPermanent(GetLastCreatedTextTag(), false)
            call SetTextTagLifespan(GetLastCreatedTextTag(), 3)
            call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 80, 90)
    endif
endfunction

