    set gg_trg_clownHaterA=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_clownHaterA, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_clownHaterA, Condition(function Trig_clownHaterA_Conditions))
    call TriggerAddAction(gg_trg_clownHaterA, function Trig_clownHaterA_Actions)
