//===========================================================================
// Trigger: BaseeD
//===========================================================================
function Trig_BaseeD_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == udg_Bosses[0] and GetOwningPlayer(GetTriggerUnit()) == Player(PLAYER_DARK_LORD) )
endfunction

function Trig_BaseeD_Actions takes nothing returns nothing
//call shakecam()

 call DropPvpBoss(GetTriggerUnit())
 call CreateFixed(GetTriggerUnit() , 1025) //Forbidden walord hands
 

 call PauseTimer(BansheeEng)
 call ReleaseTimer(BansheeEng)
set BansheeEng=null
call shakecam(GetTriggerExecCount(gg_trg_BaseeD))
//This for avoiding dump items from stealers when the players are attacking some boss
call SetUnitDrop(udg_BOSSID[0] , 0 , 0 , 0 , 0 , 0 , 0 , 0 , 0)
call EnableTrigger(gg_trg_bsnhedrop)

  if ( GetTriggerExecCount(GetTriggeringTrigger()) > 1 ) then
  call CreateItemLoc('I00D', udg_BossesP[0]) //Divine Chest
  endif
 // call CreateItemLoc(udg_itmpool[897],udg_BossesP[0])

 
  call TriggerSleepAction(respawnboss)
  set udg_BOSS[0]=CreateUnitAtLoc(Player(PLAYER_DARK_LORD), udg_Bosses[0], udg_BossesP[0], 225)
  call SetHeroLevel(udg_BOSS[0], 51, false)
  call AddSpecialEffectTarget("Light.mdx", udg_BOSS[0], "origin")
  call TriggerRegisterUnitEvent(gg_trg_bsnhedrop, udg_BOSS[0], EVENT_UNIT_DAMAGED)
  call TriggerRegisterUnitEvent(gg_trg_bansheeprvent, udg_BOSS[0], EVENT_UNIT_ATTACKED)
  call TriggerRegisterUnitEvent(gg_trg_bansheedmaged, udg_BOSS[0], EVENT_UNIT_DAMAGED)
  call TriggerRegisterUnitInRange(gg_trg_bansheeEng, udg_BOSS[0], 1024, null)
  call EnableTrigger(gg_trg_bansheeEng)
  call PauseUnit(udg_BOSS[0], true)
  call SetUnitInvulnerable(udg_BOSS[0], true)
endfunction

//===========================================================================
function InitTrig_BaseeD takes nothing returns nothing
    set gg_trg_BaseeD=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_BaseeD, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_BaseeD, Condition(function Trig_BaseeD_Conditions))
    call TriggerAddAction(gg_trg_BaseeD, function Trig_BaseeD_Actions)
endfunction


//===========================================================================
// Trigger: bansheeEng
//
// When engaging a battle
//===========================================================================

function bansheecycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit dmy= LoadUnitHandle(hts, GetHandleId(t), 0)
local unit u= LoadUnitHandle(hts, GetHandleId(t), 1)
local integer id= GetPlayerId(GetOwningPlayer(u))
local real xc= LoadReal(hts, GetHandleId(t), 2)
local real yc= LoadReal(hts, GetHandleId(t), 3)
local real distance= LoadInteger(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i=  LoadInteger(hts, GetHandleId(t), 7)
local unit h= LoadUnitHandle(hts, GetHandleId(t), 8)
local real inc= 12
local real x
local real y
local real xb
local real yb
local real amp
local real face
local real bx= xc
local real by= yc



	set it=it - 1
	set i=i + 9
	set xc=xc + inc * Cos(angle * bj_DEGTORAD)
	set yc=yc + inc * Sin(angle * bj_DEGTORAD)
	set amp=Sin(i * bj_DEGTORAD) * 120
 
 set x=xc + amp * Cos(( angle - 90 ) * bj_DEGTORAD)
 set y=yc + amp * Sin(( angle - 90 ) * bj_DEGTORAD)

 set face=Sin(i * bj_DEGTORAD)
 
  call SetUnitX(dmy, x)
  call SetUnitY(dmy, y)

 call SetUnitFacing(dmy, angle * face)


 
 call SaveReal(hts, GetHandleId(t), 2, xc)
 call SaveReal(hts, GetHandleId(t), 3, yc)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 
if it < 0 then
  call ShowUnit(u, true)
  call PauseUnit(u, false)
  call SetUnitX(u, x)
  call SetUnitY(u, y)
  call UnitApplyTimedLife(dmy, 'BTLF', 0.05)
  call IssueTargetOrder(u, "smart", h)
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  
  
endif

set t=null
set dmy=null
set u=null
set h=null



endfunction



function bansheeDispl takes unit a,unit u returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(a))
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real distance= SquareRoot(dx * dx + dy * dy) + 500
 local real it= distance / 12
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local unit dmy=  CreateUnit(Player(id), 'n00A', ux, uy, angle)
 local integer sng= GetRandomInt(0, 3)

 if sng == 0 then
  call PlaySoundOnUnitBJ(gg_snd_BansheeYesAttack1, 100, dmy)
  //call StartSound(gg_snd_BansheeYesAttack1)  
elseif sng == 1 then
 call PlaySoundOnUnitBJ(gg_snd_BansheeYesAttack2, 100, dmy)
//call StartSound(gg_snd_BansheeYesAttack2) 
elseif sng == 2 then
 call PlaySoundOnUnitBJ(gg_snd_BansheeYesAttack3, 100, dmy)
//call StartSound(gg_snd_BansheeYesAttack3) 
elseif sng == 3 then
 call PlaySoundOnUnitBJ(gg_snd_BansheePissed2, 100, dmy)
//call StartSound(gg_snd_BansheePissed2) 
endif
 
 
 call ShowUnit(a, false)
 call PauseUnit(a, true)
 set ux=ux - 90 * Cos(angle * bj_DEGTORAD)
 set uy=uy - 90 * Sin(angle * bj_DEGTORAD)
 
 call SaveUnitHandle(hts, GetHandleId(t), 0, dmy)
 call SaveUnitHandle(hts, GetHandleId(t), 1, a)
 call SaveReal(hts, GetHandleId(t), 2, ux)
 call SaveReal(hts, GetHandleId(t), 3, uy)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveUnitHandle(hts, GetHandleId(t), 8, u)
 

 call TimerStart(t, 0.03, true, function bansheecycle)
 
 set t=null
 set dmy=null
 

endfunction



function bsfilter takes nothing returns boolean
    return true
endfunction

function Trig_bansheeEng_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetPlayerController(GetOwningPlayer(GetTriggerUnit())) == MAP_CONTROL_USER //banshee
endfunction

function BansheeActions takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit B= LoadUnitHandle(AiHash, GetHandleId(t), 1)
    local integer i= LoadInteger(AiHash, GetHandleId(t), 2)
 local integer buf= LoadInteger(AiHash, GetHandleId(t), 3)
	
 local unit gu
 local unit mi
 local boolexpr filter
 local real dmg
 local real x= GetUnitX(B)
 local real y= GetUnitY(B)


set buf=buf + 1

 if buf > 9 then
 set buf=0
  call UnitRemoveBuffs(B, false, true)

 endif
 
  set i=i + 1

  if i > 180 then
    set i=0
	set bansminc=bansminc + 1
    set bansheegr=CreateGroup()
	set filter=Condition(function bsfilter)
    call GroupEnumUnitsInRange(bansheegr, x, y, 1024, filter)
    call DestroyBoolExpr(filter)
    set filter=null

	   loop
	    set gu=FirstOfGroup(bansheegr)
		  exitwhen gu == null
			if ( IsUnitType(gu, UNIT_TYPE_HERO) == true and IsUnitEnemy(gu, GetOwningPlayer(B)) == true and GetWidgetLife(gu) > 0.4 ) then
				 call GroupClear(bansheegr)
				 call bansheeDispl(B , gu)
			endif
		   
		call GroupRemoveUnit(bansheegr, gu)
		set gu=null
		endloop

	 call DestroyGroup(bansheegr)
	 set bansheegr=null
	 
  elseif bansminc > 5 then
     set bansminc=0
     call PauseUnit(B, true)
	 call SetUnitAnimationByIndex(B, 3)
	 call DestroyEffect(AddSpecialEffect(seffectclap, x, y))
	 call PauseUnit(B, false)

     set filter=Condition(function bsfilter)
     set bansheegr=CreateGroup()
     call GroupEnumUnitsInRange(bansheegr, x, y, 1024, filter)
     call DestroyBoolExpr(filter)
     set filter=null
	 
	 call GroupClear(bansheeminions)
	

	   loop
	    set gu=FirstOfGroup(bansheegr)
		  exitwhen gu == null
			if ( IsUnitType(gu, UNIT_TYPE_HERO) == true and IsUnitEnemy(gu, GetOwningPlayer(B)) == true and GetWidgetLife(gu) > 0.4 ) then
				set mi=CreateUnit(Player(13), 'n08R', GetUnitX(B), GetUnitY(B), bj_UNIT_FACING) //bansheeminion
				call SetUnitTimeScale(mi, 0.43)
				call SetUnitUserData(mi, GetPlayerId(GetOwningPlayer(gu)) + 1)
				call UnitApplyTimedLife(mi, 'BTLF', 2.4)
				set mi=null
			endif
		   
		call GroupRemoveUnit(bansheegr, gu)
		set gu=null
		endloop

	 call DestroyGroup(bansheegr)
	 set bansheegr=null

                set mi=CreateUnit(Player(13), 'n08R', GetUnitX(B), GetUnitY(B), bj_UNIT_FACING) //bansheeminion
				call SetUnitTimeScale(mi, 0.43)
				call UnitApplyTimedLife(mi, 'BTLF', 2.4)
				set mi=null
	//call TriggerSleepAction(3)			
	// / loop
	 //   set gu = FirstOfGroup(bansheeminions)
	//	  exitwhen gu == null 
	//	call TriggerSleepAction(1)  
		
	// endloop
	
	   
	     
	 //  set gu = null
  endif

  call SaveInteger(AiHash, GetHandleId(t), 2, i)
 call SaveInteger(AiHash, GetHandleId(t), 3, buf)

set B=null
set t=null
set filter=null
set mi=null

endfunction



function Trig_bansheeEng_Actions takes nothing returns nothing
 local unit B= udg_BOSS[0]
 local integer i= 0
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local integer buf= 0
 if BansheeEng == null then
 call DisableTrigger(gg_trg_bansheeEng)
 call TriggerSleepAction(1)
 if ( GetTriggerExecCount(GetTriggeringTrigger()) < 2 ) then
 call PlaySoundOnUnitBJ(gg_snd_BansheeWelcome, 127, B)
// call PlaySoundBJ( gg_snd_BansheeWelcome )  
 call TriggerSleepAction(3)
 call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "|cffffcc00Banshee says|r: Why you have come to my domains?")
 call TriggerSleepAction(5)
 call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 4, "|cffffcc00" + GetPlayerName(Player(id)) + " says|r: These places aren't yours, You are the intruder here... banshee")
 call TriggerSleepAction(5)
 call PlaySoundOnUnitBJ(gg_snd_BansheePissed4, 100, B)
 call TriggerSleepAction(3)

endif
 call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 2, "|cffffcc00Banshee says|r: You could lose yourself here...")
 //call PlaySoundOnUnitBJ(gg_snd_BansheeIntro, 100, B )   
 call StartSound(gg_snd_BansheeIntro)
 call TriggerSleepAction(3)
 call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "|cffffcc00" + GetPlayerName(GetOwningPlayer(GetTriggerUnit())) + " says|r: We have come to clean these catacombs, we will stay here...")
 call TriggerSleepAction(4)
 
 call PlaySoundOnUnitBJ(gg_snd_Bansheeifthat, 127, B)

 call TriggerSleepAction(2.8)
  
 call PlaySoundOnUnitBJ(gg_snd_BansheeYesAttack1, 127, B)
 
 call PauseUnit(B, false)
 call SetUnitInvulnerable(B, false)
 set BansheeEng=(NewTimerEx(0)) // INLINED!!
 call SaveUnitHandle(AiHash, GetHandleId(BansheeEng), 1, B)
 call SaveInteger(AiHash, GetHandleId(BansheeEng), 2, i)
 call SaveInteger(AiHash, GetHandleId(BansheeEng), 3, buf)
call TimerStart(BansheeEng, 0.2, true, function BansheeActions)
 set B=null

else
 set B=null
 return
endif


endfunction

//===========================================================================
function InitTrig_bansheeEng takes nothing returns nothing
    set gg_trg_bansheeEng=CreateTrigger()
    call TriggerAddCondition(gg_trg_bansheeEng, Condition(function Trig_bansheeEng_Conditions))
    call TriggerAddAction(gg_trg_bansheeEng, function Trig_bansheeEng_Actions)
endfunction


