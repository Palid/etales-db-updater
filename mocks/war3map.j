//===========================================================================
// Trigger: collectpages
//===========================================================================
function Trig_collectpages_Conditions takes nothing returns boolean
    return GetItemTypeId(GetManipulatedItem()) == 'I0F4'
endfunction

function RemoveExtraPages takes nothing returns nothing
  local integer data= GetItemUserData(GetEnumItem()) - 10
  
  if data == sylvanp then
     call RemoveItem(GetEnumItem())
  endif

  

endfunction

function Trig_collectpages_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer sid= GetItemUserData(GetManipulatedItem()) - 10
local integer questid= 0
 local integer sewer= GetRandomInt(0, 11)
 local real x= 0
 local real y= 0
 local integer j= 0
 
 
     if id != sid then
           set x=GetRandomReal(GetRectMinX(sewers[sewer]), GetRectMaxX(sewers[sewer]))
           set y=GetRandomReal(GetRectMinY(sewers[sewer]), GetRectMaxY(sewers[sewer]))
           
           call SetItemUserData(CreateItem('I0F4', x, y), sid + 10)
     endif
 
 

     if findpages[id] == true then
     
       
       set s__Sylvanpage[id]= s__Sylvanpage[id] + 1
       
       
         
       
       set questid=LoadInteger(udg_cache, GetHandleId(gg_unit_n08I_0090), GetHandleId(udg_PHero[id]))
       call UpdatePersQuestND(id , questid , s__Sylvanpage[id] , "-" , I2S(s__Sylvanpage[id]) , "-")
         if ( GetLocalPlayer() == Player(id) ) then
              call ClearTextMessages()
        endif
       
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "     |cffffcc00Sylvan manual pages|r: " + I2S(s__Sylvanpage[id]) + "/20")
        
       
       if s__Sylvanpage[id] > 19 then
          set findpages[id]=false
          call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Items\\AIem\\AIemTarget.mdl", udg_PHero[id], "origin"))
          call UnitAddItemById(udg_PHero[id], 'I0F9') //creo el set
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Received |cffffcc00Sylvan manual tome|r")
          call TriggerSleepAction(4)
          set questid=LoadInteger(udg_cache, GetHandleId(gg_unit_n08I_0090), GetHandleId(udg_PHero[id]))
          call UpdatePersQuestND(id , questid , 0 , "Return to the librarian with this restored |cffffcc00Sylvan Manual Tome|r" , "0" , "/1")
      
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00PERSONAL QUEST UPDATE: UNKNOWN ENEMY - PART III|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Return to the librarian and show the |cffffcc00Sylvan Manual Tome|r")
          call StartSound(bj_questUpdatedSound)
          set SylvanOk[id]=true
          set sylvanp=id
          
              loop
              exitwhen j > 11
              
               call EnumItemsInRect(sewers[j], null, function RemoveExtraPages)
              set j=j + 1
              endloop
          
          set sylvanp=20 //anything different of player id
          endif
         
     
          
     endif

endfunction

