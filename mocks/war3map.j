function InitTrig_Hero_Dies takes nothing returns nothing
    set gg_trg_Hero_Dies=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Hero_Dies, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_Hero_Dies, Condition(function herodc))
    call TriggerAddAction(gg_trg_Hero_Dies, function Trig_Hero_Dies_Actions)
endfunction


//===========================================================================
// Trigger: ItemStatDEC
//
// to get wich stat are increased i use the item level with mod operation:
// 2=AGI
// 3=STR
// 4=INT
// 5=""
// 6=Mana
// 7=Move Speed
// 8=Level ability
// 9=New ability
//===========================================================================
function Trig_ItemStatDEC_Conditions takes nothing returns boolean

    return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_ARTIFACT and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_ItemStatDEC_Actions takes nothing returns nothing
    // Removing AGi
    set udg_ItAt3=LoadIntegerBJ(2, GetHandleIdBJ(GetManipulatedItem()), udg_ItemStatHash)
    call ModifyHeroStat(bj_HEROSTAT_AGI, GetTriggerUnit(), bj_MODIFYMETHOD_SUB, udg_ItAt3)
    // Removing STR
    set udg_ItAt3=LoadIntegerBJ(3, GetHandleIdBJ(GetManipulatedItem()), udg_ItemStatHash)
    call ModifyHeroStat(bj_HEROSTAT_STR, GetTriggerUnit(), bj_MODIFYMETHOD_SUB, udg_ItAt3)
    // Removing INT
    set udg_ItAt3=LoadIntegerBJ(4, GetHandleIdBJ(GetManipulatedItem()), udg_ItemStatHash)
    call ModifyHeroStat(bj_HEROSTAT_INT, GetTriggerUnit(), bj_MODIFYMETHOD_SUB, udg_ItAt3)
    // Removing key
    call FlushChildHashtableBJ(GetHandleIdBJ(GetManipulatedItem()), udg_ItemStatHash)
endfunction

//===========================================================================
function InitTrig_ItemStatDEC takes nothing returns nothing
    set gg_trg_ItemStatDEC=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ItemStatDEC, EVENT_PLAYER_UNIT_DROP_ITEM)
    call TriggerAddCondition(gg_trg_ItemStatDEC, Condition(function Trig_ItemStatDEC_Conditions))
    call TriggerAddAction(gg_trg_ItemStatDEC, function Trig_ItemStatDEC_Actions)
endfunction


//===========================================================================
// Trigger: StaffeffectOFF
//===========================================================================
function Trig_StaffeffectOFF_Conditions takes nothing returns boolean
     return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_PERMANENT )
endfunction

function Trig_StaffeffectOFF_Actions takes nothing returns nothing
    local real me= GetWidgetLife(GetManipulatedItem())

    local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))

    if ( ModuloReal(me, 8) == 0 ) then
     set udg_magicBonus[id]=udg_magicBonus[id] - ( me / 100 )
     
         if ( udg_magicBonus[id] < 0 ) then
            set udg_magicBonus[id]=0
         endif
   //  call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()),.75,.2,2,"Magic Bonus: "+R2S(1 + udg_magicBonus[id]) )
    endif
endfunction

//===========================================================================
