function Trig_titanHdie_Actions takes nothing returns nothing
 local integer kid= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
   
    if on_event == true then
        call PlaySoundBJ(gg_snd_Tdeath)
     endif
   
      set teamBp=teamBp - titanlife
                    if teamBp <= 0 then
                      call EndTeamEvent(teamB)
                    endif
                  set s__playerkills[kid]= s__playerkills[kid] + titanlife
                  call LeaderboardSetItemValue(clashlb, LeaderboardGetPlayerIndex(clashlb, Player(kid)), s__playerkills[kid])
                  call UpdateLeaderBoard()
      set Htitan=null
endfunction

