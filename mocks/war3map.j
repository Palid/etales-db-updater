 call SetUnitMoveSpeed(hugss, 300)
 call UnitRemoveAbility(hugss, 'Avul')
 call IssuePointOrder(hugss, "move", - 17000, - 25000)
 call UnitChat("Is close!!, Is close!!!... I can feel It!!!" , hugss)
