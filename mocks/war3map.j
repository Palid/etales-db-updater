   //3nd room
     if extrarats == false then
          call CreateRat(ratID , GetRandomReal(minXMRR, maxXMRR) , GetRandomReal(minYMRR, maxYMRR))
          call CreateRat(ratID , GetRandomReal(minXMRR, maxXMRR) , GetRandomReal(minYMRR, maxYMRR))
