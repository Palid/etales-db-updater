//===========================================================================
// Trigger: fallbloody
//===========================================================================
function Trig_fallbloody_Conditions takes nothing returns boolean
 local integer id= GetPlayerId(GetOwningPlayer(GetOrderedUnit()))
   // return GetSpellAbilityId() == 'A0H2'
   return ( GetIssuedOrderId() == OrderId("drain") and s__vampready[id] == false )
endfunction

function Trig_fallbloody_Actions takes nothing returns nothing

 //local integer id = GetPlayerId(GetOwningPlayer(GetSpellAbilityUnit()))
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local integer rmattmp
 local integer enough= 0
 local integer questid
 call TriggerSleepAction(0.1)
 
 
 
         loop
         exitwhen not ( GetUnitCurrentOrder(udg_PHero[id]) == OrderId("drain") )
            call TriggerSleepAction(0.5)
            set enough=enough + 1
         endloop
         
           if enough > 3 then
           
               set s__bloodycount[id]= s__bloodycount[id] + 1
               set rmattmp=10 - s__bloodycount[id]
           
              if ( GetLocalPlayer() == Player(id) ) then
                      call ClearTextMessages()
               endif
              if s__bloodycount[id] > 9 then
               call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffff3333Finally your true blood rises from the deep of your darkness...|r")
               call TriggerSleepAction(2)
               call DestroyEffect(AddSpecialEffectTarget(udeathsfx, udg_PHero[id], "origin"))
                         
               call TriggerSleepAction(5)
               call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "Return to Lord Vingscroisse for instructions..|r")
               set s__vampready[id]= true
               call TriggerSleepAction(2)
              else
                call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "Remaining Attemps: |cffffcc00" + I2S(rmattmp) + "|r")
                set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
                call UpdatePersQuestND(id , questid , s__bloodycount[id] , "-" , I2S(s__bloodycount[id]) , "-")
               
              endif
          endif
 
endfunction

//===========================================================================
function InitTrig_fallbloody takes nothing returns nothing

   local integer i= 0

    set gg_trg_fallbloody=CreateTrigger()
    
    loop
     
     call TriggerRegisterPlayerUnitEvent(gg_trg_fallbloody, Player(i), EVENT_PLAYER_UNIT_ISSUED_TARGET_ORDER, null)
    
     set i=i + 1
     exitwhen i > 8
     endloop
    
 //   call TriggerRegisterAnyUnitEventBJ( gg_trg_fallbloody, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition(gg_trg_fallbloody, Condition(function Trig_fallbloody_Conditions))
    call TriggerAddAction(gg_trg_fallbloody, function Trig_fallbloody_Actions)
endfunction


//===========================================================================
// Trigger: fallfinal
//===========================================================================
function Trig_fallfinal_Conditions takes nothing returns boolean
 local integer id= GetPlayerId(GetOwningPlayer(GetEnteringUnit()))
 
    return nightime == true and IsUnitType(GetEnteringUnit(), UNIT_TYPE_HERO) == true and s__vampready[id] == true and IsUnitInGroup(GetEnteringUnit(), udg_inTest) == true
endfunction

function Trig_fallfinal_Actions takes nothing returns nothing
     local integer id= GetPlayerId(GetOwningPlayer(GetEnteringUnit()))
     local integer i= 1
     local unit u= GetEnteringUnit()
     local integer exp= GetHeroXP(u)
     local location p
     local integer questid
     
       call TriggerSleepAction(2)
       call IssueImmediateOrder(u, "stop")
    
       set s__vampready[id]= false
       set s__InvampTest[id]= false
       call GroupRemoveUnit(udg_inTest, u)
       set s__bloodycount[id]= 0
       
        call MakeFaceToUnit(gg_unit_n08D_0232 , udg_PHero[id])
        call UnitChat("Welcome to the inmortality brother..." , gg_unit_n08D_0232)
        call TriggerSleepAction(4)
    
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "MAIN QUEST DONE")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Fallen test...")
           
            set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
            call UpdatePersQuest(QPid[questid] , questid , Qdata[questid] , "You have reached to the inmortality.. " , "-" , "-")
            call RemoveQuestFromPlayer(questid , QPid[questid])
            
           call StartSound(bj_questCompletedSound)
            
            set p=GetUnitLoc(u)
                        
           set udg_PHero[id]=CreateUnitAtLoc(GetOwningPlayer(u), 'H035', p, 270)
           call DestroyEffect(AddSpecialEffectTarget(seffectclap, udg_PHero[id], "origin"))
           
           call AddProfaner(id) //Trigger registrado
       
           
            call SetHeroAgi(udg_PHero[id], GetHeroAgi(u, false) + 24, true)
            call SetHeroStr(udg_PHero[id], GetHeroStr(u, false) + 24, true)
            call SetHeroInt(udg_PHero[id], GetHeroInt(u, false) + 24, true)
            
            call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
            call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
            call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
           loop
               exitwhen i > 6
               call UnitRemoveItemFromSlot(u, i)
               set i=i + 1
               endloop
           
            
            
            call RemoveUnit(u)
            
            call SetHeroXP(udg_PHero[id], exp, false)
            call AdjustPlayerStateBJ(7, GetOwningPlayer(u), PLAYER_STATE_RESOURCE_LUMBER)
            set udg_Hnext[id]=4

            set u=null
            call RemoveLocation(p)
            set p=null
endfunction

