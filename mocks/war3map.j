endfunction


//===========================================================================
// Trigger: statsadministrator
//===========================================================================
//===========================================================================
// Trigger: Lvup
//===========================================================================
function Trig_Lvup_Actions takes nothing returns nothing
local sound s= gg_snd_levelup
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer multiplier= GetHeroLevel(udg_PHero[id]) - prevlevel[id]

   
   if ( multiplier < 1 or multiplier > 15 ) then
     set multiplier=1
   endif
    
    set prevlevel[id]=GetHeroLevel(udg_PHero[id])

    call PlaySoundOnUnitBJ(s, 65.00, u)
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Resurrect\\ResurrectCaster.mdl", u, "origin"))
    set s=null

     set multiplier=multiplier * 16
    if ( GetPlayerState(GetTriggerPlayer(), PLAYER_STATE_RESOURCE_LUMBER) < 100 ) then
      call AdjustPlayerStateBJ(multiplier, GetTriggerPlayer(), PLAYER_STATE_RESOURCE_LUMBER)
      call DisplayTimedTextToPlayer(GetTriggerPlayer(), 0, 0, 3, "|cff00ccffGot +" + I2S(multiplier) + " Stat points|r")
    else
      call DisplayTimedTextToPlayer(GetTriggerPlayer(), .5, .1, 3, "|cffffcc00Atributte Points lost, max points allowed = 100, please assing your Atr Points using ESC.|r")
    endif

    call SetUnitState(u, UNIT_STATE_LIFE, GetUnitState(u, UNIT_STATE_MAX_LIFE))
    call SetUnitState(u, UNIT_STATE_MANA, GetUnitState(u, UNIT_STATE_MAX_MANA))
    
      
    if famtype[id] > 0 then
       call UpdateFam(id)
    endif
  set u=null
endfunction

