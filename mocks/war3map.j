  call UnitChat("Now is time to fight for the Destiny of Enthashara..." , dadvar)
  call TriggerSleepAction(4)
  call UnitChat("The entrance to the |cffffcc00Black Hand Sanctuary|r is open." , dadvar)
  call TriggerSleepAction(5)
  call UnitChat("The Victory is nearly to impossible..." , dadvar)
  call TriggerSleepAction(3)
  call UnitChat("but this is our last hope" , dadvar)
  call TriggerSleepAction(4)
  call UnitChat("Defeat |cffffcc00Iveor, the Fallen!|r" , dadvar)
  call TriggerSleepAction(4)
  call ShowUnit(gg_unit_E007_0855, true) //iveor final
  call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00NEW WORLD QUEST DISCOVERED:|r Siege |cffffcc00Black Hand Sanctuary|r and destroy Iveor.")
