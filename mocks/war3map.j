function InitTrig_orcbacktrack takes nothing returns nothing
    set gg_trg_orcbacktrack=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_orcbacktrack, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_orcbacktrack, Condition(function orcbtc))
    call TriggerAddAction(gg_trg_orcbacktrack, function orcbta)
endfunction


