    call TriggerAddAction(gg_trg_divine_word, function divinea)
endfunction


//===========================================================================
// Trigger: HL
//===========================================================================
function Trig_HL_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A01O' or GetSpellAbilityId() == 'A06V' )
endfunction


function Trig_HL_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local unit a= GetSpellTargetUnit()
local integer idmg= 0
local real level= 0
local real inspired= 1


  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

    if ( GetSpellAbilityId() == 'A06V' ) then
    set level=5
    else
    set level=( I2R(GetUnitAbilityLevel(GetTriggerUnit(), GetSpellAbilityId())) / 2.00 )
    endif
    
    set udg_HLdmg=( I2R(GetHeroInt(GetTriggerUnit(), true)) * ( level + 5.00 ) )
    
    set udg_HLdmg=udg_HLdmg + ( udg_HLdmg * udg_magicBonus[id] )
    
     set udg_HLdmg=udg_HLdmg * inspired
     set udg_HLdmg=udg_HLdmg + udg_HLdmg * AddRacialBonus(a , id)
     
    if ( IsUnitEnemy(a, GetOwningPlayer(GetTriggerUnit())) == true ) then
	      set udg_HLdmg=udg_HLdmg / 2
          call DisableTrigger(gg_trg_DMG)
          call EnableTrigger(gg_trg_SPDMG)
          call UnitDamageTarget(GetTriggerUnit(), a, udg_HLdmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
          call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , a)
      set spelldmg[id]=0
      call EnableTrigger(gg_trg_DMG)
    else
     
       call SetUnitState(a, UNIT_STATE_LIFE, GetUnitState(a, UNIT_STATE_LIFE) + udg_HLdmg)
       set idmg=R2I(udg_HLdmg)
       call SpellDmgText(idmg , a)
    endif
    
    set a=null
endfunction

//===========================================================================
function InitTrig_HL takes nothing returns nothing
    set gg_trg_HL=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_HL, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_HL, Condition(function Trig_HL_Conditions))
    call TriggerAddAction(gg_trg_HL, function Trig_HL_Actions)
endfunction


//===========================================================================
// Trigger: SNE
//
// Sin Expieation
//===========================================================================
function Trig_SNE_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0G0' or GetSpellAbilityId() == 'A0G1' )
endfunction


function Trig_SNE_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetSpellAbilityUnit()))
local integer idmg= 0
local real sedmg= 0
local real level= 0
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

    if ( GetSpellAbilityId() == 'A0G1' ) then
    set level=4
    else
    set level=( I2R(GetUnitAbilityLevel(GetSpellAbilityUnit(), GetSpellAbilityId())) * 0.4 )
    endif
    
    set sedmg=( I2R(GetHeroInt(GetSpellAbilityUnit(), true)) * ( 1 + level ) )
    
    set sedmg=sedmg + ( sedmg * udg_magicBonus[id] )
    
    set sedmg=sedmg * inspired
    set sedmg=sedmg + sedmg * AddRacialBonus(GetSpellTargetUnit() , id)
     
    if ( IsUnitEnemy(GetSpellTargetUnit(), GetOwningPlayer(GetSpellAbilityUnit())) == true ) then
          call DisableTrigger(gg_trg_DMG)
          call EnableTrigger(gg_trg_SPDMG)
          call UnitDamageTarget(GetSpellAbilityUnit(), GetSpellTargetUnit(), sedmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
          call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , GetSpellTargetUnit())
      set spelldmg[id]=0
      call EnableTrigger(gg_trg_DMG)
    endif
endfunction

//===========================================================================
function InitTrig_SNE takes nothing returns nothing
    set gg_trg_SNE=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_SNE, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_SNE, Condition(function Trig_SNE_Conditions))
    call TriggerAddAction(gg_trg_SNE, function Trig_SNE_Actions)
endfunction


