    call TriggerAddCondition(gg_trg_Frost_Nova, Condition(function Trig_Frost_Nova_Conditions))
    call TriggerAddAction(gg_trg_Frost_Nova, function Trig_Frost_Nova_Actions)
endfunction


//===========================================================================
// Trigger: New Meteor Storm
//===========================================================================
function New_Meteor_Storm_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A07G' )
endfunction


function meteorfilter takes nothing returns boolean
    return GetUnitState(GetFilterUnit(), UNIT_STATE_LIFE) > 0.404
endfunction


function MeteorDamage takes real x,real y,integer id,real damage returns nothing
local group dmgg= CreateGroup()
local unit gu= null
local integer idmg= 0
local boolexpr mfilter= Condition(function meteorfilter)


    call GroupEnumUnitsInRange(dmgg, x, y, 296, mfilter)
    call DestroyBoolExpr(mfilter)
    set mfilter=null

	   loop
	    set gu=FirstOfGroup(dmgg)
		  exitwhen gu == null
			   
              if IsUnitEnemy(gu, Player(id)) == true then
               call UnitDamageTarget(udg_PHero[id], gu, damage, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
              endif
               
		call GroupRemoveUnit(dmgg, gu)
		set gu=null
		endloop
        

     call DestroyGroup(dmgg)
	 set dmgg=null

endfunction


function meteorcycle takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local real x= LoadReal(udg_cache, GetHandleId(t), 0)
    local real y= LoadReal(udg_cache, GetHandleId(t), 1)
    local integer i= LoadInteger(udg_cache, GetHandleId(t), 2)
    local real inspired= LoadReal(udg_cache, GetHandleId(t), 3)
    local integer extra= LoadInteger(udg_cache, GetHandleId(t), 4)
    local integer id= LoadInteger(udg_cache, GetHandleId(t), 5)
    local real xi= GetRandomReal(x - 300, x + 300)
    local real yi= GetRandomReal(y - 300, y + 300)
    local real damage= I2R(GetHeroInt(udg_PHero[id], true)) * 4 * inspired
    local real face= GetUnitFacing(udg_PHero[id])
    local destructable d= CreateDestructable('B01C', xi, yi, face, 1.5, 0)
    local integer r= i + 30
    local integer s= i + 28
    local integer q= i + 26
    local real xj= 0
    local real yj= 0

    call SaveDestructableHandle(udg_cache, GetHandleId(t), r, d)
    set i=i + 1
    
    call SaveInteger(udg_cache, GetHandleId(t), 2, i)
  
    if s > 29 then
        set d=LoadDestructableHandle(udg_cache, GetHandleId(t), s)
        set xj=GetDestructableX(d)
        set yj=GetDestructableY(d)
        call MeteorDamage(xj , yj , id , damage)
    endif
  
   if q > 29 then
        set d=LoadDestructableHandle(udg_cache, GetHandleId(t), q)
        call RemoveDestructable(d)
   endif
  
  
    if ( i == extra ) then
        call PauseTimer(t)
        call FlushChildHashtable(udg_cache, GetHandleId(t))
        call ReleaseTimer(t)
    endif
    
    set t=null
    set d=null
   

endfunction

function New_Meteor_Storm_Actions takes nothing returns nothing
local unit caster= GetSpellAbilityUnit()
local integer id= GetPlayerId(GetOwningPlayer(caster))
local real x= GetSpellTargetX()
local real y= GetSpellTargetY()
local integer i= 0
local real inspired= 1
local integer extrameteor= 10
local timer t= (NewTimerEx(0)) // INLINED!!

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
      set extrameteor=extrameteor + s__casttype[id]
 endif


call SaveReal(udg_cache, GetHandleId(t), 0, x)
call SaveReal(udg_cache, GetHandleId(t), 1, y)
call SaveInteger(udg_cache, GetHandleId(t), 2, i)
call SaveReal(udg_cache, GetHandleId(t), 3, inspired)
call SaveInteger(udg_cache, GetHandleId(t), 4, extrameteor)
call SaveInteger(udg_cache, GetHandleId(t), 5, id)

call TimerStart(t, 0.65, true, function meteorcycle)


set caster=null
set t=null

endfunction

