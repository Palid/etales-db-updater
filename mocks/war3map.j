//===========================================================================
// Trigger: CentaursIncursion
//
// sffectpunch
//===========================================================================
//TESH.scrollpos=42
//TESH.alwaysfold=0
function Trig_CentaursIncursion_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetPlayerController(GetOwningPlayer(GetTriggerUnit())) == MAP_CONTROL_USER
endfunction


function ankitmorph takes nothing returns nothing
local timer t= GetExpiredTimer()
local real h= LoadReal(questtm, GetHandleId(t), 1)
local real x= 0
local real y= 0
 local real angle= 0
 local integer anim= GetRandomInt(1, 4)
 set h=h + 1
 call SetUnitFlyHeight(ankitlord, h, 1)
 call SetUnitAnimation(ankitlord, canim[anim])
 call SaveReal(questtm, GetHandleId(t), 1, h)
 if h > 80 then
   set x=GetUnitX(ankitlord)
   set y=GetUnitY(ankitlord)
   call PauseTimer(t)
   call FlushChildHashtable(questtm, GetHandleId(t))
   call ReleaseTimer(t)

   call SetUnitExploded(ankitlord, true)
   call KillUnit(ankitlord)
   set angle=GetUnitFacing(ankitlord)
   call SetUnitOwner(gg_unit_U00N_0077, Player(10), false)
   call SetUnitFacing(gg_unit_U00N_0077, angle)
   call SetUnitPosition(gg_unit_U00N_0077, x, y)
   call ShowUnit(gg_unit_U00N_0077, true)
   call SetUnitAnimation(gg_unit_U00N_0077, "attack")
 endif
 
 set t=null
endfunction

function Trig_CentaursIncursion_Actions takes nothing returns nothing
 local real x= GetUnitX(ankitlord)
 local real y= GetUnitY(ankitlord)
 local timer t
 local real h= 0
 local integer i= 0
 local integer bonus= 0

  
 call DisableTrigger(gg_trg_CentaursIncursion)
 if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) == true ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
                 call PingMinimapEx(x, y, 15, 255, 255, 50, false)
  endif
  call TriggerExecute(gg_trg_runcentaurs)
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "|cffffcc00Lieutenant Ankit says:|r")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        Hurry!!, We need your help!!!")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        A huge force of centaurs is marching to this place, they come to destroy us...")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        They would be here in a few moments!!, We couldn't handle it alone!...")
 
 call TriggerSleepAction(9)
 
 call ForGroup(vguard, function ankitattack)
  
  call StartSound(bj_questDiscoveredSound)
     if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 7, "|cffffcc00GLOBAL QUEST DISCOVERED|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "After explored and killed some centaurs Its tribe has launched a strong attack to Valdivian forces.")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "You must help them to stop the wilds incursion. There isn't time to lose.")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "|cffffcc00Stop centaurs siege, Kill them all!!|r")
               
      endif
   call QuestSetDiscovered(ankitlordq, true)
  
  loop
      exitwhen FirstOfGroup(centaurss) == null
        call TriggerSleepAction(1)
      endloop
  call TriggerSleepAction(4)
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "|cffffcc00|cff777777You feel something disturbing on the air...|r")
  call TriggerSleepAction(3)
  call DestroyEffect(AddSpecialEffectTarget(sffectpunch, ankitlord, "origin"))
  call TriggerSleepAction(4)
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "|cffffcc00Lieutenant Ankit says:|r")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        Finally these obstacles have been removed!")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        The time for our lord |cffffcc00Rodavlas Nauj|r has come..")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        Nobody will stop his asumption, the new era will be risen over Enthashara!...")
  call TriggerSleepAction(4)
  call DestroyEffect(AddSpecialEffectTarget(sffectpunch, ankitlord, "origin"))
   call TriggerSleepAction(4)
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "|cffffcc00Valdivian guard says:|r")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 3, "        Ankit!, what the hell are you talking about!!!")
  call TriggerSleepAction(4)
  call DestroyEffect(AddSpecialEffectTarget(sffectpunch, ankitlord, "origin"))
  call PauseUnit(ankitlord, true)
  set t=(NewTimerEx(0)) // INLINED!!
  call SaveReal(questtm, GetHandleId(t), 1, h)
  call UnitAddAbility(ankitlord, 'Amrf')
  call UnitRemoveAbility(ankitlord, 'Amrf')
  call SetUnitTimeScale(ankitlord, 1.4)
  call TimerStart(t, 0.3, true, function ankitmorph)
  
  
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "|cffffcc00Lieutenant Ankit says:|r")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        The reign of |cffffcc00Irntu Hel's Cult|r will be here for the eternity!")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "        the humankind will fall under his throne. !")
  call TriggerSleepAction(4)
  call DestroyEffect(AddSpecialEffect(sffectpunch, x, y))
  call TriggerSleepAction(4)
  set x=GetUnitX(ankitlord)
  set y=GetUnitY(ankitlord)
  call DestroyEffect(AddSpecialEffect(sffectpunch, x, y))
  call TriggerSleepAction(2)
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 4, "|cffffcc00Valdivian guard says:|r")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 4, "        Ankit!, You became crazy? Stop talking man!!!")
  call TriggerSleepAction(5)
  call DestroyEffect(AddSpecialEffect(sffectpunch, x, y))
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 8, "|cffffcc00Lieutenant Ankit says:|r")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 8, "        You fools, you work here is done!")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 8, "        Your lack of knowledge made possible to start the arrival of our forces!")
  call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 8, "        Your lack of faith had make more stronger our spirit...!")
  call TriggerSleepAction(4)
  call DestroyEffect(AddSpecialEffect(sffectpunch, x, y))
  call TriggerSleepAction(7)
  call UnitChat("|cffffcc00...LONG LIFE TO CULT OF IRNTU HEL!!!!" , gg_unit_U00N_0077)
  call TriggerSleepAction(3)
  
   
    set Entrada[181]=gg_rct_alcve1in
    set Salida[181]=gg_rct_alcve1out
    set Entrada[182]=gg_rct_alcve2in
    set Salida[182]=gg_rct_alcve2out

             //gg_rct_ucryptg3out
    set Entrada[183]=gg_rct_alcve3in
    set Salida[183]=gg_rct_alcve3out
    set Entrada[184]=gg_rct_alcve4in
    set Salida[184]=gg_rct_alcve4out
    
    call rundungeon(181)
    call TriggerSleepAction(0.1)
    call rundungeon(182)
    call TriggerSleepAction(0.1)
    call rundungeon(183)
    call TriggerSleepAction(0.1)
    call rundungeon(184)
    call TriggerSleepAction(0.1)
 
  call IssuePointOrder(gg_unit_U00N_0077, "move", GetRectCenterX(gg_rct_alcve2in), GetRectCenterY(gg_rct_alcve2in))
  call EnableTrigger(gg_trg_ankitfound)
  call TriggerSleepAction(2)
  call StartSound(bj_questCompletedSound)
     if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 7, "|cffffcc00GLOBAL QUEST COMPLETED: UNKNOW ENEMY|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "The centaurs siege has been stopped, but It was a trap!!...")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "Received: ")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "     +|cffffcc00( Hero level * 200) gold|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "     +|cffffcc00( Hero level * 200) XP|r")
           
      endif
     loop
    exitwhen i > 7
    
     set bonus=GetHeroLevel(udg_PHero[i]) * 200
     call AddHeroXP(udg_PHero[i], bonus, false)
     call SetPlayerState(Player(i), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(i), PLAYER_STATE_RESOURCE_GOLD) + bonus)
     
     set i=i + 1
    
    endloop

      
      
call QuestSetCompleted(ankitlordq, true)
call QuestItemSetCompleted(ankitlordia, true)

call TriggerSleepAction(15)
 call StartSound(bj_questDiscoveredSound)
     if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 12, "|cffffcc00GLOBAL QUEST DISCOVERED: The Lord of the Abyss|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "A monster has been summoned on Valdivia's fields.")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "He invoked the name of |cffffcc00<<Irntu Hel>>|r and vanishes under the scorched farm.")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "It's dangeours for Valdivia if a new creature runs close to the citizens")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "|cffffcc00Find and destroy Lord of the Abyss!|r")
               
      endif
   call QuestSetDiscovered(abyssq, true)
   
  call TriggerSleepAction(15)
  call StartSound(bj_questDiscoveredSound)
     if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 12, "|cffffcc00GLOBAL QUEST DISCOVERED: The cult of Irntu Hel|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "The events on Valdivia has given some clues about a new enemy that is working under the shadows")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "Main information says that their leader is named |cffffcc00Rodavlas Nauj|r and they want to take the control of all country powers.")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "You must discover why Ankit turned into a traitor and were is located the enemies's home")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "|cffffcc00Investigate what is the Cult of Irntu Hel!|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 12, "|cffffcc00Search for any track about Ankit!|r")
      endif
   call QuestSetDiscovered(irntuq, true)
 
  
endfunction

