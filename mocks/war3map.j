//===========================================================================
// Trigger: movetravelers
//
// Wolf movement
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function MTVC takes nothing returns boolean
    return ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and inpvp[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == false )
endfunction

function MTVA takes nothing returns nothing
    local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
    local real x1= GetOrderPointX() - 300
    local real y1= GetOrderPointY() - 300
    local real x2= x1 + 600
    local real y2= y1 + 600
    
    local real x= 0
    local real y= 0
    
    if traveler1[id] != null then
    set x=GetRandomReal(x1, x2)
    set y=GetRandomReal(y1, y2)
    call IssuePointOrder(traveler1[id], "move", x, y)
    endif

    if traveler2[id] != null then
    set x=GetRandomReal(x1, x2)
    set y=GetRandomReal(y1, y2)
    call IssuePointOrder(traveler2[id], "move", x, y)
    endif
    
    if traveler3[id] != null then
    set x=GetRandomReal(x1, x2)
    set y=GetRandomReal(y1, y2)
    call IssuePointOrder(traveler3[id], "move", x, y)
    endif
    
    
       if traveler4[id] != null then
    set x=GetRandomReal(x1, x2)
    set y=GetRandomReal(y1, y2)
    call IssuePointOrder(traveler4[id], "move", x, y)
    endif
   
    if cslave[id] != null and IsUnitHidden(cslave[id]) == false then
    set x=GetRandomReal(x1, x2)
    set y=GetRandomReal(y1, y2)
    call IssuePointOrder(cslave[id], "attack", x, y)
    endif
   
endfunction

