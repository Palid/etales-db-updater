// Trigger: meleePrevent
//===========================================================================
function Trig_meleePrevent_Conditions takes nothing returns boolean
       local unit u= GetTriggerUnit()
       local boolean ismelee= IsUnitType(u, UNIT_TYPE_MELEE_ATTACKER) == true and IsUnitInGroup(u, meleeUnits) == false and IsUnitInGroup(u, sneakers) == false
       set u=null
       return ismelee
endfunction

  
 
function backrcicle takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit a= LoadUnitHandle(hts, GetHandleId(t), 1)
local real x= LoadReal(hts, GetHandleId(t), 2)
local real y= LoadReal(hts, GetHandleId(t), 3)
local real dist= LoadReal(hts, GetHandleId(t), 4)
local real it= LoadReal(hts, GetHandleId(t), 5)
local real angle= LoadReal(hts, GetHandleId(t), 6)
local integer i= LoadInteger(hts, GetHandleId(t), 7)
 
local real xi= LoadReal(hts, GetHandleId(t), 8) + it
local real height= dist / 2.5
local real h= GetParabolaZ(xi , dist , height)

 
 set x=x + it * Cos(angle * bj_DEGTORAD)
 set y=y + it * Sin(angle * bj_DEGTORAD)

 call SetUnitFlyHeight(a, h, 0)
 //call SetUnitPosition(a,x,y)
 if IsTerrainWalkable(x , y) then
    call SetUnitX(a, x)
    call SetUnitY(a, y)
endif
 //call DestroyEffect(AddSpecialEffect(seffectjump,x,y))
 
 if it < 1 or h < 1 or GetUnitState(a, UNIT_STATE_LIFE) < 0.4 then

  call SetUnitFlyHeight(a, 0, 0)
  //call PauseUnit(a,false)
  call SetUnitPathing(a, true)
  call SetUnitTimeScale(a, 1)
  call UnitRemoveAbility(a, 'A0HQ') //evasion 
  call IssueImmediateOrder(a, "stop")
  
  call PauseTimer(t)
  call DestroyEffect(AddSpecialEffect(seffectjump, x, y))
  
          if IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) then //false
         loop
           exitwhen IsTerrainPathable(x, y, PATHING_TYPE_WALKABILITY) == false
              call TriggerSleepAction(0.3)
              set x=x + 32 * Cos(angle * bj_DEGTORAD)
              set y=y + 32 * Sin(angle * bj_DEGTORAD)

         endloop
        call SetUnitX(a, x)
        call SetUnitY(a, y)
         
      endif
 
  call FlushChildHashtable(hts, GetHandleId(t))
  call ReleaseTimer(t)



  else
  call SaveReal(hts, GetHandleId(t), 2, x)
  call SaveReal(hts, GetHandleId(t), 3, y)
  
  set it=it - 1
  call SaveReal(hts, GetHandleId(t), 5, it)
 // call SaveReal(hts,GetHandleId(t),6,inc)  
  //call SaveReal(hts,GetHandleId(t),5,angle_t)  
      call SaveReal(hts, GetHandleId(t), 8, xi)
 endif
set a=null
set t=null

endfunction


function backrSetup takes unit u,unit a returns nothing
 local real ux= GetUnitX(a)
 local real uy= GetUnitY(a)
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 local real dx= x - ux
 local real dy= y - uy
 local real acuracy= GetRandomReal(150, 250)
 local real distance= SquareRoot(dx * dx + dy * dy) / 1.6 + acuracy
 local real it= distance / 14
 local integer i= 0
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local timer t= null
 local integer dec= 10

 
 
 if distance > 2048 or distance < 0 then
  return
 endif
 
 
 set t=(NewTimerEx(0)) // INLINED!!
 // call DestroyEffect(AddSpecialEffect(THUNDER,x,y))

// call SetUnitAnimation(u,"Attack")


 call UnitAddAbilityBJ('Amrf', u)
 call UnitRemoveAbilityBJ('Amrf', u)
   
 call SetUnitPathing(u, false)
 call UnitAddAbility(u, 'A0HQ') //evasion 
 

 
 call SaveUnitHandle(hts, GetHandleId(t), 1, u)
 call SaveReal(hts, GetHandleId(t), 2, x)
 call SaveReal(hts, GetHandleId(t), 3, y)
 call SaveReal(hts, GetHandleId(t), 4, distance)
 call SaveReal(hts, GetHandleId(t), 5, it)
 call SaveReal(hts, GetHandleId(t), 6, angle)
 call SaveInteger(hts, GetHandleId(t), 7, i)
 call SaveReal(hts, GetHandleId(t), 8, 0)

 call TimerStart(t, 0.02, true, function backrcicle)


 set t=null
 call TriggerSleepAction(5)
 call GroupRemoveUnit(backing, u)

endfunction


function Trig_meleePrevent_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local unit a= GetAttacker()
 local real x1= GetUnitX(u)
 local real y1= GetUnitY(u)
 local real x2= GetUnitX(a)
 local real y2= GetUnitY(a)
 local real dx= x2 - x1
 local real dy= y2 - y1
 local real distance= SquareRoot(dx * dx + dy * dy)
 local real angle=180 + bj_RADTODEG * Atan2(dy, dx)
 local real x
 local real y
 local real spd= GetUnitMoveSpeed(u)
 local real atspd= GetUnitMoveSpeed(a)
 local real erange= GetUnitAcquireRange(a) + atspd + 50
 local real safereq= erange - distance
 local real rtime= 0.3 + safereq / ( spd + 1 )
 local real nangle= GetRandomReal(angle - 45, angle + 45)
 local integer major= ( GetUnitLevel(a) - GetUnitLevel(u) ) / 2
 local integer fear= 5 * LoadInteger(AiHash, GetHandleId(u), 2) + major
 local integer smart=6 * LoadInteger(AiHash, GetHandleId(u), 6)
 
 
 if IsUnitInGroup(u, Ambushgroup) == true then
   set fear=fear * 3
 endif
 
 if GetRandomInt(0, 129) < fear and GetUnitState(a, UNIT_STATE_LIFE) > GetUnitState(u, UNIT_STATE_LIFE) then
 
 call GroupAddUnit(meleeUnits, u)
 
 
 
 
 if distance < 200 then
 
   if GetRandomInt(0, 99) < smart and IsUnitInGroup(u, backing) == false and IsUnitType(u, UNIT_TYPE_ANCIENT) == false then
  
   call GroupAddUnit(backing, u)
  // call TriggerSleepAction(0.2)
   call backrSetup(u , a)
   else
    call IssueTargetOrder(u, "attack", a)
   endif
 
 elseif spd > atspd then
  set x=x2 + erange * Cos(angle * bj_DEGTORAD)
  set y=y2 + erange * Sin(angle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(rtime)
  call IssueTargetOrder(u, "attack", a)

 elseif ( distance * 2 ) > erange then
 
  if IsUnitType(a, UNIT_TYPE_MELEE_ATTACKER) == true then
    set safereq=GetUnitMoveSpeed(u)
  endif
 
  set x=x1 + safereq * Cos(angle * bj_DEGTORAD)
  set y=y1 + safereq * Sin(angle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(rtime)
  call IssueTargetOrder(u, "attack", a)
 else
  
  if IsUnitType(a, UNIT_TYPE_MELEE_ATTACKER) == true then
    set erange=GetUnitMoveSpeed(u)
  endif
 
  set x=x1 + erange * Cos(nangle * bj_DEGTORAD)
  set y=y1 + erange * Sin(nangle * bj_DEGTORAD)
  call IssuePointOrder(u, "move", x, y)
  call TriggerSleepAction(1 + rtime)
  call IssueTargetOrder(u, "attack", a)
 endif
 
   call TriggerSleepAction(1)
   call GroupRemoveUnit(meleeUnits, u)
 endif
 
set a=null
set u=null


endfunction

//===========================================================================
function InitTrig_meleePrevent takes nothing returns nothing
    local integer index= 8
    set gg_trg_meleePrevent=CreateTrigger()
    
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_meleePrevent, Player(index), EVENT_PLAYER_UNIT_ATTACKED, null)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
    call TriggerAddCondition(gg_trg_meleePrevent, Condition(function Trig_meleePrevent_Conditions))
    call TriggerAddAction(gg_trg_meleePrevent, function Trig_meleePrevent_Actions)
 
endfunction


//===========================================================================
// Trigger: sneakerprevent
//===========================================================================
function Trig_sneakerprevent_Conditions takes nothing returns boolean
    return IsUnitInGroup(GetTriggerUnit(), sneakers) == true and IsUnitInGroup(GetTriggerUnit(), sneakersfnd) == false
endfunction

function Trig_sneakerprevent_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local unit a= GetAttacker()
 local real x1= GetUnitX(u)
 local real y1= GetUnitY(u)
 local real x2= GetUnitX(a)
 local real y2= GetUnitY(a)
 local real dx= x2 - x1
 local real dy= y2 - y1
 local real distance= SquareRoot(dx * dx + dy * dy)
 local real angle=180 + bj_RADTODEG * Atan2(dy, dx)
 local real x
 local real y
 local real spd= GetUnitMoveSpeed(u)
 local real atspd= GetUnitMoveSpeed(a)
 local real erange= GetUnitAcquireRange(a) + atspd + 50
 local real safereq= erange - distance
 local real rtime= 0.3 + safereq / ( spd + 1 )
 local real nangle
 local boolean run= true
 local timer t= LoadTimerHandle(AiHash, GetHandleId(u), GetHandleId(sneakers))
 local integer id= LoadInteger(AiHash, GetHandleId(t), 2)
 local real fov= 100 - ( distance * 100 ) / erange
 
 
 
 
     
     if fov < 0 then
       set fov=0
     endif
     
      set fov=( 90 * fov ) / 100
      
     set nangle=GetRandomReal(angle - fov, angle + fov)
 
  call GroupAddUnit(sneakersfnd, u)
 
  call SaveBoolean(AiHash, GetHandleId(t), 4, run)
  
  set x=x2 + erange * Cos(nangle * bj_DEGTORAD)
  set y=y2 + erange * Sin(nangle * bj_DEGTORAD)
  
  if distance < safereq then
    call IssueTargetOrder(u, "attack", a)
  else
    call IssuePointOrder(u, "move", x, y)
  endif

  call TriggerSleepAction(1)

   if GetRandomInt(0, 20) < 3 then
      call UnitChat(snkfound[GetRandomInt(0, 14)] , a)
   endif
  call TriggerSleepAction(5)
  call GroupRemoveUnit(sneakersfnd, u)
  set run=false
  call SaveBoolean(AiHash, GetHandleId(t), 4, run)
  

set t=null
set a=null
set u=null
endfunction

//===========================================================================
function InitTrig_sneakerprevent takes nothing returns nothing
    local integer index= 8
    set gg_trg_sneakerprevent=CreateTrigger()
    
       loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_sneakerprevent, Player(index), EVENT_PLAYER_UNIT_ATTACKED, null)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
    
    
    call TriggerAddCondition(gg_trg_sneakerprevent, Condition(function Trig_sneakerprevent_Conditions))
    call TriggerAddAction(gg_trg_sneakerprevent, function Trig_sneakerprevent_Actions)
endfunction


//===========================================================================
// Trigger: sneakerfnd
//===========================================================================
function Trig_sneakerfnd_Conditions takes nothing returns boolean
    return GetUnitMoveSpeed(GetTriggerUnit()) < 200 and IsUnitInGroup(GetTriggerUnit(), sneakersfnd) == true and IsUnitInGroup(GetTriggerUnit(), sneakersslw) == false
endfunction



function Trig_sneakerfnd_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local unit a= GetAttacker()
 local real x1= GetUnitX(u)
 local real y1= GetUnitY(u)
 local real x2= GetUnitX(a)
 local real y2= GetUnitY(a)
 local real dx= x2 - x1
 local real dy= y2 - y1
 local real distance= SquareRoot(dx * dx + dy * dy)


 
  call GroupAddUnit(sneakersslw, u)
  
  if distance < 210 then
    call IssueTargetOrder(u, "attack", a)
  endif

  call TriggerSleepAction(2)
  call GroupRemoveUnit(sneakersslw, u)

  


set a=null
set u=null
endfunction

