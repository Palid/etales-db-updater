    set gg_trg_deathrevprv=CreateTrigger()
    call TriggerAddCondition(gg_trg_deathrevprv, Condition(function reveMprvc))
    call TriggerAddAction(gg_trg_deathrevprv, function reveMprva)
 
endfunction


//===========================================================================
// Trigger: akashaD
//===========================================================================
function akashac takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == udg_Bosses[6] )
endfunction

function akashaa takes nothing returns nothing

 call DropPvpBoss(GetTriggerUnit())
 call CreateFixed(GetTriggerUnit() , 116) //gargoyle wings
 call CreateFixed(GetTriggerUnit() , 1029) // 'I0C7' //Legendary Agnear dom helmet
 call CreateFixed(GetTriggerUnit() , 1012) // 'I0CF' //INTELOGO king emblem 
 call shakecam(GetTriggerExecCount(gg_trg_akashaD))
 call PauseTimer(AkashaEng)
 call ReleaseTimer(AkashaEng)
 set AkashaEng=null


//This for avoiding dump items from stealers when the players are attacking some boss
call SetUnitDrop(udg_BOSSID[6] , 0 , 0 , 0 , 0 , 0 , 0 , 0 , 0)
call EnableTrigger(gg_trg_akashadrop)
call DisableTrigger(gg_trg_Akraid)
call DisableTrigger(gg_trg_akburn)
call DisableTrigger(gg_trg_aktarget)



  if ( GetTriggerExecCount(GetTriggeringTrigger()) > 1 ) then
  call CreateItemLoc('I00E', udg_BossesP[6]) //Divine Chest
  endif
  
  
  call TriggerSleepAction(respawnboss)
  set udg_BOSS[6]=CreateUnitAtLoc(Player(PLAYER_DARK_LORD), udg_Bosses[6], udg_BossesP[6], 225)
  call SetHeroLevel(udg_BOSS[6], 82, false)
  call AddSpecialEffectTarget("Light.mdx", udg_BOSS[6], "origin")
  call TriggerRegisterUnitEvent(gg_trg_akashadrop, udg_BOSS[6], EVENT_UNIT_DAMAGED)
  call TriggerRegisterUnitEvent(Akashadmgd, udg_BOSS[6], EVENT_UNIT_DAMAGED)
  call TriggerRegisterUnitEvent(Akashaprv, udg_BOSS[6], EVENT_UNIT_ATTACKED)
  call TriggerRegisterUnitInRange(AkashaTrg, udg_BOSS[6], 1024, null)
  call UnitAddAbilityBJ('Amrf', udg_BOSS[6])
  call UnitRemoveAbilityBJ('Amrf', udg_BOSS[6])
  call EnableTrigger(AkashaTrg)
  call EnableTrigger(gg_trg_Akraid)
  call EnableTrigger(gg_trg_akburn)
  call EnableTrigger(gg_trg_aktarget)
  call PauseUnit(udg_BOSS[6], true)
  call SetUnitInvulnerable(udg_BOSS[6], true)

endfunction

