endfunction


function SummonThorn takes real x,real y,real dist,real angle,integer id,boolean uber returns nothing
local real pos_x= x + dist * Cos(angle * bj_DEGTORAD)
local real pos_y= y + dist * Sin(angle * bj_DEGTORAD)

local unit d= null
if uber == true then
  set bj_lastCreatedUbersplat=CreateUbersplat(pos_x, pos_y, "THND", 255, 255, 255, 255, false, true)
  call SetUbersplatRenderAlways(GetLastCreatedUbersplat(), true)
endif

 set d=CreateUnit(Player(id), poisonivy, pos_x, pos_y, GetRandomReal(0, 359))
 call UnitApplyTimedLife(d, 'BTLF', 7)
 set d=null
endfunction


function Trig_wallofthorns_Actions takes nothing returns nothing
local unit u= GetSpellAbilityUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local real x= GetSpellTargetX()
local real y= GetSpellTargetY()

local real ux= GetUnitX(u)
local real uy= GetUnitY(u)
local real dx= x - ux
local real dy= y - uy
local unit d= null

//local real it = distance/45 //inc = 20
//local integer i = 0
local real angle= bj_RADTODEG * Atan2(dy, dx)
local real xx= x - 50 * Cos(angle * bj_DEGTORAD)
local real yy= y - 50 * Sin(angle * bj_DEGTORAD)

local real angle_l= angle - 90
local real angle_r= angle + 90

// call CreateUbersplatBJ(pq, "THND", 100, 100, 100, 0, false, false )

 call SummonThorn(x , y , 0 , angle , id , true)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 35 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 35 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 70 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 70 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 0 , angle , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 140 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 140 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 105 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 105 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 175 , angle_l , id , true)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 175 , angle_r , id , true)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 210 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 210 , angle_r , id , false)
 call TriggerSleepAction(0.01)
  call SummonThorn(xx , yy , 245 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 245 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 280 , angle_l , id , false)
 call TriggerSleepAction(0.02)
 call SummonThorn(x , y , 280 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 350 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 350 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 315 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 315 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 385 , angle_l , id , true)
 call TriggerSleepAction(0.01)
 call SummonThorn(xx , yy , 385 , angle_r , id , true)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 420 , angle_l , id , false)
 call TriggerSleepAction(0.01)
 call SummonThorn(x , y , 420 , angle_r , id , false)
 call TriggerSleepAction(0.01)
 
 set u=null
 set d=null

endfunction

