//===========================================================================
// Trigger: dgems
//===========================================================================
function DruidResp takes item it,string gem,integer owner,integer gtype returns boolean
    local integer i= 0
    local string gm= "false"
    local boolean gemok= false
    
      if s__dgems[(owner)*(7)+gtype] > 0 then
       call UnitRemoveItem(mdruid, it)
       call UnitChat("Once is enough..." , mdruid)
    
      else
       call UnitChat("Thy " + gem + " is received..." , mdruid)
       set s__dgems[(owner)*(7)+gtype]= 1
      
      endif
      
       set gemok=true
      set gm="true"
           loop
           exitwhen i > 4
             if s__dgems[(owner)*(7)+i] < 1 then
              set gemok=false
              set gm="false"
             endif
           set i=i + 1
           endloop
    
   
       call DisplayTimedTextToPlayer(Player(owner), 0, 0, bj_TEXT_DELAY_QUESTDONE, "gemok = " + gm)
      
  return gemok
endfunction

function Trig_dgems_Actions takes nothing returns nothing
 local item it= GetManipulatedItem()
 local integer itemid= GetItemTypeId(it)
 //local integer ownid = LoadInteger(nodump,GetHandleId(GetManipulatedItem()),GetHandleId(GetManipulatedItem()))
 local integer owner= GetItemUserData(it) - 1
 local string gow= "false"
 
 
 if owner < 0 then
  return
 endif
 

  call MakeFaceToUnit(mdruid , udg_PHero[owner])
  if itemid == 'I0MJ' then

  set s__gemdready[owner]= DruidResp(it , "Onix" , owner , 0)
      // set onix[id] = onix[id] + 1
   
      
  elseif itemid == 'I0MK' then
   set s__gemdready[owner]= DruidResp(it , "Rubi" , owner , 1)
    // set rubi[id] = rubi[id] + 1
    
  
  elseif itemid == 'I0ML' then
   set s__gemdready[owner]= DruidResp(it , "Diamond" , owner , 2)
  
    //   set diamond[id] = diamond[id] + 1
     
  
  elseif itemid == 'I0MM' then
    set s__gemdready[owner]= DruidResp(it , "Emerald" , owner , 3)
    // set emerald[id]  = emerald[id] + 1
    
  
  elseif itemid == 'I0MN' then
    set s__gemdready[owner]= DruidResp(it , "Saphire" , owner , 4)
   //  set saphire[id] = saphire[id] + 1
          
  else
    call UnitRemoveItem(mdruid, it)
    call UnitChat("Your offering isnt allowed" , mdruid)
  
  endif
  
  if s__gemdready[owner] == true then
      set gow="true"
   endif
  
  
  call DisplayTimedTextToPlayer(Player(owner), 0, 0, bj_TEXT_DELAY_QUESTDONE, "gemdready = " + gow)
  set it=null
endfunction

