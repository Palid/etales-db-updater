//===========================================================================
// Trigger: sarcofagolib
//===========================================================================

//===========================================================================
// Trigger: Open Sarcofagus
//
// call UpdatePersQuestND(id,tombqid[id],Qdata[tombqid[id]],"-",I2S(Qdata[tombqid[id]]),"-")
//===========================================================================
//TESH.scrollpos=63
//TESH.alwaysfold=0
function Trig_Open_Sarcofagus_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0DY' )
endfunction

function Trig_Open_Sarcofagus_Actions takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local integer i= GetRandomInt(1, 16)
    local integer itdice
    local integer j= 0
    
    local integer dice
    local sound s= gg_snd_Elevator
    local item it
    local integer herolevel= GetHeroLevel(udg_PHero[id])
    local integer eqlvl= 0
    local integer equip= 0
    
  //  call DisplayTimedTextToPlayer(Player(id),.1,0,8," funciona!" )

    call PlaySoundOnUnitBJ(s, 100, u)
    call TriggerSleepAction(0.7)
    if ( i == 1 or i == 5 or i == 9 or i == 13 or i == 14 ) then
    
   // call CreateUnit(Player(13),'n06I',GetUnitX(u),GetUnitY(u))
     call UnitApplyTimedLife(CreateUnit(Player(13), 'n06I', GetUnitX(u), GetUnitY(u), bj_UNIT_FACING), 'BTLF', 2.3)
    endif
    
    
    if ( i == 2 or i == 6 or i == 7 or i == 10 ) then
    
       set dice=GetRandomInt(2, 5)
    
        loop
          exitwhen j > dice
           set it=CreateItem(udg_itmpool[GetRandomInt(37, 41)], GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120), GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120))
           call ItemName(GetItemName(it) , GetItemX(it) , GetItemY(it))
           set it=null
           call TriggerSleepAction(0.01)
          set j=j + 1
         endloop
    endif
    
    
     if ( i == 3 or i == 8 or i == 11 ) then
     
       set dice=GetRandomInt(1, 3)
         loop
          exitwhen j > dice
           set it=CreateItem(udg_itmpool[GetRandomInt(30, 35)], GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120), GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120))
           call ItemName(GetItemName(it) , GetItemX(it) , GetItemY(it))
           set it=null
           call TriggerSleepAction(0.02)
         
          
          set j=j + 1
         endloop
     endif
    
     if ( i == 4 or i == 12 ) then
    
       set dice=GetRandomInt(0, 2)
    
        loop
          exitwhen j > dice
          
          if dice == 0 then
          
            set itdice=57 //profaner's manual
          else
            
              if GetRandomInt(1, 10) > 5 then
                  set eqlvl=1 + ( herolevel / 20 )
                  set equip=s__equipmentlvl[(eqlvl)*(7)+GetRandomInt(1, 6)]
                  set itdice=GetRandomInt(equip, equip + 12)
             else
             
                  set eqlvl=herolevel / 8
                  set itdice=s__weaponlvl[(eqlvl)*(43)+GetRandomInt(1, s__weaponsize[eqlvl])]
             endif
            endif
          
          set it=CreateItem(udg_itmpool[itdice], GetRandomReal(GetUnitX(u) - 120, GetUnitX(u) + 120), GetRandomReal(GetUnitY(u) - 120, GetUnitY(u) + 120))
          call ItemName(GetItemName(it) , GetItemX(it) , GetItemY(it))
          set it=null
          call TriggerSleepAction(0.02)
         
         
          set j=j + 1
         endloop
      endif
    if isprofanator[id] == true and Qdata[tombqid[id]] < tombreq[id] then
       set Qdata[tombqid[id]]=Qdata[tombqid[id]] + 1
       
       if Qdata[tombqid[id]] >= tombreq[id] then
       
       call UpdatePersQuest(id , tombqid[id] , Qdata[tombqid[id]] , "Job done, return to Artun to claim rewards [" , I2S(Qdata[tombqid[id]]) , "-")
       
       else
       
        call UpdatePersQuest(id , tombqid[id] , Qdata[tombqid[id]] , "-" , I2S(Qdata[tombqid[id]]) , "-")
       endif
       
    endif
  
    call TriggerSleepAction(1)
    call SetUnitAnimationByIndex(u, 2)
    call UnitRemoveAbility(u, 'A0DY')
    call SetUnitOwner(u, Player(PLAYER_NEUTRAL_PASSIVE), false)
    set s=null
    set it=null
    call TriggerSleepAction(700)
    call GroupAddUnit(tombs, u)
    call SetUnitAnimation(u, "stand")
    
    
    set u=null
   
endfunction

//===========================================================================
function InitTrig_Open_Sarcofagus takes nothing returns nothing
    set gg_trg_Open_Sarcofagus=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Open_Sarcofagus, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Open_Sarcofagus, Condition(function Trig_Open_Sarcofagus_Conditions))
    call TriggerAddAction(gg_trg_Open_Sarcofagus, function Trig_Open_Sarcofagus_Actions)
endfunction


