    set gg_trg_checkgroup=CreateTrigger()
    call DisableTrigger(gg_trg_checkgroup)
    call TriggerRegisterTimerEvent(gg_trg_checkgroup, 1.00, true)
    call TriggerAddAction(gg_trg_checkgroup, function Trig_checkgroup_Actions)
endfunction


//===========================================================================
// Trigger: kidnapped
//===========================================================================
function Trig_kidnapped_Conditions takes nothing returns boolean
    return IsUnitInGroup(GetTriggerUnit(), koboldk) == true
endfunction

function Trig_kidnapped_Actions takes nothing returns nothing
local integer i= 0
 call DisableTrigger(gg_trg_kidnapped)
  
    set childk=true
    call UnitRemoveAbility(koboldvictim, 'Awan')

    call TriggerSleepAction(1.2)
 

    call IssuePointOrder(koboldvictim, "move", - 17890, 4320)
    
    call SetUnitMoveSpeed(koboldvictim, 340.00)
    call GroupPointOrder(koboldk, "attack", - 17890, 4320)
    call TriggerSleepAction(1)
    call StartSound(bj_questDiscoveredSound)
    
      
   loop
    exitwhen i > 8
        if udg_Plugar[GetPlayerId(Player(i))] == 1 then
           call DisplayTimedTextToPlayer(Player(i), 0, 0, 12, "|cffffcc00KOBOLDS ATTACKING|r")
           call DisplayTimedTextToPlayer(Player(i), 0, 0, 12, "¡Hurry! A band of kobolds have kidnapped a child on the outskirts of Velhilmen")
           call DisplayTimedTextToPlayer(Player(i), 0, 0, 12, "Don't let them to enter into their cave! They become stronger in underground places")
           call DisplayTimedTextToPlayer(Player(i), 0, 0, 12, "|cffffcc00REWARD:|r |cff0077ff+8 Reputation, +2500 XP|r - |cffff3300[Max level allowed: 20]|r")
             if ( GetLocalPlayer() == Player(i) ) then
                   call PingMinimap(- 17890, 4320, 6)
              endif
         endif
     set i=i + 1
   endloop
 


endfunction

