function Trig_spwnegg_Conditions takes nothing returns boolean
    return ( GetDestructableTypeId(GetTriggerDestructable()) == 'DTes' )
endfunction

function Trig_spwnegg_Actions takes nothing returns nothing
local integer i= GetRandomInt(1, 3)
local destructable d= GetTriggerDestructable()
local location p= GetDestructableLoc(d)




 if ( i == 1 ) then
    call CreateUnitAtLoc(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[116], p, GetRandomReal(0, 360))
 elseif ( i == 2 ) then
    call CreateUnitAtLoc(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[36], p, GetRandomReal(0, 360))
 elseif ( i == 3 ) then
  call CreateUnitAtLoc(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[37], p, GetRandomReal(0, 360))
 endif
  call TriggerSleepAction(10)
  call CreateDestructableLoc('DTes', p, GetRandomDirectionDeg(), 1.00, 0)
  
  call RemoveLocation(p)
  set p=null
  set d=null
endfunction

