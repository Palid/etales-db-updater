function MakeFaceToUnit takes unit s,unit d returns nothing
 call SetUnitFacing(s, bj_RADTODEG * Atan2(GetUnitY(d) - GetUnitY(s), GetUnitX(d) - GetUnitX(s)))
endfunction

function EnableShop takes unit u returns nothing
    call UnitAddAbility(u, 'Apit')
    call UnitAddAbility(u, 'Aneu')
    call UnitAddAbility(u, 'Asid')
    call AddItemToStock(u, 'I08I', 1, 1) //accept taxpayment
    call AddItemToStock(u, 'I08J', 1, 1) //reject payment
endfunction


function TaxRequest takes integer l__currentTax returns string
local integer i= GetRandomInt(1, 6) - 1
if i == 0 then
 return "Hello friend, do you wanna pass? just pay |cffffcc00" + I2S(l__currentTax) + "|r gold"
 elseif i == 1 then
 return "U want pass here? Pay |cffffcc00" + I2S(l__currentTax) + "|r gold"
  elseif i == 2 then
 return "Come on boy, just put here |cffffcc00" + I2S(l__currentTax) + "|r gold coins fast!"
  elseif i == 3 then
 return "Hahahaha give me |cffffcc00" + I2S(l__currentTax) + "|r gold"
  elseif i == 4 then
 return "It's a real ganga, just give me |cffffcc00" + I2S(l__currentTax) + "|r gold"
  elseif i == 5 then
 return "All passengers must pay the amount of |cffffcc00" + I2S(l__currentTax) + "|r gold"
  endif
  return ""
endfunction


