function hapic takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I025' )
endfunction


function Seasonends takes nothing returns nothing

 local timer t= GetExpiredTimer()
 local integer id= LoadInteger(udg_MG1Hash, GetHandleId(t), 1) - 10
 
 call PauseTimer(TOrchunt[id])
 call ReleaseTimer(TOrchunt[id])
 
 call DestroyTimerDialog(TOrchuntD[id])
 set TOrchuntD[id]=null
        
  call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "|cffffcc00Orc hunter safe-conduit expired.|r")
  set orckiller[id]=false
   
endfunction

function hapia takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   if orckiller[id] == true then
   
     call UnitChat("Hey man, you already are into a hunting season, please wait until it ends" , hussarl)
     call AdjustPlayerStateBJ(21030, Player(id), PLAYER_STATE_RESOURCE_GOLD)
     return
   endif


  if orckiller[id] == false and GetUnitLevel(udg_PHero[id]) > 39 then
   set orckiller[id]=true
   call UnitChat("Hello. Please sign here to take your license." , hussarl)
   call TriggerSleepAction(2)
   call StartSound(bj_questHintSound)
    call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "|cffffcc00You have activated Orc hunter safe-conduit. You have 6 minutes to hunt orcs. Please kill them all|r")
    set TOrchunt[id]=(NewTimerEx(0)) // INLINED!!
    
    call TimerStart(TOrchunt[id], 360, false, function Seasonends)
    
    set TOrchuntD[id]=CreateTimerDialog(TOrchunt[id])
    call TimerDialogSetTitle(TOrchuntD[id], "Hunt ends:")

      if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call TimerDialogDisplay(TOrchuntD[id], true)
     endif
       call SaveInteger(udg_MG1Hash, GetHandleId(TOrchunt[id]), 1, id + 10)
       call TriggerSleepAction(5)
       call DisplayTimedTextToPlayer(Player(id), .1, 0, 8, "|cffffcc00Remember to charge your payment before season ends.|r")
 
    
   else
    call UnitChat("Sorry but you don't have the required level to sign for us" , hussarl)
   endif
endfunction

