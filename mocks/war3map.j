 if ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'I0M2') == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I0M2')
      
        if ( GetItemCharges(udg_tmpitem) < 50 ) then
