//===========================================================================
// Trigger: ankitfound
//===========================================================================
function Trig_ankitfound_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function ankitfilter takes nothing returns boolean
   return IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_ankitfound_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local boolexpr istru= Condition(function ankitfilter)
local group g= null
local unit u= null
local real x= GetUnitX(ankit)
local real y= GetUnitY(ankit)

call DisableTrigger(gg_trg_ankitfound)

call UnitChat("Anybody here?..." , ankit)
call TriggerSleepAction(3)
call UnitChat("Thanks for come..." , ankit)
call TriggerSleepAction(3)
call DestroyEffect(ankitsnare)
call PauseUnit(ankit, false)
set ankitsnare=null
call UnitChat("It's worse than I though..." , ankit)
call TriggerSleepAction(3)
call SetUnitTimeScale(ankit, 1)
call MakeFaceToUnit(ankit , udg_PHero[id])
call UnitChat("I'm bearing several days here, entramped on this... place" , ankit)
call TriggerSleepAction(4)
call SetUnitFacing(ankit, 270)
call UnitChat("I was investigating the rubbles of the burned farms." , ankit)
call TriggerSleepAction(3)
call UnitChat("When I found a lop-hole under the debris" , ankit)
call TriggerSleepAction(2)
call UnitChat("After tried to open the cover, all the ground around fell disastrously..." , ankit)
call TriggerSleepAction(5)
call UnitChat("Suddenly I was dragged down and cannot scape" , ankit)
call TriggerSleepAction(3)
call MakeFaceToUnit(ankit , udg_PHero[id])
call UnitChat("Then when I woke up, I found this kind of cave..." , ankit)
call TriggerSleepAction(3)
call UnitChat("I started to explore around to find an exit... and then a monstruosity appeared on my way..." , ankit)
call TriggerSleepAction(6)
call SetUnitFacing(ankit, 270)
call UnitChat("Something like a giant scarab started to scream in an unknown language..." , ankit)
call TriggerSleepAction(4)
call UnitChat("I felt my body falling into a weakness..." , ankit)
call TriggerSleepAction(3)
call SetUnitFacing(ankit, 180)
call UnitChat("Then I saw the farmer's face growing fast from the monster mouth..." , ankit)
call TriggerSleepAction(5)
call UnitChat("he threw me a viscose liquid that paralized my entire body..." , ankit)
call TriggerSleepAction(4)
call UnitChat("And then I fell asleep..." , ankit)
call TriggerSleepAction(2)
call UnitChat("I can't remember anything after that, I just was trapped here all these days..." , ankit)
call TriggerSleepAction(6)
call UnitChat("Thanks for come again..." , ankit)
call TriggerSleepAction(3)

  
  call GroupEnumUnitsInRange(g, x, y, 600, istru)
  call DestroyBoolExpr(istru)
  set istru=null
  
  call StartSound(bj_questUpdatedSound)
  call FlashQuestDialogButton()
  call QuestItemSetCompleted(irntuid, true)
  
  loop
   set u=FirstOfGroup(g)
   exitwhen u == null
   
         set id=GetPlayerId(GetOwningPlayer(u))
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 8, "|cffffcc00MAIN QUEST UPDATE|r: The cult of Irntu Hel")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 8, "Searching Ankit track (completed)")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 8, "  ")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 8, "Got |cff00bfff+" + I2S(35) + "|r Reputation.")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 8, "    |cff00bfff+" + I2S(15834) + "|r gold coins.")
            
            call AdjustPlayerStateBJ(15834, Player(id), PLAYER_STATE_RESOURCE_GOLD)
             set Reputation[id]=Reputation[id] + 35
   
   call GroupRemoveUnit(g, u)
   endloop
  
  call DestroyGroup(g)
  set g=null
  set u=null
 call DestroyEffect(AddSpecialEffectTarget(seblink, ankit, "chest"))
 call TriggerSleepAction(0.4)
 call SetUnitPosition(ankit, - 2881, 52)


endfunction

