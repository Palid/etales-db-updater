// Trigger: ScorpionDusk
//===========================================================================
function Trig_ScorpionDusk_Conditions takes nothing returns boolean
    return Scorpionevent3 > 1 and ScorpionSwp == false and ScorpionTg == false and ScorpionRd == false
endfunction


function ScDskCycle takes nothing returns nothing
local timer t= GetExpiredTimer()
local integer i= LoadInteger(AiHash, GetHandleId(t), 0)
local unit ua= LoadUnitHandle(AiHash, GetHandleId(t), 1)
local unit ub= LoadUnitHandle(AiHash, GetHandleId(t), 5)
local unit uc= LoadUnitHandle(AiHash, GetHandleId(t), 6)
local real delta= LoadReal(AiHash, GetHandleId(t), 2)
local real trazo= LoadReal(AiHash, GetHandleId(t), 3)
local real angle= LoadReal(AiHash, GetHandleId(t), 4)
 
local real x= 0
local real y= 0
local real angleb= angle + 20
local real anglec= angle - 20
local real xc= 0
local real yc= 0
local real xb= 0
local real yb= 0


     set i=i + 1
  //Unidad a============================================================
	set x=GetUnitX(ua) + trazo * Cos(angle * bj_DEGTORAD)
	set y=GetUnitY(ua) + trazo * Sin(angle * bj_DEGTORAD)

          if x < 31830 and y < 19480 then
              call SetUnitX(ua, x)
              call SetUnitY(ua, y)
             // call DestroyEffect(AddSpecialEffect(sffectdusta,x,y))
              call DestroyEffect(AddSpecialEffect(terranfx, x, y))


          endif

  //Unidad b============================================================
    set xb=GetUnitX(ub) + trazo * Cos(angleb * bj_DEGTORAD)
	set yb=GetUnitY(ub) + trazo * Sin(angleb * bj_DEGTORAD)

          if xb < 31830 and yb < 19480 then
              call SetUnitX(ub, xb)
              call SetUnitY(ub, yb)
             // call DestroyEffect(AddSpecialEffect(sffectdusta,x,y))
              call DestroyEffect(AddSpecialEffect(terranfx, xb, yb))
          endif
   //Unidad c============================================================
    set xc=GetUnitX(uc) + trazo * Cos(anglec * bj_DEGTORAD)
	set yc=GetUnitY(uc) + trazo * Sin(anglec * bj_DEGTORAD)

          if xc < 31830 and yc < 19480 then
              call SetUnitX(uc, xc)
              call SetUnitY(uc, yc)
             // call DestroyEffect(AddSpecialEffect(sffectdusta,x,y))
              call DestroyEffect(AddSpecialEffect(terranfx, xc, yc))
          endif
     
            

 call SaveInteger(AiHash, GetHandleId(t), 0, i)

  
  if i > 45 then
      call FlushChildHashtable(AiHash, GetHandleId(t))
      call PauseTimer(t)
      call ReleaseTimer(t)
  endif

 


set t=null
set ua=null
set ub=null
set uc=null
endfunction

function ScorpionDusks takes unit B,unit gu returns nothing
local real Bx= GetUnitX(B)
local real By= GetUnitY(B)
local real gux= GetUnitX(gu)
local real guy= GetUnitY(gu)

local real x= Bx - gux
local real y= By - guy

local real delta= 1280
local real trazo= delta / 45
local real angle= bj_RADTODEG * Atan2(y, x) - 180
local integer i= 0
local integer j= 0
local integer k= 0

local timer ta= (NewTimerEx(0)) // INLINED!!

local unit ua= null
local unit ub= null
local unit uc= null
local effect fx= AddSpecialEffectTarget("ChargeEnrage (chest attachement).mdx", gg_unit_U00O_0266, "head")

 call SetUnitFacing(B, angle)
 call PauseUnit(B, true)
 call SetUnitAnimationByIndex(B, 6)
 call PlaySoundOnUnitBJ(gg_snd_scordk, 100, B)
 call TriggerSleepAction(1)
 call DestroyEffect(fx)
 set fx=null
 
 set ua=CreateUnit(Player(12), 'n08Y', Bx, By, angle)
 call UnitApplyTimedLife(ua, 'BTLF', 1.36)
 set ub=CreateUnit(Player(12), 'n08Y', Bx, By, angle)
 call UnitApplyTimedLife(ub, 'BTLF', 1.36)
 set uc=CreateUnit(Player(12), 'n08Y', Bx, By, angle)
 call UnitApplyTimedLife(uc, 'BTLF', 1.36)
 
  
  
 
 call SaveInteger(AiHash, GetHandleId(ta), 0, i)
 call SaveUnitHandle(AiHash, GetHandleId(ta), 1, ua)
 call SaveReal(AiHash, GetHandleId(ta), 2, delta)
 call SaveReal(AiHash, GetHandleId(ta), 3, trazo)
 call SaveReal(AiHash, GetHandleId(ta), 4, angle)
 call SaveUnitHandle(AiHash, GetHandleId(ta), 5, ub)
 call SaveUnitHandle(AiHash, GetHandleId(ta), 6, uc)
  
 call TimerStart(ta, 0.03, true, function ScDskCycle)

 
  
 
 call TriggerSleepAction(1.8)

 call PauseUnit(B, false)



set ua=null
set ub=null
set uc=null
set ta=null


 endfunction



function Trig_ScorpionDusk_Actions takes nothing returns nothing
local unit B= gg_unit_U00O_0266
local real x= GetUnitX(B)
local real y= GetUnitY(B)

local boolexpr filter= null
local unit gu= null
local unit target= null
  
  set ScorpionRd=true
  set Scorpionevent3=0

  
  set Scorpiongr=CreateGroup()
  set filter=Condition(function Scorpionfilter)
  call GroupEnumUnitsInRange(Scorpiongr, x, y, 1024, filter)
  call DestroyBoolExpr(filter)
  set filter=null

   loop
	    set gu=FirstOfGroup(Scorpiongr)
		  exitwhen gu == null
			if ( IsUnitEnemy(gu, GetOwningPlayer(B)) == true ) then
                set target=gu
                call GroupClear(Scorpiongr)
           endif
		   
		call GroupRemoveUnit(Scorpiongr, gu)
		set gu=null
		endloop
     
     call DestroyGroup(Scorpiongr)
	 set Scorpiongr=null
     
    if not ( target == null ) then
        
         call DestroyEffect(AddSpecialEffect(sffectdusta, x, y))
       //  call SetUnitPropWindow(B, 0)
         //call IssueTargetOrder(B,"smart",target)
        // call TriggerSleepAction(2)
       
                 if GetUnitState(B, UNIT_STATE_LIFE) > 0.4 then
                     call ScorpionDusks(B , target)
                 endif
    else
       
      
    endif
 

  call TriggerSleepAction(5)
  set ScorpionRd=false
  set B=null
  set gu=null
  set target=null

endfunction

