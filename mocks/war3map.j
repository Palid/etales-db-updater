//===========================================================================
// Trigger: MAa
//===========================================================================
function MAAC takes nothing returns boolean
    return UnitHasBuffBJ(GetAttacker(), 'B00K') == true
endfunction

function MAAA takes nothing returns nothing
 local location p= GetUnitLoc(GetTriggerUnit())
 local integer ratio= GetRandomInt(0, 100)
 local sound s= null
    
    if ( ratio <= 7 ) then
    set s=gg_snd_MetalHeavyChopFlesh1
        call CreateNUnitsAtLoc(1, 'n01A', Player(bj_PLAYER_NEUTRAL_EXTRA), p, 90)
        call IssueTargetOrder(GetLastCreatedUnit(), "cripple", GetTriggerUnit())
        call PlaySoundOnUnitBJ(s, 100.00, GetTriggerUnit())
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        endif
    call RemoveLocation(p)
    set s=null
    set p=null
endfunction

