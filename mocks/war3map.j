function Trig_Hero_Dies_Actions takes nothing returns nothing
 local unit victi= GetTriggerUnit()
 local integer i= GetRandomInt(0, 4)
 local integer time= 0
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer id= GetPlayerId(GetOwningPlayer(victi))
 local integer kid= GetPlayerId(GetOwningPlayer(GetKillingUnit()))
 local integer questid
 local integer dtax= GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD)
 local integer ftax= dtax
 local real ddtax= 0
 
 
  if s__dstate[id] != 0 then
   call CleanAllStates(id)
  endif
 
  if DeathTax == true and IsUnitInForce(victi, teamEventForce) == false and GetUnitPointValue(victi) > 120 and inpvp[id] == false then
      
      set ddtax=dtax * 0.029
      set dtax=R2I(ddtax)
      set ftax=ftax - dtax
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "You lose |cffff3311-" + I2S(dtax) + " gold|r by |cff999999Rigor Extrema Tax|r")
      call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, ftax)

  endif
 
 if s__InvampTest[id] == true then
      call UnitRemoveAbility(victi, 'A0H2') //bloodylust
      set s__InvampTest[id]= false
      call GroupRemoveUnit(udg_inTest, victi)
      set s__bloodycount[id]= 0
      call StartSound(bj_questFailedSound)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffff0000PERSONAL QUEST FAILED|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "You have been discovered as evil servant... (test failed.. try again)")
      set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
      call RemoveQuestFromPlayer(questid , QPid[questid])
           
    endif
   
    if udg_Hashawk[id] == true then
     call KillUnit(udg_Hawkarray[id])
    endif
    
    set time=10 + GetUnitLevel(GetDyingUnit()) / 2
    set udg_DieTime=I2R(time)
    
    call TimerStart(t, udg_DieTime, false, function herolive)
    call CreateTimerDialogBJ(t, "TRIGSTR_5218")
    call TimerDialogDisplayBJ(false, GetLastCreatedTimerDialogBJ())
    call TimerDialogDisplayForPlayerBJ(true, GetLastCreatedTimerDialogBJ(), GetOwningPlayer(GetDyingUnit()))
    call SaveTimerDialogHandleBJ(GetLastCreatedTimerDialogBJ(), 18, GetHandleIdBJ(victi), udg_MG1Hash)
    call TriggerSleepAction(1.74)
    call SetUnitPosition(hsoul[id], GetUnitX(GetDyingUnit()), GetUnitY(GetDyingUnit()))
    call ShowUnit(hsoul[id], true)
    set time=time - 2
    
    loop
    set time=time - 1
    call TriggerSleepAction(0.87)
    if resurrected[id] == true then
    
       set resurrected[id]=false
       call DestroyTimerDialog(LoadTimerDialogHandle(udg_MG1Hash, GetHandleId(victi), 18))
       call FlushChildHashtableBJ(GetHandleIdBJ(victi), udg_MG1Hash)
    
       set victi=null
       call PauseTimer(t)
       call ReleaseTimer(t)
       set t=null
       set time=0
       return
    endif
    
    exitwhen time < 1
    endloop
    
    
    call ReviveHeroLoc(victi, udg_RevivalPoints[id], true)
    call SetUnitPositionLoc(udg_Slave[id], udg_RevivalPoints[id])
    call SetUnitPositionLoc(udg_Familiar[id], udg_RevivalPoints[id])
    call ShowUnit(hsoul[id], false)
    call SetUnitPosition(hsoul[id], hsoulx[id], hsouly[id])
    
      if ( cslave[id] != null ) then
        call SetUnitPositionLoc(cslave[id], udg_RevivalPoints[id])
     endif
       if ( traveler1[id] != null ) then
        call SetUnitPositionLoc(traveler1[id], udg_RevivalPoints[id])
     endif
         if ( traveler2[id] != null ) then
        call SetUnitPositionLoc(traveler2[id], udg_RevivalPoints[id])
     endif
         if ( traveler3[id] != null ) then
        call SetUnitPositionLoc(traveler3[id], udg_RevivalPoints[id])
     endif
         if ( traveler4[id] != null ) then
        call SetUnitPositionLoc(traveler4[id], udg_RevivalPoints[id])
     endif
    
    call DestroyTimerDialog(LoadTimerDialogHandle(udg_MG1Hash, GetHandleId(victi), 18))
    call FlushChildHashtableBJ(GetHandleIdBJ(victi), udg_MG1Hash)
    call PanCameraToTimedLocForPlayer(GetOwningPlayer(victi), udg_RevivalPoints[id], 0)
    
    
 set victi=null
 call PauseTimer(t)
 call ReleaseTimer(t)
 set t=null
       
          call CheckCurrentCamera(id)
          call CameraSetSmoothingFactor(4.00)
    
    
endfunction

