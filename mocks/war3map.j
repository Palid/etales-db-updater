//===========================================================================
// Trigger: troll
//
// gg_unit_Hvwd_1037
//===========================================================================
//TESH.scrollpos=3
//TESH.alwaysfold=0
function trolltc takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I03K' )
endfunction

function trollta takes nothing returns nothing
   local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   local integer questid
     call SetUnitFacingToFaceUnitTimed(gg_unit_h02S_0463, udg_PHero[id], 0)
   if ( GetUnitTypeId(GetTriggerUnit()) != 'H02A' ) then
        call UnitChat("You haven't born from the inner of the Earth (orc), you cannot take this test" , gg_unit_h02S_0463)

        
   elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
        call UnitChat("You know what you must do" , gg_unit_h02S_0463)
 
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
            call UnitChat(". |n|cffffcc00Needs 300 kills|r" , gg_unit_h02S_0463)

        else
            call UnitChat("There is a cave, north from Valdivia where you can find a Earth blood pool, go there and sink into the pool" , gg_unit_h02S_0463)

            set trolladviced[id]=true
            
         call GroupAddUnitSimple(GetTriggerUnit(), udg_inTest)
         call TriggerSleepAction(3)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00MAIN QUEST DISCOVERED|r")
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "          |cffeeee88Blood of Troll|r: Go to the cave, find the pit and enter in the blood")
         set questid=SetupQuest(id , null , "BLOOD OF TROLL" , "Go to the trolls cave and enter into the black blood pit" , "-" , "-" , 0 , s__qty[2])
         call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
        
        call StartSound(bj_questDiscoveredSound)
         
          
     if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
           call PingMinimap(- 6480, 3300, 15)
        //call StartSound(bj_pingMinimapSound)
    endif

    endif

endfunction



