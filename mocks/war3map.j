           call Setwidth(id , 13 , 0 , col0)
           call Setwidth(id , 11 , 1 , col1)
           call Setwidth(id , 12 , 1 , col1)
           call Setwidth(id , 13 , 1 , col1)
         
           call SetInfo(id , 0 , 3 , col3 , "Main Attributes")
           call SetInfo(id , 0 , 4 , col4 , "  ")
           
          call SetInfo(id , 1 , 3 , col3 , sstr)
          call SetInfo(id , 1 , 4 , col4 , I2S(udg_STR[id]))
           
          call SetInfo(id , 2 , 3 , col3 , sagi)
          call SetInfo(id , 2 , 4 , col4 , I2S(udg_AGI[id]))
           
          call SetInfo(id , 3 , 3 , col3 , sint)
          call SetInfo(id , 3 , 4 , col4 , I2S(udg_INT[id]))
           
          call SetInfo(id , 4 , 3 , col3 , "Advanced Attributes")
          call SetInfo(id , 4 , 4 , col4 , "  ")
          call SetInfo(id , 5 , 3 , col3 , cons)
          call SetInfo(id , 5 , 4 , col4 , I2S(s__Constitution[id]))
         
          call SetInfo(id , 6 , 3 , col3 , mstr)
          call SetInfo(id , 6 , 4 , col4 , I2S(s__Mstrength[id]))
           
          call SetInfo(id , 7 , 3 , col3 , fort)
          call SetInfo(id , 7 , 4 , col4 , I2S(s__Fortune[id]))
           
           
          call SetInfo(id , 8 , 3 , col3 , "Special cast chance:")
        //  call SetInfo(id, 8, 4,col4,ylw+R2S(sp_cast_chance)+"%|r")
           
          call SetInfo(id , 9 , 3 , col3 , "Special cast xdmg:")
       //   call SetInfo(id, 9, 4,col4,ylw+R2S(sp_cast_xdmg)+"x|r")
 
          call SetInfo(id , 10 , 3 , col3 , "Lethal attack chance:")
       //   call SetInfo(id, 10, 4,col4,ylw+R2S(lethal_attack_per)+"%|r")
           
          call SetInfo(id , 11 , 3 , col3 , "Lethal attack xdmg:")
        //  call SetInfo(id, 11, 4,col4,ylw+R2S(lethal_attack_edmg)+"x|r") 

          call SetInfo(id , 12 , 3 , col3 , "Inner restoration chance:")
      //    call SetInfo(id, 12, 4,col4,ylw+R2S(I2R(Mstrength[id])/23)+"%|r") 
           
          call SetInfo(id , 13 , 3 , col3 , "Inner restoration amount:")
       //   call SetInfo(id, 13, 4,col4,ylw+R2S(I2R(Constitution[id])/402)+"%|r")         
        
           set hname=null
           set mspeed=null
           set level=null

          

          set n=ManagePersQuest(id)

          set Qboard[id]=sc__Board_create()
        //  call Qboard[id].setStyle(true, false)
         
          call MultiboardSetTitleText(s__Board_Board___bBoard[(Qboard[id])], ("|cffff7700" + Pnombre[id] + "'|rs quest Log")) // INLINED!!
           
         //   set Qboard[id].column[0].width = .26
         //   set Qboard[id].column[1].width = .04
        
         
           
           call SetInfoQ(id , 0 , 0 , .3 , "|cff777777¤|r  |cff999999" + questr_Done[id])
           call SetInfoQ(id , 2 , 0 , .3 , "|cffffcc00______________________________________________________________|r")
      set i=0
         set j=3
        loop
        exitwhen i > n
          if tmpQid[i] > 0 then
          // set Qboard[id][j][0].text = "|cff777777¤|r  |cffffcc00"+QTitle[tmpQid[i]]+"|r"
           call SetInfoQ(id , j , 0 , .25 , "|cff777777¤|r  |cffffcc00" + QTitle[tmpQid[i]] + "|r")
          // set Qboard[id][j+1][0].text = Qtype[tmpQid[i]]+" |cffdddddd"+QSid[tmpQid[i]]+"|r"
           call SetInfoQ(id , j + 1 , 0 , .3 , Qtype[tmpQid[i]] + " |cffdddddd" + QSid[tmpQid[i]] + "|r")
          // set Qboard[id][j+1][1].text = QSidx[tmpQid[i]] + QSidy[tmpQid[i]]
           call SetInfoQ(id , j , 1 , .05 , QSidx[tmpQid[i]] + QSidy[tmpQid[i]])
         endif
          set j=j + 2
          set i=i + 1
         endloop

         set faction=null
         set pname=null
        set boardCreated[id]=true
        
        if IsTriggerEnabled(gg_trg_updatequests) == false then
        
             call EnableTrigger(gg_trg_updatequests)
        endif
        
       
endfunction
 
 



