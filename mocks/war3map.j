function Trig_nokeys_Actions takes nothing returns nothing
local group g= GetUnitsInRectOfPlayer(gg_rct_Garden2, Player(11))
local group gb= GetUnitsInRectOfPlayer(gg_rct_Garden1, Player(11))

     set loadingcounter=loadingcounter + 0.01
     set loadingDisplay="TRG: Init sundeads"

    set sundeads=CreateGroup()
    call GroupAddGroup(g, sundeads)
    call TriggerSleepAction(0.05)
    call GroupAddGroup(gb, sundeads)
    call TriggerSleepAction(0.05)
  
  call DestroyGroup(g)
  set g=null
  call DestroyGroup(gb)
  set g=null
endfunction

