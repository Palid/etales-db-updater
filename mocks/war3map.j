function GetWeapon takes nothing returns integer
    return ( ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100 )
endfunction 


function IsTwoHand takes nothing returns boolean
    return ( ModuloInteger(GetItemLevel(GetManipulatedItem()), 10000) / 1000 == 6 )
endfunction 

function IsAxe takes nothing returns boolean
