//===========================================================================
// Trigger: AncientCoreTest
//===========================================================================
function ACETC takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0M5' )
endfunction

function ACETA takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer lev= GetUnitPointValue(udg_PHero[id]) - 100
local location p=udg_Pit_loc[0]

     if ( udg_pit_ocupado == true ) then
        call UnitChat("Wait a moment, someone is taking the test now...." , gg_unit_H01H_0305)
 
   elseif ( GetUnitTypeId(udg_PHero[id]) == 'H00G' or GetUnitTypeId(udg_PHero[id]) == 'H00G' ) then
       call UnitChat("Novices get out of here!!!" , gg_unit_H01H_0305)
     
 
    elseif ( GetUnitUserData(udg_PHero[id]) < 900 ) then
           call UnitChat("You dont have neccesary experience to take this examen |n|cffffcc00Need 900 kills|r" , gg_unit_H01H_0305)

    elseif ( GetHeroLevel(udg_PHero[id]) < 17 ) then
           call UnitChat("You dont have neccesary level to take this examen |n|cffffcc00Need level 17|r" , gg_unit_H01H_0305)
        
           
    elseif ( 0 < lev and lev < 20 ) then
    
            call UnitChat("OK, now you will be sent to confront your destiny.." , gg_unit_H01H_0305)
            call TriggerSleepAction(2)
            call SetUnitPositionLoc(udg_PHero[id], p)
            call SetUnitPositionLoc(udg_Slave[id], p)
            call SetUnitPositionLoc(udg_Familiar[id], p)
            
            call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
            set udg_pit_ocupado=true
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "NEW QUEST")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "Defeat the Wendigo...")
            call StartSound(bj_questDiscoveredSound)
            set udg_unit_in_pit=udg_PHero[id]
            set PlayerInTest[id]=true
    endif
        

set p=null
set u=null

endfunction

