//===========================================================================
// Trigger: fallenstarttest
//
// gg_unit_Hvwd_1037
//===========================================================================
function fallenvc takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I09G' )
endfunction

function fallenva takes nothing returns nothing
   local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
   local integer questid
   call MakeFaceToUnit(gg_unit_n08D_0232 , udg_PHero[id])

   if ( GetUnitTypeId(GetTriggerUnit()) != 'H00H' ) then
    
      call UnitChat("I can smell your fear, I can smell your blood human, get out here!!!" , gg_unit_n08D_0232)
      
        
   elseif ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
      call UnitChat("You know what you must do!" , gg_unit_n08D_0232)
        
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
      call UnitChat("Fear... your hearth is lost in fear... |n|cffffcc00Needs 300 kills|r!" , gg_unit_n08D_0232)
          
        else
         call UnitChat("As you want, blood is our most delicious wine, Go, go to the valley and drink lots of blood without death in the intend... " , gg_unit_n08D_0232)
                  set s__InvampTest[id]= true
         set s__bloodycount[id]= 0
         call GroupAddUnit(udg_inTest, GetTriggerUnit())
         call TriggerSleepAction(2)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " The vampires touches you... |cffffcc00[Received <bloody lust> skill]|r")
         call UnitAddAbility(udg_PHero[id], 'A0H2')
         call TriggerSleepAction(5)
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00MAIN QUEST DISCOVERED|r")
         call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "          |cffeeee88Bloody Lust|r: Drink blood of 10 enemies without die...")
         call StartSound(bj_questDiscoveredSound)
         set questid=SetupQuest(id , null , "BLOODY LUST" , " Drink blood of 10 enemies without die..." , "0" , "/10" , 0 , s__qty[2])
         call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
        
          
      endif

endfunction



