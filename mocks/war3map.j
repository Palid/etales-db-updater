//===========================================================================
// Trigger: foot switch1
//===========================================================================
function Trig_foot_switch1_Actions takes nothing returns nothing
    call DisableTrigger(GetTriggeringTrigger())
    set udg_tpcam=GetUnitLoc(GetEnteringUnit())
    call CinematicModeBJ(true, GetPlayersAll())
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=16
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call CameraSetupApplyForPlayer(true, gg_cam_minedoorcam, ConvertedPlayer(GetForLoopIndexA()), 0)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call TriggerSleepAction(1.00)
    call ModifyGateBJ(bj_GATEOPERATION_OPEN, gg_dest_ZTd2_9380)
    call KillDestructable(gg_dest_DTfx_9444)
    call TriggerSleepAction(2.00)
    call CinematicModeBJ(false, GetPlayersAll())
    set bj_forLoopBIndex=1
    set bj_forLoopBIndexEnd=16
    loop
        exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
        call PanCameraToTimedLocForPlayer(ConvertedPlayer(GetForLoopIndexB()), udg_tpcam, 0)
        call ResetToGameCameraForPlayer(ConvertedPlayer(GetForLoopIndexB()), 0)
        set bj_forLoopBIndex=bj_forLoopBIndex + 1
    endloop
   // call DisableTrigger( GetTriggeringTrigger() )
    call RemoveLocation(udg_tpcam)
endfunction

