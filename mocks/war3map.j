    set gg_trg_FindingspidersA=CreateTrigger()
   call TriggerRegisterUnitInRange(gg_trg_FindingspidersA, gg_unit_n05F_0958, 255, Condition(function rescok))
   call TriggerAddCondition(gg_trg_FindingspidersA, Condition(function findingc))
