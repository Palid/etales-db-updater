//===========================================================================
// Trigger: DMGhawk
//
// local texttag tt2 = null
//     local integer x = 0
//     local integer y = 0
//     local real c = 1
//     if GetLocalPlayer() == GetOwningPlayer(au) then
//         set tt2 = CreateTextTag()
//     endif
//     if GetLocalPlayer() == GetOwningPlayer(tu) then
//         set tt2 = CreateTextTag()
//         call SetTextTagColor(tt2,150,10,10,255)
//     endif
//   local texttag t=CreateTextTagUnitBJ("MASSIVE KILL +5kp", k, 0, 14.00, 100.00, 0.00, 0.00, 100.00 )
//  if GetLocalPlayer() == GetOwningPlayer(au) then
//===========================================================================
function hawkON takes nothing returns boolean
  return ( GetUnitTypeId(GetEventDamageSource()) == 'n005' )
endfunction

function DMGTA takes nothing returns nothing

 local integer id= GetPlayerId(GetOwningPlayer(GetEventDamageSource()))
 local unit k= GetTriggerUnit()
 
 local integer STAT= GetHeroAgi(udg_PHero[id], true) + GetHeroInt(udg_PHero[id], true)
 local real damage= I2R(STAT) * hawkspeed[id]
 
 
 local integer d
  local real angle= GetUnitFacing(GetEventDamageSource())
//we damages the target with calculated damage, after disabling unit damage event triggers 
  call DisableTrigger(gg_trg_DMG)
    
    
   call EnableTrigger(gg_trg_DMGhawkb) //enabling this we can register damage dealed event
   call UnitDamageTarget(udg_PHero[id], k, damage / 25, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
        // call UnitDamageTargetBJ( u, GetTriggerUnit(), udg_Lethalstrikestack, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL )
   call DisableTrigger(gg_trg_DMGhawkb)
    
    set d=R2I(udg_HawkDmg[id])
    
    
    call CreateTextTagUnitBJ(I2S(d), k, - 150, 10 + ( hawkspeed[id] / 2 ), 100, 18, 0, 0)
    call SetTextTagPermanent(GetLastCreatedTextTag(), false)
    call SetTextTagLifespan(GetLastCreatedTextTag(), 0.70)
    call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 300.00, angle)
    
    
      set k=null
      set d=0
      set udg_HawkDmg[id]=0
  call EnableTrigger(gg_trg_DMG)
  
endfunction

//===========================================================================
function InitTrig_DMGhawk takes nothing returns nothing
    set gg_trg_DMGhawk=CreateTrigger()
    call TriggerAddCondition(gg_trg_DMGhawk, Condition(function hawkON))
    call TriggerAddAction(gg_trg_DMGhawk, function DMGTA)
endfunction


