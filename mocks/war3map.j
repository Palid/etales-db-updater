//===========================================================================
// Trigger: Henrymeeting
//===========================================================================
function Trig_Henrymeeting_Conditions takes nothing returns boolean
    local unit u= GetTriggerUnit()
    local boolean herook= IsUnitType(u, UNIT_TYPE_HERO) == true
    local boolean status= GetUnitPointValue(u) > 139
    local boolean nokath= s__KatherineAdvice[GetPlayerId(GetOwningPlayer(u))] == false
    local boolean henryo= iveordiscovered == true

    return ( herook and status and nokath and henryo )
endfunction

function Trig_Henrymeeting_Actions takes nothing returns nothing
    call DisableTrigger(gg_trg_Henrymeeting)
    set iveordiscovered=false
    call SetupTextForce()
    
    call DisplayTimedTextToForce(textforce, 8, "|cffffcc00Baron Henry starts talking to you...|r")
    call DisplayTimedTextToForce(textforce, 16, "      First of all, I'm grateful to all warriors those helped Enthashara finding Iveor's nest!")
    call DisplayTimedTextToForce(textforce, 16, "      Indeed, the idea of get Iveor's true form was very good to be real, That's because we are dealing ")
    call DisplayTimedTextToForce(textforce, 16, "      with a superior entity whose existence cannot be understood by common visions about life. (type |cffffcc00-skip|r to skip dialogs)")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Baron Henry says.|r")
    call DisplayTimedTextToForce(textforce, 16, "      Iveor has a divine legacy, He is a god...")
    call DisplayTimedTextToForce(textforce, 16, "      With him there are other gods those are considered world equilibrium protectors; our stories talks")
    call DisplayTimedTextToForce(textforce, 16, "      about a beggining where were seven well known gods: Sun, Moon, Nature, Magic, Lucifer, Satan and Science")
    call DisplayTimedTextToForce(textforce, 16, "      and over them the high one, Kreator... Father of all things.")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Baron Henry says.|r")
    call DisplayTimedTextToForce(textforce, 16, "      These gods some day were common men. They should demonstrate their bravery and integrity")
    call DisplayTimedTextToForce(textforce, 16, "      to be chosen by Kreator and be invested with their divine condition")
    call DisplayTimedTextToForce(textforce, 16, "      Last investment was at the end of the ancient war. 400 years ago a huge incident started by Iveor apparition")
    call DisplayTimedTextToForce(textforce, 16, "      and finished with its destruction by the hand of Ethernal and Calemor, the earth saviors.")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Baron Henry says.|r")
    call DisplayTimedTextToForce(textforce, 16, "      While Calemor disposed his new divine condition, Ethernal was chosen to be the new Nature's Keeper")
    call DisplayTimedTextToForce(textforce, 16, "      Lordfion was chosen to be Lucifer... well known as Omnekron. Kripper was chosen to be the Moonguard")
    call DisplayTimedTextToForce(textforce, 16, "      Avahor was chosen to be the new Magic spirit. Hida, the dragonknight was chosen be Science Pilar")
    call DisplayTimedTextToForce(textforce, 16, "      and finally Sanzero, the warscream was chosen to be new Satan... ")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Baron Henry says.|r")
    call DisplayTimedTextToForce(textforce, 16, "      Only Sun, after being defeated and purged by his acts, got Kreator's favour and kept his investment")
    call DisplayTimedTextToForce(textforce, 16, "      Our fears starts here. Last Iveor aparition was made by the fusion of Sun and Satan...")
    call DisplayTimedTextToForce(textforce, 16, "      These events say that the evil inside Sun was never erased completely, and finally He")
    call DisplayTimedTextToForce(textforce, 16, "      convinced Sanzero to enter into a new fusion...")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Baron Henry says.|r")
    call DisplayTimedTextToForce(textforce, 16, "      I can't understand why...")
    call DisplayTimedTextToForce(textforce, 16, "      Why again?... Is this Iveor same as the horrible spirit that provoked ancient war?")
    call DisplayTimedTextToForce(textforce, 16, "      Why Sun fell into the darkness again? He knew Kreator's wrath...")
    call DisplayTimedTextToForce(textforce, 16, "      why Sanzero followed him...")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Elrus Skraven interrupts...|r")
    call DisplayTimedTextToForce(textforce, 16, "      Hero, we have only one way to decipher this mistery..")
    call DisplayTimedTextToForce(textforce, 16, "      The old knowledge told us that there were ceremonials events named <<Ejio versals>> practiced by our ancestors")
    call DisplayTimedTextToForce(textforce, 16, "      Better known as gods meetings, an instance where humans can talk with gods, We must call an Ejio versal")
    call DisplayTimedTextToForce(textforce, 16, "      and ask them directly why all these events are happening...")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Bernard Berger adds:|r")
    call DisplayTimedTextToForce(textforce, 16, "      We will require your help.")
    call DisplayTimedTextToForce(textforce, 16, "      Our suspects about movements on Serantas seem to be in the right way")
    call DisplayTimedTextToForce(textforce, 16, "      They are not related to Iveor actions, indeed the warning about Serantas came")
    call DisplayTimedTextToForce(textforce, 16, "      not from our agents into Blackhand...")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Bernard Berger adds:|r")
    call DisplayTimedTextToForce(textforce, 16, "      Our contact, Captain Drako told us that the messenger was a close relative servant of Iveor")
    call DisplayTimedTextToForce(textforce, 16, "      The advice arrived us just after the news about the undead occupation on Coldream access")
    call DisplayTimedTextToForce(textforce, 16, "      I can't believe this fact but all these things say that Iveor is trying to tell us")
    call DisplayTimedTextToForce(textforce, 16, "      something very important and we cannot explain what is that...")
    call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Baron Henry adds:|r")
    call DisplayTimedTextToForce(textforce, 16, "      Son, the bad news is that there exist only one place that can receive an Ejio versal")
    call DisplayTimedTextToForce(textforce, 16, "      It's located where the ancient war ended, into the gardens of death.... on Serantas.")
    call DisplayTimedTextToForce(textforce, 16, "      As we can see everything indicates that our forces must reach Serantas land")
    call DisplayTimedTextToForce(textforce, 16, "      We dont know who or what are triggering these movements warned by Iveor...")
   call TriggerSleepAction(16)
     call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Baron Henry adds:|r")
    call DisplayTimedTextToForce(textforce, 16, "      The city of Varanger on winter lands became our basement for army actions ")
    call DisplayTimedTextToForce(textforce, 16, "      From here the waypass to Serantas has been fortified and guarded to prevent new intrusions ")
    call DisplayTimedTextToForce(textforce, 16, "      You and your friends must travel to Varanger...we will mail orders to General Valan")
    call DisplayTimedTextToForce(textforce, 16, "      Who's in charge of Varanger forces to bring you all the help required.")
   call TriggerSleepAction(16)
    call DisplayTimedTextToForce(textforce, 16, "|cffffcc00Elrus Skraven interrupts again...|r")
    call DisplayTimedTextToForce(textforce, 16, "      Hero, before you travel to Varanger..")
    call DisplayTimedTextToForce(textforce, 16, "      your first step is talk with the Oracle")
    call DisplayTimedTextToForce(textforce, 16, "      he will tell you what to do when reached garden of death ")
    call DisplayTimedTextToForce(textforce, 16, "      He knows how to call an Ejio Versal...")
    call TriggerSleepAction(16)
   
   
   call StartSound(bj_questUpdatedSound)
   
    call QuestMessageBJ(bj_FORCE_ALL_PLAYERS, bj_QUESTMESSAGE_DISCOVERED, "|cffcccc00WORLD QUEST UPDATE|r: Iveor's Destiny")
    call QuestMessageBJ(bj_FORCE_ALL_PLAYERS, bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00Start a new Ejio Versal. ")
    call QuestMessageBJ(bj_FORCE_ALL_PLAYERS, bj_QUESTMESSAGE_DISCOVERED, "          |cff888888- Travel to Varanger and meets General Valan. ")
    call QuestMessageBJ(bj_FORCE_ALL_PLAYERS, bj_QUESTMESSAGE_DISCOVERED, "          |cff888888- Talk with Oracle about Ejio Versal requirements. ")
    call FlashQuestDialogButton()
   
     call QuestItemSetCompleted(iveordi, true)
     set iveordia=CreateQuestItemBJ(iveordq, "Travel to Varanger and meets |cffffcc00General Valan|r.")
     set iveordib=CreateQuestItemBJ(iveordq, "Find and Ask to the Oracle about Ejio Versal requirements")

   
   
   

 set Oracletalk=true
 set Valanmeets=true
   call EnableTrigger(gg_trg_valanmeet)
   call EnableTrigger(gg_trg_oracletalk)
   
  // call QuestSetDiscovered(katherinneq, true )
 //  set KatherineAngry = true


endfunction

