function InitTrig_ScorpionKingDie takes nothing returns nothing
    set gg_trg_ScorpionKingDie=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_ScorpionKingDie, gg_unit_U00O_0266, EVENT_UNIT_DEATH)
    call TriggerAddAction(gg_trg_ScorpionKingDie, function Trig_ScorpionKingDie_Actions)
endfunction


