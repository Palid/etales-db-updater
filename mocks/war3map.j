//===========================================================================
// Trigger: cursedlady
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function crsdlyc takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I00G' )
endfunction

function crsdlya takes nothing returns nothing
 local integer Qid= GetUnitUserData(cursedlady)
 local real x= 0
 local real y= 0
 local real f= 100
local integer id= GetPlayerId(GetOwningPlayer(spiderkiller))

          call DisableTrigger(gg_trg_cursedlady)
          call DestroyTrigger(gg_trg_warning)
               if ( GetLocalPlayer() == Player(id) ) then
                call ClearTextMessages()
            endif
            call UpdatePersQuest(id , Qid , 0 , "Erudito's Potion" , null , null)
            call RemoveQuestFromPlayer(Qid , id)
             call UpdatePersQuest(id , Qid , 0 , "Erudito's Potion" , null , null)
            call StartSound(bj_questCompletedSound)
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00PERSONAL QUEST FINISHED|r")
            call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, "Erudito's Potion")
            call UnitRemoveAbility(cursedlady, 'Awan')
            call SetUnitMoveSpeed(cursedlady, 140)
            //call IssueTargetOrder(cursedlady,"follow",spiderkiller)
                        
            call TriggerSleepAction(4)
            call UnitChat("(...she drinks the potion)" , cursedlady)
            call TriggerSleepAction(3)
            call SetUnitMoveSpeed(cursedlady, 0)

            call SetUnitAnimationByIndex(cursedlady, 5)
           // call PauseUnit(spiderkiller,true)
            call SetUnitFacingToFaceUnitTimed(spiderkiller, cursedlady, 0)
            call UnitChat("...snif..." , cursedlady)
            call TriggerSleepAction(2)
            call UnitChat("...I'm dreaming?..." , cursedlady)
            call TriggerSleepAction(2)
            call UnitChat("calm down... I'm here" , spiderkiller)
            call TriggerSleepAction(3)
            call UnitChat("what's your name" , spiderkiller)
            call TriggerSleepAction(3)
            call UnitChat("...My...My name is Darla" , cursedlady)
            call TriggerSleepAction(4)
             call UnitChat("What happens to you Darla??" , spiderkiller)
            call TriggerSleepAction(3)
            call UnitChat("...I...I don't know" , cursedlady)
            call TriggerSleepAction(3)
            call UnitChat("...I just stayed close to the river, south of Valdivia" , cursedlady)
            call TriggerSleepAction(4)
            call UnitChat("...A nice guy came to me" , cursedlady)
            call TriggerSleepAction(3)
            call UnitChat("...He looked me, and then" , cursedlady)
            call TriggerSleepAction(3)
            call UnitChat("...He said some unknown words" , cursedlady)
            call TriggerSleepAction(3)
            call UnitChat("...I was paralyzed" , cursedlady)
            call TriggerSleepAction(6)
            call UnitChat("...He kissed me and then I cannot remember anything" , cursedlady)
            call TriggerSleepAction(4)

            call UnitChat("Do you know that guy??" , spiderkiller)
            call TriggerSleepAction(3)
            call UnitChat("...No, He just appeared next to me" , cursedlady)
            call TriggerSleepAction(4)
            call PlaySoundOnUnitBJ(gg_snd_Tensions, 100, cursedlady)
            call UnitChat("...Then, the pain" , cursedlady)
            call TriggerSleepAction(3)
            call UnitChat("...NO!" , cursedlady)
            call TriggerSleepAction(2)
            call UnitChat("...NO! the pain is comming!!!" , cursedlady)
            call TriggerSleepAction(1.5)
            call UnitChat("...NO! NO!!!" , cursedlady)
            call TriggerSleepAction(1)
            call UnitChat("...AAGGGHHH!!!" , cursedlady)
            call TriggerSleepAction(1)
            set x=GetUnitX(cursedlady)
            set y=GetUnitY(cursedlady)
            call ShowUnit(cursedlady, false)
            call ShowUnit(gg_unit_n05H_0959, true) //ladyegg
            call SetUnitVertexColorBJ(cursedladyegg, 100, 100, 100.00, f)
            call SetUnitPosition(cursedladyegg, x, y)
            loop
            exitwhen f < 1
            call TriggerSleepAction(0.03)
             call SetUnitVertexColorBJ(cursedladyegg, 100, 100, 100.00, f)
            set f=f - 2
            endloop
            call SetUnitUserData(cursedladyegg, id)
          //  call PauseUnit(spiderkiller,false)

            call UnitApplyTimedLifeBJ(2.00, 'BTLF', cursedladyegg)
               
            
endfunction

//===========================================================================
function InitTrig_cursedlady takes nothing returns nothing
    set gg_trg_cursedlady=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_cursedlady, gg_unit_n05C_0662, EVENT_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_cursedlady, Condition(function crsdlyc))
    call TriggerAddAction(gg_trg_cursedlady, function crsdlya)
endfunction


//===========================================================================
// Trigger: spawncursedspider
//===========================================================================
//TESH.scrollpos=21
//TESH.alwaysfold=0
function Trig_spawncursedspider_Actions takes nothing returns nothing
local integer questid= GetUnitUserData(cursedladyegg)
local integer Id= 0
local real speed= 0
local real x= GetUnitX(GetTriggerUnit())
local real y= GetUnitY(GetTriggerUnit())


 call DestroyEffect(AddSpecialEffect(sffectpunch, x, y))
 set spidermonster=CreateUnit(Player(PLAYER_DARK_LORD), 'n05B', x, y, 225)
 set speed=GetUnitDefaultMoveSpeed(spidermonster)
 call SetUnitMoveSpeed(spidermonster, 0)
 call SetUnitAnimationByIndex(spidermonster, 1)
 if ( GetLocalPlayer() == Player(Id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call CameraSetTargetNoiseEx(30 * 2.0, 60 * Pow(10, 4), true)
         call CameraSetSourceNoiseEx(30 * 2.0, 60 * Pow(10, 4), true)
    endif
 call TriggerSleepAction(0.7)
  
  if ( GetLocalPlayer() == Player(Id) ) then
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
    endif
 
    
 call TriggerSleepAction(3)
 call AttachSoundToUnitBJ(gg_snd_spider, spidermonster)
 call StartSound(bj_questDiscoveredSound)
 // if (GetLocalPlayer() == Player(Id)) then
   //       call ClearTextMessages()
  // endif 

   //call DisplayTimedTextToPlayer(Player(Id),0,0,4,"|cffffcc00NEW GLOBAL QUEST|r")
   //call DisplayTimedTextToPlayer(Player(Id),.1,0,4,"DEFEAT THE SPIDER MONSTER!!!")
   
  call DisplayTimedTextToForce(GetPlayersAll(), 6, "|cffffcc00NEW GLOBAL QUEST|r")
  call DisplayTimedTextToForce(GetPlayersAll(), 6, "      DEFEAT THE SPIDER MONSTER!!!")
    
    
  //set questid = SetupQuest(Id,cursedlady,"Defeat the spider monster",null,null,0)
  call ResetUnitAnimation(spidermonster)
  call SetUnitMoveSpeed(spidermonster, speed)
  call SetUnitUserData(cursedlady, questid) //here I can take the quest id.
  call TriggerSleepAction(1)
  call TriggerRegisterUnitEvent(gg_trg_endspider, spidermonster, EVENT_UNIT_DEATH)
  
endfunction

//===========================================================================
function InitTrig_spawncursedspider takes nothing returns nothing
    set gg_trg_spawncursedspider=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_spawncursedspider, gg_unit_n05H_0959, EVENT_UNIT_DEATH)
    call TriggerAddAction(gg_trg_spawncursedspider, function Trig_spawncursedspider_Actions)
endfunction


//===========================================================================
// Trigger: endspider
//===========================================================================
//TESH.scrollpos=33
//TESH.alwaysfold=0
function Trig_endspider_Actions takes nothing returns nothing
local real x= GetUnitX(GetTriggerUnit())
local real y= GetUnitY(GetTriggerUnit())

local real ix= GetUnitX(gg_unit_E00I_2515)
local real iy= GetUnitY(gg_unit_E00I_2515)
local integer f= 100
local integer i= 0
    call TriggerSleepAction(3)
    
    
  call DisplayTimedTextToForce(GetPlayersAll(), 6, "|cffffcc00You listen an unknown voice|r")
  call DisplayTimedTextToForce(GetPlayersAll(), 6, "       ~Did you like my pet?...~")
    call TriggerSleepAction(6)
    
            call ShowUnit(gg_unit_E00I_2515, true) //iveor
            call SetUnitVertexColorBJ(gg_unit_E00I_2515, 100, 100, 100.00, f)
            call SetUnitPosition(gg_unit_E00I_2515, x, y)
            loop
            exitwhen f < 1
            call TriggerSleepAction(0.03)
             call SetUnitVertexColorBJ(gg_unit_E00I_2515, 100, 100, 100.00, f)
            set f=f - 5
            endloop
            
            set f=0
            
  call DisplayTimedTextToForce(GetPlayersAll(), 16, "|cffffcc00You listen an unknown voice|r")
  call DisplayTimedTextToForce(GetPlayersAll(), 16, "       This is only the beginning! UAWAHAHAHAHAHAHAHAAAAaaaa~")
             call TriggerSleepAction(6)
           
           loop
            exitwhen f > 100
            call TriggerSleepAction(0.03)
             call SetUnitVertexColorBJ(gg_unit_E00I_2515, 100, 100, 100.00, f)
            set f=f + 7
            endloop
            
            set f=0
       call ShowUnit(gg_unit_E00I_2515, false)
       call SetUnitPosition(gg_unit_E00I_2515, ix, iy)
      
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffcccc00MAIN QUEST COMPLETED|r")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_COMPLETED, "|cffffcc00 THE CURSED MAIDEN|r: All players got +10000 XP, +1 King Chest")
    call StartSound(bj_questCompletedSound)
    
    loop
    exitwhen i > 8
      
      call UnitAddItem(udg_PHero[i], CreateItem(udg_itmpool[81], GetUnitX(udg_PHero[i]), GetUnitY(udg_PHero[i])))
      call AddHeroXP(udg_PHero[i], 10000, false)
     set i=i + 1
    
    endloop
       
            
   
endfunction

//===========================================================================
function InitTrig_endspider takes nothing returns nothing
    set gg_trg_endspider=CreateTrigger()
    call TriggerAddAction(gg_trg_endspider, function Trig_endspider_Actions)
endfunction


//===========================================================================
// Trigger: arcanistlibrary
//===========================================================================
//TESH.scrollpos=54
//TESH.alwaysfold=0
//===========================================================================
// Trigger: meetArcanist
//===========================================================================
//TESH.scrollpos=233
//TESH.alwaysfold=0
function Trig_meetArcanist_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and arcanistteach[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == false
endfunction

function ThrowJoke takes unit ear returns nothing
local integer i= GetRandomInt(0, 6)
local integer id= GetPlayerId(GetOwningPlayer(ear))
if i == 0 then
  call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
  call PlaySoundOnUnitBJ(gg_snd_drunkwhat, 100, Arcanist)
  call TriggerSleepAction(1.1)
   call SetUnitAnimation(Arcanist, "stand")
 
elseif i == 1 then
  call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
  call PlaySoundOnUnitBJ(gg_snd_arcanistjoke1, 100, Arcanist)
  call TriggerSleepAction(4.0)
   call SetUnitAnimation(Arcanist, "stand")
elseif i == 2 then
   call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
  call PlaySoundOnUnitBJ(gg_snd_arcanistjoke6, 100, Arcanist)
  call TriggerSleepAction(2.6)
   call SetUnitAnimation(Arcanist, "stand")
elseif i == 3 then
   call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
  call PlaySoundOnUnitBJ(gg_snd_arcanistjoke2, 100, Arcanist)
  call TriggerSleepAction(15.4)
   call SetUnitAnimation(Arcanist, "stand")
elseif i == 4 then
   call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
  call PlaySoundOnUnitBJ(gg_snd_arcanistjoke3, 100, Arcanist)
  call TriggerSleepAction(2.3)
   call SetUnitAnimation(Arcanist, "stand")
elseif i == 5 then
   call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
  call PlaySoundOnUnitBJ(gg_snd_arcanistjoke5, 100, Arcanist)
  call TriggerSleepAction(3.6)
   call SetUnitAnimation(Arcanist, "stand")
elseif i == 6 then
   call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
   call PlaySoundOnUnitBJ(gg_snd_arcanistjoke4, 100, Arcanist)
   call TriggerSleepAction(5.1)
   call SetUnitAnimation(Arcanist, "stand")
endif

  call PlaySoundOnUnitBJ(gg_snd_laugh, 100, ear)
  call TriggerSleepAction(23)
endfunction


function Trig_meetArcanist_Actions takes nothing returns nothing
  local real tday= GetFloatGameState(GAME_STATE_TIME_OF_DAY)
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local integer questid
  call DisableTrigger(gg_trg_meetArcanist)
  
  if tavernhour == true then
     call ThrowJoke(udg_PHero[id])
  elseif arcanistgotav == true then
   call TriggerSleepAction(1)
    if not ( arnistadviced[id] == false ) then
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Baldfor says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    If you wanna collect bottles, the tavern is the best place!")
        call TriggerSleepAction(3)
    endif
   
   elseif arcanistreturning == true then
   call TriggerSleepAction(1)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    It's too late boy, what are you doing at this hour here... go to sleep!!")
   call TriggerSleepAction(5)
  elseif arcanistsleep == true then
   call TriggerSleepAction(1)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, " You listen the dwarf:|r zzZZzzZZzzzZZZZZzz")
   call TriggerSleepAction(5)
  elseif tday > 6.0 and tday < 16.0 then
   call PlaySoundOnUnitBJ(gg_snd_arcanebusyb, 100, Arcanist)
   call TriggerSleepAction(1)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Dwarf says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    I'm a lot busy at this moment, come back at 16:00 with some coal!")
   set arnistadviced[id]=true
   call TriggerSleepAction(10)
  elseif arnistadviced[id] == false then
   set arcanistattend=true
   call PlaySoundOnUnitBJ(gg_snd_arcanebusyb, 100, Arcanist)
   call TriggerSleepAction(1)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Dwarf says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    ejhmmm? who goes there")
   set arnistadviced[id]=true
   call TriggerSleepAction(10)
   set arcanistattend=false
  elseif arcanistready[id] == true and GetIndexItemOfType(udg_PHero[id] , 'I0FH') > 0 then
   set arcanistattend=true
   call TriggerSleepAction(1)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Hey Ron, look! I have a bottle filled with sublime fire")
   call TriggerSleepAction(5)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Yeah, you did it, Well done |cffaaaaaa(He looks you with no surprise..)|r")
   call MakeFaceToUnit(Arcanist , udg_PHero[id])
   call TriggerSleepAction(6)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "You examine the bottle in detail, the flame looks alive")
   call TriggerSleepAction(5)
      call StartSound(bj_questUpdatedSound)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "You get +1643 XP")
      call AddHeroXP(udg_PHero[id], 1643, true)
   call TriggerSleepAction(6)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    Those fire are useless in your hands, they need to iluminate the darkness")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    Night time is perfect to see them in action. ")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    Reinhard asked me how we could act against some minor inconvenience.")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    The answer is those fires, Have you seen some lantern posts around velhilmen?.")
   call TriggerSleepAction(13)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Yeah, I noticed them, I didn't recognize their use")
   call TriggerSleepAction(6)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    Well, your next job is enlighten them. ")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    I've made a deal with Reinhard, He will give you |cffffcc00+rep|r for each")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    activated lantern, of course I'll get some good beer in change")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    I think it's a very good deal... Right boy?")
   call TriggerSleepAction(13)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "    Aye sir!")
   call TriggerSleepAction(3)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00QUEST UPDATED|r: |cffffcc00ENLIGHTEN LANTERNS|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "     Find and put sublime fire on any lantern post located around Velhilmen")
   set questid=LoadInteger(udg_cache, GetHandleId(Arcanist), GetHandleId(udg_PHero[id]))
   call UpdatePersQuest(id , questid , Qdata[questid] , "Put sublime fires on any lantern post in Velhilmen" , "-" , "-")
  
  call StartSound(bj_questDiscoveredSound)
   
   set arcanistattend=false
  
  elseif arcanistready[id] == true then
   set arcanistattend=true
   call TriggerSleepAction(1)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Hey boy, how is it going there?, Did you find the items?")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    Remember you need to put in that stove collected emerald fragments,")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    a piece of meat, a coal stone and an empty glass bottle...")
   call TriggerSleepAction(11)
   set arcanistattend=false
  
  else
   set arcanistattend=true
   call PlaySoundOnUnitBJ(gg_snd_arcanisthello, 100, Arcanist)
   call MakeFaceToUnit(Arcanist , udg_PHero[id])
   call SetUnitAnimation(gg_unit_h03S_0435, "stand")
   call TriggerSleepAction(1)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Dwarf says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Hello boy, tell me what are you doing here?")
   call TriggerSleepAction(6)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Hi, You told me to come at night")
   call TriggerSleepAction(5)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00Dwarf says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "    Me, really? |cffaaaaaa(He doesn't remembers you)|r")
   call TriggerSleepAction(6)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Yeah, you said something related to coal stones")
   call TriggerSleepAction(5)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Dwarf says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Oh, I see...")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    then your help is welcome here, I'm |cffffcc00Ron|r, |cffffcc00Ron Baldfor|r, Kingdom Emisary Arcanist")
   call TriggerSleepAction(7)
   
    set arcanistteach[id]=true
    set arcanistattend=false
    call EnableTrigger(gg_trg_meetArcanist)
   
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Nice to meet you Ron, Do you have something in change of my help?")
   call TriggerSleepAction(6)
   call MakeFaceToUnit(Arcanist , udg_PHero[id])
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Well...")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    I don't own any kind of reward, boy... ")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Let me explain it, I'm here by Reinhard request. I don't have personal interests involved")
   call TriggerSleepAction(8)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 3.5, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 3.5, "    Excuse me sir, I wasn't trying to bother you")
   call TriggerSleepAction(4)
   call MakeFaceToUnit(Arcanist , udg_PHero[id])
   call PlaySoundOnUnitBJ(gg_snd_arcanisttroll, 100, Arcanist)
   call TriggerSleepAction(3)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    jajajaja my beard's itchiness upsets me more than your questions boy,")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Don't worry about that, I need you do some watchman work")
   call TriggerSleepAction(7)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 2, "    Aha, tell me")
   call TriggerSleepAction(3)
   call MakeFaceToUnit(Arcanist , udg_PHero[id])
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    Look...")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    First of all we need some materials to make special luminaries, you must collect at least")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    a |cffffcc00coal stone|r, an |cffffcc00emerald fragment|r, an |cffffcc00animal grease|r ")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    and the most important piece: an |cffffcc00empty glass bottle|r")
   call TriggerSleepAction(12)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    coal can be found in underground places, animals flesh contains enough grease for the formula.")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "    These items compounded plus some arcanist secrets can build a |cffffcc00Sublime fire|r on its basic form")
   call TriggerSleepAction(11)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "    Sublime fire?")
   call TriggerSleepAction(4)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    Yes boy, a kind of fire that can reveals spiritual things")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    The legendary arcane spires are sublime fires on its advanced form")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    My old ancestors told us through dwarf poems that there were sublime fires")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 12, "    on its ultimate form but I never saw them in this era")
   call TriggerSleepAction(13)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00You:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Wow, that's a nice story")
   call TriggerSleepAction(5)
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "|cffffcc00Baldfor says:|r")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    Yeah...")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    a beautyful poem...")
   call TriggerSleepAction(3)
   call MakeFaceToUnit(Arcanist , udg_PHero[id])
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    Come on, let's go to collect those items.")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    My arcanist stove is ready to receive the parts")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 11, "    If we obtain sublime fires I can tell Reinhard to give you some reputation")
   call TriggerSleepAction(13)
   set arcanistteach[id]=false
   set arcanistready[id]=true
          set questid=SetupQuest(id , Arcanist , "FILL A BOTTLE OF SUBLIME FIRE" , "Put coal stone, emerald fragment, meat and bottle on the stove" , "-" , "-" , 0 , s__qty[3])
          call SaveInteger(udg_cache, GetHandleId(Arcanist), GetHandleId(udg_PHero[id]), questid)
          set Qrequ[questid]=4
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "|cffffcc00NEW QUEST ENABLED|r: |cffffcc00FILL A BOTTLE OF SUBLIME FIRE|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 10, "     Find and put 1 coal stone, 1 emerald fragment, 1 meat and 1 clean bottle on the stove")
          call StartSound(bj_questDiscoveredSound)
   call SetUnitFacing(Arcanist, 90)
   call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
   call TriggerSleepAction(11)
   
  endif
 
call TriggerSleepAction(1)
call EnableTrigger(gg_trg_meetArcanist)

endfunction

//===========================================================================
function InitTrig_meetArcanist takes nothing returns nothing
    set gg_trg_meetArcanist=CreateTrigger()
    call TriggerRegisterUnitInRange(gg_trg_meetArcanist, gg_unit_h03S_0435, 256, null)
    call TriggerAddCondition(gg_trg_meetArcanist, Condition(function Trig_meetArcanist_Conditions))
    call TriggerAddAction(gg_trg_meetArcanist, function Trig_meetArcanist_Actions)
    
    call SetUnitAnimationByIndex(gg_unit_h03S_0435, 2)
    
endfunction


//===========================================================================
// Trigger: arcanisttaver
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_arcanisttaver_Actions takes nothing returns nothing
  loop
  exitwhen arcanistattend == false
     call TriggerSleepAction(1)
  endloop
  set arcanistgotav=true
  call SetUnitPosition(Arcanist, GetRectCenterX(gg_rct_arcan2out), GetRectCenterY(gg_rct_arcan2out))
  call TriggerSleepAction(0.4)
  call IssuePointOrder(Arcanist, "move", GetRectCenterX(gg_rct_veltab2in), GetRectCenterY(gg_rct_veltab2in))
  
    call EnableTrigger(gg_trg_arcaentertav)
    call EnableTrigger(gg_trg_arcaniststop)
  
endfunction

