//===========================================================================

function fevent takes nothing returns nothing
local integer index= 0
 
  set KillGnollAssasins=CreateTrigger()
  set killranging=CreateTrigger()

  loop
        call TriggerRegisterPlayerUnitEvent(KillGnollAssasins, Player(index), EVENT_PLAYER_UNIT_DEATH, Condition(function bool))
        call TriggerRegisterPlayerUnitEvent(killranging, Player(index), EVENT_PLAYER_UNIT_DEATH, Condition(function bool))
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
  endloop
    
  call TriggerAddCondition(KillGnollAssasins, Condition(function KillGnollAssasinsC))
  call TriggerAddCondition(killranging, Condition(function rangingc))
 
   call TriggerAddAction(KillGnollAssasins, function KillGnollAssasinsA)
   call TriggerAddAction(killranging, function ranging)

  
endfunction

