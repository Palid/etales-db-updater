function releasejewelB takes integer id returns nothing

    call RemoveItemFromStock(udg_MAVault[id], 'I0MJ')
    call AddItemToStock(udg_MAVault[id], 'I0MJ', onix[id], onix[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0MK')
    call AddItemToStock(udg_MAVault[id], 'I0MK', rubi[id], rubi[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0ML')
    call AddItemToStock(udg_MAVault[id], 'I0ML', diamond[id], diamond[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0MM')
    call AddItemToStock(udg_MAVault[id], 'I0MM', emerald[id], emerald[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0MN')
    call AddItemToStock(udg_MAVault[id], 'I0MN', saphire[id], saphire[id])
    
    call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
    call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
    
    
    
endfunction

function SetupTextForce takes nothing returns nothing
    local integer i= 0
    
    call ForceClear(textforce)
    loop
     exitwhen i > 8
          if GetPlayerSlotState(Player(i)) == PLAYER_SLOT_STATE_PLAYING then
             call ForceAddPlayer(textforce, Player(i))
          endif
     set i=i + 1
     endloop
 

endfunction



function SetupReward takes unit hero,integer level,integer reward returns integer
   local integer herolevel= GetHeroLevel(hero)
   local integer eqlvl= 0
   local integer equip= 0
   local integer amount= 0
   
   
       if reward == 0 then //gold
        set amount=GetRandomInt(1, 99) + herolevel * level * 3
   elseif reward == 1 then //exp
        set amount=herolevel * level
   elseif reward == 2 then //gems
        set amount=1 + R2I(( herolevel * level ) / 600)
   elseif reward == 3 then //equipment
   
       
     if GetRandomInt(1, 10) > 5 then
          set eqlvl=1 + ( herolevel / 20 )
          set equip=s__equipmentlvl[(eqlvl)*(7)+GetRandomInt(1, 6)]
          set amount=GetRandomInt(equip, equip + 12)
     else
     
          set eqlvl=herolevel / 8
          set amount=s__weaponlvl[(eqlvl)*(43)+GetRandomInt(1, s__weaponsize[eqlvl])]
     endif
        
   endif
   
   
   return amount

endfunction



function GiveReward takes integer id,integer amount,integer reward returns string
 local integer i= 0
 local integer subamount= 0
 local integer rest= amount
 local item it= null
 
       if reward == 0 then //gold
        call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) + amount)
        return I2S(amount) + " gold coins"
   elseif reward == 1 then //exp
   
        call AddHeroXP(udg_PHero[id], amount, false)
        return I2S(amount) + " experience"
        
   elseif reward == 2 then //gems
    
    
      call sequencer(5)
       
       
      loop
      exitwhen i > 4
      
      set s__jewelreward[seq[i]]= 0
      set subamount=GetRandomInt(0, rest / 2)
      set s__jewelreward[seq[i]]= subamount
      set rest=rest - subamount
      set i=i + 1
      endloop
      
      set s__jewelreward[seq[5]]= 0
      set s__jewelreward[seq[5]]= rest

      
       set onix[id]=onix[id] + s__jewelreward[0]
         
       set rubi[id]=rubi[id] + s__jewelreward[1]
    
       set diamond[id]=diamond[id] + s__jewelreward[2]
   
       set emerald[id]=emerald[id] + s__jewelreward[3]

       set saphire[id]=saphire[id] + s__jewelreward[4]
     
       set GemVar_A[id]=GemVar_A[id] + s__jewelreward[5]
       call releasejewelB(id)
       
       return "+" + I2S(s__jewelreward[0]) + " onixs, +" + I2S(s__jewelreward[1]) + " rubies, +" + I2S(s__jewelreward[2]) + " diamonds, +" + I2S(s__jewelreward[3]) + " emeralds, +" + I2S(s__jewelreward[4]) + " saphires, +" + I2S(s__jewelreward[5]) + " pvp gems"
         
   elseif reward == 3 then //equipment
   
       set it=CreateItem(udg_itmpool[amount], GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id]))
       call UnitAddItem(udg_PHero[id], it)
       set it=null
       return GetObjectName(udg_itmpool[amount])
   endif
   
   set Reputation[id]=Reputation[id] + GetRandomInt(3, 7)
   return null
endfunction


function gtrue takes nothing returns boolean
return true
endfunction

function ActivatePquestUnit takes unit u returns nothing
 if GetUnitState(u, UNIT_STATE_LIFE) > 0.404 then
    call UnitAddAbility(u, newquest) //visuals
    call UnitAddAbility(u, 'Apit')
    call UnitAddAbility(u, 'Aneu')
    call UnitAddAbility(u, 'Asid')
    call AddItemToStock(u, 'I08O', 1, 1) //Request
 endif
endfunction

function TravelerKilled takes unit u returns nothing
 local integer questid=LoadInteger(questtm, GetHandleId(u), 1223)
 local integer id= QPid[questid]
   
   call TriggerSleepAction(1)
   call RemoveTraveler(id , u)
   call UnitChat("Aarghhh!!!" , u)
   call MakeFaceToUnit(u , udg_PHero[id])
   call TriggerSleepAction(3)
   call UnitChat("I wish... I had reached my destination but it's too late....." , u)
   call TriggerSleepAction(2)
  if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
  endif
  call StartSound(bj_questFailedSound)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffff0000PERSONAL QUEST FAILED|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Enthashara's Travelers: The traveler has died...")
 
  call UpdatePersQuestND(id , questid , Qdata[questid] , "-" , "-" , "-")
  call TriggerSleepAction(0.02)
  call RemoveQuestFromPlayer(questid , id)
endfunction

function Ishere takes unit u returns nothing
 local integer questid=LoadInteger(questtm, GetHandleId(u), 1223)
 local integer id= QPid[questid]
   
   call SetUnitUserData(u, 0)
   call TriggerSleepAction(2)
   call RemoveTraveler(id , u)
   call UnitChat("Good Job Hero!!!, Finally we are safe now, I can continue alone from here" , u)
   call MakeFaceToUnit(u , udg_PHero[id])
   call TriggerSleepAction(2)
   call UnitChat("Take this for your services" , u)
   call TriggerSleepAction(1)
  if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
  endif
  call StartSound(bj_questCompletedSound)
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00PERSONAL QUEST COMPLETED|r")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Enthashara's Travelers: The " + GetUnitName(u) + " traveler gives you |cffffcc00+" + I2S(Qdata[questid]) + "|r gold")
  call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) + Qdata[questid])
  call UpdatePersQuestND(id , questid , Qdata[questid] , "-" , "-" , "-")
  call TriggerSleepAction(0.02)
  call RemoveQuestFromPlayer(questid , id)
  call TriggerSleepAction(20)
  call SetUnitPosition(u, GetUnitX(u) - 1, GetUnitY(u) - 1)
  call UnitAddAbility(u, 'Awan')
  call UnitAddAbility(u, 'Asid')
  call UnitAddAbility(u, 'Aneu')
  call UnitAddAbility(u, 'Apit')
  call EnableTrigger(LoadTriggerHandle(questtm, GetHandleId(u), 15))
  
  

endfunction



function Pquesthero takes nothing returns boolean
if ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetPlayerController(GetOwningPlayer(GetTriggerUnit())) == MAP_CONTROL_USER ) then
 call ExecuteFunc("Pquestactions")
endif
   return false
endfunction


function Pquestactions takes nothing returns nothing

  local trigger Pquesttrg= GetTriggeringTrigger()
  local unit qu= LoadUnitHandle(questtm, GetHandleId(Pquesttrg), 0)
  local unit u= GetTriggerUnit()
  local integer id= GetPlayerId(GetOwningPlayer(u))
  local unit rmte= null
  local item it= null
  local integer questid
  
  call DisableTrigger(Pquesttrg)
  
  if ( GetUnitState(qu, UNIT_STATE_LIFE) > 0.405 ) then
  
  if GetUnitUserData(qu) != 1320 and GetRandomInt(0, 2) != 2 then // old GetRandomInt(0,5)!=5 then
 
  if GetUnitState(qu, UNIT_STATE_LIFE) > 0.405 then
      call UnitChat("Hello..." , qu)
      call MakeFaceToUnit(qu , u)
  endif

  set qu=null
  set u=null
  set it=null
  set rmte=null
  call TriggerSleepAction(45)
  call EnableTrigger(Pquesttrg)
  set Pquesttrg=null

  return
  endif
  
  call TriggerSleepAction(1)
  call UnitChat(s__rescuedsh[GetRandomInt(1, 11)] , qu)
  call MakeFaceToUnit(qu , u)
  call TriggerSleepAction(1)
  
  if GetUnitUserData(qu) == 1320 then //unit marked as mail destination
     set it=LoadItemHandle(questtm, GetHandleId(qu), StringHash("delivery"))
     if UnitHasItem(u, it) == true then
     
     call SetUnitUserData(qu, 0)
     call TriggerSleepAction(3)
     call UnitChat("What, you have an entrustment for me??" , qu)
     call MakeFaceToUnit(qu , u)
     call TriggerSleepAction(3)
     call UnitChat("Nice!!, finally it's here" , qu)
     call MakeFaceToUnit(qu , u)
     call TriggerSleepAction(2)
     call UnitChat("Thanks for your services mate, take this for the good work!!" , qu)
     call MakeFaceToUnit(qu , u)
     call TriggerSleepAction(3)
     
     
    
     set questid=LoadInteger(questtm, GetHandleId(it), 1321)
     
      if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
      endif
      call StartSound(bj_questCompletedSound)
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00PERSONAL QUEST COMPLETED|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Mail Service: The " + GetUnitName(qu) + " gives you |cffffcc00+" + I2S(Qdata[questid]) + "|r gold")
      call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) + Qdata[questid])
      call UpdatePersQuestND(id , questid , Qdata[questid] , "-" , "-" , "-")
     call TriggerSleepAction(0.02)
      call RemoveQuestFromPlayer(questid , id)
      call FlushChildHashtable(questtm, GetHandleId(it))
      call RemoveItem(it)
      set it=null
                     //=============================
               
    
     endif //item true
   
   call EnableTrigger(Pquesttrg)
   set Pquesttrg=null
   set qu=null
   set u=null
   return
  endif
  call TriggerSleepAction(2)
  call ActivatePquestUnit(qu)
  call UnitShareVision(qu, Player(id), true)
  call SaveTriggerHandle(questtm, GetHandleId(qu), 15, Pquesttrg)
  else
   call EnableTrigger(Pquesttrg)
  endif // GetUnitState(qu,UNIT_STATE_LIFE)>0.405
 
  
 
  set Pquesttrg=null
  set qu=null
  set u=null
  set it=null
  set rmte=null
endfunction



function addwander takes nothing returns nothing
local trigger Pquesttrg= CreateTrigger()
  if ( IsUnitInGroup(GetEnumUnit(), taxbandits) == false ) then
    call UnitAddAbility(GetEnumUnit(), 'Awan')
