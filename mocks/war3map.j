//===========================================================================
// Trigger: chuckdrop
//===========================================================================
function Trig_chuckdrop_Actions takes nothing returns nothing
local destructable d= GetTriggerDestructable()
local integer i= 0
local integer dice= GetRandomInt(1, 3)
local integer f
local integer j= GetRandomInt(0, 3)
  local real x= GetDestructableX(d)
  local real y= GetDestructableY(d)
  
 if j == 2 then
  loop
   exitwhen i > dice
      set f=GetRandomInt(37, 41)
      call CreateItem(udg_itmpool[f], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
   
   set i=i + 1
   endloop
  
endif
set d=null
endfunction

