function movegroup takes integer pid,location p returns nothing

     if ( rescuedscout[pid] != null ) then
             call SetUnitPositionLoc(rescuedscout[pid], p)
     endif
     
     if ( traveler1[pid] != null ) then
        call SetUnitPositionLoc(traveler1[pid], p)
     endif
         if ( traveler2[pid] != null ) then
        call SetUnitPositionLoc(traveler2[pid], p)
     endif
         if ( traveler3[pid] != null ) then
        call SetUnitPositionLoc(traveler3[pid], p)
     endif
         if ( traveler4[pid] != null ) then
        call SetUnitPositionLoc(traveler4[pid], p)
     endif
         if ( cslave[pid] != null and IsUnitHidden(cslave[pid]) == false ) then
        call SetUnitPositionLoc(cslave[pid], p)
     endif
        
         if not ( spiritfollowed == null ) and spiritfollowed == udg_PHero[pid] then
            call SetUnitPositionLoc(natuspirit, p)
      endif
       
      
endfunction

function enterHero takes nothing returns boolean
    return ( IsUnitType(GetEnteringUnit(), UNIT_TYPE_HERO) == true )
endfunction

function boolfil takes nothing returns boolean
return true
endfunction

function setdungeon takes nothing returns nothing
local integer id= LoadInteger(udg_cache, GetHandleId(GetTriggeringRegion()), 0)
local unit u= GetEnteringUnit()
local location p= GetRectCenter(Salida[id])
local integer pid= GetPlayerId(GetOwningPlayer(u))
     
     
     call SetUnitPositionLoc(u, p)
     call SetUnitPositionLoc(udg_Slave[pid], p)
     
     if ( IsUnitHidden(udg_Familiar[pid]) == false ) then
        call SetUnitPositionLoc(udg_Familiar[pid], p)
     endif
     call movegroup(pid , p)

     
     if udg_Hashawk[pid] == true then
          call SetUnitPositionLoc(udg_Hawkarray[pid], p)
     endif
     
     call PanCameraToTimedLocForPlayer(GetOwningPlayer(u), p, 0)
     call RemoveLocation(p)
       set p=null
   // call CameraSetSmoothingFactor( 4.00 )
      if ( udg_rpgc[pid] == true ) then
        call SetCameraTargetControllerNoZForPlayer(GetOwningPlayer(u), udg_PHero[pid], 0.00, 0.00, false)
     
     endif
          call CameraSetSmoothingFactor(4.00)
     //call ResetToGameCameraForPlayer(GetOwningPlayer(u), 0 )   
  set u=null

endfunction

function rundungeon takes integer intro returns nothing
local region rectRegion= CreateRegion()
local region rectRegionO= CreateRegion()
    set entrance=intro
    
    call RegionAddRect(rectRegion, Entrada[entrance])
    call RegionAddRect(rectRegionO, Salida[entrance])
   // call TriggerRegisterEnterRegion(dtr, rectRegion, Condition( function boolfil ) )
    call TriggerRegisterEnterRegion(dtr, rectRegion, null)
    call SaveInteger(udg_cache, GetHandleId(rectRegion), 0, entrance)
  
set rectRegion=null
set rectRegionO=null
endfunction

function dungeons takes nothing returns nothing
local integer i= 1
set dtr=CreateTrigger()
    loop
        exitwhen i > 224
            call rundungeon(i)
            call TriggerSleepAction(0.01)
        set i=i + 1
    endloop
  
 set loadingDisplay="Dungeon entrances ready"
 
 call TriggerAddCondition(dtr, Condition(function enterHero))
 call TriggerAddAction(dtr, function setdungeon)
    
endfunction


