//===========================================================================
// Trigger: orcbacktrack
//===========================================================================
function orcbtc takes nothing returns boolean
    return GetSpellAbilityId() == 'A0EA'
endfunction

function getfilt takes nothing returns boolean
    return true
endfunction



function exebu takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local real face= LoadReal(hts, GetHandleId(t), 1)
local integer dist= LoadInteger(hts, GetHandleId(t), 2)
local real x= GetUnitX(u) + dist * Cos(face * bj_DEGTORAD)
local real y= GetUnitY(u) + dist * Sin(face * bj_DEGTORAD)
local group enemy= LoadGroupHandle(hts, GetHandleId(t), 3)
local group g= CreateGroup()
local unit gu
local boolexpr filter= Condition(function getfilt)
local location q= Location(x, y)
local real dmg


if ( dist > 0 ) then
 set dist=dist - 2
else
 set dist=0
endif
 
 call SaveInteger(hts, GetHandleId(t), 2, dist)

   if ( GetUnitState(u, UNIT_STATE_LIFE) > 0.3 and IsTerrainWalkable(x , y) ) then
 
     call SetUnitPosition(u, x, y)
   
   endif

   call GroupEnumUnitsInRangeOfLoc(g, q, 200, filter)
   call DestroyBoolExpr(filter)
   set filter=null

   loop
  
     set gu=FirstOfGroup(g)
      exitwhen gu == null
    if ( IsUnitInGroup(gu, enemy) != true and IsUnitEnemy(gu, GetOwningPlayer(u)) == true and GetWidgetLife(gu) > 0 ) then
    
     call GroupAddUnit(enemy, u)
  
     call DestroyEffect(AddSpecialEffectTarget(seffect, gu, "chest"))
   
    
     call UnitDamageTarget(u, gu, 3236, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
    endif
   
    call GroupRemoveUnit(g, gu)
    set gu=null
    endloop

 call DestroyGroup(g)
 set g=null

call RemoveLocation(q)
set q=null

call SaveGroupHandle(hts, GetHandleId(t), 3, enemy)


set t=null
set enemy=null

set gu=null
set filter=null
endfunction

function orcbtb takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
local real face= LoadReal(hts, GetHandleId(t), 1)
local integer dist= LoadInteger(hts, GetHandleId(t), 2)
local location p= GetUnitLoc(u)
local real x= GetLocationX(p) + dist * Cos(face * bj_DEGTORAD)
local real y= GetLocationY(p) + dist * Sin(face * bj_DEGTORAD)

local location q= Location(x, y)
local real dmg



if ( dist > 0 ) then
 set dist=dist - 1
else
 set dist=0
endif
 
 call SaveInteger(hts, GetHandleId(t), 2, dist)
 
 if IsTerrainPathable(GetLocationX(q), GetLocationY(q), PATHING_TYPE_WALKABILITY) == false then
 call SetUnitPosition(u, x, y)
 call DestroyEffect(AddSpecialEffect(sffectdusta, x, y))
endif

   


 
call RemoveLocation(p)
set p=null
call RemoveLocation(q)
set q=null


set t=null


endfunction




function orcbta takes nothing returns nothing

 local unit u= GetTriggerUnit()
 local real faceb= GetUnitFacing(u)
 local real face= faceb - 180
 local timer t= (NewTimerEx(0)) // INLINED!!
 local timer ta= (NewTimerEx(0)) // INLINED!!
 local integer dist= 35
 local integer distb=60
 local real x= GetUnitX(u)
 local real y= GetUnitY(u)
 
 local integer a= 0
 local group enemy= CreateGroup()
 local unit ut
 local boolexpr istru= Condition(function istrue)
 
   
   
   call SetUnitVertexColor(u, 255, 255, 55, 140)
   if GetRandomInt(0, 3) == 2 then
     call SetUnitInvulnerable(u, true)
   endif
   
   call SaveUnitHandle(hts, GetHandleId(t), 0, u)
   call SaveReal(hts, GetHandleId(t), 1, face)
   call SaveInteger(hts, GetHandleId(t), 2, dist)
   
   
   


   call SetUnitPathing(u, false)

   
   call TimerStart(t, 0.02, true, function orcbtb)


   call TriggerSleepAction(0.5)

   call PauseTimer(t)
   call FlushChildHashtable(hts, GetHandleId(t))
   call ReleaseTimer(t)
 // call SetUnitAnimationByIndex(u,2)
  call SetUnitPathing(u, true)
  
  loop
  
  exitwhen a == 1
  
  set a=GetRandomInt(1, 4)
  
  if ( a == 1 ) then

   call TriggerSleepAction(0.7)
   call UnitRemoveBuffs(gg_unit_h02T_0468, false, true)
   
   call PauseUnit(u, true)
   call SetUnitTimeScale(u, 1)
   call SetUnitAnimationByIndex(u, 9)
   call TriggerSleepAction(0.05)
   call SetUnitAnimationByIndex(u, 3)
   call UnitAddAbility(u, 'A0EC')

   call TriggerSleepAction(0.2)
   call SetUnitPathing(u, false)
   
   set faceb=GetUnitFacing(u)
   
   call SaveUnitHandle(hts, GetHandleId(ta), 0, u)
   call SaveReal(hts, GetHandleId(ta), 1, faceb)
   call SaveInteger(hts, GetHandleId(ta), 2, distb)
   call SaveGroupHandle(hts, GetHandleId(ta), 3, enemy)
   
   call TimerStart(ta, 0.02, true, function exebu)
  

   call TriggerSleepAction(0.6)
   

   call PauseTimer(ta)
   call PauseUnit(u, false)
   call FlushChildHashtable(hts, GetHandleId(ta))
   call ReleaseTimer(ta)


   
   call SetUnitVertexColor(u, 255, 255, 255, 255)
   call SetUnitPathing(u, true)
   call UnitRemoveAbility(u, 'A0EC')
   call TriggerSleepAction(0.6)
  
   call ReleaseTimer(ta)
  
   
   call TriggerSleepAction(0.6)
   
   call SetUnitAnimation(u, "stand")
   call TriggerSleepAction(0.3)
  
   call IssuePointOrder(u, "attack", x, y)

  
  else
   call TriggerSleepAction(0.3)
   call GroupEnumUnitsInRange(executionershock, x, y, 1100, istru)
   call DestroyBoolExpr(istru)
   set istru=null
   
    if executionershock != null then
        set ut=FirstOfGroup(executionershock)
        call IssuePointOrder(u, "carrionswarm", GetUnitX(ut), GetUnitY(ut))
        call TriggerSleepAction(1.4)
        call PauseUnit(u, true)
        call SetUnitTimeScale(u, 1)
        call SetUnitAnimationByIndex(u, 9)
        if GetUnitState(u, UNIT_STATE_LIFE) > 300000 then
          call TriggerSleepAction(3.6)
        else
          call TriggerSleepAction(2)
        endif
        call PauseUnit(u, false)
    endif
  // call DestroyGroup(executionershock)
  // set executionershock = null
   set ut=null
  endif
  
  endloop
  
 //    call SetUnitVertexColor(u,255,255,55,140)
  call SetUnitInvulnerable(u, false)
  call DestroyGroup(enemy)
  set enemy=null
  
  
   set u=null
  // set enemy = null

   set t=null
   set ta=null


endfunction

