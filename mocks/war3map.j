function ScorpionEnemyfilter takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(gg_unit_U00O_0266)) == true and GetUnitState(GetFilterUnit(), UNIT_STATE_LIFE) > 0.4 )
endfunction

function Scorpionec takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetPlayerController(GetOwningPlayer(GetTriggerUnit())) == MAP_CONTROL_USER //banshee
endfunction


function ScorpionJumpDamage takes unit B,real x,real y returns nothing
local unit gu= null
local boolexpr xfilter= Condition(function ScorpionEnemyfilter)
local real life= 0
local real lifea= 0
local real sdmg= 0
local integer idmg= 0
local group dmgg= CreateGroup()
local integer id= 99

   
	
    call GroupEnumUnitsInRange(dmgg, x, y, 224, xfilter)
    call DestroyBoolExpr(xfilter)
    set xfilter=null

	   loop
	    set gu=FirstOfGroup(dmgg)
		  exitwhen gu == null
			    set id=GetPlayerId(GetOwningPlayer(gu))
                set life=GetUnitState(gu, UNIT_STATE_LIFE)
                set sdmg=life * 0.07 + 1200
                
               // call DisableTrigger(gg_trg_DMG)
                call UnitDamageTarget(B, gu, sdmg, true, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
             //   call EnableTrigger(gg_trg_DMG)
              //  set lifea = GetUnitState(gu,UNIT_STATE_LIFE)
             //   set idmg = R2I(life - lifea)
              //  call RedDmgText(idmg,gu)
               // call shakebattle(id,12,I2R(idmg),gu)
		   
		call GroupRemoveUnit(dmgg, gu)
		set gu=null
		endloop
        

     call DestroyGroup(dmgg)
	 set dmgg=null

endfunction 

function ScAtkCycle takes nothing returns nothing
local timer t= GetExpiredTimer()

local unit B= LoadUnitHandle(AiHash, GetHandleId(t), 1)
local unit gu= LoadUnitHandle(AiHash, GetHandleId(t), 2)
local real delta= LoadReal(AiHash, GetHandleId(t), 3)
local real trazo= LoadReal(AiHash, GetHandleId(t), 4)
local real angle= LoadReal(AiHash, GetHandleId(t), 5)
local real Bx= LoadReal(AiHash, GetHandleId(t), 6)
local real By= LoadReal(AiHash, GetHandleId(t), 7)
local boolean end= LoadBoolean(AiHash, GetHandleId(t), 8)
local real x= Bx
local real y= By

local real xi= LoadReal(AiHash, GetHandleId(t), 9)
local real i= LoadReal(AiHash, GetHandleId(t), 10) + 4
local real height
local real h
local real scale= LoadReal(AiHash, GetHandleId(t), 11) - 0.01
local integer id= 0

 



 // set trazo = trazo * Sin(i* bj_DEGTORAD)  
 
  set xi=xi + trazo
  set height=delta / 2.4
  set h=GetParabolaZ(xi , delta , height)
  
   call SetUnitFlyHeight(B, h, 0)

	set x=x + trazo * Cos(angle * bj_DEGTORAD)
	set y=y + trazo * Sin(angle * bj_DEGTORAD)

          if IsPointInRegion(scorpArea, x, y) then
                call SetUnitX(B, x)
                call SetUnitY(B, y)
                set Bx=x
                set By=y

            endif


    
  if i > 140 then

   
     if end == false then
       set end=true
       call SaveBoolean(AiHash, GetHandleId(t), 8, end)
       // call SetUnitAnimationByIndex(B,2)
     endif
    
   endif

 // set trazo = trazo*0.93

 
 //call SaveReal(AiHash,GetHandleId(t),4,trazo) 
 call SaveReal(AiHash, GetHandleId(t), 6, Bx)
 call SaveReal(AiHash, GetHandleId(t), 7, By)
 call SaveReal(AiHash, GetHandleId(t), 9, xi)
 call SaveReal(AiHash, GetHandleId(t), 10, i)
 call SaveReal(AiHash, GetHandleId(t), 11, scale)
  
  if h < 1 then
      call DestroyEffect(AddSpecialEffect(sffectdusta, Bx, By))
      call DestroyEffect(AddSpecialEffect(terranfx, Bx, By))
      set bj_lastCreatedUbersplat=CreateUbersplat(Bx, By, "THND", 255, 255, 255, 255, false, false)
      call SetUbersplatRenderAlways(bj_lastCreatedUbersplat, true)
      call SetUnitFlyHeight(B, 0, 0)
      call PauseUnit(B, false)
      call SetUnitPropWindow(B, GetUnitDefaultPropWindow(B))
      call SetUnitTimeScale(B, 1)
      call SetUnitPathing(B, true)
      call ScorpionJumpDamage(B , Bx , By)
      //call IssueImmediateOrder(B,"stand")
      call IssueTargetOrder(B, "smart", gu)
      call FlushChildHashtable(AiHash, GetHandleId(t))
      call PauseTimer(t)
      call ReleaseTimer(t)

      set angle=GetUnitFacing(B)
      set i=0
          loop
           exitwhen i > 5
          set x=Bx + 200 * Cos(angle * bj_DEGTORAD)
          set y=By + 200 * Sin(angle * bj_DEGTORAD)
          
          call DestroyEffect(AddSpecialEffect(terranfx, x, y))
          
          set angle=angle - 60
          set i=i + 1
          endloop
      
    //  call ShakeScorpion (id,0.3,4600) 
     // call shakebattle(0,12,4300,B)
      set ScorpionSwp=false
  
  endif

 


set t=null
set B=null
set gu=null

endfunction

function ScorpionAttacks takes unit B,unit gu returns nothing
local real Bx= GetUnitX(B)
local real By= GetUnitY(B)
local real gux= GetUnitX(gu)
local real guy= GetUnitY(gu)

local real x= Bx - gux
local real y= By - guy

local real delta= SquareRoot(x * x + y * y) + 200
local real trazo= delta / 45
local real angle= bj_RADTODEG * Atan2(y, x) - 180
local real xi= 1
local real i= 0
local real sc= 1
local boolean end= false
local timer tatk= (NewTimerEx(0)) // INLINED!!

 call PlaySoundOnUnitBJ(gg_snd_scorj, 100, B)
 call UnitAddAbilityBJ('Amrf', B)
 call UnitRemoveAbilityBJ('Amrf', B)
 call SetUnitTimeScale(B, 1)
 call SetUnitFacing(B, angle)
 call SetUnitAnimationByIndex(B, 2)
 call SetUnitPathing(B, false)
 call SaveUnitHandle(AiHash, GetHandleId(tatk), 1, B)
 call SaveUnitHandle(AiHash, GetHandleId(tatk), 2, gu)
 call SaveReal(AiHash, GetHandleId(tatk), 3, delta)
 call SaveReal(AiHash, GetHandleId(tatk), 4, trazo)
 call SaveReal(AiHash, GetHandleId(tatk), 5, angle)
 call SaveReal(AiHash, GetHandleId(tatk), 6, Bx)
 call SaveReal(AiHash, GetHandleId(tatk), 7, By)
 call SaveBoolean(AiHash, GetHandleId(tatk), 8, end)
 call SaveReal(AiHash, GetHandleId(tatk), 9, xi)
 call SaveReal(AiHash, GetHandleId(tatk), 10, i)
 call SaveReal(AiHash, GetHandleId(tatk), 11, sc)
 call TimerStart(tatk, 0.02, true, function ScAtkCycle)
 call TriggerSleepAction(2)
 set tatk=null

 endfunction

function FindTargetAttack takes unit B,real x,real y returns unit
local unit gu= null
local boolexpr filter= Condition(function ScorpionUfilter)

    set Scorpiongr=CreateGroup()
	
    call GroupEnumUnitsInRange(Scorpiongr, x, y, 1024, filter)
    call DestroyBoolExpr(filter)
    set filter=null

	   loop
	    set gu=FirstOfGroup(Scorpiongr)
		  exitwhen gu == null
			if ( IsUnitEnemy(gu, GetOwningPlayer(B)) == true ) then
                set ctarget=gu //global unit
                call GroupClear(Scorpiongr)
           endif
		   
		call GroupRemoveUnit(Scorpiongr, gu)
		set gu=null
		endloop
     
     call DestroyGroup(Scorpiongr)
	 set Scorpiongr=null

    return ctarget
endfunction 
 


function ScorpionActions takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit B= LoadUnitHandle(AiHash, GetHandleId(t), 1)
    local integer i= LoadInteger(AiHash, GetHandleId(t), 2)
 local integer buf= LoadInteger(AiHash, GetHandleId(t), 3)
    local boolean low= LoadBoolean(AiHash, GetHandleId(t), 4)
 local unit gu= null
 local boolexpr filter= null
 local real dmg= 0
 local real x= GetUnitX(B)
 local real y= GetUnitY(B)
    local unit target= null


  set buf=buf + 1

 if buf > 4 then
   set buf=0
   call UnitRemoveBuffs(B, false, true)
 endif
 
  set i=i + 1
 if i > 64 and ScorpionTg == false and GetUnitFlyHeight(B) < 1 then
 
    if low == true then
       set low=false
       set i=0
       call SaveBoolean(AiHash, GetHandleId(t), 4, low)
    elseif GetUnitStatePercent(B, UNIT_STATE_LIFE, UNIT_STATE_MAX_LIFE) < 33.0 then
       set low=true
       call SaveBoolean(AiHash, GetHandleId(t), 4, low)
    else
       set i=0
    endif
    
    call SaveInteger(AiHash, GetHandleId(t), 2, i)
	set Scorpionevent1=Scorpionevent1 + 1
    set Scorpionevent3=Scorpionevent3 + 1


    set Scorpiongr=CreateGroup()
	set filter=Condition(function Scorpionfilter)
    call GroupEnumUnitsInRange(Scorpiongr, x, y, 1024, filter)
    call DestroyBoolExpr(filter)
    set filter=null

	   loop
	    set gu=FirstOfGroup(Scorpiongr)
		  exitwhen gu == null
			if ( IsUnitEnemy(gu, GetOwningPlayer(B)) == true ) then
                set target=gu
                call GroupClear(Scorpiongr)
           endif
		   
		call GroupRemoveUnit(Scorpiongr, gu)
		set gu=null
		endloop
     
     call DestroyGroup(Scorpiongr)
	 set Scorpiongr=null
     
     if not ( target == null ) then
         call EnableTrigger(gg_trg_ScopionSpawn)
         call DestroyEffect(AddSpecialEffect(sffectdusta, x, y))
         call SetUnitPropWindow(B, 0)
         call IssueTargetOrder(B, "smart", target)
        // call TriggerSleepAction(2)
         set bj_lastCreatedUbersplat=CreateUbersplat(x, y, "THND", 255, 255, 255, 255, false, false)
         call SetUbersplatRenderAlways(bj_lastCreatedUbersplat, true)
                 if GetUnitState(B, UNIT_STATE_LIFE) > 0.4 then
                     call ScorpionAttacks(B , target)
                     set ScorpionSwp=true
                 endif
     else
       call DisableTrigger(gg_trg_ScopionSpawn)
       set Scorpionevent1=Scorpionevent1 - 1
     endif
     
 else // i>32
 
  call FindTargetAttack(B , x , y)
  call IssueTargetOrder(B, "smart", ctarget)
  
 endif
  
  call SaveInteger(AiHash, GetHandleId(t), 2, i)
  call SaveInteger(AiHash, GetHandleId(t), 3, buf)

set B=null
set t=null
set filter=null
set target=null
set ctarget=null


endfunction



function Scorpionea takes nothing returns nothing
 local unit B= gg_unit_U00O_0266
 local integer i= 64
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local boolean low= false
 local integer buf= 0
 local real x= GetUnitX(B)
 local real y= GetUnitY(B)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local integer j= 0
 local real sAng= 0
 local real xd= 0
 local real yd= 0
 local unit dfx

 if ScorpionEng == null then
 call DisableTrigger(ScorpionTrg)
 call EnableTrigger(gg_trg_ScorpionWounded)
 
 call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS, 7, "|cffffcc00" + GetPlayerName(Player(id)) + " says|r: I sense a horrible power hidden here...")
 
 call TriggerSleepAction(3)
 call PlaySoundOnUnitBJ(gg_snd_scorh, 127, B)
 call SaveReal(AiHash, GetHandleId(t), 1, x)
 call SaveReal(AiHash, GetHandleId(t), 2, y)
 call TimerStart(t, 0.08, true, function spawndust)
 
 call TriggerSleepAction(5)
 set bj_lastCreatedUbersplat=CreateUbersplat(x, y, "THND", 255, 255, 255, 255, false, false)
 call SetUbersplatRenderAlways(bj_lastCreatedUbersplat, true)
 call SetUnitTimeScale(B, 0.35)
 call SetUnitAnimationByIndex(B, 11)
 call TriggerSleepAction(0.3)
 call ShowUnit(B, true)
 call DestroyEffect(AddSpecialEffect(dustvfx, x, y))
 call TriggerSleepAction(2)
 call FlushChildHashtable(AiHash, GetHandleId(t))
 call PauseTimer(t)
 call ReleaseTimer(t)
 call SetUnitAnimationByIndex(B, 6)
 

 call TriggerSleepAction(0.8)
 set sAng=GetUnitFacing(B)
 set x=GetUnitX(B)
 set y=GetUnitY(B)
 set xd=x + 100 * Cos(sAng * bj_DEGTORAD)
 set yd=y + 100 * Sin(sAng * bj_DEGTORAD)
 

 call PlaySoundBJ(gg_snd_scorWelcome)
 call TriggerSleepAction(0.6)
 call SetUnitTimeScale(B, 0.2)
 call ShakeScorpionOn(id , 5600)
 set dfx=CreateUnit(Player(12), 'n08X', xd, yd, 270) //enragerunit
 call SetUnitVertexColor(dfx, 127, 127, 127, 48)
 call UnitApplyTimedLife(dfx, 'BTLF', 2)
 
 call TriggerSleepAction(1)
 call ShakeScorpionOff(id)
 

 call StartSound(gg_snd_BansheeIntro)
 
 call SetUnitTimeScale(B, 1)
 call PauseUnit(B, false)
 call SetUnitInvulnerable(B, false)
 call IssueTargetOrder(B, "attack", udg_PHero[id])
 set ScorpionEng=(NewTimerEx(0)) // INLINED!!
 call SaveUnitHandle(AiHash, GetHandleId(ScorpionEng), 1, B)
 call SaveInteger(AiHash, GetHandleId(ScorpionEng), 2, i)
 call SaveInteger(AiHash, GetHandleId(ScorpionEng), 3, buf)
 call SaveBoolean(AiHash, GetHandleId(ScorpionEng), 4, low)
call TimerStart(ScorpionEng, 1, true, function ScorpionActions)
 set B=null
 set dfx=null

else
 set B=null
 set dfx=null
 return
endif


endfunction

