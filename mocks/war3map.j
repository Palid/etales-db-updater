function singlemonster takes unit qgiver,unit qtaker returns nothing

  local integer id= GetPlayerId(GetOwningPlayer(qtaker))
  local integer nrect= LoadInteger(questtm, GetHandleId(qgiver), StringHash("nrect")) + 1
  local integer nplayer= IdPlayerRect[SpawnRectId[nrect]]
  local integer i= CreepIni[nrect] + 1
  local integer j= 0
  local integer k= 0
  local integer maxloc= CreepFin[nrect]
  local integer target= 0
  local integer lvl= GetHeroLevel(qtaker) / 15
  local integer ltr= 0
  local unit u= null
  local real x= 0
  local real y= 0
  local integer questid= 0
  local integer unitId= 0
  local integer count= 0
  local integer rwd= GetRandomInt(0, 3)
  local integer amount= 0
  local string samount= null
  local fogmodifier monfog= null
  local integer l__killer= 0

  
  
        if lvl > 5 then
           set lvl=5
        endif
        
        set ltr=1 + GetRandomInt(lvl, lvl + 1)
  
   call UnitChat("I was pursuing a monster, but I lost myself and monster's track... can you find him by me please?" , qgiver)
   call MakeFaceToUnit(qgiver , qtaker)
  
     
    call TriggerSleepAction(3)
   
   call UnitRemoveAbility(qgiver, 'Awan')
   call UnitRemoveAbility(qgiver, 'Asid')
   call UnitRemoveAbility(qgiver, 'Aneu')
   call UnitRemoveAbility(qgiver, 'Apit')
   call UnitRemoveAbility(qgiver, newquest)
   call RemoveItemFromStock(qgiver, 'I08O')
   
  set target=GetRandomInt(i, maxloc)
  set x=CreepX[target]
  set y=CreepY[target]
 
 
 //  call UnitChat("The group is near here",qgiver)
      
  set k=GetRandomInt(0, 10)

   set u=CreateUnit(Player(nplayer), s__monster[(ltr)*(11)+k], x, y, GetRandomReal(0, 360))
   
   call SetUnitUserData(u, 3713)
   //call SaveInteger(questtm,GetHandleId(u),StringHash("quest"),id+10)
   
  set amount=SetupReward(udg_PHero[id] , GetUnitLevel(u) + 1 , rwd)
  if rwd == 3 then
     set samount=GetObjectName(udg_itmpool[amount])
  else
  
   set samount=I2S(amount)
  endif
  
  
  call UnitChat("A reward of |cffffcc00" + samount + " " + s__rewards[rwd] + "|r  will be received if you kill that " + GetUnitName(u) , qgiver)
   call MakeFaceToUnit(qgiver , qtaker)

   set monfog=CreateFogModifierRadius(Player(id), FOG_OF_WAR_VISIBLE, x, y, 512, true, false)
   call FogModifierStart(monfog)
   call TriggerSleepAction(2)
      if ( GetLocalPlayer() == Player(id) ) then
           call PingMinimapEx(GetUnitX(u), GetUnitY(u), 7, 255, 255, 50, false)
       endif
  // call SaveUnitHandle(questtm, GetHandleId(tx),1,u)
   call TriggerSleepAction(4)

  
   call UnitAddAbility(u, 'A0I5') //hunt mark
   call UnitAddAbility(u, 'Awan')
   call enabledmg(u)
 
       call TriggerSleepAction(1)
    
      
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00NEW PERSONAL QUEST|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Kill a " + GetUnitName(u) + ".")
      set questid=SetupQuest(id , qgiver , "KILLING MONSTERS" , "Find and Kill a " + GetUnitName(u) + "." , "0" , "/" + I2S(1) , 1 , s__qty[0])
         call TriggerSleepAction(2)
         call FogModifierStop(monfog)
         call DestroyFogModifier(monfog)
         set monfog=null
  
  loop
   call TriggerSleepAction(1)
   exitwhen GetUnitState(u, UNIT_STATE_LIFE) < 0.404
  endloop
  
  
  
 
  if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
          
  endif
  call StartSound(bj_questCompletedSound)
  
  set l__killer=LoadInteger(questtm, GetHandleId(u), StringHash("killer")) - 10

   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00FINISHED QUEST|r")
   if l__killer == id then
  
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Good job hero, the monster has been exterminated!!")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    you receive " + GiveReward(id , amount , rwd))
    else
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    Someone has killed the monster... thanks for your effort!!")
   endif
   
  call UpdatePersQuestND(id , questid , count , "-" , I2S(count) , "-")
  call TriggerSleepAction(0.02)
  call RemoveQuestFromPlayer(questid , id)

  
   set u=null
   set samount=null
  set tmpid=20 //no player id
  
  call UnitAddAbility(qgiver, 'Awan')
  call UnitAddAbility(qgiver, 'Asid')
  call UnitAddAbility(qgiver, 'Aneu')
  call UnitAddAbility(qgiver, 'Apit')
  call EnableTrigger(LoadTriggerHandle(questtm, GetHandleId(qgiver), 15))
  
endfunction


//=============GROUP KILL REQUEST===========================

function createhunt takes nothing returns nothing
 local timer t= GetExpiredTimer()
 local integer nrect= LoadInteger(questtm, GetHandleId(t), 0)
 local integer unitslot= LoadInteger(questtm, GetHandleId(t), 1)
 local integer unitId= 0
 local real x= LoadReal(questtm, GetHandleId(t), 2)
 local real y= LoadReal(questtm, GetHandleId(t), 3)
 local integer count= LoadInteger(questtm, GetHandleId(t), 4)
 local integer lvlcount= LoadInteger(questtm, GetHandleId(t), 5)
 local integer nplayer= LoadInteger(questtm, GetHandleId(t), 6)
 local group Hunt= LoadGroupHandle(questtm, GetHandleId(t), 7)
 local integer amount= LoadInteger(questtm, GetHandleId(t), 8) - 1
 local location p= Location(x, y)
 local unit u= null
 
 //call DisplayTimedTextToPlayer(Player(0),0,0,10,"in timer")
  set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
 
   set count=count + 1
 
 set u=CreateUnitAtLoc(Player(nplayer), udg_CreepType[unitId], p, GetRandomReal(0, 359))
 //call DisplayTimedTextToPlayer(Player(0),0,0,10,"This is: "+GetUnitName(u))
 set lvlcount=lvlcount + GetUnitLevel(u)
 call UnitAddAbility(u, 'A0I5') //hunt mark
   call enabledmg(u)
   call GroupAddUnit(Hunt, u)
   
   call SaveInteger(questtm, GetHandleId(t), 4, count)
   call SaveInteger(questtm, GetHandleId(t), 5, lvlcount)
   call SaveInteger(questtm, GetHandleId(t), 8, amount)
  // call SaveGroupHandle(questtm,GetHandleId(u),10,Hunt)
   
   if amount < 1 then
     call PauseTimer(t)
   endif
   
   call RemoveLocation(p)
   set p=null
   set Hunt=null
   set u=null
   set t=null

endfunction



function setuphunt takes nothing returns nothing

call SaveGroupHandle(questtm, GetHandleId(GetEnumUnit()), 10, tmphunt)
call SaveInteger(questtm, GetHandleId(GetEnumUnit()), 11, tmpid + 10)
call SetUnitUserData(GetEnumUnit(), 3711)
endfunction


function huntmover takes nothing returns nothing
  call IssuePointOrder(GetEnumUnit(), "attack", huntx + GetRandomReal(- 150, 150), hunty + GetRandomReal(- 150, 150))
endfunction



function huntmove takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(questtm, GetHandleId(t), 1)
local group g= LoadGroupHandle(questtm, GetHandleId(t), 2)
local real x
local real y

  set x=GetUnitX(u)
  set y=GetUnitY(u)
  set huntx=GetRandomReal(x - 500, x + 500)
  set hunty=GetRandomReal(y - 500, y + 500)
  
  call ForGroup(g, function huntmover)
  
  set u=null
  set g=null
  set t=null

endfunction




function qgroupActions takes unit qgiver,unit qtaker returns nothing

  local integer id= GetPlayerId(GetOwningPlayer(qtaker))
  local integer nrect= LoadInteger(questtm, GetHandleId(qgiver), StringHash("nrect"))
  local integer nplayer= IdPlayerRect[SpawnRectId[nrect]]
  local integer i= CreepIni[nrect] + 1
  local integer j= 0
  local integer k= 0
  local integer maxloc= CreepFin[nrect]
  local integer target= 0
  local unit u= null
  local real x= 0
  local real y= 0
  local real xx= 0
  local real yy= 0
  local integer questid= 0
  local group Hunt= CreateGroup()
  local integer unitslot= 0
  local integer unitId= 0
  local integer maxeasy= LoadInteger(HTcreep, GetHandleId(rects[nrect]), 80)
  local integer maxnorm= LoadInteger(HTcreep, GetHandleId(rects[nrect]), 90)
  local integer maxhard= LoadInteger(HTcreep, GetHandleId(rects[nrect]), 100)
  local integer maxvery= LoadInteger(HTcreep, GetHandleId(rects[nrect]), 110)
  local integer count= 0
  local integer lvlcount= 0
  local integer dispatched= 0
  local integer killed= 0
  local timer t= (NewTimerEx(0)) // INLINED!!
  local timer tx= (NewTimerEx(0)) // INLINED!!
  local real dist= 0
  local integer enough= 20
  local real distance= 1500
  local integer rwd= GetRandomInt(0, 3)
  local integer amount= 0
  local string samount= null
  
  
   call UnitChat("I'm in track of monsters group that I need to dispatch, Do you want to helpme?" , qgiver)
   call MakeFaceToUnit(qgiver , qtaker)
  
     
    call TriggerSleepAction(2)
   
       call AddTraveler(id , qgiver)
        if travelerc[id] > 3 then
          call UnitChat(" You have a lot of people here (+4)" , qgiver)
          call TriggerSleepAction(2)
          call UnitChat(" Please finish your other bussines before" , qgiver)
          call TriggerSleepAction(2)
          call UnitChat("Anyway, I have another things to do" , qgiver)
          
          set t=null
          set tx=null
          set u=null
          call DestroyGroup(Hunt)
          set Hunt=null
          return
        endif
    
    
      call UnitRemoveAbility(qgiver, 'Awan')
      call UnitRemoveAbility(qgiver, newquest)
      call UnitRemoveAbility(qgiver, 'Asid')
      call UnitRemoveAbility(qgiver, 'Aneu')
      call UnitRemoveAbility(qgiver, 'Apit')
      call RemoveItemFromStock(qgiver, 'I08O')
  

  
    //CreepX[i],CreepY[i]
  
  loop
  
  set target=GetRandomInt(i, maxloc)
  set x=CreepX[target]
  set y=CreepY[target]
  set xx=GetUnitX(qtaker) - x
  set yy=GetUnitY(qtaker) - y
  set dist=SquareRoot(xx * xx + yy * yy)
  set enough=enough - 1
  
  
  exitwhen dist > distance
  if enough < 1 then
    set distance=700
    set enough=10
  endif
  
  call TriggerSleepAction(0.02)
  endloop
  
      
  
  
 //  call UnitChat("The group is near here",qgiver)
   
   
  
  set k=GetRandomInt(3, 5)
  
 set unitslot=GetRandomInt(80, maxeasy) + 1
 set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
  
  
//   call DisplayTimedTextToPlayer(Player(0),0,0,10,"("+I2S(unitId)+")")
   
 call SaveInteger(questtm, GetHandleId(t), 0, nrect)
 call SaveInteger(questtm, GetHandleId(t), 1, unitslot)
 call SaveReal(questtm, GetHandleId(t), 2, x)
 call SaveReal(questtm, GetHandleId(t), 3, y)
 call SaveInteger(questtm, GetHandleId(t), 4, count)
 call SaveInteger(questtm, GetHandleId(t), 5, lvlcount)
 call SaveInteger(questtm, GetHandleId(t), 6, nplayer)
 call SaveGroupHandle(questtm, GetHandleId(t), 7, Hunt)
 call SaveInteger(questtm, GetHandleId(t), 8, k)
 
  call TimerStart(t, 0.01, true, function createhunt)
  call TriggerSleepAction(0.5)
 
    
  set unitslot=GetRandomInt(90, maxnorm) + 1
  set k=GetRandomInt(2, 3)
  
   call SaveInteger(questtm, GetHandleId(t), 1, unitslot)
   call SaveInteger(questtm, GetHandleId(t), 8, k)
  
  call TimerStart(t, 0.02, true, function createhunt)
  call TriggerSleepAction(0.5)
  
  

  
   set unitslot=GetRandomInt(100, maxhard) + 1
   set k=GetRandomInt(1, 2)
  
   call SaveInteger(questtm, GetHandleId(t), 1, unitslot)
   call SaveInteger(questtm, GetHandleId(t), 8, k)
  
  call TimerStart(t, 0.03, true, function createhunt)
  call TriggerSleepAction(0.5)
 

  set lvlcount=LoadInteger(questtm, GetHandleId(t), 5)
    set tx=(NewTimerEx(0)) // INLINED!!
  
  // if (GetRandomInt(0,2)==1) then
   set unitslot=GetRandomInt(110, maxvery) + 1
   set unitId=LoadInteger(HTcreep, GetHandleId(rects[nrect]), unitslot)
   set u=CreateUnit(Player(nplayer), udg_CreepType[unitId], x, y, GetRandomReal(0, 360))
   set count=count + 1
   set lvlcount=lvlcount + GetUnitLevel(u)
   call UnitAddAbility(u, 'A0I5') //hunt mark
   call enabledmg(u)
   call GroupAddUnit(Hunt, u)
   call SaveUnitHandle(questtm, GetHandleId(tx), 1, u)
   call TriggerSleepAction(0.1)
 // endif
  
   set count=count + LoadInteger(questtm, GetHandleId(t), 4)
  
   call PauseTimer(t)
   call ReleaseTimer(t)
   set t=null
  
  
   set amount=SetupReward(udg_PHero[id] , lvlcount + 1 , rwd)
   
  if rwd == 3 then
     set samount=GetObjectName(udg_itmpool[amount])
  else
  
   set samount=I2S(amount)
  endif
  
    call UnitChat("I'll pay you with |cffffcc00" + samount + " " + s__rewards[rwd] + "|r when the work be done..." , qgiver)
    call MakeFaceToUnit(qgiver , qtaker)
    call TriggerSleepAction(2)
    call UnitChat("Be careful..." , qgiver)


    set tmpid=id
    set tmphunt=Hunt
 
    call ForGroup(Hunt, function setuphunt)
    
    set tmphunt=null
 
  
     call SaveGroupHandle(questtm, GetHandleId(tx), 2, Hunt)
    
      call TriggerSleepAction(1)
       if ( GetLocalPlayer() == Player(id) ) then
           call PingMinimapEx(GetUnitX(u), GetUnitY(u), 15, 255, 255, 50, false)
       endif
    
      set u=null
        
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00NEW PERSONAL QUEST|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "Help the " + GetUnitName(qgiver) + " to hunt a monster group")
      set questid=SetupQuest(id , qgiver , "HUNTING MISSION" , "Help the " + GetUnitName(qgiver) + " to hunt a monster group" , "0" , "/" + I2S(count) , lvlcount , s__qty[0])
      call SaveInteger(questtm, GetHandleId(Hunt), 1708, questid) //guardo id de quest en el viajero
      call SaveInteger(questtm, GetHandleId(Hunt), 1709, count)
      call SaveInteger(questtm, GetHandleId(Hunt), 1707, dispatched)
      call SaveInteger(questtm, GetHandleId(Hunt), 1706, killed)
      
    // call SetUnitUserData(qgiver,1708)
     call TimerStart(tx, 8, true, function huntmove)
      
      //  if (GetLocalPlayer() == Player(id)) then
      //     call PingMinimapEx(x,y, 7, 255,255,50, false)
      // endif 
  
  loop
   call TriggerSleepAction(2)
   exitwhen FirstOfGroup(Hunt) == null
  endloop
  

  
  call RemoveSavedHandle(questtm, GetHandleId(tx), 1)
  call RemoveSavedHandle(questtm, GetHandleId(tx), 2)
  call FlushChildHashtable(questtm, GetHandleId(tx))
  
   call PauseTimer(tx)
   call ReleaseTimer(tx)
   set tx=null
  

  if ( GetLocalPlayer() == Player(id) ) then
          call ClearTextMessages()
          
  endif
  call StartSound(bj_questCompletedSound)
   
  
  set dispatched=LoadInteger(questtm, GetHandleId(Hunt), 1707) + 1
  set lvlcount=lvlcount + 1
  
  
    call DestroyGroup(Hunt)
  set Hunt=null
  

   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00FINISHED QUEST|r")
  
  if ( I2R(dispatched) / I2R(lvlcount) ) > 0.74 then
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " Good job hero, the gang has been exterminated!, You killed them all!!")
  call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    you receive " + GiveReward(id , amount , rwd))
  //call AddHeroXP(udg_PHero[id], 5000, false)
  else
   if rwd != 3 then
     set amount=R2I(amount * ( I2R(dispatched / lvlcount) ))
   endif
   
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, " Finally, the gang has been exterminated but another people gets in the way. the reward will be proportional as your work")
   call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "    you receive " + GiveReward(id , amount , rwd))
  endif
  
  call UpdatePersQuestND(id , questid , count , "-" , I2S(count) , "-")
  call TriggerSleepAction(0.02)
  call RemoveQuestFromPlayer(questid , id)

  
 
  set tmpid=20 //no player id
  call RemoveTraveler(id , qgiver)
    
  if GetUnitState(qgiver, UNIT_STATE_LIFE) > 0.405 then

  call UnitAddAbility(qgiver, 'Awan')
  call UnitAddAbility(qgiver, 'Asid')
  call UnitAddAbility(qgiver, 'Aneu')
  call UnitAddAbility(qgiver, 'Apit')
  call EnableTrigger(LoadTriggerHandle(questtm, GetHandleId(qgiver), 15))
  endif
  
endfunction
