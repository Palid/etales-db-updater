//===========================================================================
// Trigger: mercenaries
//===========================================================================
function morders takes nothing returns nothing
local timer t= GetExpiredTimer()
local unit u= LoadUnitHandle(questtm, GetHandleId(t), 0)
local integer id= LoadInteger(questtm, GetHandleId(u), 1)
local real face= GetUnitFacing(u)
local real x= GetUnitX(u) + 100 * Cos(face * bj_DEGTORAD)
local real y= GetUnitY(u) + 100 * Sin(face * bj_DEGTORAD)
local real xt
local real yt
local real horizonti= face - 90
local real horizonte= face + 90
local real horizont

   
    if safer[id] == true then
      call IssueImmediateOrder(u, "holdposition")
    elseif IsTerrainWalkable(x , y) then
      call IssueTargetOrder(u, "attack", udg_PHero[id])
    else
        
        set horizont=GetRandomReal(horizonti, horizonte)
        set xt=x + 800 * Cos(horizont * bj_DEGTORAD)
        set yt=y + 800 * Sin(horizont * bj_DEGTORAD)
           
    call IssuePointOrder(u, "blink", xt, yt)
    call TriggerSleepAction(2)
    call IssueTargetOrder(u, "attack", udg_PHero[id])
    endif
   //call DisplayTimedTextToPlayer(Player(0),.1,0,8,"Attacking")
 
set t=null
set u=null

endfunction

function SetupMercenary takes integer idtype,integer mtipo,integer level,integer amount returns unit
local integer spwn= GetRandomInt(1, 3)
set thismerc=CreateUnit(Player(PLAYER_NEUTRAL_PASSIVE), udg_HeroTipe[mtipo], mercx[spwn], mercy[spwn], 270)
call SetHeroLevel(thismerc, level, false)
call SetHeroAgi(thismerc, R2I(amount * pcagi[idtype]), true)
call SetHeroStr(thismerc, R2I(amount * pcstr[idtype]), true)
call SetHeroInt(thismerc, R2I(amount * pcint[idtype]), true)

    if mtipo > 39 then
        call UnitAddAbility(thismerc, 'A089') //battleexpertise
    endif
call UnitAddAbility(thismerc, 'A055') //blackhand
call UnitAddAbility(thismerc, 'A0AR') //blink

call UnitAddItemById(thismerc, 'I0T2') //ogre
call UnitAddItemById(thismerc, 'I0LK') //shell
//call UnitAddItemById(thismerc ,'I05D') //pots
call UnitAddItemById(thismerc, 'I0HC') //dagger
call UnitAddItemById(thismerc, 'I05F') //assasin armor

call SelectHeroSkill(thismerc, bookscode[idtype]) //level 1
call SelectHeroSkill(thismerc, bookscode[idtype]) //level 2
call SelectHeroSkill(thismerc, bookscode[idtype]) //level 3
call SelectHeroSkill(thismerc, bookscode[idtype]) //level 4
call SelectHeroSkill(thismerc, bookscode[idtype]) //level 5

return thismerc
endfunction


function Trig_mercenaries_Actions takes nothing returns nothing
 local integer id= 999
 local integer level= 0
 local integer re= GetRandomInt(1, 160 / udg_totalPlaying)
 local integer i= 0
 local integer tipo= GetRandomInt(1, 8)
 local integer mtipo= 0
 local integer amount= 0
 local timer t= null
 local unit m= null


 local integer questid= 0
 
 //call DisplayTimedTextToPlayer(Player(0),.1,0,8,I2S(re))
 if re == 1 then
  
  set id=User[GetRandomInt(1, udg_totalPlaying)]
    if hasbounty[id] == false then
         set i=GetUnitPointValue(udg_PHero[id]) - 100
       //  call DisplayTimedTextToPlayer(Player(0),.1,0,8,I2S(i))
          if i > 20 then
                
                 set hasbounty[id]=true
                 set amount=10 + GetHeroAgi(udg_PHero[id], true) + GetHeroStr(udg_PHero[id], true) + GetHeroInt(udg_PHero[id], true)
                   //call DisplayTimedTextToPlayer(Player(0),.1,0,8,I2S(amount))
                   set tipo=GetRandomInt(1, 8)
                   if tipo == 5 then //no healer
                    set tipo=6
                   endif
                   if tipo == 3 then //no paladin
                    set tipo=2
                   endif
            set mtipo=( ( i / 10 ) * 10 ) + tipo
          //  call DisplayTimedTextToPlayer(Player(0),.1,0,8,"mtipo "+I2S(mtipo))
            set m=SetupMercenary(tipo , mtipo , GetUnitLevel(udg_PHero[id]) , amount)
            set thismerc=null
            call SaveInteger(questtm, GetHandleId(m), 1, id)
            //added event register on nextclass library 
           
           
            set t=(NewTimerEx(0)) // INLINED!!
            call SaveUnitHandle(questtm, GetHandleId(t), 0, m)
            call SaveTimerHandle(questtm, GetHandleId(udg_PHero[id]), GetHandleId(m), t)
            call TimerStart(t, 3, true, function morders)
            
             call StartSound(bj_questDiscoveredSound)
            set questid=SetupQuest(id , m , "HIRED BLACK HAND SLAYER" , "Survive an assault from Black Hand mercenary " , "0" , "/1" , 0 , s__qty[2])
            call SetUnitUserData(m, questid)
           // call SaveUnitHandle(questtm,GetHandleId(gg_trg_mercinrange),questid,udg_PHero[id])
            set bhmerc[id]=m
            
             call DisplayTimedTextToPlayer(Player(id), .1, 0, 10, "|cffffcc00SURVIVOR QUEST!!!|r")
             call DisplayTimedTextToPlayer(Player(id), .1, 0, 10, "   |cffffcc00Iveor|r has hired a powerfull mercenary to |cffff0000EXTERMINATE YOU|r.")
             call DisplayTimedTextToPlayer(Player(id), .1, 0, 10, "   |cffffcc00The slayer has been ordered to stealth an item from your inventory|r")
            
           endif
   
    
     
    endif
  
    call TriggerSleepAction(1)
   
 endif
 
 set t=null
 set m=null
endfunction

