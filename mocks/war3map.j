//===========================================================================
//TESH.scrollpos=9
//TESH.alwaysfold=0
//===========================================================================
// Trigger: updatemulti
//
// EVENT_PLAYER_UNIT_PICKUP_ITEM
// Player(id)
//===========================================================================
function showc takes nothing returns boolean
  return ( GetItemTypeId(GetManipulatedItem()) == 'I09D' or GetItemTypeId(GetManipulatedItem()) == 'I09E' or GetItemTypeId(GetManipulatedItem()) == 'I09F' or GetItemTypeId(GetManipulatedItem()) == 'I0LU' or GetItemTypeId(GetManipulatedItem()) == 'I0LV' or GetItemTypeId(GetManipulatedItem()) == 'I0LW' )
endfunction

function infc takes nothing returns boolean
  return GetSpellAbilityId() == 'A08A'
endfunction


function showa takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local string pname= GetPlayerName(GetOwningPlayer(u))
local string hname= GetUnitName(udg_PHero[id])
local string level= I2S(GetUnitLevel(udg_PHero[id]))
local string rpoint= ""
local string mspeed="|cff8888ffMSpeed|r = " + I2S(R2I(GetUnitMoveSpeed(udg_PHero[id])))
local string cadd= "Class:|cffbbbbff" + hname + "|r Level:" + level
local real sp_cast_chance= 0
local real sp_cast_xdmg= 0
local real lethal_attack_edmg= 0
local real lethal_attack_per= 0
local real destr_drop_per= 0
local integer find_gold_chance= 0
        local real col0= .07
        local real col1= .05
        local real col2= .01
        local real col3= .11
        local real col4= .05
         
         call TriggerSleepAction(0.1)
       
       call GetStats(udg_PHero[id] , id)
        
           set rpoint=I2S(GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_LUMBER))
           set sp_cast_chance=I2R(s__Fortune[id]) / 30
           set sp_cast_xdmg=I2R(s__Mstrength[id]) / 1447
           set lethal_attack_edmg=1.618 * ( logg(10 , 10 + I2R(s__Constitution[id])) - 1 )
           set lethal_attack_per=( I2R(s__Fortune[id]) / 1618 ) * 100
           set destr_drop_per=7 + ( I2R(s__Fortune[id]) / 1618 ) * 100
           set find_gold_chance=R2I(12 + logg(1.618 , I2R(1 + s__Fortune[id])))
        
        call SetInfo(id , 1 , 0 , col0 , cadd)
        call SetInfo(id , 1 , 1 , col1 , "Level:" + level)
        call SetInfo(id , 2 , 0 , col0 , mspeed)
        call SetInfo(id , 4 , 1 , col1 , rpoint)
        call SetInfo(id , 5 , 1 , col1 , "|cffffcc00" + I2S(GetUnitUserData(udg_PHero[id])) + "/" + I2S(SetNext(id) * 300) + "|r") //killer points
        call SetInfo(id , 6 , 1 , col1 , "|cffffcc00" + s__drunkenlvl[s__dstate[id]] + "|r") //state
        call SetInfo(id , 1 , 4 , col4 , I2S(udg_STR[id]))
        call SetInfo(id , 2 , 4 , col4 , I2S(udg_AGI[id]))
        call SetInfo(id , 3 , 4 , col4 , I2S(udg_INT[id]))
        call SetInfo(id , 5 , 4 , col4 , I2S(s__Constitution[id]))
        call SetInfo(id , 6 , 4 , col4 , I2S(s__Mstrength[id]))
        call SetInfo(id , 7 , 4 , col4 , I2S(s__Fortune[id]))
        call SetInfo(id , 7 , 1 , col1 , I2S(find_gold_chance) + "%")
        call SetInfo(id , 8 , 1 , col1 , R2S(destr_drop_per) + "%")
        call SetInfo(id , 9 , 1 , col1 , udg_Factionname[udg_Faction[id]])
       call SetInfo(id , 10 , 1 , col1 , I2S(Reputation[id]))
        call SetInfo(id , 8 , 4 , col4 , ylw + R2S(sp_cast_chance) + "%|r")
        call SetInfo(id , 9 , 4 , col4 , ylw + R2S(sp_cast_xdmg) + "x|r")
       call SetInfo(id , 10 , 4 , col4 , ylw + R2S(lethal_attack_per) + "%|r")
       call SetInfo(id , 11 , 4 , col4 , ylw + R2S(lethal_attack_edmg) + "x|r")
       call SetInfo(id , 12 , 4 , col4 , ylw + R2S(I2R(s__Mstrength[id]) / 23) + "%|r")
       call SetInfo(id , 13 , 4 , col4 , ylw + R2S(I2R(s__Constitution[id]) / 402) + "%|r")
        
        // if Player(id) == GetLocalPlayer() then
                //  set board.minimize = true
                  call s__Board___VisibleHelper__setindex(((Qboard[id])),Player(id), false) // INLINED!!
                  call s__Board___VisibleHelper__setindex(((Pboard[id])),Player(id), true) // INLINED!!
                  call s__Board___MinimizedHelper__setindex(((Pboard[id])),Player(id), false) // INLINED!!
                  
                  
       //   endif
           
           set cadd=null
           set rpoint=null
           set pname=null
           set hname=null
           set mspeed=null
           set level=null
           set u=null
               
     
   
endfunction

//===========================================================================
function InitTrig_updatemulti takes nothing returns nothing
   local integer index= 0
   local trigger inf= CreateTrigger()
   set gg_trg_updatemulti=CreateTrigger()
   
    loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_updatemulti, Player(index), EVENT_PLAYER_UNIT_PICKUP_ITEM, null)
        call TriggerRegisterPlayerUnitEvent(inf, Player(index), EVENT_PLAYER_UNIT_SPELL_EFFECT, null)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
  
  
    call TriggerAddCondition(gg_trg_updatemulti, Condition(function showc))
    call TriggerAddCondition(inf, Condition(function infc))
    
    call TriggerAddAction(gg_trg_updatemulti, function showa)
    call TriggerAddAction(inf, function showa)
endfunction


//===========================================================================
// Trigger: qlogshow
//===========================================================================
function Trig_qlog_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A0AQ' )
endfunction

function Trig_qlog_Actions takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  local integer n= ManagePersQuest(id)
  local integer i= 0
  local integer j
  

          call SetInfoQ(id , 0 , 0 , .3 , "|cff777777¤|r  |cff999999" + questr_Done[id])
          set i=0
          set j=3
          loop
          exitwhen i > n
           if tmpQid[i] > 0 then
           // set Qboard[id][j][0].text = "|cff777777¤|r  |cffffcc00"+QTitle[tmpQid[i]]+"|r"
           call SetInfoQ(id , j , 0 , .25 , "|cff777777¤|r  |cffffcc00" + QTitle[tmpQid[i]] + "|r")
          // set Qboard[id][j+1][0].text = Qtype[tmpQid[i]]+" |cffdddddd"+QSid[tmpQid[i]]+"|r"
           call SetInfoQ(id , j + 1 , 0 , .3 , Qtype[tmpQid[i]] + " |cffdddddd" + QSid[tmpQid[i]] + "|r")
          // set Qboard[id][j+1][1].text = QSidx[tmpQid[i]] + QSidy[tmpQid[i]]
           call SetInfoQ(id , j , 1 , .05 , QSidx[tmpQid[i]] + QSidy[tmpQid[i]])
             endif
           set j=j + 2
           set i=i + 1
          endloop
 
 
   //if (GetLocalPlayer() == Player(id)) then
          call s__Board___VisibleHelper__setindex(((Pboard[id])),Player(id), false) // INLINED!!
          call s__Board___VisibleHelper__setindex(((Qboard[id])),Player(id), true) // INLINED!!
          call s__Board___MinimizedHelper__setindex(((Qboard[id])),Player(id), false) // INLINED!!
  // endif   
 
endfunction

//===========================================================================
function InitTrig_qlogshow takes nothing returns nothing
 local integer i= 0
    set gg_trg_qlogshow=CreateTrigger()
    
    
        
       loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_qlogshow, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, null)
        set i=i + 1
        exitwhen i == bj_MAX_PLAYER_SLOTS
      endloop
   
    call TriggerAddCondition(gg_trg_qlogshow, Condition(function Trig_qlog_Conditions))
    call TriggerAddAction(gg_trg_qlogshow, function Trig_qlog_Actions)
endfunction


//===========================================================================
// Trigger: updatequests
//
// call Requestlog(id)
//===========================================================================
function Trig_UpdateTable_Actions takes nothing returns nothing
   local integer i= 0
   local integer b
   local integer q
   
   loop
   exitwhen i > 7
   
    if boardCreated[i] == true then
            set q=Qboard[i]
            
              if s__Board___VisibleHelper__getindex(((q)),Player(i)) == true then // INLINED!!
                call RequestLog(i)
              endif
              
              set b=Pboard[i]
               
              if s__Board___VisibleHelper__getindex(((b)),Player(i)) == true then // INLINED!!
                call RequestStats(i)
              endif
    endif
   set i=i + 1
   endloop

    
endfunction

