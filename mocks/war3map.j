function InitTrig_sneakerfnd takes nothing returns nothing
    local integer index= 8
    set gg_trg_sneakerfnd=CreateTrigger()
    
       loop
        call TriggerRegisterPlayerUnitEvent(gg_trg_sneakerfnd, Player(index), EVENT_PLAYER_UNIT_ATTACKED, null)
        set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
    
    
    
    call TriggerAddCondition(gg_trg_sneakerfnd, Condition(function Trig_sneakerfnd_Conditions))
    call TriggerAddAction(gg_trg_sneakerfnd, function Trig_sneakerfnd_Actions)
endfunction


