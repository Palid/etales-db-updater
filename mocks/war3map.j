function SpreadPages takes nothing returns nothing
 local timer t= GetExpiredTimer()
 local integer count= LoadInteger(questtm, GetHandleId(t), 1)
 local integer id= LoadInteger(questtm, GetHandleId(t), 2)
 local integer sewer= GetRandomInt(0, 11)
 local real x= GetRandomReal(GetRectMinX(sewers[sewer]), GetRectMaxX(sewers[sewer]))
 local real y= GetRandomReal(GetRectMinY(sewers[sewer]), GetRectMaxY(sewers[sewer]))
 
  
     call SetItemUserData(CreateItem('I0F4', x, y), id) //spreaded page
 
 set count=count - 1
 call SaveInteger(questtm, GetHandleId(t), 1, count)
// call UnitChat("created",udg_PHero[0])
 if count < 1 then
 call PauseTimer(t)
 endif
 
 set t=null
 

endfunction


