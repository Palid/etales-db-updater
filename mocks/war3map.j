//library ARGB:
//******************************************************************************
//*
//* ARGB 1.2
//* ====
//*  For your color needs.
//*  
//*  An ARGB object is a by-value struct, this means that assigning copies the
//* contents of the struct and that you don't have to use .destroy(), the
//* downside is that you cannot assign its members (can't do set c.r= 123 )
//*
//*  This library should have plenty of uses, for example, if your spell involves
//* some unit recoloring you can allow users to input the color in the config
//* section as 0xAARRGGBB and you can then use this to decode that stuff.
//*
//* You can also easily merge two colors and make fading effects using ARGB.mix
//*
//* There's ARGB.fromPlayer which gets an ARGB object containing the player's
//* color. Then you can use the previous utilities on it.
//*
//* The .str() instance method can recolor a string, and the recolorUnit method
//* will apply the ARGB on a unit
//*
//* For other uses, you can use the .red, .green, .blue and .alpha members to get
//* an ARGB object's color value (from 0 to 255).
//*
//* structs that have a recolor method that takes red,green,blue and alpha as 0.255
//* integers can implement the ARGBrecolor module to gain an ability to quickly
//* recolor using an ARGB object.
//*
//********************************************************************************

//=================================================================================

//this double naming stuff is beginning to make me insane, if only TriggerEvaluate() wasn't so slow...
    function s__ARGB_create takes integer a,integer r,integer g,integer b returns integer
        return (b + g * 0x100 + r * 0x10000 + a * 0x1000000)
    endfunction
    
    // not really part of the exported stuff, I may remove it in the future, so please don't call this textmacro
    function s__ARGB_fromPlayerColor takes playercolor pc returns integer
//textmacro instance: ARGB_PLAYER_COLOR_2_ARGB()
        if ( pc == PLAYER_COLOR_RED ) then
            return 0xFFFF0303
        elseif ( pc == PLAYER_COLOR_BLUE ) then
            return 0xFF0042FF
        elseif ( pc == PLAYER_COLOR_CYAN ) then
            return 0xFF1CE6B9
        elseif ( pc == PLAYER_COLOR_PURPLE ) then
            return 0xFF540081
        elseif ( pc == PLAYER_COLOR_YELLOW ) then
            return 0xFFFFFC01
        elseif ( pc == PLAYER_COLOR_ORANGE ) then
            return 0xFFFE8A0E
        elseif ( pc == PLAYER_COLOR_GREEN ) then
            return 0xFF20C000
        elseif ( pc == PLAYER_COLOR_PINK ) then
            return 0xFFE55BB0
        elseif ( pc == PLAYER_COLOR_LIGHT_GRAY ) then
            return 0xFF959697
        elseif ( pc == PLAYER_COLOR_LIGHT_BLUE ) then
            return 0xFF7EBFF1
        elseif ( pc == PLAYER_COLOR_AQUA ) then
            return 0xFF106246
        elseif ( pc == PLAYER_COLOR_BROWN ) then
            return 0xFF4E2A04
        endif
        
      return 0xFF111111
//end of: ARGB_PLAYER_COLOR_2_ARGB()
    endfunction

    function s__ARGB_fromPlayer takes player p returns integer
     local playercolor pc=GetPlayerColor(p)
//textmacro instance: ARGB_PLAYER_COLOR_2_ARGB()
        if ( pc == PLAYER_COLOR_RED ) then
            return 0xFFFF0303
        elseif ( pc == PLAYER_COLOR_BLUE ) then
            return 0xFF0042FF
        elseif ( pc == PLAYER_COLOR_CYAN ) then
            return 0xFF1CE6B9
        elseif ( pc == PLAYER_COLOR_PURPLE ) then
            return 0xFF540081
        elseif ( pc == PLAYER_COLOR_YELLOW ) then
            return 0xFFFFFC01
        elseif ( pc == PLAYER_COLOR_ORANGE ) then
            return 0xFFFE8A0E
        elseif ( pc == PLAYER_COLOR_GREEN ) then
            return 0xFF20C000
        elseif ( pc == PLAYER_COLOR_PINK ) then
            return 0xFFE55BB0
        elseif ( pc == PLAYER_COLOR_LIGHT_GRAY ) then
            return 0xFF959697
        elseif ( pc == PLAYER_COLOR_LIGHT_BLUE ) then
            return 0xFF7EBFF1
        elseif ( pc == PLAYER_COLOR_AQUA ) then
            return 0xFF106246
        elseif ( pc == PLAYER_COLOR_BROWN ) then
            return 0xFF4E2A04
        endif
        
      return 0xFF111111
//end of: ARGB_PLAYER_COLOR_2_ARGB()
    endfunction

    function s__ARGB__get_alpha takes integer this returns integer
        if ( (this) < 0 ) then
            return 0x80 + ( - ( - (this) + 0x80000000 ) ) / 0x1000000
        else
            return ( (this) ) / 0x1000000
        endif
    endfunction
    function s__ARGB__set_alpha takes integer this,integer na returns integer
     local integer a
     local integer r
     local integer g
     local integer b
     local integer col=(this)

       if ( col < 0 ) then
           set col=- ( - col + 0x80000000 )
           set a=0x80 + col / 0x1000000
           set col=col - ( a - 0x80 ) * 0x1000000
       else
           set a=col / 0x1000000
           set col=col - a * 0x1000000
       endif
       set r=col / 0x10000
       set col=col - r * 0x10000
       set g=col / 0x100
       set b=col - g * 0x100
       return (b + g * 0x100 + r * 0x10000 + na * 0x1000000)
    endfunction




    function s__ARGB__get_red takes integer this returns integer
     local integer c=(this) * 0x100
        if ( c < 0 ) then
            return 0x80 + ( - ( - c + 0x80000000 ) ) / 0x1000000
        else
            return c / 0x1000000
        endif
    endfunction
    function s__ARGB__set_red takes integer this,integer nr returns integer
     local integer a
     local integer r
     local integer g
     local integer b
     local integer col=(this)

       if ( col < 0 ) then
           set col=- ( - col + 0x80000000 )
           set a=0x80 + col / 0x1000000
           set col=col - ( a - 0x80 ) * 0x1000000
       else
           set a=col / 0x1000000
           set col=col - a * 0x1000000
       endif
       set r=col / 0x10000
       set col=col - r * 0x10000
       set g=col / 0x100
       set b=col - g * 0x100
       return (b + g * 0x100 + nr * 0x10000 + a * 0x1000000)
    endfunction

    function s__ARGB__get_green takes integer this returns integer
     local integer c=(this) * 0x10000
        if ( c < 0 ) then
            return 0x80 + ( - ( - c + 0x80000000 ) ) / 0x1000000
        else
            return c / 0x1000000
        endif
    endfunction
    function s__ARGB__set_green takes integer this,integer ng returns integer
     local integer a
     local integer r
     local integer g
     local integer b
     local integer col=(this)

       if ( col < 0 ) then
           set col=- ( - col + 0x80000000 )
           set a=0x80 + col / 0x1000000
           set col=col - ( a - 0x80 ) * 0x1000000
       else
           set a=col / 0x1000000
           set col=col - a * 0x1000000
       endif
       set r=col / 0x10000
       set col=col - r * 0x10000
       set g=col / 0x100
       set b=col - g * 0x100
       return (b + ng * 0x100 + r * 0x10000 + a * 0x1000000)
    endfunction

    //=======================================================
    //
    //
    function s__ARGB__get_blue takes integer this returns integer
     local integer c=(this) * 0x1000000
        if ( c < 0 ) then
            return 0x80 + ( - ( - c + 0x80000000 ) ) / 0x1000000
        else
            return c / 0x1000000
        endif
    endfunction
    function s__ARGB__set_blue takes integer this,integer nb returns integer
     local integer a
     local integer r
     local integer g
     local integer b
     local integer col=(this)

       if ( col < 0 ) then
           set col=- ( - col + 0x80000000 )
           set a=0x80 + col / 0x1000000
           set col=col - ( a - 0x80 ) * 0x1000000
       else
           set a=col / 0x1000000
           set col=col - a * 0x1000000
       endif
       set r=col / 0x10000
       set col=col - r * 0x10000
       set g=col / 0x100
       set b=col - g * 0x100
       return (nb + g * 0x100 + r * 0x10000 + a * 0x1000000)
    endfunction

    //====================================================================
    // Mixes two colors, s would be a number 0<=s<=1 that determines
    // the weight given to color c2.
    //
    //  mix(c1,c2,0)   = c1
    //  mix(c1,c2,1)   = c2
    //  mix(c1,c2,0.5) = Mixing the colors c1 and c2 in equal proportions.
    //
    function s__ARGB_mix takes integer c1,integer c2,real s returns integer
      //widest function ever
      return (R2I(s__ARGB__get_blue(c2) * s + s__ARGB__get_blue(c1) * ( 1 - s ) + 0.5) + R2I(s__ARGB__get_green(c2) * s + s__ARGB__get_green(c1) * ( 1 - s ) + 0.5) * 0x100 + R2I(s__ARGB__get_red(c2) * s + s__ARGB__get_red(c1) * ( 1 - s ) + 0.5) * 0x10000 + R2I(s__ARGB__get_alpha(c2) * s + s__ARGB__get_alpha(c1) * ( 1 - s ) + 0.5) * 0x1000000)
    endfunction

    function s__ARGB_str takes integer this,string s returns string
       return "|c" + ARGB___i2cc[s__ARGB__get_alpha(this)] + ARGB___i2cc[s__ARGB__get_red(this)] + ARGB___i2cc[s__ARGB__get_green(this)] + ARGB___i2cc[s__ARGB__get_blue(this)] + s + "|r"
    endfunction

    function s__ARGB_recolorUnit takes integer this,unit u returns nothing
     local integer a
     local integer r
     local integer g
     local integer b
     local integer col=(this)

       if ( col < 0 ) then
           set col=- ( - col + 0x80000000 )
           set a=0x80 + col / 0x1000000
           set col=col - ( a - 0x80 ) * 0x1000000
       else
           set a=col / 0x1000000
           set col=col - a * 0x1000000
       endif
       set r=col / 0x10000
       set col=col - r * 0x10000
       set g=col / 0x100
       set b=col - g * 0x100
       call SetUnitVertexColor(u, r, g, b, a)
    endfunction



