function Trig_Winterpauldrons_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local unit a= GetAttacker()
local unit frz= null
local effect frez= null

 if ( GetRandomInt(0, 99) < 8 ) then
   
   set frz=CreateUnit(GetOwningPlayer(u), 'n06F', GetUnitX(a), GetUnitY(a), 0)

   call IssueTargetOrder(frz, "attack", a)
    // call IssueTargetOrder( frz, "creepthunderbolt", gu )
    // call UnitAddAbility(frz,'Aloc') 
   call UnitApplyTimedLife(frz, 'BTLF', 3)
  // call SetUnitVertexColor( a, 240, 248,255,30 )
   call SetUnitTimeScale(a, 0.00)
   set frez=AddSpecialEffect("Light.mdx", GetUnitX(a), GetUnitY(a))
   call TriggerSleepAction(4)
   call DestroyEffect(frez)
   set frez=null
  //  call SetUnitVertexColor(a, 255, 255,255,0 )
   call SetUnitTimeScale(a, 1)
   if GetUnitState(a, UNIT_STATE_LIFE) > 0 then
     call SetUnitAnimation(a, "stand")
    endif
endif

set frz=null
set a=null
set u=null

endfunction

