    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and GetIssuedOrderId() == OrderId("innerfire")
endfunction

function Trig_NoOverBuff_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local unit a= GetOrderTargetUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 
 if ( IsUnitType(a, UNIT_TYPE_HERO) == false and GetUnitLevel(a) > 49 ) then
     call IssueImmediateOrder(u, "stop")
     call CS_Error(Player(id) , "Imposible to buff due unit target level (slave max lvl=49)")
 endif
 set u=null
 set a=null
endfunction

