function initshaman takes nothing returns nothing

set s__fnatured[0]= 'n091' //trent lev 33
set s__fnatured[1]= 'n08Z' //trent lev 16
set s__fnatured[2]= 'n090' //trent lev 23
set s__fnatured[3]= 'n091' //trent lev 33

set s__natureforce[(0)*(2)+0]= 'n04S' //unit
set s__natureforce[(0)*(2)+1]= 3 //amount

set s__natureforce[(1)*(2)+0]= 'n04S' //unit
set s__natureforce[(1)*(2)+1]= 4 //amount

set s__natureforce[(2)*(2)+0]= 'e00D' //unit
set s__natureforce[(2)*(2)+1]= 2 //amount

set s__natureforce[(3)*(2)+0]= 'n04S' //unit
set s__natureforce[(3)*(2)+1]= 4 //amount

set s__natureforce[(4)*(2)+0]= 'n04S' //unit
set s__natureforce[(4)*(2)+1]= 5 //amount

set s__natureforce[(5)*(2)+0]= 'e00D' //unit
set s__natureforce[(5)*(2)+1]= 3 //amount

set s__natureforce[(6)*(2)+0]= 'e00D' //unit
set s__natureforce[(6)*(2)+1]= 4 //amount

set s__natureforce[(7)*(2)+0]= 'n04T' //unit
set s__natureforce[(7)*(2)+1]= 2 //amount

set s__natureforce[(8)*(2)+0]= 'e00D' //unit
set s__natureforce[(8)*(2)+1]= 5 //amount

set s__natureforce[(9)*(2)+0]= 'n026' //unit
set s__natureforce[(9)*(2)+1]= 3 //amount

endfunction

