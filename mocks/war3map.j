//===========================================================================
// Trigger: openchest
//
// set udg_itmpool[49] = 'I0SL' //scroll of Armored Soul
// set udg_itmpool[50] = 'I0SM' //scroll of Necromancy
// set udg_itmpool[51] = 'I0SN' //scroll of Fireball
// set udg_itmpool[52] = 'I0SO' //scroll of damage
// set udg_itmpool[53] = 'I0SP' //scroll of Hurricane
// set udg_itmpool[54] = 'I0SQ' //scroll of Mana Restore
// set udg_itmpool[55] = 'I0SR' //scroll of Golem Summon
// set udg_itmpool[56] = 'I0SS' //scroll of Meteor Storm
// set udg_itmpool[57] = 'I0ST' //Profaner's Manual
//===========================================================================
function Trig_openchest_Conditions takes nothing returns boolean
    return ( GetItemLevel(GetManipulatedItem()) / 10 ) == 8
endfunction

function SelectScroll takes nothing returns integer
local integer i= GetRandomInt(0, 99)
local integer scroll= 0

if i < 20 then
 set scroll=53 //hurricane
 elseif i < 30 then
 set scroll=50 //scroll of necromancy
elseif i < 40 then
 set scroll=52 //letter of the queen
elseif i < 50 then
 set scroll=56 //meteor storm
elseif i < 60 then
 set scroll=55 //Golem summoning
elseif i < 70 then
 set scroll=51 //Fireball
elseif i < 80 then
 set scroll=54 //mana restore
else
 set scroll=49 //armored sooul
endif
 return scroll
endfunction

function Trig_openchest_Actions takes nothing returns nothing
local unit u= GetManipulatingUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer loopend= GetItemLevel(GetManipulatedItem()) - 80
local integer i= 0
local integer select= 0
local integer selectx= 0
local integer selects= 0
local integer l__rand= 0
local integer extra= 0
local integer herolevel= GetHeroLevel(udg_PHero[id])
local integer eqlvl= 0
local integer equip= 0
loop
  exitwhen i > loopend
   set selectx=GetRandomInt(1, 3)
   set selects=GetRandomInt(1, 10)
   set select=GetRandomInt(30, 48)
 
   if ( selectx == 1 ) then
       call UnitAddItem(u, CreateItem(udg_itmpool[select], GetUnitX(u), GetUnitY(u)))
   endif
   
   if ( selects == 2 ) then
       call UnitAddItem(u, CreateItem(udg_itmpool[SelectScroll()], GetUnitX(u), GetUnitY(u)))
   endif
   
  // set rand = GetRandomInt(1,1162)
   set extra=GetRandomInt(1, 11)
    if ( extra == 3 ) then
      
       if GetRandomInt(1, 10) > 5 then
          set eqlvl=1 + ( herolevel / 20 )
          set equip=s__equipmentlvl[(eqlvl)*(7)+GetRandomInt(1, 6)]
          set l__rand=GetRandomInt(equip, equip + 12)
     else
     
          set eqlvl=herolevel / 8
          set l__rand=s__weaponlvl[(eqlvl)*(43)+GetRandomInt(1, s__weaponsize[eqlvl])]
     endif
        
        
      call UnitAddItem(u, CreateItem(udg_itmpool[l__rand], GetUnitX(u), GetUnitY(u)))
    endif
   
   
   set i=i + 1
endloop

set u=null

endfunction

