    set gg_trg_dforge=CreateTrigger()
    call DisableTrigger(gg_trg_dforge)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_dforge, EVENT_PLAYER_UNIT_DROP_ITEM)
    call TriggerAddCondition(gg_trg_dforge, Condition(function ISNF))
    call TriggerAddAction(gg_trg_dforge, function Trig_droping_forge_Actions)
