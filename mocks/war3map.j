function InitTrig_Ekromtest takes nothing returns nothing
    set gg_trg_Ekromtest=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Ekromtest, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_Ekromtest, Condition(function EARC))
    call TriggerAddAction(gg_trg_Ekromtest, function EARA)
endfunction


