//===========================================================================
// Trigger: promoteMinorFortune
//
// oolean edictFortune = false
// boolean edictWealth = false
// boolean edictKnowledge = false
// real globalFortune = 1
// real globalWealth = 1
// integer globalKnowledge = 1
// function promoteEdict takes string edict, string Pname, string amount, string time, real duration returns nothing
// function derogateEdict takes string edict, string Pname, real duration
//===========================================================================
function minforc takes nothing returns boolean
     return ( GetItemTypeId(GetManipulatedItem()) == 'I0EX' )
endfunction

function minfora takes nothing returns nothing
  local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
  //local unit hero = udg_PHero[id]
  
  if Reputation[id] < 75 then
     call RejectByRep(id)
     return
  endif
  
   if edictFortune == false then
     set edictFortune=true
     set globalFortune=1.35
     
     set Reputation[id]=Reputation[id] - 75
     
     call promoteEdict("|cffffcc00Minor Fortune|r" , GetPlayerName(Player(id)) , R2S(1.35) , I2S(R2I(700 / 50)) , 18)
     call TriggerSleepAction(700)
     set edictFortune=false
     set globalFortune=1
     call derogateEdict("|cffffcc00Minor Fortune|r" , GetPlayerName(Player(id)) , 5)
   else
      call DisplayTimedTextToPlayer(Player((id)), 0, 0, 5, "There's already an edict related to these issues. Please wait until previous edict ends") // INLINED!!
   endif
 
 
endfunction

