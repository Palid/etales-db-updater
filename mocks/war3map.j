// Trigger: globalsfam
//===========================================================================
//===========================================================================
// Trigger: callfamiliar
//===========================================================================
function Trig_callfamiliar_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == callfamiliar
endfunction

function Trig_callfamiliar_Actions takes nothing returns nothing
local integer pid= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local location p= GetUnitLoc(udg_PHero[pid])

call TriggerSleepAction(1)
if ( IsUnitHidden(udg_Familiar[pid]) == true ) then
 call ShowUnit(udg_Familiar[pid], true)
endif

if ( IsUnitHidden(cslave[pid]) == true ) then
 call ShowUnit(cslave[pid], true)
endif

call SetUnitPosition(udg_Familiar[pid], GetLocationX(p), GetLocationY(p))
call SetUnitPosition(cslave[pid], GetLocationX(p), GetLocationY(p))
call SetUnitPosition(udg_Slave[pid], GetLocationX(p), GetLocationY(p))

call RemoveLocation(p)
set p=null
endfunction

