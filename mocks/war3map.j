//===========================================================================
// Trigger: healerend
//===========================================================================
//TESH.scrollpos=45
//TESH.alwaysfold=0
function Trig_healerend_Conditions takes nothing returns boolean
    return ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true )
endfunction

function Trig_healerend_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local integer i= 1
 local location p=  GetUnitLoc(u)
 local integer exp= GetHeroXP(u)
 local integer level= GetHeroLevel(u)
 local integer questid
     
 if ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'I0LY') == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I0LY')
      
         if ( GetItemCharges(udg_tmpitem) > 6 ) then
           call UnitRemoveItem(GetTriggerUnit(), udg_tmpitem)
           
               loop
               exitwhen i > 6
               call UnitRemoveItemFromSlotSwapped(i, u)
               set i=i + 1
               endloop
           
               
            call UnitChat("Well done my friend, now you can heal this wounded land with the power of the Light. Use it wisely..." , gg_unit_hcth_0257)

            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "QUEST DONE")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTDONE, "Completed Healers Quest")
            set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
            call UpdatePersQuest(id , questid , 0 , "Reached first class tier" , "-" , "-")
            call RemoveQuestFromPlayer(questid , QPid[questid])
            call StartSound(bj_questCompletedSound)

                        
            set udg_PHero[id]=CreateUnitAtLoc(GetOwningPlayer(u), 'H002', p, 270)
            call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\Orc\\Reincarnation\\ReincarnationTarget.mdl")
            call DestroyEffect(GetLastCreatedEffectBJ())
            call AddProfaner(id) //Trigger registrado
            call SetHeroXP(udg_PHero[id], exp, false)
    
            call SetHeroAgi(udg_PHero[id], GetHeroAgi(u, false) + 24, true)
            call SetHeroStr(udg_PHero[id], GetHeroStr(u, false) + 24, true)
            call SetHeroInt(udg_PHero[id], GetHeroInt(u, false) + 24, true)
            
            call TriggerRegisterUnitEvent(gg_trg_Noorder, udg_PHero[id], EVENT_UNIT_ACQUIRED_TARGET)
            call TriggerRegisterUnitEvent(gg_trg_VS, udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitEvent(InsRestTrg[id], udg_PHero[id], EVENT_UNIT_DAMAGED)
            call TriggerRegisterUnitInRange(herodiag[id], udg_PHero[id], 256, null)
          call TriggerRegisterUnitInRange(s__enemyAcquire[id], udg_PHero[id], 1000, null)
            call RemoveUnit(u)
            

            call AdjustPlayerStateBJ(7, GetOwningPlayer(u), PLAYER_STATE_RESOURCE_LUMBER)
            set udg_Hnext[id]=4
           
            call DisableTrigger(gg_trg_growbulb)
            call DisableTrigger(gg_trg_healbulb)
            call RemoveAllQuestFromPlayer(id)
         endif
          set udg_tmpitem=null
    endif

    set u=null
    call RemoveLocation(p)
    set p=null
endfunction

//===========================================================================
function InitTrig_healerend takes nothing returns nothing
    set gg_trg_healerend=CreateTrigger()
    call TriggerRegisterEnterRectSimple(gg_trg_healerend, gg_rct_healer_bulbs)
    call TriggerAddCondition(gg_trg_healerend, Condition(function Trig_healerend_Conditions))
    call TriggerAddAction(gg_trg_healerend, function Trig_healerend_Actions)
endfunction


//===========================================================================
// Trigger: Soldier
//===========================================================================
//TESH.scrollpos=27
//TESH.alwaysfold=0
function Trig_Soldier_Conditions takes nothing returns boolean
    return ( GetItemLifeBJ(GetManipulatedItem()) == 120.00 )
endfunction

function Trig_Soldier_Actions takes nothing returns nothing
local location p= GetUnitLoc(GetTriggerUnit())
local unit u
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer questid

 if ( IsUnitInGroup(GetTriggerUnit(), udg_inTest) == true ) then
        call UnitChat("What are you doing here?, go back to keep safe the delivery!" , gg_unit_hcth_0257)

        
    elseif ( GetUnitTypeId(GetTriggerUnit()) != 'H00H' ) then
        call UnitChat(udg_SoldierNoType , gg_unit_hcth_0257)

        
    elseif ( GetUnitUserData(GetTriggerUnit()) < 300 ) then
            call UnitChat(udg_SoldierRejected , gg_unit_hcth_0257)

        else
            call UnitChat(udg_SoldierAccepted , gg_unit_hcth_0257)
            call TriggerSleepAction(3)
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00MAIN QUEST DISCOVERED|r")
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "          |cffeeee88The big Brother|r: Protect the traveler until he reach Velhilmen's destiny")
            set questid=SetupQuest(id , null , "THE BIG BROTHER" , "Protect the traveler until he reach Velhilmen's destiny" , "-" , "-" , 0 , s__qty[2])
            call SaveInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]), questid)
            set deliverwander[id]=true
           
            call CreateNUnitsAtLoc(1, 'n01D', Player(10), p, bj_UNIT_FACING)
            set u=GetLastCreatedUnit()
            call SetUnitUserData(u, GetPlayerId(GetOwningPlayer(GetTriggerUnit())))
            call GroupAddUnitSimple(GetTriggerUnit(), udg_inTest)
            call TriggerSleepAction(5.00)
            //call IssueTargetOrder( u, "move", GetTriggerUnit())
            
                loop
                 exitwhen deliverwander[id] == false
                   call TriggerSleepAction(5)
                   call IssuePointOrderLoc(u, "move", udg_VelhimenP)
                 endloop
        endif
    call RemoveLocation(p)
    set p=null
    set u=null
endfunction

