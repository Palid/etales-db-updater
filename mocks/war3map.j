function InitTrig_Molten_Arrow takes nothing returns nothing
    set gg_trg_Molten_Arrow=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Molten_Arrow, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Molten_Arrow, Condition(function Trig_Molten_Arrow_Conditions))
    call TriggerAddAction(gg_trg_Molten_Arrow, function Trig_Molten_Arrow_Actions)
endfunction


//===========================================================================
// Trigger: EE
//
// Expansive Effect
//===========================================================================
function Trig_EE_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A079' and ( GetUnitAbilityLevel(GetTriggerUnit(), 'A078') > 2 or GetUnitAbilityLevel(GetTriggerUnit(), 'A08X') > 0 )
endfunction


function showeed takes nothing returns nothing

   local real rdmg= LoadReal(udg_spelledh, GetHandleId(GetEnumUnit()), 10)
   local integer idmg= R2I(rdmg)
   
   call SpellDmgText(idmg , GetEnumUnit())

endfunction

function Trig_EE_Actions takes nothing returns nothing

 local unit u= GetTriggerUnit()
 local unit t= GetSpellTargetUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 //local real face = GetUnitFacing(u)
 local unit gu= null
 local location p= GetUnitLoc(t)
 
 local group g= CreateGroup()
 local integer l__l= 10
 local real dmg= ( GetHeroAgi(u, true) * 0.2 * l__l )
 local real fdmg
 local real rdmg
 local integer idmg
 local boolexpr istru= Condition(function bool)

 
 call GroupEnumUnitsInRangeOfLoc(g, p, 256, istru)
 call DestroyBoolExpr(istru)
 set istru=null
// call GroupEnumUnitsInRangeOfLoc(f, p, 256,Condition(function bool))
 call TriggerSleepAction(0.2)
 
 loop

   set gu=FirstOfGroup(g)
    exitwhen gu == null
   call CheckIfHasDMG(gu)
   
   if ( not ( gu == t ) and GetUnitState(gu, UNIT_STATE_LIFE) > 0.5 and IsUnitEnemy(gu, GetOwningPlayer(u)) ) then
   // set angle = bj_RADTODEG * Atan2(GetLocationY(tp) - GetLocationY(p), GetLocationX(tp) - GetLocationX(p))
   // call CreateDestructableLoc( 'B019',tp, angle ,1.3, 0 )
    set fdmg=dmg + dmg * AddRacialBonus(gu , id)
  call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\OrbOfDeath\\OrbOfDeathMissile.mdl", gu, "chest"))
  call EnableTrigger(gg_trg_SPDMG)
   call UnitDamageTarget(u, gu, fdmg, true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
    call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , gu)
      set spelldmg[id]=0
  // call TriggerSleepAction(0.1)
   // set rdmg = LoadReal(udg_spelledh,GetHandleId(gu),10)
   // set idmg = R2I(rdmg)
   
  // call SpellDmgText(idmg,gu)  
 //  call FlushChildHashtable(udg_spelledh,GetHandleId(gu)) 
   
   endif
   call GroupRemoveUnit(g, gu)

  // set gu = null
     
endloop
 

  
 // call ForGroup(f, function showeed)
  
 //  call DestroyGroup(f)
   call DestroyGroup(g)
   set g=null

   call RemoveLocation(p)
   set p=null
   set gu=null
   set g=null
   set u=null
   set t=null
   

endfunction

//===========================================================================
function InitTrig_EE takes nothing returns nothing
    set gg_trg_EE=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_EE, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_EE, Condition(function Trig_EE_Conditions))
    call TriggerAddAction(gg_trg_EE, function Trig_EE_Actions)
endfunction


//===========================================================================
// Trigger: PSE
//===========================================================================
function Trig_PSE_Conditions takes nothing returns boolean
    return ( GetSpellAbilityId() == 'A062' or GetSpellAbilityId() == 'A079' )
endfunction

function Trig_PSE_Actions takes nothing returns nothing
local unit a= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(a))
local unit u=  GetSpellTargetUnit()
local integer did= GetPlayerId(GetOwningPlayer(u))
 local sound s= gg_snd_arrowshot
 local integer idmg
 local real dmg= GetHeroAgi(a, true) * 10 * ( 1 + ( piercebonus[id] * 0.2 ) )
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif
    
    set dmg=dmg * inspired
 
    call DisableTrigger(gg_trg_DMG)
  //  call DisableTrigger(GetTriggeringTrigger())
    call PlaySoundOnUnitBJ(s, 100, u)
    
    call CheckIfHasDMG(u)
    call TriggerSleepAction(0.1)
    set dmg=dmg + dmg * AddRacialBonus(u , id)
    call EnableTrigger(gg_trg_SPDMG)
    call UnitDamageTarget(a, u, dmg, true, false, ATTACK_TYPE_PIERCE, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
    call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , GetSpellTargetUnit())
     
   // call TriggerSleepAction(0.1)
   // set dmg = LoadReal(udg_spelledh,GetHandleId(u),10)
   // set idmg = R2I(dmg)
    
  //  call SpellDmgText(idmg,u)
    
   
   
  // if (GetPlayerController(Player(id)) == MAP_CONTROL_USER and IsUnitType(a,UNIT_TYPE_HERO)==true and  spelldmg[id]>550  ) then
      // call shakebattle(id,did,spelldmg[id],u)
    //endif
     set spelldmg[id]=0
      call EnableTrigger(gg_trg_DMG)
 //   call TriggerSleepAction(0.3)
 //   call EnableTrigger(GetTriggeringTrigger())
    call FlushChildHashtable(udg_spelledh, GetHandleId(u))
    set u=null
    set a=null
    set s=null
endfunction

//===========================================================================
function InitTrig_PSE takes nothing returns nothing
    set gg_trg_PSE=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_PSE, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_PSE, Condition(function Trig_PSE_Conditions))
    call TriggerAddAction(gg_trg_PSE, function Trig_PSE_Actions)
endfunction


//===========================================================================
// Trigger: Paladin Fury
//
// paladin fury
//===========================================================================
//TESH.scrollpos=39
//TESH.alwaysfold=0
function Trig_Paladin_Fury_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A0CF'
endfunction

function PFU takes nothing returns nothing
    local timer t= GetExpiredTimer()
    local unit u= LoadUnitHandle(hts, GetHandleId(t), 0)
    local real ang= LoadReal(hts, GetHandleId(t), 1)
    local real inc= LoadReal(hts, GetHandleId(t), 2)
    
    local real x= GetUnitX(u) + inc * Cos(ang * bj_DEGTORAD)
    local real y= GetUnitY(u) + inc * Sin(ang * bj_DEGTORAD)
   // local location p = GetUnitLoc(u)
   // local location p1 = PolarProjectionBJ(p, inc, ang)
    
    
    set inc=inc - 1
  
    call SetUnitPathing(u, false)
 
  
    call SetUnitPosition(u, x, y) //( u, p1 )
   

    
  //  call RemoveLocation(p) 
   // call RemoveLocation(p1) 
    call SaveReal(hts, GetHandleId(t), 2, inc)
    
    set u=null
    set t=null
  
 endfunction


function Trig_Paladin_Fury_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local unit tar= GetSpellTargetUnit()
local real angle= GetUnitFacing(u)
local real dmg= 0.25 * ( GetUnitState(u, UNIT_STATE_MAX_LIFE) - GetUnitState(u, UNIT_STATE_LIFE) )
local integer idmg= 0
local real x= GetUnitX(tar) - 80 * Cos(angle * bj_DEGTORAD)
local real y= GetUnitY(tar) - 80 * Sin(angle * bj_DEGTORAD)
local destructable l__hit= CreateDestructable('B01T', x, y, angle - 180, 1.2, 0)
local timer tc= (NewTimerEx(0)) // INLINED!!
local real inspired= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif

 set dmg=dmg * inspired
 set dmg=dmg + dmg * AddRacialBonus(tar , id)
 
   call SaveUnitHandle(hts, GetHandleId(tc), 0, tar)
   call SaveReal(hts, GetHandleId(tc), 1, angle)
   call SaveReal(hts, GetHandleId(tc), 2, 14)
  // call TriggerSleepAction(0.1)
     call EnableTrigger(gg_trg_SPDMG)
      call UnitDamageTarget(u, tar, dmg, true, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
      call DisableTrigger(gg_trg_SPDMG)
     
      set idmg=R2I(spelldmg[id])
      call SpellDmgText(idmg , tar)
      set spelldmg[id]=0
  
  
   call TimerStart(tc, 0.02, true, function PFU)
 
   call TriggerSleepAction(0.14)
   call PauseTimer(tc)
   call ReleaseTimer(tc)
   call SetUnitPathing(tar, true)
   call TriggerSleepAction(0.7)
   call RemoveDestructable(l__hit)
      
set l__hit=null


 set u=null
 set tar=null
 set tc=null

endfunction

//===========================================================================
function InitTrig_Paladin_Fury takes nothing returns nothing
    set gg_trg_Paladin_Fury=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Paladin_Fury, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Paladin_Fury, Condition(function Trig_Paladin_Fury_Conditions))
    call TriggerAddAction(gg_trg_Paladin_Fury, function Trig_Paladin_Fury_Actions)
endfunction


