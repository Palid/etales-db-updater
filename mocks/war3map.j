//===========================================================================
// Trigger: sublimefire
//===========================================================================
//TESH.scrollpos=39
//TESH.alwaysfold=0
function Trig_sublimefire_Conditions takes nothing returns boolean
   local item it= GetManipulatedItem()
   local integer itid= GetItemTypeId(it)
   local boolean itema
   local boolean itemb
   local boolean itemc
   local boolean itemd
   local integer itca
   local integer itcb
   local integer itcc
   local integer itcd
   local real x= GetUnitX(gg_unit_e00Z_0428)
   local real y= GetUnitY(gg_unit_e00Z_0428)
   local integer i= 0
   

   if itid == 'I091' or itid == 'I005' or itid == 'I006' or itid == 'I0FC' then
      
     call DestroyEffect(AddSpecialEffect(crispfx, GetUnitX(gg_unit_e00Z_0428), GetUnitY(gg_unit_e00Z_0428)))
     set itca=GetIndexItemOfType(gg_unit_e00Z_0428 , 'I091')
     set itema=itca > 0
     
     set itcb=GetIndexItemOfType(gg_unit_e00Z_0428 , 'I005')
     set itemb=itcb > 0
      
     set itcc=GetIndexItemOfType(gg_unit_e00Z_0428 , 'I006')
     set itemc=itcc > 0
     
     set itcd=GetIndexItemOfType(gg_unit_e00Z_0428 , 'I0FC')
     set itemd=itcd > 0
     
     
        if ( itema and itemb and itemc and itemd ) then
         loop
           exitwhen i > 3
            call RemoveItem(UnitItemInSlot(gg_unit_e00Z_0428, i))
          set i=i + 1
         endloop
         call UnitAddItem(gg_unit_e00Z_0428, CreateItem('I0FH', x, y))
         call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl", x, y))
          
        elseif CountItems(gg_unit_e00Z_0428) > 3 then
         loop
         exitwhen i > 3
           call UnitRemoveItemFromSlot(gg_unit_e00Z_0428, i)
         set i=i + 1
         endloop
        
        endif
   
   else
     call UnitRemoveItem(gg_unit_e00Z_0428, it)
     if not ( GetItemTypeId(it) == 'I0FH' ) then
        call UnitChat("(Item rejected...)" , gg_unit_e00Z_0428)
     endif
   endif
   
     set it=null
     return false
endfunction


//===========================================================================
function InitTrig_sublimefire takes nothing returns nothing
    set gg_trg_sublimefire=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_sublimefire, gg_unit_e00Z_0428, EVENT_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_sublimefire, Condition(function Trig_sublimefire_Conditions))
   
endfunction


