//===========================================================================
function Trig_movefallenpaladin_Actions takes nothing returns nothing
   local location p= Location(20584.00, - 19574.00)
   local integer i= 0
   
    set i=GetRandomInt(1, 3)
     call SetUnitPositionLoc(gg_unit_n05C_0662, cursedloc[i])
     
    set i=0
   
    call SetUnitPositionLoc(gg_unit_H000_1423, p)
    call RemoveLocation(p)
    set p=null
    call DisableTrigger(GetTriggeringTrigger())
endfunction

