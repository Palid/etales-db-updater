function antidc takes nothing returns boolean
    return ( ( GetItemTypeId(GetManipulatedItem()) != 'I0LU' ) and GetItemTypeId(GetManipulatedItem()) != 'I0LV' and GetItemTypeId(GetManipulatedItem()) != 'I0LW' )
endfunction

 
function removedump takes nothing returns nothing
 local integer id= LoadInteger(nodump, GetHandleId(GetEnumItem()), 16)
 set id=id - 1
  if ( id == dumperid ) then
     call RemoveItem(GetEnumItem())
  endif
endfunction

function removedumping takes integer id returns nothing
  set dumperid=id
  call EnumItemsInRect(bj_mapInitialPlayableArea, Condition(function bool), function removedump)
endfunction



function chkda takes nothing returns nothing
    local integer id= GetPlayerId(GetTriggerPlayer())
     call SaveInteger(nodump, GetHandleId(GetManipulatedItem()), 16, id + 1)
endfunction

//===========================================================================
function checkdump takes nothing returns nothing
 local integer index= 0
 set dumptrg=CreateTrigger()
    loop
         set dumprisk[index]=false
        call TriggerRegisterPlayerUnitEvent(dumptrg, Player(index), EVENT_PLAYER_UNIT_DROP_ITEM, Condition(function bool))
         set index=index + 1
        exitwhen index == bj_MAX_PLAYER_SLOTS
    endloop
        call TriggerAddCondition(dumptrg, Condition(function antidc))
        call TriggerAddAction(dumptrg, function chkda)
endfunction



