//===========================================================================
// Trigger: forgerit
//===========================================================================
function FORJC takes nothing returns boolean
    return ( GetItemLifeBJ(GetManipulatedItem()) > 24 and GetItemLifeBJ(GetManipulatedItem()) < 32 )
endfunction

function FORJA takes nothing returns nothing
local item forjar= GetManipulatedItem()
set udg_typef=R2I(GetItemLifeBJ(forjar) - 25)

if ( udg_playerforging == true ) then
  call AdjustPlayerStateBJ(99999, GetOwningPlayer(GetTriggerUnit()), PLAYER_STATE_RESOURCE_GOLD)
  call UnitChat("Sorry guy, I'm busy with another work, Take here your gold.|nCome back later" , udg_forger)
  call TriggerSleepAction(0.5)
  call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "Received 99999 gold from brok the Dwarven forger...")
else

  call TriggerSleepAction(0.3)
  set udg_playerforging=true
  set udg_FIct=0
  set udg_currentforger=GetTriggerUnit()

  
  call UnitChat("Ok Son, drop on the ground your forgeable weapon/shield and your 5 jewels" , udg_forger)
  call SetUnitAnimationByIndex(udg_forger, 5)
  call EnableTrigger(gg_trg_dforge)

  call TriggerSleepAction(1)
 // call UnitChat(I2S(udg_typef),udg_forger)
  call ResetUnitAnimation(udg_forger)
  call TriggerSleepAction(9)
  call UnitChat("If you don't want to lose your gold, then don't leave this place while i'm forging..." , udg_forger)
  
endif
set forjar=null
endfunction

