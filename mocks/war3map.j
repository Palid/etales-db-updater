//===========================================================================
// Trigger: shamanlibrary
//
// set udg_CreepType[162] = 'e00D' //Lost Guardian
// set udg_CreepType[163] = 'n04S' //Posion Treant
// set udg_CreepType[164] = 'n04T' //Corrupted Ancient
// satyr hellcaller = 'n026'
//===========================================================================
//TESH.scrollpos=12
//TESH.alwaysfold=0
//===========================================================================
// Trigger: spirittouch
//===========================================================================
//TESH.scrollpos=43
//TESH.alwaysfold=0
function Trig_spirittouch_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == SPIRTOUCH
endfunction

function Trig_spirittouch_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local unit a= GetSpellTargetUnit()
 local integer amount= GetHeroInt(udg_PHero[id], true) * 6
 local real unitmana= GetUnitState(a, UNIT_STATE_MANA)
 local real inspired= 1
 local real dmg= I2R(amount)
 local integer idmg= 0

  if ActSpecast(id , GetSpellAbilityId()) == true then
      set inspired=1 + s__castamount[id] * s__casttype[id]
 endif
 
  set dmg=dmg * inspired
  set dmg=dmg + dmg * AddRacialBonus(a , id)
 
    if IsUnitEnemy(a, Player(id)) then
         if dmg > unitmana then
        
         set dmg=dmg - unitmana
         call SetUnitState(a, UNIT_STATE_MANA, 0)
         call DisableTrigger(gg_trg_DMG)
         set idmg=R2I(dmg)
         
          call EnableTrigger(gg_trg_SPDMG)
          call UnitDamageTarget(u, a, dmg, true, false, ATTACK_TYPE_MAGIC, DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
          call DisableTrigger(gg_trg_SPDMG)
         
          set idmg=R2I(spelldmg[id])
          call SpellDmgText(idmg , a)
          set spelldmg[id]=0
          call EnableTrigger(gg_trg_DMG)
          set u=null
          set a=null
          return
          else
           set unitmana=unitmana - dmg
           call SetUnitState(a, UNIT_STATE_MANA, unitmana)
         
          endif
   else //unit is ally
      
       set unitmana=unitmana + dmg
       call SetUnitState(a, UNIT_STATE_MANA, unitmana)
      
   endif
   
  
  set idmg=R2I(dmg)
  call SpellDmgText(idmg , a)
  set a=null
  set u=null

endfunction

