//===========================================================================
// Trigger: clownlibrary
//===========================================================================
//TESH.scrollpos=39
//TESH.alwaysfold=0
//===========================================================================
// Trigger: DMGhater
//
// lclown
//===========================================================================
//TESH.scrollpos=30
//TESH.alwaysfold=0
function haterON takes nothing returns boolean
  return ( GetUnitTypeId(GetEventDamageSource()) == 'n065' )
endfunction

function DMGHTA takes nothing returns nothing

 local integer id= GetPlayerId(GetOwningPlayer(GetEventDamageSource()))
 local unit k= GetTriggerUnit()
 
 local integer STAT= GetHeroAgi(udg_PHero[id], true) + GetHeroStr(udg_PHero[id], true)
 local real damage= I2R(STAT) / 2
 
 
 local integer d
 local real angle= GetUnitFacing(GetEventDamageSource())
 local real inspired= LoadReal(hts, GetHandleId(GetEventDamageSource()), StringHash("spcast"))
//we damages the target with calculated damage, after disabling unit damage event triggers 
  call DisableTrigger(gg_trg_DMG)
 if inspired > 0 then
  set damage=damage * inspired
 endif
    set damage=damage + damage * AddRacialBonus(k , id)
    
   call EnableTrigger(gg_trg_DMGhaterb) //enabling this we can register damage dealed event
   call UnitDamageTarget(udg_PHero[id], k, damage, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL, WEAPON_TYPE_WHOKNOWS)
        // call UnitDamageTargetBJ( u, GetTriggerUnit(), udg_Lethalstrikestack, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL )
   call DisableTrigger(gg_trg_DMGhaterb)
    
    set d=R2I(haterdmg[id])
    
    
    call CreateTextTagUnitBJ(I2S(d), k, - 150, 19, 100, 18, 0, 0)
    call SetTextTagPermanent(GetLastCreatedTextTag(), false)
    call SetTextTagLifespan(GetLastCreatedTextTag(), 0.70)
    call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 300.00, angle)
    
    
      set k=null
      set d=0
      set haterdmg[id]=0
  call EnableTrigger(gg_trg_DMG)
  
endfunction

//===========================================================================
function InitTrig_DMGhater takes nothing returns nothing
    set gg_trg_DMGhater=CreateTrigger()
    call TriggerAddCondition(gg_trg_DMGhater, Condition(function haterON))
    call TriggerAddAction(gg_trg_DMGhater, function DMGHTA)
endfunction


