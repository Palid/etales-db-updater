    call SaveUnitHandle(questtm, GetHandleId(Pquesttrg), 0, GetEnumUnit())
    call TriggerAddCondition(Pquesttrg, Condition(function Pquesthero))
    call TriggerRegisterUnitEvent(gg_trg_activeghost, GetEnumUnit(), EVENT_UNIT_DEATH)
  endif
    
    //=====Random quest setup=====
   
    
set Pquesttrg=null
endfunction

