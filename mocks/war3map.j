    call TriggerAddCondition(gg_trg_dwarwenteleport, Condition(function Trig_dwarwenteleport_Conditions))
    call TriggerAddAction(gg_trg_dwarwenteleport, function Trig_dwarwenteleport_Actions)
endfunction


