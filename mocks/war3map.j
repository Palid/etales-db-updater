    set gg_trg_PS=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_PS, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_PS, Condition(function Trig_PS_Conditions))
    call TriggerAddAction(gg_trg_PS, function Trig_PS_Actions)
endfunction


//===========================================================================
// Trigger: miscsets
//===========================================================================
//===========================================================================
// Trigger: goldcoins
//
// potions of power v healing
//===========================================================================
function cellgoldc takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I08H' ) //gold coins
endfunction


function cellgolda takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local integer id= GetPlayerId(GetOwningPlayer(u))
    local integer count= 0
    local integer amount= R2I(GetRandomReal(1, logg(2 , I2R(s__Fortune[id]) * globalFortune)))
    local real x= GetItemX(GetManipulatedItem())
    local real y= GetItemY(GetManipulatedItem())
    local real textHeight= 11 * 0.023 / 10
   
    
  
      
       set count=( 1 + amount ) * globalWealth
     //  call CreateTextTagUnitBJ( "+" +I2S(count), u, 0, 11.00, 100, 100, 0, 0.00 )
     
     set bj_lastCreatedTextTag=CreateTextTag()
     call SetTextTagText(bj_lastCreatedTextTag, "+" + I2S(count), textHeight)
     call SetTextTagPos(bj_lastCreatedTextTag, x, y, 0)
     call SetTextTagColor(bj_lastCreatedTextTag, 255, 255, 0, 255)
     call SetTextTagPermanent(bj_lastCreatedTextTag, false)
     call SetTextTagLifespan(bj_lastCreatedTextTag, 2)
     call SetTextTagFadepoint(bj_lastCreatedTextTag, 0.00)
     call SetTextTagVelocityBJ(bj_lastCreatedTextTag, 50, 90)
     
    //   call SetTextTagPermanentBJ( bj_lastCreatedTextTag, false )
    //   call SetTextTagLifespanBJ( bj_lastCreatedTextTag, 2.00 )
    //   call SetTextTagFadepointBJ( bj_lastCreatedTextTag, 1.00 )
    //   call SetTextTagVelocityBJ( bj_lastCreatedTextTag, 50, 90 )
       
       call AdjustPlayerStateBJ(count, Player(id), PLAYER_STATE_RESOURCE_GOLD)
       
       set u=null
  
endfunction

//===========================================================================
function InitTrig_goldcoins takes nothing returns nothing
    set gg_trg_goldcoins=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_goldcoins, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_goldcoins, Condition(function cellgoldc))
    call TriggerAddAction(gg_trg_goldcoins, function cellgolda)
endfunction


