//textmacro instance: SAVER()
    
function CodeVersioning__StoreItems takes integer l__CodeVersioning__stack,unit u,integer id returns nothing
      local integer j= GetInventory(u , id)
      local integer l__l= udg_Slots[6]
      local integer i= 0
    
         set i=0
     loop
        exitwhen i == l__l
           call s__NumberStack_push(l__CodeVersioning__stack,udg_tempinvcharges[i] , CodeVersioning__MAX_CHARGES)
          // call DisplayTimedTextToPlayer(triggerPlayer,.75,.2,10,"IT CHR: " +I2S(udg_tempinvcharges[i])+"in slot "+I2S(i))  
         set i=i + 1
     endloop
 
   set i=0
     loop
        exitwhen i == l__l
           call s__NumberStack_push(l__CodeVersioning__stack,udg_Slots[i] , 7)
       //   call DisplayTimedTextToPlayer(triggerPlayer,.75,.2,10,"IT CHR: " +I2S(udg_tempinvcharges[i]))  
          set i=i + 1
     endloop

        set i=0
        loop
         exitwhen i == j
          call s__NumberStack_push(l__CodeVersioning__stack,LoadInteger(udg_itempoolhash, udg_tmpItemId[i], 1) , typesize[currentType[i]])
          //call DisplayTimedTextToPlayer(triggerPlayer,.75,.2,10,"Typesize: " +I2S(typesize[currentType[i]])+"in slot "+I2S(i))  
         set i=i + 1
         endloop

   
     set i=0
        loop
         exitwhen i == j
          call s__NumberStack_push(l__CodeVersioning__stack,currentType[i] , 7)
         set i=i + 1
         endloop
    set i=0
        
        call s__NumberStack_push(l__CodeVersioning__stack,udg_Slots[6] , 7)
        call s__NumberStack_push(l__CodeVersioning__stack,udg_Slots[7] , 7)

      call FreeInventory() //nullifing temp inventory
    endfunction
 
    function CodeVersioning__OnSave takes nothing returns nothing
     // local integer unitID = GetUnitTypeId(udg_PHero[playerId])
      local string l__advice= null
      local integer heroID= LoadInteger(herohash, GetUnitTypeId(udg_PHero[CodeVersioning__playerId]), 0)
      local integer heroXP= GetHeroXP(udg_PHero[CodeVersioning__playerId])
      local integer lumber= GetPlayerState(CodeVersioning__triggerPlayer, PLAYER_STATE_RESOURCE_LUMBER)
      local integer gold= 0
      local integer slaveID= LoadInteger(udg_itempoolhash, GetUnitTypeId(cslave[CodeVersioning__playerId]), 0)
      local integer j= 0
      local integer l__l= 0
      local integer i= 0
      local integer k= GetUnitUserData(udg_PHero[CodeVersioning__playerId])
    
   //saving slave
   
    call s__NumberStack_push(CodeVersioning__stack,slaveID , CodeVersioning__MAX_CREEP)
 //  set saveddataI[0]=slaveID
   //saving familiar
       
      call FreeInventory()
           //saving attributes 
        call GetStats(udg_PHero[CodeVersioning__playerId] , CodeVersioning__playerId)
       
       //saving stats  
       if ( udg_INT[CodeVersioning__playerId] > 1200 ) then
       set udg_INT[CodeVersioning__playerId]=1200
       endif
       if ( udg_STR[CodeVersioning__playerId] > 1200 ) then
       set udg_STR[CodeVersioning__playerId]=1200
       endif
       if ( udg_AGI[CodeVersioning__playerId] > 1200 ) then
       set udg_AGI[CodeVersioning__playerId]=1200
       endif
       
