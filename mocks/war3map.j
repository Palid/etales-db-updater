     call TriggerRegisterAnyUnitEventBJ(gg_trg_aprent, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_aprent, Condition(function APRTC))
     call TriggerAddAction(gg_trg_aprent, function APRTA)
endfunction


