//library questglobal ends
//library ratsinemerald:


function UnitIsHero takes unit u returns boolean
  return IsUnitType(u, UNIT_TYPE_HERO) == true
endfunction

function UnitHasThisItem takes unit u,integer itemID returns boolean
    local integer index
    local item indexItem

    set index=0
    loop
        set indexItem=UnitItemInSlot(u, index)
        if ( indexItem != null ) and ( GetItemTypeId(indexItem) == itemID ) then
        set ratsinemerald___ThisItem=indexItem
        set indexItem=null
            return true
        endif
        set indexItem=null
        set index=index + 1
        exitwhen index >= bj_MAX_INVENTORY
    endloop
    
    return false
endfunction


function cellardoor1 takes nothing returns boolean
   if ( (IsUnitType((GetTriggerUnit()), UNIT_TYPE_HERO) == true) == true and UnitHasThisItem(GetTriggerUnit() , 'I08C') == true ) then // INLINED!!
  // puerta1
    //call ModifyGateBJ( bj_GATEOPERATION_OPEN, gg_dest_DTc1_24107 )
     call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, 15, "|cffAAAAAAYou have used the first key door. It opens the door loudly|r")
    //call TriggerSleepAction(0.3)
    call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, GetTriggerUnit())
    call KillDestructable(gg_dest_DTc1_24107)
    call SetDestructableAnimation(gg_dest_DTc1_24107, "death alternate")
    call KillDestructable(gg_dest_Ytlc_25550)
    call KillDestructable(gg_dest_Ytlc_25551)
    
   
    
    call RemoveItem(ratsinemerald___ThisItem)
    set ratsinemerald___ThisItem=null
    call DestroyBoolExpr(ratsinemerald___haskey1)
    set ratsinemerald___haskey1=null
    call DisableTrigger(ratsinemerald___trg_cellar1)
    call DestroyTrigger(ratsinemerald___trg_cellar1)
    set ratsinemerald___trg_cellar1=null
    call RemoveRegion(ratsinemerald___cellar1)
    set ratsinemerald___cellar1=null
    call RemoveRect(gg_rct_bodegapuerta1)
    set gg_rct_bodegapuerta1=null
    endif
return false
endfunction

function cellardoor2 takes nothing returns boolean

    
 if ( (IsUnitType((GetTriggerUnit()), UNIT_TYPE_HERO) == true) == true and UnitHasThisItem(GetTriggerUnit() , 'I08B') == true ) then // INLINED!!
      call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, GetTriggerUnit())
  // puerta2
   // call ModifyGateBJ( bj_GATEOPERATION_OPEN, gg_dest_DTc1_24081 )
call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, 15, "|cffAAAAAAYou have used the second key door. You hear the squeak of the hinges as the door opens|r")
   //    call TriggerSleepAction(0.3)
    call KillDestructable(gg_dest_DTc1_24081)
    call SetDestructableAnimation(gg_dest_DTc1_24081, "death alternate")
    call KillDestructable(gg_dest_Ytlc_25541)
    call KillDestructable(gg_dest_Ytlc_25539)
    
    
    call RemoveItem(ratsinemerald___ThisItem)
    set ratsinemerald___ThisItem=null
    call DestroyBoolExpr(ratsinemerald___haskey2)
    set ratsinemerald___haskey2=null
    call DisableTrigger(ratsinemerald___trg_cellar2)
    call DestroyTrigger(ratsinemerald___trg_cellar2)
    set ratsinemerald___trg_cellar2=null
     call RemoveRegion(ratsinemerald___cellar2)
    set ratsinemerald___cellar2=null
     call RemoveRect(gg_rct_bodegapuerta1)
    set gg_rct_bodegapuerta1=null
    endif
    
    
    
  return false
endfunction

function cellardoor3 takes nothing returns boolean

    
    
 if ( (IsUnitType((GetTriggerUnit()), UNIT_TYPE_HERO) == true) == true and UnitHasThisItem(GetTriggerUnit() , 'I088') == true ) then // INLINED!!

     // puerta3
   // call ModifyGateBJ( bj_GATEOPERATION_OPEN, gg_dest_DTc1_24082 )
    call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, 15, "|cffAAAAAAYou have used the final third key door. The room next looks darken|r")
        call PlaySoundOnUnitBJ(gg_snd_dooropens, 80, GetTriggerUnit())
   // call TriggerSleepAction(0.3)
    
    call KillDestructable(gg_dest_DTc1_24082)
    call SetDestructableAnimation(gg_dest_DTc1_24082, "death alternate")
    call KillDestructable(gg_dest_Ytlc_25518)
    call KillDestructable(gg_dest_Ytlc_25519)
    
  
   
    call RemoveItem(ratsinemerald___ThisItem)
    set ratsinemerald___ThisItem=null
    call DestroyBoolExpr(ratsinemerald___haskey3)
    set ratsinemerald___haskey3=null
    call DisableTrigger(ratsinemerald___trg_cellar3)
    call DestroyTrigger(ratsinemerald___trg_cellar3)
    set ratsinemerald___trg_cellar3=null
    call RemoveRegion(ratsinemerald___cellar3)
    set ratsinemerald___cellar3=null
     call RemoveRect(gg_rct_bodegapuerta1)
    set gg_rct_bodegapuerta1=null
    endif
        
    
    
    return false
endfunction


function initRats takes nothing returns nothing
 set ratgroup=CreateGroup()
 set ratheroes=CreateGroup()

 set ratsinemerald___trg_cellar1=CreateTrigger()
 set ratsinemerald___trg_cellar2=CreateTrigger()
 set ratsinemerald___trg_cellar3=CreateTrigger()
 
 set ratsinemerald___haskey1=Condition(function cellardoor1)
 set ratsinemerald___haskey2=Condition(function cellardoor2)
 set ratsinemerald___haskey3=Condition(function cellardoor3)
   //puerta numero 1
    set ratsinemerald___cellar1=CreateRegion()
    call RegionAddRect(ratsinemerald___cellar1, gg_rct_bodegapuerta1)
    call TriggerRegisterEnterRegion(ratsinemerald___trg_cellar1, ratsinemerald___cellar1, null)
    call TriggerAddCondition(ratsinemerald___trg_cellar1, ratsinemerald___haskey1)
  
    //puerta numero 2
    set ratsinemerald___cellar2=CreateRegion()
    call RegionAddRect(ratsinemerald___cellar2, gg_rct_bodegapuerta2)
    call TriggerRegisterEnterRegion(ratsinemerald___trg_cellar2, ratsinemerald___cellar2, null)
    call TriggerAddCondition(ratsinemerald___trg_cellar2, ratsinemerald___haskey2)
  
    //puerta numero 3
    set ratsinemerald___cellar3=CreateRegion()
    call RegionAddRect(ratsinemerald___cellar3, gg_rct_bodegapuerta3)
    call TriggerRegisterEnterRegion(ratsinemerald___trg_cellar3, ratsinemerald___cellar3, null)
    call TriggerAddCondition(ratsinemerald___trg_cellar3, ratsinemerald___haskey3)
  
set minXERR=GetRectMinX(gg_rct_rats1)
set maxXERR=GetRectMaxX(gg_rct_rats1)
set minYERR=GetRectMinY(gg_rct_rats1)
set maxYERR=GetRectMaxY(gg_rct_rats1)

set minXMRR=GetRectMinX(gg_rct_rats2)
set maxXMRR=GetRectMaxX(gg_rct_rats2)
set minYMRR=GetRectMinY(gg_rct_rats2)
set maxYMRR=GetRectMaxY(gg_rct_rats2)

set minXNRR=GetRectMinX(gg_rct_rats4)
set maxXNRR=GetRectMaxX(gg_rct_rats4)
set minYNRR=GetRectMinY(gg_rct_rats4)
set maxYNRR=GetRectMaxY(gg_rct_rats4)

set minXIRR=GetRectMinX(gg_rct_rats3)
set maxXIRR=GetRectMaxX(gg_rct_rats3)
set minYIRR=GetRectMinY(gg_rct_rats3)
set maxYIRR=GetRectMaxY(gg_rct_rats3)

    // puertainit
endfunction



//library ratsinemerald ends
//library rescuescout:


function rescok takes nothing returns boolean
return true
endfunction


function FindScoutCond takes nothing returns boolean
  local handle this_scout= LoadUnitHandle(questtm, GetHandleId(GetTriggeringTrigger()), 1)
  local handle find_scout= LoadUnitHandle(questtm, GetHandleId(GetTriggerUnit()), StringHash("scout"))
  
  local boolean is_the_scout= false
  
   if ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true and this_scout == find_scout ) then
        set is_the_scout=true
   endif
  
  set this_scout=null
  set find_scout=null

  return is_the_scout
endfunction


function findscout takes nothing returns nothing
local unit scout= null
local real sx= 0
local real sy= 0
local real x= 0
local real y= 0
local integer id= 0
local integer state= 0
local integer questid= 0


set scout=LoadUnitHandle(questtm, GetHandleId(GetTriggerUnit()), StringHash("scout"))
set state=LoadInteger(questtm, GetHandleId(scout), StringHash("rescue"))

  if ( state < 1 ) then
 
     call TriggerSleepAction(2)
   
     set id=GetUnitUserData(scout) - 1
    
     call UnitChat("What!?, The Captain sent you to find me?" , scout)
     call TriggerSleepAction(2)
     call UnitChat("Ok, I wanna go back..., Let's go" , scout)
         
     call TriggerSleepAction(2)
     call StartSound(gg_snd_QuestActivateWhat1)
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00Quest Update:|r Return to the captain with the scout")
      
      
     set questid=LoadInteger(udg_cache, GetHandleId(reinhard), GetHandleId(udg_PHero[id]))
     call UpdatePersQuestND(id , questid , 1 , "Return to the captain with the scout" , "1" , "-")
     // call UpdateQuestLog(reinhard,id,"|cffffcc00Return to the captain with the scout")
         
         
         set rescuedscout[id]=scout
         call SaveInteger(questtm, GetHandleId(scout), StringHash("rescue"), 1)
         set state=1
      
           loop
               exitwhen state < 1
  
               set x=GetUnitX(udg_PHero[id])
               set y=GetUnitY(udg_PHero[id])
  
               set sx=GetRandomReal(x - 200, x + 200)
               set sy=GetRandomReal(y - 200, y + 200)
      
                call IssuePointOrder(scout, "move", sx, sy)
                set state=LoadInteger(questtm, GetHandleId(scout), StringHash("rescue"))
               call TriggerSleepAction(2)
      
          endloop

 
  
  endif //if state

  set scout=null

endfunction

function setupscouts takes integer idhero returns nothing
   local integer i= 0
   local unit scout= null
   local real scx= 0
   local real scy= 0
   local boolean b= true
   local real time= 16
   local trigger l__foundscout= CreateTrigger()
   set i=GetRandomInt(0, 8)
 
 
    set scx=scoutx[i]
    set scy=scouty[i]
 
   set scout=CreateUnit(Player(10), velscout, scx, scy, 270)
   call SetUnitUserData(scout, idhero + 1)
   call SaveUnitHandle(questtm, GetHandleId(udg_PHero[idhero]), StringHash("scout"), scout)
   

   call TriggerRegisterUnitInRange(l__foundscout, scout, 256, null)
   call TriggerAddCondition(l__foundscout, Condition(function FindScoutCond))
   call TriggerAddAction(l__foundscout, function findscout)
   call SaveUnitHandle(questtm, GetHandleId(l__foundscout), 1, scout)
   call SaveTriggerHandle(questtm, GetHandleId(udg_PHero[idhero]), StringHash("scouttrg"), l__foundscout)
   
   call TriggerRegisterUnitEvent(gg_trg_scoutdead, scout, EVENT_UNIT_DEATH)
   
     if ( GetLocalPlayer() == Player(idhero) ) then
     
        // Use only local code (no net traffic) within this block to avoid desyncs.
     call PingMinimapEx(scx, scy, time, 255, 50, 50, false)
    // call PingMinimap(scx, scy,10)
        //call StartSound(bj_pingMinimapSound)
     endif
   

   set scout=null
   set l__foundscout=null
endfunction

