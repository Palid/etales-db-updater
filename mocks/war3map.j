// Trigger: stackscrvit
//===========================================================================

function scrcvit takes nothing returns boolean
    return GetItemTypeId(GetManipulatedItem()) == 'I0SN'
endfunction

function scravit takes nothing returns nothing
 local integer chargues= GetItemCharges(GetManipulatedItem())

   if ( GetItemTypeCount(GetTriggerUnit() , 'I0SN') > 1 ) then
     if ( GetItemCharges(GetMainJewel(GetTriggerUnit() , 'I0SN')) < 20 ) then
     call RemoveItem(GetManipulatedItem())
    
     set chargues=chargues + GetItemCharges(GetMainJewel(GetTriggerUnit() , 'I0SN'))
     call SetItemCharges(GetMainJewel(GetTriggerUnit() , 'I0SN'), chargues)
    endif
    
  endif
endfunction

