function tombcond takes nothing returns boolean
    return ( IsUnitInGroup(GetTriggerUnit(), tombs) == true )
endfunction

function tombact takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer id= LoadInteger(hts, GetHandleId(GetTriggeringTrigger()), 0)
 
 set rand=20 + ( GetPlayerTechCount(Player(id), 'R009', true) * 2 )
 
 call GroupRemoveUnit(tombs, u)
 
 if ( GetRandomInt(0, 99) < rand ) then
 
 
  call UnitAddAbility(u, 'A0DY')
  call SetUnitVertexColor(u, 255, 240, 60, 255)
  call TriggerSleepAction(0.15)
  call SetUnitVertexColor(u, 255, 255, 255, 255)
  
    if isprofanator[id] == true then
     call SetUnitOwner(u, Player(id), false)
    endif
  
 else
  call TriggerSleepAction(500)
  call GroupAddUnit(tombs, u)
 endif
 



  set u=null
 endfunction

