   call GroupPointOrder(workerstoship[i], "move", - 10850, 720)
   call GroupPointOrder(workerstogrocery[i], "move", - 4165, - 1140)
   
   endif

 call TriggerSleepAction(0.4)
 set i=i + 1
 endloop
    return false
endfunction



