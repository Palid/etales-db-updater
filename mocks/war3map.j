// Trigger: zombiesmove
//===========================================================================
function zmover takes nothing returns nothing
  call IssuePointOrder(GetEnumUnit(), "attack", zombx + GetRandomReal(- 150, 150), zomby + GetRandomReal(- 150, 150))

endfunction



function zmove takes nothing returns nothing
local real x
local real y
set zloop=0

loop

exitwhen zloop > 8

 if haszombi[zloop] == true then
  set x=GetUnitX(zleader[zloop])
  set y=GetUnitY(zleader[zloop])
  set zombx=GetRandomReal(x - 500, x + 500)
  set zomby=GetRandomReal(y - 500, y + 500)
  
  call ForGroup(zombieg[zloop], function zmover)
  call TriggerSleepAction(0.2)
 endif



set zloop=zloop + 1
endloop
 
 




endfunction

