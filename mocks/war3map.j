endfunction

function IsSword takes nothing returns boolean
    return (ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 5 // INLINED!!
endfunction

function IsShield takes nothing returns boolean
    return (ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 6 // INLINED!!
endfunction

function IsDagger takes nothing returns boolean
    return (ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 1 // INLINED!!
endfunction

function IsStaff takes nothing returns boolean
    return (ModuloInteger(GetItemLevel(GetManipulatedItem()), 1000) / 100) == 4 // INLINED!!
endfunction

function IsBow takes nothing returns boolean
