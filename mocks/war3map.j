  function GetIndexItemOfType takes unit whichUnit,integer itemId returns integer
    local integer index
    local item indexItem

    set index=0
    loop
        set indexItem=UnitItemInSlot(whichUnit, index)
        if not ( indexItem == null ) and ( GetItemTypeId(indexItem) == itemId ) then
            set indexItem=null
            return index + 1
        endif

        set index=index + 1
        exitwhen index >= bj_MAX_INVENTORY
    endloop
    set indexItem=null
    return 0
    endfunction

    function CountItems takes unit whichUnit returns integer
    local integer index
    local integer count
    local item indexItem

    set index=0
    set count=0
    loop
        set indexItem=UnitItemInSlot(whichUnit, index)
        if not ( indexItem == null ) then
              set count=count + 1
        endif
        set index=index + 1
        exitwhen index >= bj_MAX_INVENTORY
    endloop
    set indexItem=null
    return count
    endfunction
   
  function arcanist___init takes nothing returns nothing
   local integer i= 0
   
   loop
       exitwhen i > 8
       set arnistadviced[i]=false
       set arcanistteach[i]=false
       set lanternsp[i]=0
       
       set i=i + 1
   endloop
    
  
  endfunction



