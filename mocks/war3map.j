   return ( IsUnitInGroup(GetDyingUnit(), koboldk) == true and childk == false )
endfunction

function kknka takes nothing returns nothing
 call GroupRemoveUnit(koboldk, GetDyingUnit())
 call ForGroup(koboldk, function CountKobolds)
  if koboldnumber < 1 then
    call RemoveSavedHandle(questtm, GetHandleId(koboldk), 0)
    call TriggerSleepAction(30)
    call SetUnitPosition(koboldvictim, - 14900, 10670)
    call UnitAddAbility(koboldvictim, 'Awan')
  
  endif
endfunction

