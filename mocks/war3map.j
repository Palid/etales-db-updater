    set gg_trg_kidnapped=CreateTrigger()
    call TriggerAddCondition(gg_trg_kidnapped, Condition(function Trig_kidnapped_Conditions))
    call TriggerAddAction(gg_trg_kidnapped, function Trig_kidnapped_Actions)
endfunction


