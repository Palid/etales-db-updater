//===========================================================================
// Trigger: saveVelhimen
//===========================================================================
function Trig_saveVelhimen_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer dest= 0

   if IsUnitType(u, UNIT_TYPE_HERO) == true then
          if udg_Plugar[GetPlayerId(GetOwningPlayer(u))] != 1 then
           call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 5, " Welcome to |cffffcc00Velhilmen!|r")
          endif

           set udg_Plugar[GetPlayerId(GetOwningPlayer(u))]=1
           call RemoveLocation(udg_RevivalPoints[GetPlayerId(GetOwningPlayer(u))])
           set udg_RevivalPoints[GetPlayerId(GetOwningPlayer(u))]=GetRectCenter(gg_rct_Revival)
           set homeloc[GetPlayerId(GetOwningPlayer(u))]=GetRectCenter(gg_rct_veltarget)
   elseif GetUnitUserData(u) == 2222 then
        set dest=LoadInteger(questtm, GetHandleId(u), 1222)
         if dest == 1 then
         //is here
          call Ishere(u)
          call TriggerSleepAction(50)
          call EnableTrigger(LoadTriggerHandle(questtm, GetHandleId(u), 15))
           
         endif
   
   endif
set u=null
endfunction

