    set gg_trg_saveVelhimen=CreateTrigger()
    call TriggerRegisterEnterRectSimple(gg_trg_saveVelhimen, gg_rct_savep2)
    call TriggerRegisterEnterRectSimple(gg_trg_saveVelhimen, gg_rct_savep3)
    call TriggerRegisterEnterRectSimple(gg_trg_saveVelhimen, gg_rct_savep1)
