//textmacro instance: CORE_SETTINGS()
    //maximum versions of the code possible (50000 is typically more than enough)
constant integer CodeVersioning__MAX_CODE_VERSIONS= 50000
    
    //this improves CRC (out of bounds checking) but increases code size based on the
    //code's version. The increase is typically 0 but can average at 1. With a very large amount of
    //code versions it can get up to 2.
    //The improved CRC offers better security and has absolutely no chance of invalid codes bleeding
    //across different versions. This bleeding may occur in rare situations on regular CRC.
constant boolean CodeVersioning__IMPROVED_CRC= true
    
    //commands
constant string CodeVersioning__SAVE_COMMAND="-save"
constant string CodeVersioning__LOAD_COMMAND="-load"
    
    //online security
constant integer CodeVersioning__ONLINE_CHECKSUM=1000000
constant string CodeVersioning__ONLINE_PASSWORD="H3tGRF"
   // private constant string ONLINE_ENCRYPTION_KEY="abcdefghijlkmnopqrstuvwxyzABCDEFGHKLMNOPQRSTUVWXYZ0123456789"
constant string CodeVersioning__ONLINE_ENCRYPTION_KEY="abcdefghijlkmnopqrstuvwxyzABCDEFGHKLMNOPQRSTUVWXYZ0123456789@#$%&?"
constant integer CodeVersioning__ONLINE_SHUFFLES=2
    
    //offline security
constant integer CodeVersioning__OFFLINE_CHECKSUM=1000000
constant string CodeVersioning__OFFLINE_PASSWORD="Jlp8Fg"
   // private constant string OFFLINE_ENCRYPTION_KEY="abcdefghijlkmnopqrstuvwxyzABCDEFGHKLMNOPQRSTUVWXYZ0123456789"
constant string CodeVersioning__OFFLINE_ENCRYPTION_KEY="abcdefghijlkmnopqrstuvwxyzABCDEFGHKLMNOPQRSTUVWXYZ0123456789@#$%&?"
constant integer CodeVersioning__OFFLINE_SHUFFLES=2
    
    //delimiters
constant string CodeVersioning__DELIMITER="-"
constant integer CodeVersioning__DELIMITER_SPACING=4
    
    //removing spacing? -load 4444        - 4444 -> -load 4444-4444
constant boolean CodeVersioning__REMOVE_SPACE=true
    
    //coloring
constant string CodeVersioning__NUM_COLOR="40e0d0"
constant string CodeVersioning__LOWERCASE_COLOR="ff69b4"
constant string CodeVersioning__UPPERCASE_COLOR="00AA00"
constant string CodeVersioning__SPEC_CHAR_COLOR="ffff00"
