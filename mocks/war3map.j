    set gg_trg_New_Meteor_Storm=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_New_Meteor_Storm, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_New_Meteor_Storm, Condition(function New_Meteor_Storm_Conditions))
    call TriggerAddAction(gg_trg_New_Meteor_Storm, function New_Meteor_Storm_Actions)
endfunction


