//===========================================================================
// Trigger: cellardestdrop
//===========================================================================
//TESH.scrollpos=19
//TESH.alwaysfold=0


function cellards takes nothing returns nothing
  local integer f
  local real x= GetDestructableX(GetTriggerDestructable())
  local real y= GetDestructableY(GetTriggerDestructable())
  //  set udg_tmpit = GetDestructableLoc(GetDyingDestructable())
    set udg_percent1=GetRandomInt(1, 4)
    if ( udg_percent1 == 1 ) then
      set f=GetRandomInt(37, 41)
      call CreateItem(udg_itmpool[f], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
    endif
    set udg_percent1=GetRandomInt(1, 4)
    if ( udg_percent1 == 1 ) then
      set f=GetRandomInt(37, 41)
      call CreateItem(udg_itmpool[f], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
    endif
    set udg_percent1=GetRandomInt(1, 5)
    if ( udg_percent1 == 2 ) then
          call CreateItem(udg_itmpool[91], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
    endif
     set udg_percent1=GetRandomInt(1, 5)
    if ( udg_percent1 == 3 ) then
            call CreateItem(udg_itmpool[91], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
    endif
     set udg_percent1=GetRandomInt(1, 5)
    if ( udg_percent1 == 4 ) then
            call CreateItem(udg_itmpool[91], GetRandomReal(x - 50, x + 50), GetRandomReal(y - 50, y + 50))
    endif
    
    
endfunction

