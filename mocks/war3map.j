//===========================================================================
function InitTrig_setspawntype takes nothing returns nothing
    set gg_trg_setspawntype=CreateTrigger()
    call TriggerRegisterTimerEventSingle(gg_trg_setspawntype, 10)
    call TriggerAddAction(gg_trg_setspawntype, function Trig_setspawntype_Actions)
endfunction


//===========================================================================
// Trigger: testdcampeon Copy
//===========================================================================
function Trig_testdcampeon_Copy_Actions takes nothing returns nothing
    call RemoveUnit(udg_PHero[0])
    call CreateNUnitsAtLoc(1, 'H00F', GetTriggerPlayer(), udg_RevivalPoints[0], bj_UNIT_FACING)
    call SetHeroLevelBJ(GetLastCreatedUnit(), 86, false)
    call ModifyHeroStat(bj_HEROSTAT_STR, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 605)
    call ModifyHeroStat(bj_HEROSTAT_AGI, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 543)
    call ModifyHeroStat(bj_HEROSTAT_INT, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 243)
    call UnitAddItemByIdSwapped('I0RS', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I02U', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I09I', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I0KS', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I069', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I0UG', GetLastCreatedUnit())
    set udg_PHero[0]=GetLastCreatedUnit()
    set udg_Faction[0]=2
endfunction

//===========================================================================
function InitTrig_testdcampeon_Copy takes nothing returns nothing
    set gg_trg_testdcampeon_Copy=CreateTrigger()
    call TriggerRegisterPlayerChatEvent(gg_trg_testdcampeon_Copy, Player(0), "-super9", true)
    call TriggerAddAction(gg_trg_testdcampeon_Copy, function Trig_testdcampeon_Copy_Actions)
endfunction

//===========================================================================
// Trigger: testdungeon Copy Copy
//===========================================================================
function Trig_testdungeon_Copy_Copy_Actions takes nothing returns nothing
    call RemoveUnit(udg_PHero[0])
    call CreateNUnitsAtLoc(1, 'U00H', GetTriggerPlayer(), udg_RevivalPoints[0], bj_UNIT_FACING)
    call SetHeroLevelBJ(GetLastCreatedUnit(), 81, false)
    call ModifyHeroStat(bj_HEROSTAT_STR, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 432)
    call ModifyHeroStat(bj_HEROSTAT_AGI, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 186)
    call ModifyHeroStat(bj_HEROSTAT_INT, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 378)
    call UnitAddItemByIdSwapped('I0NS', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I0T2', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I09I', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I046', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I0UI', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I06M', GetLastCreatedUnit())
    set udg_PHero[0]=GetLastCreatedUnit()
    set udg_Faction[0]=2
    call SetUnitUserData(udg_PHero[0], 2700)
    set s__Fortune[0]= 178
    set s__Mstrength[0]= 122
    set s__Constitution[0]= 34
endfunction

//===========================================================================
function InitTrig_testdungeon_Copy_Copy takes nothing returns nothing
    set gg_trg_testdungeon_Copy_Copy=CreateTrigger()
    call TriggerRegisterPlayerChatEvent(gg_trg_testdungeon_Copy_Copy, Player(0), "-super2", true)
    call TriggerAddAction(gg_trg_testdungeon_Copy_Copy, function Trig_testdungeon_Copy_Copy_Actions)
endfunction

//===========================================================================
// Trigger: testdungeonb Copy 2 Copy
//===========================================================================
function Trig_testdungeonb_Copy_2_Copy_Actions takes nothing returns nothing
    call RemoveUnit(udg_PHero[0])
    call CreateNUnitsAtLoc(1, 'N009', GetTriggerPlayer(), udg_RevivalPoints[0], bj_UNIT_FACING)
    call SetHeroLevelBJ(GetLastCreatedUnit(), 85, false)
    call ModifyHeroStat(bj_HEROSTAT_STR, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 485)
    call ModifyHeroStat(bj_HEROSTAT_AGI, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 660)
    call ModifyHeroStat(bj_HEROSTAT_INT, GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 110)
    call UnitAddItemByIdSwapped('I0N6', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I0T2', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I04B', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I0QK', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('I0UA', GetLastCreatedUnit())
    set udg_PHero[0]=GetLastCreatedUnit()
    set udg_Faction[0]=2
endfunction

