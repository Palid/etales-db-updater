//===========================================================================
// Trigger: killingspiders
//
// function UpdatePersQuest takes integer id, integer QuestIndex,integer Data, string log, string var, string total returns nothing
//===========================================================================
//TESH.scrollpos=30
//TESH.alwaysfold=0
function Trig_killingspiders_Conditions takes nothing returns boolean
    return ( GetUnitTypeId(GetTriggerUnit()) == 'n03S' and GetUnitUserData(cursedlady) > 0 ) //spitting spider
endfunction

function Trig_killingspiders_Actions takes nothing returns nothing
 local integer Qid= GetUnitUserData(cursedlady)
 local unit spd= GetTriggerUnit()
 local unit k= spiderkiller
 local real speed= GetUnitDefaultMoveSpeed(erudito)
 local integer id= GetPlayerId(GetOwningPlayer(k))
 local real dx= GetUnitX(spd) - GetUnitX(k)
 local real dy= GetUnitY(spd) - GetUnitY(k)
 local real d= SquareRoot(dx * dx + dy * dy)
 
    if d < 600 then
     set Qdata[Qid]=Qdata[Qid] + 1
        if Qdata[Qid] > 14 then
            call DisableTrigger(gg_trg_killingspiders)
            if ( GetLocalPlayer() == Player(id) ) then
                call ClearTextMessages()
            endif
            call UpdatePersQuestND(id , Qid , Qdata[Qid] , "-" , I2S(Qdata[Qid]) , "-")
            call RemoveQuestFromPlayer(Qid , id)
           // call UpdatePersQuestND(id,Qid,Qdata[Qid],"-",I2S(Qdata[Qid]),"-")
            call StartSound(bj_questCompletedSound)
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00PERSONAL QUEST FINISHED|r")
            call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, "Killed 15 Giant Spiders")
            call TriggerSleepAction(3)
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00REWARD:|r +2 Legendary Chests ")
            call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "      |cff00ccffGot +26000 Experience|r")
            call AddHeroXP(udg_PHero[id], 26000, false)

           call UnitAddItem(udg_PHero[id], CreateItem(Comprables[11], GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])))
           call UnitAddItem(udg_PHero[id], CreateItem(Comprables[11], GetUnitX(udg_PHero[id]), GetUnitY(udg_PHero[id])))
        else
        call UpdatePersQuest(id , Qid , Qdata[Qid] , "-" , I2S(Qdata[Qid]) , "-")
        set dx=GetUnitX(spd)
        set dy=GetUnitY(spd)
          call IssuePointOrder(erudito, "move", dx, dy)
          call SetUnitMoveSpeed(erudito, 450)
          call DisableTrigger(gg_trg_movetravelers) //for extracting
          call TriggerSleepAction(2)
          call UnitChat("..Extracting...ghghg..(*.*).." , erudito)
          call TriggerSleepAction(0.5)
          call SetUnitMoveSpeed(erudito, speed)
          call EnableTrigger(gg_trg_movetravelers)
        endif
    endif
set spd=null
set k=null
endfunction

//===========================================================================
function InitTrig_killingspiders takes nothing returns nothing
    set gg_trg_killingspiders=CreateTrigger()
    call DisableTrigger(gg_trg_killingspiders)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_killingspiders, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_killingspiders, Condition(function Trig_killingspiders_Conditions))
    call TriggerAddAction(gg_trg_killingspiders, function Trig_killingspiders_Actions)
endfunction


