//===========================================================================
// Trigger: IveorCalls
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_IveorCalls_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A0GC'
endfunction

function ivfilter takes nothing returns boolean
  local boolean a= IsUnitEnemy(GetFilterUnit(), Player(PLAYER_DARK_LORD)) == true
  local boolean b= IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true
   return a and b
endfunction


function hitiveor takes nothing returns nothing
local timer t= GetExpiredTimer()
local real x= LoadReal(questtm, GetHandleId(t), 1)
local real y= LoadReal(questtm, GetHandleId(t), 2)
local unit u= CreateUnit(Player(11), 'n08Q', x, y, GetRandomReal(0, 359))



call UnitApplyTimedLife(u, 'BTLF', 2)
call SetUnitTimeScale(u, 0.85)

set u=null
call PauseTimer(t)
call FlushChildHashtable(questtm, GetHandleId(t))
call ReleaseTimer(t)
set t=null


endfunction


function Iveorj takes nothing returns nothing
local timer t= GetExpiredTimer()
local timer tb=  (NewTimerEx(0)) // INLINED!!
local real x= GetUnitX(gg_unit_E00I_2515)
local real y= GetUnitY(gg_unit_E00I_2515)



set x=GetRandomReal(x - 1200, x + 1200)
set y=GetRandomReal(y - 1200, y + 1200)
call DestroyEffect(AddSpecialEffect(sethunder, x, y))

call SaveReal(questtm, GetHandleId(tb), 1, x)
call SaveReal(questtm, GetHandleId(tb), 2, y)
call TimerStart(tb, 0.4, false, function hitiveor)

set tb=null
set t=null


endfunction

function Trig_IveorCalls_Actions takes nothing returns nothing
local effect judge= null
local timer t= null

local boolexpr istru= Condition(function ivfilter)



call DisableTrigger(gg_trg_IveorCalls)
 call TriggerSleepAction(8)
 
  set tiveorg=CreateGroup()
 
  call GroupEnumUnitsInRange(tiveorg, GetUnitX(gg_unit_E00I_2515), GetUnitY(gg_unit_E00I_2515), 1200, istru)
  call DestroyBoolExpr(istru)
  set istru=null
  set TiveorCH=true
 
 call DestroyEffect(AddSpecialEffectTarget(seblink, gg_unit_E00I_2515, "chest"))
 call TriggerSleepAction(0.4)
 call SetUnitPosition(gg_unit_E00I_2515, GetRectCenterX(gg_rct_iveorfinal), GetRectCenterY(gg_rct_iveorfinal))
 call SetUnitAnimation(gg_unit_E00I_2515, "spell")
 call PauseUnit(gg_unit_E00I_2515, true)
 call SetUnitInvulnerable(gg_unit_E00I_2515, true)
 set judge=AddSpecialEffectTarget("SharedModels\\UBirth.mdl", gg_unit_E00I_2515, "origin")
 set t=(NewTimerEx(0)) // INLINED!!
 call TimerStart(t, 0.3, true, function Iveorj)
 call TriggerSleepAction(15)
 
 set TiveorCH=false
 call PauseTimer(t)
 call FlushChildHashtable(questtm, GetHandleId(t))
 call ReleaseTimer(t)
 set t=null
 call DestroyEffect(judge)
 set judge=null
call DestroyGroup(tiveorg)
set tiveorg=null

 
 
 call SetUnitInvulnerable(gg_unit_E00I_2515, false)
 call SetUnitAnimation(gg_unit_E00I_2515, "stand")
 call TriggerSleepAction(5)
 call PauseUnit(gg_unit_E00I_2515, false)
 
 call TriggerSleepAction(35)
 call EnableTrigger(gg_trg_IveorCalls)
endfunction

