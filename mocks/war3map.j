//===========================================================================
// Trigger: stackpotpow
//
// potions of power v healing
//===========================================================================
function stackpowc takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I0LO' )
endfunction


function stackpowa takes nothing returns nothing
    local unit u= GetTriggerUnit()
    local integer index= 0
    local integer count= 0

    loop
        if ( UnitItemInSlot(u, index) != null ) then
            set count=count + 1
        endif

        set index=index + 1
        exitwhen index >= bj_MAX_INVENTORY
    endloop
    
  if ( UnitHasItemOfTypeBJ(u, 'I0LN') == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(u, 'I0LN')
       if ( GetItemCharges(udg_tmpitem) < 20 ) then
           call SetItemCharges(udg_tmpitem, ( GetItemCharges(udg_tmpitem) + GetItemCharges(GetManipulatedItem()) ))
        endif
       
        set udg_tmpitem=null
   elseif count > 5 then
    
       call UnitAddItemById(u, 'I087')

     else
     
       call UnitAddItemById(u, 'I0LN')
     
    endif
    
    set u=null

endfunction

//===========================================================================
function InitTrig_stackpotpow takes nothing returns nothing
    set gg_trg_stackpotpow=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_stackpotpow, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_stackpotpow, Condition(function stackpowc))
    call TriggerAddAction(gg_trg_stackpotpow, function stackpowa)
endfunction


