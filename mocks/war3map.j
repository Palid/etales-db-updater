        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 7, "|cffffcc00GLOBAL QUEST COMPLETED|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "Lady Katherinne has been killed, The Bandits's Syndicate loses their political power...")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0.1, 0, 7, "|cff999999RIGOR EXTREMA TAX|r has been derogated!.")
               
      endif
call QuestSetCompleted(katherinneq, true)
call QuestItemSetCompleted(katherinneia, true)
