//===========================================================================
// Trigger: slayers
//===========================================================================
//TESH.scrollpos=85
//TESH.alwaysfold=0
function Trig_slayers_Conditions takes nothing returns boolean
    return GetSpellAbilityId() == 'A0J4'
endfunction

function slayfilter takes nothing returns boolean
    return GetUnitState(GetFilterUnit(), UNIT_STATE_LIFE) > 0.4
endfunction

function addcolor takes nothing returns nothing
  call SetUnitVertexColor(GetEnumUnit(), 10, 10, 10, vcolor)
endfunction

function vertexc takes nothing returns nothing
local timer t= GetExpiredTimer()
local group g= LoadGroupHandle(hts, GetHandleId(t), 0)
local integer c= LoadInteger(hts, GetHandleId(t), 1)

set c=c + 1
set vcolor=c * 7
call ForGroup(g, function addcolor)

call SaveInteger(hts, GetHandleId(t), 1, c)
if c > 36 then
       call FlushChildHashtable(hts, GetHandleId(t))
       call PauseTimer(t)
       call ReleaseTimer(t)
      


endif

set g=null
set t=null

endfunction

function clearslayers takes nothing returns nothing
call UnitApplyTimedLife(GetEnumUnit(), 'BTLF', 0.1)

endfunction



function Trig_slayers_Actions takes nothing returns nothing
local unit u= GetSpellAbilityUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local real x= GetUnitX(u)
local real y= GetUnitY(u)
local boolexpr filter= Condition(function slayfilter)
local group g= CreateGroup()
local unit gu= null
local unit s= null
local group slayers= CreateGroup()
local timer t= (NewTimerEx(0)) // INLINED!!
local integer c= 1

 call GroupEnumUnitsInRange(g, x, y, 600, filter)
  call DestroyBoolExpr(filter)
  set filter=null

	   loop
            set gu=FirstOfGroup(g)
              exitwhen gu == null
              
                if IsUnitEnemy(gu, Player(id)) == true and not IsUnitType(gu, UNIT_TYPE_MAGIC_IMMUNE) == true then
                //  call SetUnitPathing(gu,false)
                set c=c + 1
                set s=CreateUnit(Player(id), 'n095', x, y, 270)
                call SetUnitVertexColor(s, 10, 10, 10, 0)
                call IssueTargetOrder(s, "entanglingroots", gu)
                call GroupAddUnit(slayers, s)
                    if c > 6 then
                     call GroupClear(g)
                    endif
                endif
            call GroupRemoveUnit(g, gu)
            set gu=null
       endloop
     
     call DestroyGroup(g)
	 set g=null
 
 set c=1
 call SaveGroupHandle(hts, GetHandleId(t), 0, slayers)
 call SaveInteger(hts, GetHandleId(t), 1, c)
 
 call TimerStart(t, 0.05, true, function vertexc)

set u=null

set s=null
call TriggerSleepAction(8)
call ForGroup(slayers, function clearslayers)
call DestroyGroup(slayers)
set slayers=null

endfunction

//===========================================================================
function InitTrig_slayers takes nothing returns nothing
    set gg_trg_slayers=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_slayers, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_slayers, Condition(function Trig_slayers_Conditions))
    call TriggerAddAction(gg_trg_slayers, function Trig_slayers_Actions)
endfunction


//===========================================================================
// Trigger: Fireball
//===========================================================================
function fireballc takes nothing returns boolean
    return GetSpellAbilityId() == 'A0J0'
endfunction


function firecicle takes nothing returns nothing
local timer t= GetExpiredTimer()
local real ix= LoadReal(hts, GetHandleId(t), 1)
local real iy= LoadReal(hts, GetHandleId(t), 2)
local real angle= LoadReal(hts, GetHandleId(t), 3)
local real inc= LoadReal(hts, GetHandleId(t), 4)
local unit u= LoadUnitHandle(hts, GetHandleId(t), 5)
local real xini= LoadReal(hts, GetHandleId(t), 7) + inc
local real dist= LoadReal(hts, GetHandleId(t), 8)
local effect flame= null
local effect fire= null
local real h= GetParabolaZ(xini , dist , 50)
local integer vx= R2I(255 - ( xini / dist ) * 200)
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer c= LoadInteger(hts, GetHandleId(t), 0)

    
 set ix=ix + inc * Cos(angle * bj_DEGTORAD)
 set iy=iy + inc * Sin(angle * bj_DEGTORAD)


   if IsTerrainWalkable(ix , iy) then
       call SetUnitX(u, ix)
       call SetUnitY(u, iy)
     //  call SetUnitPosition(dummy,ix,iy)
    endif


 set c=c + 1
 
 call SaveInteger(hts, GetHandleId(t), 0, c)
    if c > 45 then
  set flame=LoadEffectHandle(hts, GetHandleId(t), 6)
    set fire=LoadEffectHandle(hts, GetHandleId(t), 9)

  
  call SetUnitPathing(u, true)
  call UnitApplyTimedLife(u, 'BTLF', 0.1)
  call DestroyEffect(flame)
  set flame=null
  call DestroyEffect(fire)
  set fire=null
  call FlushChildHashtable(hts, GetHandleId(t))
  call PauseTimer(t)
  call ReleaseTimer(t)
  
  
 else
  call SaveReal(hts, GetHandleId(t), 1, ix)
  call SaveReal(hts, GetHandleId(t), 2, iy)
  call SaveReal(hts, GetHandleId(t), 7, xini)
 endif


set t=null
set u=null

  set flame=null
  set fire=null



endfunction




function fireballa takes nothing returns nothing

 local unit a= GetSpellAbilityUnit()
 local integer id= GetPlayerId(GetOwningPlayer(a))
  //fireball unit
 local real i= GetUnitX(a)
 local real j= GetUnitY(a)
 local real xini= 1
 local real x= GetSpellTargetX()
 local real y= GetSpellTargetY()
 
 local real dx= x - i
 local real dy= y - j
 local real angle= bj_RADTODEG * Atan2(dy, dx)
 local unit u= CreateUnit(Player(id), 'n092', i, j, angle)
 local real dist= SquareRoot(dx * dx + dy * dy)
 local timer t= (NewTimerEx(0)) // INLINED!!
 local real inc= dist / 30

 local real ix= i + inc * Cos(angle * bj_DEGTORAD)
 local real iy= j + inc * Sin(angle * bj_DEGTORAD)
 local effect flame
 local effect fire
 local real inspired= 1
 local integer c= 1

  if ActSpecast(id , GetSpellAbilityId()) == true then
       set inspired=1 + s__castamount[id] * s__casttype[id]
  endif

  call SetUnitColor(u, PLAYER_COLOR_YELLOW)
  call AddSpecialEffectTarget("Light.mdx", u, "chest")

  call SaveInteger(hts, GetHandleId(t), 0, c)
  call SaveReal(hts, GetHandleId(t), 1, ix)
  call SaveReal(hts, GetHandleId(t), 2, iy)
  call SaveReal(hts, GetHandleId(t), 3, angle)
  call SaveReal(hts, GetHandleId(t), 4, inc)
  call SaveUnitHandle(hts, GetHandleId(t), 5, u)
  call SaveReal(hts, GetHandleId(t), 7, xini)
  call SaveReal(hts, GetHandleId(t), 8, dist)



  //set u = CreateUnit(Player(id),'n092',i,j,angle) //fireball unit

  call SaveReal(hts, GetHandleId(u), StringHash("fbspcast"), inspired)
  
  set fire=AddSpecialEffectTarget(burnbolt, u, "chest")
   call SaveEffectHandle(hts, GetHandleId(t), 6, fire)

  set flame=AddSpecialEffectTarget(flamefx, u, "chest")
   call SaveEffectHandle(hts, GetHandleId(t), 9, flame)

  call TimerStart(t, 0.02, true, function firecicle)

  set t=null
  set a=null
  set u=null
  set flame=null
  set fire=null

    
endfunction

