function flamesa takes nothing returns nothing
 local integer i= 0
 local unit u= GetTriggerUnit()
       //call ShowUnit( gg_unit_E00I_2515,false)
    call DisableTrigger(gg_trg_flamesq)
    call UnitChat("Long time no breath the air of this land..." , dadvar)
    call TriggerSleepAction(2.5)
    call UnitChat("But I can smell the corruption of |cffff3333Iveor|r too, He is back all these rare events." , dadvar)
    call TriggerSleepAction(4)
    call UnitChat("Sadly I see the altars have been burned out." , dadvar)
    call TriggerSleepAction(3)
    call UnitChat("Their spires are living flames, those never extincts" , dadvar)
    call TriggerSleepAction(3)
    call UnitChat("But They aren't here." , dadvar)
    call TriggerSleepAction(3)
    call UnitChat("Certainly Iveor has stolen them to take control of another creatures" , dadvar)
    call TriggerSleepAction(4)
    call UnitChat("|cffffcc00Arcane Spires|r can take life control, open dimensional portals and boost owner's abilities" , dadvar)
    call TriggerSleepAction(5)
    call UnitChat("The gods have given us these flames to make a permanently contact with them" , dadvar)
    call TriggerSleepAction(4)
    call UnitChat("It was a gift to the first king of the new Age, |cffffcc00Calemor|r the Naiar..." , dadvar)
    call TriggerSleepAction(4)
    call SetUnitFacingToFaceUnitTimed(dadvar, u, 0)
    call UnitChat("Hero... Please Recover the spires as fast as you can, There isn't time to lose." , dadvar)
    call TriggerSleepAction(4)
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffcccc00NEW WORLD QUEST|r:THE FLAMES OF ENTHASHARA")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00Recover the arcane spires and give it to Dadvar to activate the altars.")
  //  call StartSound(bj_questCompletedSound )
    call QuestSetDiscovered(etflameq, true)
    if ( IsPlayerInForce(GetLocalPlayer(), GetPlayersAll()) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
                call PingMinimap(- 8790, 7640, 16)
                call PingMinimap(- 1430, - 9190, 8)
                call PingMinimap(14250, 3190, 8)
        //call StartSound(bj_pingMinimapSound)
        endif
     call ShowUnit(madancient, true)
  //  call ShowUnit(arcanehydra,false)
  //  call ShowUnit(winterkeeper,false)
   // call TriggerSleepAction(8)
    
    set u=null

endfunction

