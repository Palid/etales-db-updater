//
// Magnum Break Trigger
//===========================================================================
function MBTC takes nothing returns boolean
    return GetSpellAbilityId() == 'A00N'
endfunction

function Enemy takes nothing returns boolean
    return ( IsPlayerEnemy(GetOwningPlayer(GetFilterUnit()), GetOwningPlayer(GetTriggerUnit())) == true )
endfunction


function displace takes nothing returns nothing
    call TriggerRegisterUnitEvent(gg_trg_MBA, GetEnumUnit(), EVENT_UNIT_DAMAGED)
    call DestroyEffectBJ(AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Spells\\Other\\Incinerate\\FireLordDeathExplode.mdl"))
    call UnitDamageTargetBJ(udg_mbreakunit, GetEnumUnit(), ( I2R(GetHeroStatBJ(bj_HEROSTAT_STR, udg_mbreakunit, true)) * 5.00 ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)

endfunction

function MBTA takes nothing returns nothing
local boolexpr istru=  Condition(function Enemy)
    set udg_mbreakunit=GetSpellAbilityUnit()
    set udg_tmp2=GetUnitLoc(udg_mbreakunit)
    
   
    set udg_tmpgrop1=GetUnitsInRangeOfLocMatching(350.00, udg_tmp2, istru)
    call DestroyBoolExpr(istru)
    set istru=null
    

    call ForGroupBJ(udg_tmpgrop1, function displace)
    call RemoveLocation(udg_tmp2)
    set udg_tmp2=null
    set udg_mbreakunit=null
    call DestroyGroup(udg_tmpgrop1)
    set udg_tmpgrop1=null
    
endfunction

