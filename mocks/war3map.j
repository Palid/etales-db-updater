call UnitRemoveAbility(GetEnumUnit(), 'Ashm') //remove shadow meld for tax bandts
endfunction


function Trig_init_Actions takes nothing returns nothing
    local integer i= 0
    local rect r= null
    local boolexpr filter= null
  
       //Initialize Hashtables
       //  call TriggerSleepAction(0.05)
         
    set udg_cache=InitHashtable()
    set udg_Spawhash=InitHashtable()
    set udg_ItemStatHash=InitHashtable()
    set udg_itempoolhash=InitHashtable()
    set udg_MG1Hash=InitHashtable()
    set udg_spelledh=InitHashtable()
    set questtm=InitHashtable()
    set nodump=InitHashtable()
    set herohash=InitHashtable()
    set AiHash=InitHashtable()
    //Flags
   set teamA=CreateForce()
   set teamB=CreateForce()
   
   
      loop
