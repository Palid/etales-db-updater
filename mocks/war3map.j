endfunction

function Trig_Slaves_Actions takes nothing returns nothing
    local integer i= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
    local real x= GetOrderPointX() + 500
    local real y= GetOrderPointY() + 500
    local real x2= x - 1000
    local real y2= y - 1000

    call IssuePointOrder(udg_Slave[i], "move", GetRandomReal(x2, x), GetRandomReal(y2, y))


endfunction

