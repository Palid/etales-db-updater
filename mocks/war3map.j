function lofa takes nothing returns nothing
local integer j= 0
    
  loop
    exitwhen j > 23
    
      if ( GetPlayerSlotState(Player(j)) == PLAYER_SLOT_STATE_PLAYING ) then
       call DestroyEffect(lights[j])
        set lights[j]=null
      endif
    
    set j=j + 1
    endloop
   
