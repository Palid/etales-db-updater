  else
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00The Trader says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Don't lie me... You don't have the required amount..")
  endif
  
set itm=null
endfunction

