function falena takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
 local item itm
 local real x= GetUnitX(GetTriggerUnit())
 local real y= GetUnitY(GetTriggerUnit())
 
   if ( GemVar_A[id] >= 150 ) then
  
    set itm=CreateItem('I0UI', x, y) //rare chest
      call UnitAddItem(GetTriggerUnit(), itm)
      set GemVar_A[id]=GemVar_A[id] - 150
     
        call RemoveItemFromStock(udg_MAVault[id], 'I0UH')
        call AddItemToStock(udg_MAVault[id], 'I0UH', GemVar_A[id], GemVar_A[id])
       
      
      
      
  else
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "|cffffcc00The Trader says:|r")
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 4, "    Don't lie me... You don't have the required amount..")
  endif
  
set itm=null
endfunction

