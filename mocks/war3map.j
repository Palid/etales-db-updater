function ActSpecast takes integer id,integer abilcode returns boolean
local real base= 1.1 + ( ( s__Fortune[id] * globalFortune ) + s__Mstrength[id] ) / ( 1 + ( s__Fortune[id] * globalFortune ) )
local boolean chance= ( I2R(s__Fortune[id]) * globalFortune ) / 30 > GetRandomReal(1, 100)

if chance == true then
 // set casttype[id] = R2I(logg(base,GetRandomReal(Fortune[id],100+Fortune[id]+Mstrength[id])))
      set s__casttype[id]= R2I(GetRandomReal(1, logg(base , 100 + s__Fortune[id] + s__Mstrength[id])))
      if s__casttype[id] < 3 then
        set s__casttype[id]= 3
      endif
      if s__casttype[id] > 9 then
        set s__casttype[id]= 9
      endif
      
      set s__castamount[id]= I2R(s__Mstrength[id]) / 1447
      
       if s__castamount[id] < 0.01 then
         set s__castamount[id]= 0.01
       endif
      
       call SpellName(s__castname[s__casttype[id]] + GetObjectName(abilcode) + "!!" , udg_PHero[id] , I2R(s__casttype[id]))
      call DestroyEffect(AddSpecialEffectTarget(s__castfx[s__casttype[id]], udg_PHero[id], "origin"))
      
else
      set s__casttype[id]= 1
endif

//call DisplayTimedTextToPlayer(Player(id),0,0, 1.5, " Cons: "+I2S(Constitution[id])+"  Mstr: "+I2S(Mstrength[id])+" Ctype: "+I2S(casttype[id])+" Luck: "+I2S(Fortune[id])+".")  

return chance
endfunction
   

   

function CleanState takes integer id,integer state returns nothing
local real movespd
local integer i= 0
local integer drunken= 0

if s__altstatelvl[(id)*(10)+state] < 1 then
 return
endif

//set dstate[id] = cups[id]/4 + 1
           if state == LUCK then
               
                set s__Fortune[id]= s__Fortune[id] - s__altstate[(id)*(10)+state]
                call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) - s__altstate[(id)*(10)+STR], true)
               
               set s__altstate[(id)*(10)+STR]= s__altstate[(id)*(10)+STR] + s__altstate[(id)*(10)+state]
              
                set s__altstate[(id)*(10)+state]= 0
               
                call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) + s__altstate[(id)*(10)+STR], true)
        
            elseif state == MSTR then
                set s__Mstrength[id]= s__Mstrength[id] - s__altstate[(id)*(10)+state]
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) - s__altstate[(id)*(10)+AGI], true)
                
                set s__altstate[(id)*(10)+AGI]= s__altstate[(id)*(10)+AGI] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= 0
                
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) + s__altstate[(id)*(10)+AGI], true)
                
             elseif state == CONS then
                set s__Constitution[id]= s__Constitution[id] - s__altstate[(id)*(10)+state]
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) - s__altstate[(id)*(10)+INT], true)
                
                set s__altstate[(id)*(10)+INT]= s__altstate[(id)*(10)+INT] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= 0
               
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) + s__altstate[(id)*(10)+INT], true)
                
            elseif state == MSPD then
                set movespd=GetUnitDefaultMoveSpeed(udg_PHero[id])
                  
                call SetUnitMoveSpeed(udg_PHero[id], movespd + s__initspeed[id])
                set s__initspeed[id]= 0
                
                call UnitRemoveAbility(udg_PHero[id], ARMOR)
               
        
                set s__altstate[(id)*(10)+DEF]= s__altstate[(id)*(10)+DEF] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= 0
                
            elseif state == INT then
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) - s__altstate[(id)*(10)+state], true)
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) - s__altstate[(id)*(10)+AGI], true)
                
                set s__altstate[(id)*(10)+AGI]= s__altstate[(id)*(10)+AGI] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= 0
                
                call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) + s__altstate[(id)*(10)+AGI], true)
            
            elseif state == AGI then
               
               call SetHeroAgi(udg_PHero[id], GetHeroAgi(udg_PHero[id], false) - s__altstate[(id)*(10)+state], true)
               call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) - s__altstate[(id)*(10)+STR], true)
               
                set s__altstate[(id)*(10)+STR]= s__altstate[(id)*(10)+STR] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= 0
                 
              
               call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) + s__altstate[(id)*(10)+STR], true)
               
            elseif state == STR then
                call SetHeroStr(udg_PHero[id], GetHeroStr(udg_PHero[id], false) - s__altstate[(id)*(10)+state], true)
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) - s__altstate[(id)*(10)+INT], true)
                
                 set s__altstate[(id)*(10)+INT]= s__altstate[(id)*(10)+INT] + s__altstate[(id)*(10)+state]
                 set s__altstate[(id)*(10)+state]= 0
           
                call SetHeroInt(udg_PHero[id], GetHeroInt(udg_PHero[id], false) + s__altstate[(id)*(10)+INT], true)
            
            elseif state == HITP then
            
                call UnitRemoveAbility(udg_PHero[id], s__HITSP[1])
                call UnitRemoveAbility(udg_PHero[id], s__HITSP[2])
                call UnitRemoveAbility(udg_PHero[id], s__HITSP[3])
                call UnitRemoveAbility(udg_PHero[id], s__HITSP[4])
                call UnitRemoveAbility(udg_PHero[id], s__HITSP[5])
                    
                set s__Fortune[id]= s__Fortune[id] - s__altstate[(id)*(10)+LUCK]
                
                set s__altstate[(id)*(10)+LUCK]= s__altstate[(id)*(10)+LUCK] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= 0
                
                set s__Fortune[id]= s__Fortune[id] + s__altstate[(id)*(10)+LUCK]
                
                
            elseif state == DEF then
            
                call UnitRemoveAbility(udg_PHero[id], ARMOR)
                set s__Mstrength[id]= s__Mstrength[id] - s__altstate[(id)*(10)+MSTR]
                
                set s__altstate[(id)*(10)+MSTR]= s__altstate[(id)*(10)+MSTR] + s__altstate[(id)*(10)+state]
                set s__altstate[(id)*(10)+state]= 0
                 
               
                set s__Mstrength[id]= s__Mstrength[id] + s__altstate[(id)*(10)+MSTR]
            
            
            endif
         
   // set altstate[id][state] = 0
    set s__altstatedur[(id)*(10)+state]= 0
    set s__curstatedur[(id)*(10)+state]= 0
    set s__altstatelvl[(id)*(10)+state]= 0
    //set cups[id] = 0
    loop
    exitwhen i > 9
        if s__altstate[(id)*(10)+i] != 0 then
         set drunken=drunken + 1
        endif
        set i=i + 1
    endloop
    
    if drunken < 1 then
        set s__cups[id]= 0
        set s__dstate[id]= 0
        set s__AltStDmg[id]= false
        set s__AltStVis[id]= false
        set s__AltStMov[id]= false
        set s__AltStEva[id]= false
        call UnitRemoveAbility(udg_PHero[id], DRUNKEN)
   endif
    
endfunction



function CleanAllStates takes integer id returns nothing


    call CleanState(id , LUCK)
        call TriggerSleepAction(0.01)
    call CleanState(id , MSTR)
       call TriggerSleepAction(0.01)
    call CleanState(id , CONS)
      call TriggerSleepAction(0.01)
    call CleanState(id , MSPD)
      call TriggerSleepAction(0.01)
    call CleanState(id , INT)
      call TriggerSleepAction(0.01)
    call CleanState(id , STR)
       call TriggerSleepAction(0.01)
    call CleanState(id , AGI)
      call TriggerSleepAction(0.01)
    call CleanState(id , HITP)
       call TriggerSleepAction(0.01)
    call CleanState(id , DEF)
      

endfunction


