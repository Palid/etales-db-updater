           // call UpdatePersQuestND(id,Qid,Qdata[Qid],"-","-","-")
            call RemoveQuestFromPlayer(Qid , Id)
            
 call UnitChat("Ok... Let see" , erudito)
 call TriggerSleepAction(3)
