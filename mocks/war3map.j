function InitTrig_ogrenull takes nothing returns nothing
    set gg_trg_ogrenull=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ogrenull, EVENT_PLAYER_UNIT_DEATH)
