function Trig_gruntbrother_Conditions takes nothing returns boolean
    return ( orcadviced[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))] == true and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_gruntbrother_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer questid
    set orcadviced[id]=false
     call SetUnitFacingToFaceUnitTimed(gg_unit_h01W_0106, udg_PHero[id], 0)
    call UnitChat("Wut?, my brother send you for grunt request?" , gg_unit_h01W_0106)
    call TriggerSleepAction(4)
    call UnitChat("Yes, me want become more stronger" , udg_PHero[id])
    call TriggerSleepAction(3)
    call SetUnitFacingToFaceUnitTimed(gg_unit_h01W_0106, udg_PHero[id], 0)
    call UnitChat("Elder want new warriors, We are a new tribe. " , gg_unit_h01W_0106)
    call TriggerSleepAction(4)
    call UnitChat("We live in peace with humans, but take care " , gg_unit_h01W_0106)
    call TriggerSleepAction(4)
    call UnitChat("In the fields there are another orcs, They are our enemies" , gg_unit_h01W_0106)
    call TriggerSleepAction(4)
    call UnitChat("Our enemies?, why" , udg_PHero[id])
    call TriggerSleepAction(3)
    call SetUnitFacingToFaceUnitTimed(gg_unit_h01W_0106, udg_PHero[id], 0)
    call UnitChat("They treat us as traitors. don't listen their words" , gg_unit_h01W_0106)
    call TriggerSleepAction(3)
    call UnitChat("They will kill you if you walk in The Northlands." , gg_unit_h01W_0106)
    call TriggerSleepAction(3)
    call SetUnitFacingToFaceUnitTimed(gg_unit_h01W_0106, udg_PHero[id], 0)
    call UnitChat("Go to talk with the elder, he live in a cave in the Northlands." , gg_unit_h01W_0106)
    call TriggerSleepAction(4)
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "|cffffcc00MAIN QUEST UPDATE|r: Seeking your own fate")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 3, "     Go to talk with the Elder in the cave...")
    set questid=LoadInteger(udg_cache, GetHandleId(udg_inTest), GetHandleId(udg_PHero[id]))
    call UpdatePersQuestND(id , questid , 0 , "Go to talk with the Elder in the cave..." , "-" , "-")
               
    
    call StartSound(bj_questDiscoveredSound)
     if ( GetLocalPlayer() == Player(id) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call PingMinimap(5433, 14692, 10)
        //call StartSound(bj_pingMinimapSound)
    endif

    set broadviced[id]=true
    call TriggerSleepAction(3)
    
endfunction

