          call CreateRat(giantratID , GetRandomReal(minXMRR, maxXMRR) , GetRandomReal(minYMRR, maxYMRR))
          call CreateRat(giantratID , GetRandomReal(minXMRR, maxXMRR) , GetRandomReal(minYMRR, maxYMRR))
          call CreateRat(ratID , GetRandomReal(minXMRR, maxXMRR) , GetRandomReal(minYMRR, maxYMRR))
     endif
