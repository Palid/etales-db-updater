    call TriggerRegisterEnterRectSimple(gg_trg_activeincident, gg_rct_valdvia_incident)
    call TriggerAddCondition(gg_trg_activeincident, Condition(function Trig_activeincident_Conditions))
    call TriggerAddAction(gg_trg_activeincident, function Trig_activeincident_Actions)
