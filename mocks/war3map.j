endfunction


//===========================================================================
// Trigger: enablebh
//===========================================================================
//TESH.scrollpos=6
//TESH.alwaysfold=0
function Trig_enablebh_Conditions takes nothing returns boolean
     return GetItemTypeId(GetManipulatedItem()) == 'I063' and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_enablebh_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
local integer lev= GetUnitPointValue(u) - 100
    
    if udg_Faction[id] == 4 then
     call UnitChat("Thanks for enter into the Brotherhood. You are part of my hope" , drako)
    elseif bhrequest[id] == true then
    
    call UnitChat("What are you doing here?... Quickly warrior!, we have no time to lose..." , drako)
    
    elseif ( GetUnitUserData(GetTriggerUnit()) < 6480 ) then
            call UnitChat("This place isn't for you |cffff3333(6480 kills required)|r" , drako)

    elseif ( 40 < lev ) then
    
            call UnitChat("How do you know about this place?" , drako)
            call TriggerSleepAction(2.5)
            call UnitChat("Ankalia told me about the resistence..." , u)
            call TriggerSleepAction(2.5)
            call UnitChat("Uhm... I don't know that -Ankalia- but If she isn't against us then" , drako)
            call TriggerSleepAction(4)
            call UnitChat("I will give credits to your words. We need strong people like you here" , drako)
            call TriggerSleepAction(2)
            call UnitChat("Are you creating an army?" , u)
            call TriggerSleepAction(2.5)
            call UnitChat("Certainly not..." , drako)
            call TriggerSleepAction(2.5)
            call UnitChat("We are dealing with a superior power" , drako)
            call TriggerSleepAction(3.5)
            call UnitChat("Common swords and axes are useless against him" , drako)
            call TriggerSleepAction(2)
            call UnitChat("What? (joking), perhaps Is he a demigod?" , u)
            call TriggerSleepAction(2)
            call UnitChat("Well, If his name is true, then he is the Arcane Sun Father" , drako)
            call TriggerSleepAction(2.5)
            call UnitChat("..." , u)
            call TriggerSleepAction(2.5)
            call UnitChat("For law, we... the Black Hand brotherhood are secret keepers of the Enthashara's Monarchy" , drako)
            call TriggerSleepAction(4)
            call UnitChat("But that mission requires divine recognition" , drako)
            call TriggerSleepAction(3)
            call UnitChat("Today, Enthashara hasn't king" , drako)
            call TriggerSleepAction(2.5)
            call UnitChat("and Iveor has used it to take control of the brotherhood" , drako)
            call TriggerSleepAction(3.4)
            call UnitChat("Some of us are according to follow Iveor..." , drako)
            call TriggerSleepAction(3.4)
            call UnitChat("Some of us are misers those want own fortune growth ." , drako)
            call TriggerSleepAction(3.4)
            call UnitChat("And some of us wait for the true king..." , drako)
            call TriggerSleepAction(3.4)
            call UnitChat("That is the reason because our loyalty has been questioned" , drako)
            call TriggerSleepAction(2.5)
            call UnitChat("I understand. What must I do?..." , u)
            call TriggerSleepAction(2.5)
            call UnitChat("you must first be recognized by the brotherhood" , drako)
            call TriggerSleepAction(3.6)
            call UnitChat("This condition will give you a special skill that allows to handle battles against mighty enemies" , drako)
            call TriggerSleepAction(5)
            call UnitChat("Unfortunately the person that has the power of invest you is a corrupted chancellor" , drako)
            call TriggerSleepAction(4)
            call UnitChat("Who is found in the underground of the sanctuary" , drako)
            call TriggerSleepAction(3)
            call UnitChat("He's a dirty bastard who seeks his own benefit" , drako)
            call TriggerSleepAction(3)
            call UnitChat("but with a good bribe you can take the recognition" , drako)
            call TriggerSleepAction(3)
            call UnitChat("Make sure you have more than |cffffcc00161803|r gold" , drako)
            call TriggerSleepAction(2)
            set bhrequest[id]=true
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "LAST CLASS MISSION")
            call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, bj_TEXT_DELAY_QUESTREQUIREMENT, "Reach to the Black Hand Chancelor...")
            
            call StartSound(bj_questDiscoveredSound)
    else
       call UnitChat("You're losing your time here" , drako)
    endif
        
set u=null
endfunction

//===========================================================================
function InitTrig_enablebh takes nothing returns nothing
    set gg_trg_enablebh=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_enablebh, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_enablebh, Condition(function Trig_enablebh_Conditions))
    call TriggerAddAction(gg_trg_enablebh, function Trig_enablebh_Actions)
endfunction


//===========================================================================
// Trigger: investBH
//===========================================================================
//TESH.scrollpos=0
//TESH.alwaysfold=0
function Trig_investBH_Conditions takes nothing returns boolean
    return IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true
endfunction

function Trig_investBH_Actions takes nothing returns nothing
local unit u= GetTriggerUnit()
local integer id= GetPlayerId(GetOwningPlayer(u))
call DisableTrigger(gg_trg_investBH)

    if bhrequest[id] == false then
        call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 6, "The chancellor ignores you...")
        call TriggerSleepAction(5)
     elseif GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) < 161803 then
       call UnitChat("Guards!!!, we have a poor rat here! (not enought money)" , chancellor)
       call TriggerSleepAction(5)
     else
        call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 6, "The chancellor checks your aspect.")
        call TriggerSleepAction(4)
        call UnitChat("So... you come to enter into the Black hand brotherhood?" , chancellor)
        call TriggerSleepAction(3)
        call UnitChat("yes!! I want to serve into this prestigious entity..." , u)
        call TriggerSleepAction(3)
        call UnitChat("Come on... Less words and more gold! Give me the money" , chancellor)
        call TriggerSleepAction(3)
        call UnitChat("..." , u)
        call TriggerSleepAction(3)
        call DisplayTimedTextToPlayer(GetOwningPlayer(u), 0, 0, 6, "You give |cffffcc00161803|r gold to the chancellor")
        call SetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(Player(id), PLAYER_STATE_RESOURCE_GOLD) - 161803)
        call TriggerSleepAction(3)
        call UnitChat("Well that is enought...I invest you as |cffffcc00Black Hand Server|r" , chancellor)
        call TriggerSleepAction(2)
        
        call UnitRemoveAbility(u, 'A0CX') //ancient core
        call UnitRemoveAbility(u, 'A02L') //wolffang
        call UnitRemoveAbility(u, 'A054') //ekrom
        call UnitAddAbility(u, 'A0EW') //relocation
        call UnitAddAbility(u, 'A0FQ') //black hand
        set udg_Faction[id]=4
        
        call DestroyEffect(AddSpecialEffectTarget(blessunit, u, "origin"))
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00LAST CLASS QUEST COMPLETED|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "You are regular member of Black Hand Brotherhood")
        call StartSound(bj_questCompletedSound)
        
        call TriggerSleepAction(6)
        call UnitChat("Now get out of my face.. I have another bussines to attend" , chancellor)
    endif

set u=null
call EnableTrigger(gg_trg_investBH)
endfunction

//===========================================================================
function InitTrig_investBH takes nothing returns nothing
    set gg_trg_investBH=CreateTrigger()
    call TriggerRegisterUnitInRangeSimple(gg_trg_investBH, 256, gg_unit_n04X_0858)
    call TriggerAddCondition(gg_trg_investBH, Condition(function Trig_investBH_Conditions))
    call TriggerAddAction(gg_trg_investBH, function Trig_investBH_Actions)
endfunction


