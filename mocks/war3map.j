function InitTrig_exetacle takes nothing returns nothing
    set gg_trg_exetacle=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_exetacle, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_exetacle, Condition(function ETACC))
    call TriggerAddAction(gg_trg_exetacle, function ETACA)
endfunction


