//===========================================================================
// Trigger: IveorMove
//===========================================================================
function Trig_IveorMovement_Conditions takes nothing returns boolean
 local boolean a= IsUnitType(GetOrderedUnit(), UNIT_TYPE_HERO) == true
 local boolean b= IsUnitInGroup(GetOrderedUnit(), tiveorg) == true
 
    return TiveorCH and a and b
    
endfunction

function Trig_IveorMovement_Actions takes nothing returns nothing
 local integer id= GetPlayerId(GetOwningPlayer(GetOrderedUnit()))


local real x= GetOrderPointX()
local real y= GetOrderPointY()
local unit u= null
local real delay= GetRandomReal(0.1, 0.6)

call DisableTrigger(tiveormoves[id])
call TriggerSleepAction(delay)

call DestroyEffect(AddSpecialEffect(sffectdusta, x, y))
call TriggerSleepAction(0.7)

set u=CreateUnit(Player(11), 'n08Q', x, y, GetRandomReal(0, 359))
call UnitApplyTimedLife(u, 'BTLF', 1.6)
call SetUnitTimeScale(u, 0.85)


set u=null
call TriggerSleepAction(1)
call EnableTrigger(tiveormoves[id])


endfunction

