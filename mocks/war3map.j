function InitTrig_chuckdrop takes nothing returns nothing
    set gg_trg_chuckdrop=CreateTrigger()
    call TriggerAddAction(gg_trg_chuckdrop, function Trig_chuckdrop_Actions)
endfunction


//===========================================================================
// Trigger: sfjewel
//===========================================================================
function Trig_sfjewel_Conditions takes nothing returns boolean
    return ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_CHARGED )
endfunction

function Trig_sfjewel_Actions takes nothing returns nothing
 local unit u= GetTriggerUnit()
 local integer dmp= LoadInteger(nodump, GetHandleId(GetManipulatedItem()), GetHandleId(GetManipulatedItem()))
 local integer id= GetPlayerId(GetOwningPlayer(u))
 local boolean owner= dmp - 10 == id
 
 
 if u == udg_forger or u == mdruid then
 set u=null
 return
 endif
 
 if ( dmp > 9 and owner == false ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, GetManipulatedItem())

     set u=null
     return
   endif
    call PlaySoundOnUnitBJ(gg_snd_pickup, 100, u)
    set u=null
endfunction

