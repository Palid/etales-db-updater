function shakebattle takes integer pid,integer did,real d,unit u returns nothing
local real l__l= 1

     
     set d=d * l__l
     if d > noise then
     set d=noise
     endif
     
    set d=d * hit[pid] //0.6 - 0.8 - 1
     
     
       if ( GetLocalPlayer() == Player(pid) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call CameraSetTargetNoiseEx(( d / 100 ) * 2.0, d / 200 * Pow(10, d / 200), false)
         call CameraSetSourceNoiseEx(2 * 2.0, 3 * Pow(10, 2), false)
      endif
      if ( GetLocalPlayer() == Player(did) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
         call CameraSetTargetNoiseEx(( d / 100 ) * 2.0, d / 200 * Pow(10, d / 200), false)
         call CameraSetSourceNoiseEx(2 * 2.0, 3 * Pow(10, 2), false)
      endif
        call TriggerSleepAction(miles)
       //call TriggerSleepAction(d/20000)
      if ( GetLocalPlayer() == Player(pid) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
      endif
     if ( GetLocalPlayer() == Player(did) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call CameraSetSourceNoise(0, 0)
        call CameraSetTargetNoise(0, 0)
      endif
      
      set hit[pid]=hit[pid] + 0.1
       if hit[pid] > 1 then //GetUnitState(u,UNIT_STATE_LIFE)<1 or 
       set hit[pid]=0.4
    endif

endfunction



