            call CreateRat(giantratID , GetRandomReal(minXERR, maxXERR) , GetRandomReal(minYERR, maxYERR))
            call CreateRat(blackratID , GetRandomReal(minXERR, maxXERR) , GetRandomReal(minYERR, maxYERR))
        endif
      
endfunction


function enablecella takes nothing returns nothing
local integer i= 0
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))

if GetUnitLevel(GetManipulatingUnit()) > 15 then
   
    call UnitChat("Excuse me sir, I cannot hire your services" , shydealer)
    call TriggerSleepAction(3)
    call UnitChat("Don't waste your precious time here |cffaaaaaa(max lev required = 15)|r" , shydealer)
elseif AlreadyIncellar[id] == true then
    return
  
elseif HeroIncellar > 0 then
    set AlreadyIncellar[id]=true
    set HeroIncellar=HeroIncellar + 1
    call GroupAddUnit(ratheroes, udg_PHero[id])
    call TriggerSleepAction(0.4)
  
    call UnitChat("Hurry! Help the others to kill all those dirty rats!!! (>_<)" , shydealer)
    loop
    exitwhen i > 8
    
     if AlreadyIncellar[i] == true then
          call DisplayTimedTextToPlayer(Player(i), 0, 0, 3, "|cffffcc00Warning!!!|r the number of rats in cellars has grown")
     endif
    
    set i=i + 1
    endloop
     call SetupRats()


else
    set extrarats=true
    set AlreadyIncellar[id]=true
    set HeroIncellar=HeroIncellar + 1
    call GroupAddUnit(ratheroes, udg_PHero[id])
    call TriggerSleepAction(0.4)
  
    call UnitChat("Hurry! clean cellar's rooms, you will need to open all doors. I cannot remember where I dropped my keydoors. At least they are somewhere in Velhilmen..:$" , shydealer)

   
    
    
  set Entrada[163]=gg_rct_cellar1in
  set Salida[163]=gg_rct_cellar1out
  call rundungeon(163)
    
    call CreateUnit(Player(10), 'n06P', - 13250, 11910, 45)
    
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "|cffffcc00NEW QUEST DISCOVERED:|r")
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "        Clean |cffffcc00Velhilmen's cellars|r from all rats hidden in|r.")
    call StartSound(bj_questDiscoveredSound)
    call QuestSetDiscovered(cellarq, true)
    call SetupRats()
    endif

endfunction

