// ============================================================
// Helper Structs (For [][], .col[], .row[], etc)
// ============================================================

    function s__Board___ItemHelper__getindex takes integer this,integer row returns integer
        local integer col= s__Board_Board___bTemp
        
        if row < 0 then
            return 0
        elseif col < 0 then
            return 0
        endif
        //i = brd * 10000 + row * 100 + col
        
        if col >= s__Board_Board___bColCount[(this)] then
            call MultiboardSetColumnCount(s__Board_Board___bBoard[(this)], col + 1)
            set s__Board_Board___bColCount[(this)]=col + 1
        endif
        
        if row >= s__Board_Board___bRowCount[(this)] then
            call MultiboardSetRowCount(s__Board_Board___bBoard[(this)], row + 1)
            set s__Board_Board___bRowCount[(this)]=row + 1
        endif
        
        return (this) * 10000 + row * 100 + s__Board_Board___bTemp
    endfunction

    function s__Board___RowHelper__get_count takes integer this returns integer
        return s__Board_Board___bRowCount[(this)]
    endfunction
    function s__Board___RowHelper__set_count takes integer this,integer i returns nothing
        call MultiboardSetRowCount(s__Board_Board___bBoard[(this)], i + 1)
        set s__Board_Board___bRowCount[(this)]=i + 1
    endfunction
    
    function s__Board___RowHelper__getindex takes integer this,integer row returns integer
        if row < 0 then
            return 0
        endif
        
        if row >= s__Board_Board___bRowCount[(this)] then
            call MultiboardSetRowCount(s__Board_Board___bBoard[(this)], row + 1)
            set s__Board_Board___bRowCount[(this)]=row + 1
        endif
        
        if s__Board_Board___bColCount[(this)] < 1 then
            call MultiboardSetColumnCount(s__Board_Board___bBoard[(this)], 1)
            set s__Board_Board___bColCount[(this)]=1
        endif
        
        return (row + (this) * 100)
    endfunction

    function s__Board___ColumnHelper__get_count takes integer this returns integer
        return s__Board_Board___bColCount[(this)]
    endfunction
    function s__Board___ColumnHelper__set_count takes integer this,integer i returns nothing
        call MultiboardSetColumnCount(s__Board_Board___bBoard[(this)], i + 1)
        set s__Board_Board___bColCount[(this)]=i + 1
    endfunction
    
    function s__Board___ColumnHelper__getindex takes integer this,integer col returns integer
        if col < 0 then
            return 0
        endif
        
        if col >= s__Board_Board___bColCount[(this)] then
            call MultiboardSetColumnCount(s__Board_Board___bBoard[(this)], col + 1)
            set s__Board_Board___bColCount[(this)]=col + 1
        endif
        
        if s__Board_Board___bRowCount[(this)] < 1 then
            call MultiboardSetRowCount(s__Board_Board___bBoard[(this)], 1)
            set s__Board_Board___bRowCount[(this)]=1
        endif
        
        return (col + (this) * 100)
    endfunction

    function s__Board___VisibleHelper__setindex takes integer this,player p,boolean b returns nothing
        if GetPlayerId(p) > 11 then
            return
        endif
        
        set s___Board_Board___bVisibleFor[s__Board_Board___bVisibleFor[(this)]+GetPlayerId(p)]=b
        
        if GetLocalPlayer() == p then
            call MultiboardDisplay(s__Board_Board___bBoard[(this)], b)
        endif
    endfunction
    function s__Board___VisibleHelper__getindex takes integer this,player p returns boolean
        if GetPlayerId(p) > 11 then
            return false
        endif
        
        return s___Board_Board___bVisibleFor[s__Board_Board___bVisibleFor[(this)]+GetPlayerId(p)]
    endfunction

    function s__Board___MinimizedHelper__setindex takes integer this,player p,boolean b returns nothing
        if GetPlayerId(p) > 11 then
            return
        endif
        
        if GetLocalPlayer() == p then
            call MultiboardMinimize(s__Board_Board___bBoard[(this)], b)
        endif
    endfunction

    function s__Board___AllHelper__set_text takes integer this,string val returns nothing
        call MultiboardSetItemsValue(s__Board_Board___bBoard[(this)], val)
    endfunction
    
    function s__Board___AllHelper__set_icon takes integer this,string val returns nothing
        call MultiboardSetItemsIcon(s__Board_Board___bBoard[(this)], val)
    endfunction
    
    function s__Board___AllHelper__set_color takes integer this,integer c returns nothing
        call MultiboardSetItemsValueColor(s__Board_Board___bBoard[(this)], s__ARGB__get_red(c), s__ARGB__get_green(c), s__ARGB__get_blue(c), s__ARGB__get_alpha(c))
    endfunction
    
    function s__Board___AllHelper__set_width takes integer this,real r returns nothing
        call MultiboardSetItemsWidth(s__Board_Board___bBoard[(this)], r)
    endfunction
    
    function s__Board___AllHelper_setDisplay takes integer this,boolean text,boolean icon returns nothing
        call MultiboardSetItemsStyle(s__Board_Board___bBoard[(this)], text, icon)
    endfunction

// ============================================================
// Board Struct
// ============================================================

    
    
    
    
    function s__Board_create takes nothing returns integer
        local integer this= s__Board__allocate()
        
        set s__Board_Board___bBoard[this]=CreateMultiboard()
        
        call MultiboardSetItemsWidth(s__Board_Board___bBoard[this], 0.01)
        call MultiboardSetItemsStyle(s__Board_Board___bBoard[this], true, false)
        
        return this
    endfunction
    
    function s__Board_onDestroy takes integer this returns nothing
        call DestroyMultiboard(s__Board_Board___bBoard[this])
        set s__Board_Board___bBoard[this]=null
    endfunction

//Generated destructor of Board
function s__Board_deallocate takes integer this returns nothing
    if this==null then
        return
    elseif (si__Board_V[this]!=-1) then
        return
    endif
    call s__Board_onDestroy(this)
    set si__Board_V[this]=si__Board_F
    set si__Board_F=this
endfunction
    
    //==================
    
    function s__Board__getindex takes integer this,integer column returns integer
        set s__Board_Board___bTemp=column
        return (this)
    endfunction
    
    function s__Board__get_col takes integer this returns integer
        return (this)
    endfunction
    
    function s__Board__get_row takes integer this returns integer
        return (this)
    endfunction
    
    //==================
    
    function s__Board__get_all takes integer this returns integer
        return (this)
    endfunction
    
    function s__Board__set_title takes integer this,string value returns nothing
        call MultiboardSetTitleText(s__Board_Board___bBoard[this], value)
    endfunction
    
    function s__Board__set_titleColor takes integer this,integer color returns nothing
        call MultiboardSetTitleTextColor(s__Board_Board___bBoard[this], s__ARGB__get_red(color), s__ARGB__get_green(color), s__ARGB__get_blue(color), s__ARGB__get_alpha(color))
    endfunction
    
    function s__Board__get_visible takes integer this returns integer
        return (this)
    endfunction
    function s__Board__set_visible takes integer this,boolean b returns nothing
        local integer i= 0
        loop
            exitwhen i == 12
            
            set s___Board_Board___bVisibleFor[s__Board_Board___bVisibleFor[this]+i]=b
            
            set i=i + 1
        endloop
        
        call MultiboardDisplay(s__Board_Board___bBoard[this], b)
    endfunction
    
    function s__Board__get_minimized takes integer this returns integer
        return (this)
    endfunction
    function s__Board__set_minimized takes integer this,boolean b returns nothing
        call MultiboardMinimize(s__Board_Board___bBoard[this], b)
    endfunction
    
    function s__Board_clear takes integer this returns nothing
        call MultiboardClear(s__Board_Board___bBoard[this])
    endfunction


//library Board ends
//library itemglobal:


function EnableArmor takes unit u,item it,integer id returns nothing

 //local unit u = GetTriggerUnit()
 //local integer itemlevel = GetItemLevel(GetManipulatedItem())
 // local integer id = GetPlayerId(GetOwningPlayer(u))
 local integer itemlevel= GetItemLevel(it)
 local integer islevel=  ( ( ( ( itemlevel / 1000000 ) - 1 ) * 15 ) + 5 ) + ( ( ModuloInteger(itemlevel, 10000) / 1000 ) * 4 )
 local integer dmp= LoadInteger(nodump, GetHandleId(it), GetHandleId(it))

 local boolean owner= dmp - 10 == id
 
 
 
 if ( dmp > 9 and owner == false ) then
     call UnitChat("Item linked!" , u)
     call UnitRemoveItem(u, it)
     set u=null
     return
   endif

 
    if ( GetUnitTypeId(u) == 'H00G' ) then
        set udg_HeroTipe[0]='H00G'
    endif
    
    //call BJDebugMsg("calc level "+I2S(islevel))  
    //call BJDebugMsg("itm level "+I2S(itemlevel))   
    //call BJDebugMsg("hero level "+I2S(GetHeroLevel(u)))   
     
     
    if ( islevel > GetHeroLevel(u) ) then
       call UnitChat("|cffffcc00I don't have the required level for that armor.|r" , GetTriggerUnit())
       call UnitRemoveItem(u, it)
    
      else
         set udg_ItSlotNULL=0
         set udg_ItClass=( ModuloInteger(itemlevel, 100000) / 10000 )
         set udg_ItLev=0
            
            loop
                exitwhen udg_ItLev > 5
                          
               if ( GetItemType(UnitItemInSlot(u, udg_ItLev)) == ITEM_TYPE_ARTIFACT ) then
                 set udg_ItSlotNULL=udg_ItSlotNULL + 1
               endif
              set udg_ItLev=udg_ItLev + 1
            endloop
            
            if ( udg_ItSlotNULL > 1 ) then
                 call UnitChat("|cffffcc00I cannot use more than one armor|r" , GetTriggerUnit())
                 call UnitRemoveItem(u, it)
                else
                    set udg_ItBon=ModuloInteger(itemlevel, 10000) / 1000
                    set udg_ItS1=ModuloInteger(itemlevel, 1000) / 100
                    set udg_ItS2=ModuloInteger(itemlevel, 100) / 10
                    set udg_ItS3=ModuloInteger(itemlevel, 10) // 1 
                
                        if ( udg_ItBon == 1 ) then
                            set udg_ItFBON=0.15
                        elseif ( udg_ItBon == 2 ) then
                            set udg_ItFBON=0.25
                        elseif ( udg_ItBon == 3 ) then
                            set udg_ItFBON=0.45
                        endif

                    if ( udg_ItS1 == 2 or udg_ItS2 == 2 or udg_ItS3 == 2 ) then
                        set udg_ItAt1=GetHeroAgi(u, false)
                        call ModifyHeroStat(bj_HEROSTAT_AGI, u, bj_MODIFYMETHOD_ADD, R2I(( I2R(GetHeroAgi(u, false)) * udg_ItFBON )))
                        set udg_ItAt2=( GetHeroAgi(u, false) - udg_ItAt1 )
                       // call SaveIntegerBJ( udg_ItAt2, 2, GetHandleIdBJ(it), udg_ItemStatHash )
                        call SaveInteger(udg_ItemStatHash, GetHandleId(it), 2, udg_ItAt2)
                    endif
                 
                    if ( udg_ItS1 == 3 or udg_ItS2 == 3 or udg_ItS3 == 3 ) then
                        set udg_ItAt1=GetHeroStr(u, false)
                        call ModifyHeroStat(bj_HEROSTAT_STR, u, bj_MODIFYMETHOD_ADD, R2I(( I2R(GetHeroStr(u, false)) * udg_ItFBON )))
                        set udg_ItAt2=( GetHeroStr(u, false) - udg_ItAt1 )
                       // call SaveIntegerBJ( udg_ItAt2, 3, GetHandleIdBJ(it), udg_ItemStatHash )
                         call SaveInteger(udg_ItemStatHash, GetHandleId(it), 3, udg_ItAt2)
                    endif
                
                    if ( udg_ItS1 == 4 or udg_ItS2 == 4 or udg_ItS3 == 4 ) then
                        set udg_ItAt1=GetHeroInt(u, false)
                        call ModifyHeroStat(bj_HEROSTAT_INT, u, bj_MODIFYMETHOD_ADD, R2I(( I2R(GetHeroInt(u, false)) * udg_ItFBON )))
                        set udg_ItAt2=( GetHeroInt(u, false) - udg_ItAt1 )
                       // call SaveInteger( udg_ItAt2, 4, GetHandleIdBJ(it), udg_ItemStatHash )
                        call SaveInteger(udg_ItemStatHash, GetHandleId(it), 4, udg_ItAt2)
                    endif

               endif
    endif

    set udg_HeroTipe[0]='H00H'
  //  set u = null

endfunction

function promoteEdict takes string edict,string Pname,string amount,string time,real duration returns nothing

  call PlaySoundBJ(gg_snd_Newedict)
  
    if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "|cffffcc00NEW ROYAL EDICT OF ENTHASHARA|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "By mandate of the high office of the kingdom is given free rein to the favour")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "requested by |cffffcc00" + Pname + "|r, who has demonstrated the chivalry")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "and reputation necessary to give faith and be support of the requirements:")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "<<From this moment and during the following " + time + " hours")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "all the kingdom's " + edict + " will be multiplied by " + amount + ">>")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "|cffa0a0a0Another issue decree related to the same without prior removal of current, will be not considered|r")
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, "|cffa0a0a0Write into registers and communicate this to the provinces and counties across the kingdom.|r")
         
      endif

endfunction

function derogateEdict takes string edict,string Pname,real duration returns nothing

  call PlaySoundBJ(gg_snd_Endedict)
  
  
    if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
        // Use only local code (no net traffic) within this block to avoid desyncs.
        call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, duration, Pname + "' " + edict + " edict expires now by lifetime dispose.")
    endif

endfunction


function RejectByRep takes integer id returns nothing
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00The officer says:|r")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "Excuse me.. You have not enough reputation to support these requests")
    call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "We are too busy to attend you in this moment. Please leave out this room.")

endfunction

function EdictInCurse takes integer id returns nothing
      call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "There's already an edict related to these issues. Please wait until previous edict ends")
endfunction


//library itemglobal ends
