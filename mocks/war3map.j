 function TeamInfo takes integer id returns nothing
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "|cffffcc00--------------------------------TEAM EVENT RULES--------------------------------|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "1- You will be teleported to teams battle stage where each team has " + I2S(teamAp) + " points")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "Battle Objective is decrease enemy team points to |cffffcc00zero|r, killing enemy players (-1 point) Or killing enemy |cffffcc00Titan|r (-" + I2S(titanlife) + " points).")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "2- If you leave the stage during battle stance your team will lose 3 point first time. Battle stage doesn't count inner rooms or undergrounds places, entering here means you leave the stage too, if you die out the battle It will be not counted as point")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "3- There will be special bonus stones spreaded into the stage, its number depends of players participating. Each stone destroyed will increase your team points by +2.")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "4- To make Titan alive and able to defend himself you must collect |cffffcc00" + I2S(tlifereq) + "|r life values from killing spawned creeps into the battle area, value size is directly related to creep level")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "|cffffcc00Important: Battle team is an experimental feature that needs to be fully tested.|r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "|cffffcc00Its development requires enough information from feedback. if all works fine there will be extended Team events following this way and Team rewards for win clash events. |r")
     call DisplayTimedTextToPlayer(Player(id), 0, 0, 70, "|cffffcc00If you find some malfunctioning issue please report it into forum comunity.|r")
  endfunction
    
    
  function EventAnnounce takes string Pname returns nothing
    call PlaySoundBJ(gg_snd_Newedict)
    if ( IsPlayerInForce(GetLocalPlayer(), bj_FORCE_ALL_PLAYERS) ) then
      // Use only local code (no net traffic) within this block to avoid desyncs.
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "|cffffcc00NEW CLASH CALL |r")
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "The Kingdom has started a new Team battle season")
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "From now every hero is invited to enter into the game invoked by |cffffcc00" + Pname + "|r")
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "The battle will start when teams be ready. First signer will be team leader to each side")
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "Run to any nearby Pvp Master and claim your |cffffcc00Team Key|r to participate")
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "|cffa0a0a0Teams will be balanced by members count to avoid overloaded groups|r")
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "|cffffcc00Players have 3 minutes to select a team, Event will be cancelled if teams aren't ready|r")
      call DisplayTimedTextToPlayer(GetLocalPlayer(), 0, 0, 20, "|cffffcc00Minimun team requirement for match is 2 vs 2 players|r")
 
      endif
    
    endfunction

    function Isclashclass takes nothing returns boolean
      return GetItemTypeId(GetManipulatedItem()) == clashcall
    endfunction

    function SetupClashCall takes nothing returns nothing
     local integer id= GetPlayerId(GetOwningPlayer(GetManipulatingUnit()))
     local integer i= 0
     //if Reputation[id]<130 then
     if Reputation[id] < 105 then
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00The officer says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "Excuse me.. You have not enough reputation to support these requests")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "We are too busy to attend you in this moment. Please leave out this room.")
      elseif on_event == true then
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "You cannot request a new event while another event is in course")
      elseif udg_totalPlaying < 4 then
       call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "Sorry but there isn't enough online players to play a team event")
      else
        set Reputation[id]=Reputation[id] - 130
        set on_event=true
        set diedheroes=CreateGroup()
        set Idclash=GetRandomInt(100, 1000000)
        set EventsInCourse[EventIndex]=Idclash
        set EventsInCourseInfo[EventIndex]="New Event"
        set EventIndex=EventIndex + 1
        set TeamTimer=(NewTimerEx(0)) // INLINED!!
        call TimerStart(TeamTimer, 180, false, function StartBattle)
        set TeamTdialog=CreateTimerDialog(TeamTimer)
        call TimerDialogSetTitle(TeamTdialog, "Teams battle start: ")
        call TimerDialogDisplay(TeamTdialog, true)
        set InsetupBattle=true
        
        if udg_totalPlaying > 6 then
           set maxTeam=4
        elseif udg_totalPlaying > 4 then
           set maxTeam=3
        else
           set maxTeam=2
        endif
        
        set tlifereq=100 + ( maxTeam * 200 )
        
        set teamAp=maxTeam * 6
        set teamBp=maxTeam * 6
        
        set teamAc=0
        set teamBc=0
       
          if lanceralive == true then
             call PauseUnit(gg_unit_n06A_0475, true)
             call ShowUnit(gg_unit_n06A_0475, false) //hide lancer
          endif
        
        call EventAnnounce(GetPlayerName(Player(id)))
        
        loop
         exitwhen i > 9
         set tleaver[i]=false
         set s__playerkills[i]= 0
         set i=i + 1
         endloop
    
      endif
    
    endfunction
    
    function init takes nothing returns nothing
         local integer i= 0
    endfunction

