//textmacro instance: Board_DeclareRowCol("row", "col", "Row",    "Column", "Col", "Row")
    // =====
    // Notes:
    // -----
    // this  = board * 100 + pos
    // pos   = Mod(integer(this), 100)
    // board = (integer(this) - Mod(integer(this), 100)) / 100
    // =====
    
    function s__BoardRow__getindex takes integer this,integer col returns integer
        local integer board= ( ( (this) - Board___Mod((this) , 100) ) / 100 )
        local integer row= Board___Mod((this) , 100)
        
        if col >= s__Board_Board___bColCount[board] then
            call MultiboardSetColumnCount(s__Board_Board___bBoard[board], col + 1)
            set s__Board_Board___bColCount[board]=col + 1
        endif
        
        return ((board) * 10000 + row * 100 + col)
    endfunction
    
    function s__BoardRow__get_position takes integer this returns integer
        return Board___Mod((this) , 100)
    endfunction
    
    // ==============
    
    function s__BoardRow__set_text takes integer this,string val returns nothing
        local integer board= (( (this) - Board___Mod((this) , 100) ) / 100)
        local integer row= (Board___Mod((this) , 100))
        
        local multiboarditem mbi
        local integer col= 0
        
        if s__Board_Board___bBoard[board] == null then
            return
        endif
        
        if row >= s__Board_Board___bRowCount[board] then
            call MultiboardSetRowCount(s__Board_Board___bBoard[board], row + 1)
            set s__Board_Board___bRowCount[board]=row + 1
        endif
        
        loop
            exitwhen col == s__Board_Board___bColCount[board]
            set mbi=MultiboardGetItem(s__Board_Board___bBoard[board], row, col)
            
            call MultiboardSetItemValue(mbi, val)
            
            call MultiboardReleaseItem(mbi)
            set col=col + 1
        endloop
        
        set mbi=null
    endfunction
    
