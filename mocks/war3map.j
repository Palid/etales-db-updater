function InitTrig_checkcentaurs takes nothing returns nothing
    set gg_trg_checkcentaurs=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_checkcentaurs, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_checkcentaurs, Condition(function Trig_checkcentaurs_Conditions))
    call TriggerAddAction(gg_trg_checkcentaurs, function Trig_checkcentaurs_Actions)
endfunction


//===========================================================================
// Trigger: Startincident
//===========================================================================
function Trig_Startincident_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == farm and IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true )
endfunction

function SetupSacr takes nothing returns nothing
 

endfunction

function scoutattack takes nothing returns nothing
local unit s= GetEnumUnit()
call SetUnitMoveSpeed(s, 220)
set s=null
endfunction



function markcentaur takes nothing returns nothing
call SetUnitUserData(GetEnumUnit(), 1123)
call SaveInteger(questtm, GetHandleId(GetEnumUnit()), 1123, CentCuId)
endfunction

function SetupCentaurs takes integer id returns nothing
local integer i= 7
set s__centaurs[id]= CreateGroup()
 loop
        set i=i - 1
        exitwhen i < 0
        call GroupAddUnit(s__centaurs[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[68], - 3680, 5856, 270))
         call TriggerSleepAction(0.05)
 endloop
    set i=4
  loop
        set i=i - 1
        exitwhen i < 0
        call GroupAddUnit(s__centaurs[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[67], - 3680, 5856, 270))
          call TriggerSleepAction(0.05)
 endloop
       call GroupAddUnit(s__centaurs[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[13], - 3680, 5856, 270))
       call GroupAddUnit(s__centaurs[id], CreateUnit(Player(PLAYER_NEUTRAL_AGGRESSIVE), udg_CreepType[13], - 3680, 5856, 270))
       call TriggerSleepAction(0.5)
      
endfunction

function Trig_Startincident_Actions takes nothing returns nothing
local integer id= GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer questid
local integer reward
//call DisableTrigger(gg_trg_Startincident)
    if ( GetUnitLevel(udg_PHero[id]) < 40 ) then
        call UnitChat("Sorry boy, you seem to be very weak to help us" , ankit)
    elseif ( GetUnitLevel(udg_PHero[id]) > 110 ) then
        call UnitChat("Thanks for your help, but we can handle it (max lev = 110)." , ankit)
    elseif s__valincident[id] == true then
        call UnitChat("How is it going mate??" , ankit)
    else
    
        
        
        set s__valincident[id]= true
        call MakeFaceToUnit(ankit , udg_PHero[id]) //wolfang
        call UnitChat("You have come in tense moments, we need some help here" , ankit)
    
       call TriggerSleepAction(3)
        
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Lieutenant Ankit says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    It's very strange, this farm was abandoned some years ago. Owner's vanishes into centaurs land ...")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Nobody has seen he or his family and the farm just stay abandoned day after day")
        call TriggerSleepAction(9)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Lieutenant Ankit says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Only beggars sleep here at the night but we found some of them killed and decapitated days ago")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    We suspect about those centaurs, people saw groups of them rounding these farms...")
        call TriggerSleepAction(9)
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Lieutenant Ankit says:|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Valdivia's Consul order is to investigate what happened here but ")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    my soldiers are too weak to enter into centaurs lairs...")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    You seem to be trained and experienced in dealing with those wilds...")
        call SetupCentaurs(id)
        set CentCuId=id
        
        call ForGroup(s__centaurs[id], function markcentaur)
        set CentCuId=999
        call TriggerSleepAction(1)
        call ForGroup(s__centaurs[id], function centattack)
        call TriggerSleepAction(8)
        call GroupAddUnit(vguard, scoutguard)
        call ForGroup(vguard, function scoutattack)
        call UnitChat("|cffffcc00SIRRR!!!, CENTAURS ARE ATTACKING.....!!!!!|r" , scoutguard)
        call TriggerSleepAction(2)
        call UnitChat("Guards!! protect ourselves!" , ankit)
        call TriggerSleepAction(1)
 
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "|cffffcc00NEW PERSONAL QUEST|r: |cffffcc00UNKNOWN ENEMY - PART I|r")
        call DisplayTimedTextToPlayer(Player(id), 0, 0, 5, "     Stop the centaurs ambush...")
        call StartSound(bj_questDiscoveredSound)
   
  
        set questid=SetupQuest(id , valdkeeper , "UNKNOWN ENEMY - PART I" , "Destroy the centaurs group " , "-" , "-" , 0 , s__qty[3])
       
       loop
        exitwhen FirstOfGroup(s__centaurs[id]) == null
          call ForGroup(s__centaurs[id], function centattack)
          call TriggerSleepAction(1)
        endloop
          call DestroyGroup(s__centaurs[id])
          set s__centaurs[id]= null
         
          call StartSound(bj_questCompletedSound)
          call UpdatePersQuestND(id , questid , 1 , "-" , I2S(1) , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
          call TriggerSleepAction(4)
          call UnitChat("We must stop these incursions!!!" , ankit)
          call MakeFaceToUnit(ankit , udg_PHero[id]) //wolfang
          set reward=322 * s__centaurkiller[id]
          set s__centaurkiller[id]= 0
          call AddHeroXP(udg_PHero[id], reward, false)
          call DisplayTimedTextToPlayer(Player(id), .1, 0, 4, " Got +|cffffcc00" + I2S(reward) + "|r Experience!")
          call TriggerSleepAction(2)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Lieutenant Ankit says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    This can't continue!. They attacked in broad daylight, It has traspased the limits..")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Our people is in danger, We must prepare an erradication plan against those centaurs....")
          call TriggerSleepAction(8)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00Lieutenant Ankit says:|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    We mustn't take these risks in false")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Please explore the land and check if there are any base or location where they are launching attacks...")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "    Destroy any centaur blocking your way!..")
          call TriggerSleepAction(8)
           set questid=SetupQuest(id , valdkeeper , "UNKNOWN ENEMY - PART II" , "Explore centaurs land, Destroy 40 centaurs " , "0" , "/40" , 0 , s__qty[3])
          call SaveInteger(udg_cache, GetHandleId(ankit), GetHandleId(udg_PHero[id]), questid)
          set Qrequ[questid]=40
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "|cffffcc00NEW PERSONAL QUEST: UNKNOWN ENEMY - PART II|r")
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 7, "     Explore centaurs land, Destroy 40 centaurs, We need to find their main base")
          call StartSound(bj_questDiscoveredSound)
          set s__killingcentaurs[id]= true
          set Tryingsylvan[id]=true
          
           loop
          exitwhen s__killingcentaurs[id] == false
          call TriggerSleepAction(1)
          endloop
          call StartSound(bj_questCompletedSound)
          call UpdatePersQuestND(id , questid , 1 , "-" , I2S(1) , "-")
          call TriggerSleepAction(0.02)
          call RemoveQuestFromPlayer(questid , id)
          call DisplayTimedTextToPlayer(Player(id), 0, 0, 6, "|cffffcc00Quest Completed: " + QTitle[questid] + "|r")
          call DisplayTimedTextToPlayer(Player(id), .1, 0, 6, " Got +|cffffcc008090|r Experience!")
          call AddHeroXP(udg_PHero[id], 8090, false)
          set libraryseek[id]=true
          call TriggerSleepAction(10)
          call StartSound(bj_questHintSound)
          call DisplayTimedTextToPlayer(Player(id), .1, 0, 6, "|cffffcc00HINT:|r")
          call DisplayTimedTextToPlayer(Player(id), .1, 0, 6, "    If you need to understand centaurs language you could need to read a book from a bookstore")
          endif //quest
endfunction

