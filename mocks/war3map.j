// GetItemTypeId(GetManipulatedItem()) == 'I005' or
//===========================================================================
function Trig_stackMeat_Conditions takes nothing returns boolean
    return ( GetItemTypeId(GetManipulatedItem()) == 'I004' )
endfunction



function Trig_stackMeat_Actions takes nothing returns nothing
 
 if ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'I005') == true ) then
        set udg_tmpitem=GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I005')
      
        if ( GetItemCharges(udg_tmpitem) < 20 ) then
           call SetItemCharges(udg_tmpitem, ( GetItemCharges(udg_tmpitem) + GetItemCharges(GetManipulatedItem()) ))
        endif
       
        set udg_tmpitem=null
    else
      
            call UnitAddItemByIdSwapped('I005', GetTriggerUnit())
      
    endif
 
 
    
endfunction

