    set gg_trg_IveorCalls=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_IveorCalls, gg_unit_E00I_2515, EVENT_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_IveorCalls, Condition(function Trig_IveorCalls_Conditions))
    call TriggerAddAction(gg_trg_IveorCalls, function Trig_IveorCalls_Actions)
